    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "Router OS upgrade completed successfully on router-core01.corp.example.com." .

noria:ChangeRequest_RouterOSUpgrade dcterms:relation noria:EventRecord_RouterOSUpgradeComplete .

# Example of an alarm being mitigated by a procedure execution container (which can be a TT or CR)
noria:EventRecord_RouterInterfaceDown noria:alarmMitigatedBy noria:TroubleTicket_DNSOutageTT . # Assuming the DNS outage TT also covered the router interface issue.

# More detailed network interface properties
noria:NetworkInterface_RouterCore01_Gi0_0_0 noria:networkInterfaceLaserRxHighPowerWarningThreshold -3 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetworkInterface_FWDMZ01_Eth1 noria:networkInterfaceLaserRxHighPowerWarningThreshold -4 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -12 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -8 .

# Add a Corporate User Identifier
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    foaf:accountName "jdoe" ;
    observable:accountLogin "jdoe" ;
    observable:accountIdentifier "jdoe@example.com" .

foaf:Agent_JohnDoe foaf:holdsAccount noria:CUid_JohnDoe .

# Add another resource and link it
noria:Resource_LoadBalancer01 a noria:Resource ;
    rdfs:label "Application Load Balancer 01"@en ;
    rdfs:comment "Load balancer distributing traffic to web servers."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:resourceHostName "lb01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/Firewall> ; # Using Firewall as a proxy for network appliance
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceForApplication noria:Application_CorpWebsite ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.60> .

noria:NetworkInterface_LB01_Eth0 a noria:NetworkInterface ;
    rdfs:label "LB01 Ethernet 0"@en ;
    rdfs:comment "Interface for internal web server traffic."@en ;
    noria:networkInterfaceOf noria:Resource_LoadBalancer01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_LAN_A .

noria:Application_CorpWebsite seas:subSystem noria:Resource_LoadBalancer01 .

# Add a virtual server status
noria:Resource_VirtualDB01 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

# Add a Change Request for the Load Balancer
noria:ChangeRequest_LoadBalancerConfig a noria:ChangeRequest ;
    rdfs:label "Load Balancer Configuration Update"@en ;
    rdfs:comment "Update load balancing algorithm for corporate website."@en ;
    noria:changeRequestPlannedStartTime "2024-04-28T01:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-28T01:15:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Planned> ;
    noria:changeRequestImpact noria:Resource_LoadBalancer01 ;
    noria:changeRequestInitiatorParty foaf:Agent_AppSupport ;
    noria:changeRequestPilotParty foaf:Agent_JaneSmith ;
    noria:changeRequestActorParty foaf:Agent_NetworkOps ;
    noria:changeRequestOutageDuration "PT0S"^^xsd:duration ;
    noria:documentExternalId "CR-20240428-003" .

# Add an Event Record for a successful change
noria:EventRecord_LoadBalancerConfigSuccess a noria:EventRecord ;
    rdfs:label "Load Balancer Config Applied"@en ;
    rdfs:comment "Configuration successfully applied to Load Balancer 01."@en ;
    noria:loggingTime "2024-04-28T01:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_LoadBalancer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logOriginatingAgent foaf:Agent_JaneSmith ;
    noria:logText "Load balancer algorithm updated to 'least connections'." .

noria:ChangeRequest_LoadBalancerConfig dcterms:relation noria:EventRecord_LoadBalancerConfigSuccess .

# Add a Trouble Ticket related to a security event
noria:TroubleTicket_SecurityIncident a noria:TroubleTicket ;
    rdfs:label "Security Incident: Unauthorized Access Attempt"@en ;
    rdfs:comment "Investigation into multiple unauthorized access attempts on DMZ Firewall."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedResource noria:Resource_FirewallDMZ01 ;
    noria:troubleTicketRelatedParty foaf:Agent_SecurityTeam ;
    noria:troubleTicketTrigger noria:EventRecord_LoginFailure ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ; # Can be adapted to a security specific category if available
    noria:troubleTicketCause "Brute-force attack attempt detected."@en ;
    noria:troubleTicketSupervisionTool "SIEM System" ;
    noria:documentExternalId "SEC-20240420-001" .

noria:EventRecord_LoginFailure noria:alarmMitigatedBy noria:TroubleTicket_SecurityIncident .

# Add a Trouble Ticket Note for the security incident
noria:TroubleTicketNote_SecurityIncident_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Security Incident Analysis"@en ;
    rdfs:comment "Identified source IP 192.168.1.100 as malicious. Blocked IP at edge firewall. Further investigation ongoing."@en ;
    dcterms:created "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_SecurityTeam ;
    dcterms:isPartOf noria:TroubleTicket_SecurityIncident ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

# Add a DocumentAttachment
noria:DocumentAttachment_NetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Corporate Network Diagram"@en ;
    rdfs:comment "PDF document showing the high-level corporate network topology."@en ;
    dcterms:format "application/pdf" ;
    dcterms:identifier "NET-DIAG-V2.3" ;
    dcterms:source "https://docs.example.com/network_diagram_v2.3.pdf" ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutageTT . # Attached to a TT for reference

noria:DocumentAttachment_FirewallLogs a noria:DocumentAttachment ;
    rdfs:label "Firewall Logs for Security Incident"@en ;
    rdfs:comment "Exported logs from FWDMZ01 related to the security incident."@en ;
    dcterms:format "text/plain" ;
    dcterms:identifier "FW-LOGS-20240420" ;
    dcterms:source "https://logs.example.com/fw_dmz01_20240420.log" ;
    dcterms:isPartOf noria:TroubleTicket_SecurityIncident .

# Add a new service that aggregates multiple application modules
noria:Service_CRM_E2E a noria:Service ;
    rdfs:label "End-to-End CRM Service"@en ;
    rdfs:comment "Comprehensive service for customer relationship management, including development and production modules."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystem noria:ApplicationModule_CRM_Dev ;
    seas:subSystem noria:Application_CRMSystem . # Assuming Application_CRMSystem represents the production module for simplicity here, or could create a dedicated production module.

# Ensure all entities are connected.
# The current structure ensures this:
# - Agents manage Resources and Application Modules.
# - Resources are part of Applications, have Product Models, and are located at Loci.
# - Network Interfaces are part of Resources and connect to Network Links.
# - Network Links connect Resources (via interfaces).
# - Application Modules are part of Applications.
# - Services aggregate Application Modules/Resources.
# - Trouble Tickets relate to Services/Applications/Resources and Agents, and are triggered by Event Records.
# - Trouble Ticket Notes are part of Trouble Tickets and can correlate to Event Records.
# - Change Requests impact Services/Applications/Resources and involve Agents.
# - Event Records originate from Managed Objects (Resources/Applications), Management Systems (Applications), and Agents.
# - Operation Plans have Pre/Post Conditions.

# Final check for density and completeness:
# - Multiple instances of each core class.
# - Extensive use of properties defined in NORIA.
# - rdfs:label, rdfs:comment, skos:example (where appropriate) for most instances.
# - No ldp prefix.
# - KOS concepts used for controlled vocabularies.
# - Interconnectedness: Each entity has at least one link to another.

# This graph is quite dense and covers a wide range of NORIA concepts.
# The token count should be well within the limit.
