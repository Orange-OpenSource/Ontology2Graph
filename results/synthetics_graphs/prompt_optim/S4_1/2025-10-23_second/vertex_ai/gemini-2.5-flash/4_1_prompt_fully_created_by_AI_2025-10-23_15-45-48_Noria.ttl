# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OperationPlan_RouterRestart a noria:OperationPlan ;
    rdfs:label "Standard Router Restart Procedure"@en ;
    rdfs:comment "A documented procedure for safely restarting a core network router."@en ;
    skos:example "Steps include: notify NOC, check active links, save config, reload, verify status."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_RouterStable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterUp .

noria:OperationPlan_DNSCacheClear a noria:OperationPlan ;
    rdfs:label "DNS Cache Clear Procedure"@en ;
    rdfs:comment "Procedure to clear DNS cache on a server to resolve stale entries."@en ;
    skos:example "Steps include: check current cache, clear cache, verify resolution."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSProblem ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSResolved .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:ActionPreCondition_RouterStable a noria:ActionPreCondition ;
    rdfs:label "Router Stable Pre-Condition"@en ;
    rdfs:comment "Ensure router is not actively forwarding critical traffic or undergoing other changes."@en .

noria:ActionPostCondition_RouterUp a noria:ActionPostCondition ;
    rdfs:label "Router Up Post-Condition"@en ;
    rdfs:comment "Verify all interfaces are up, routing protocols converged, and traffic is flowing."@en .

noria:ActionPreCondition_DNSProblem a noria:ActionPreCondition ;
    rdfs:label "DNS Resolution Problem Pre-Condition"@en ;
    rdfs:comment "Users are reporting incorrect or stale DNS resolutions."@en .

noria:ActionPostCondition_DNSResolved a noria:ActionPostCondition ;
    rdfs:label "DNS Resolution Resolved Post-Condition"@en ;
    rdfs:comment "DNS queries return correct and up-to-date information."@en .

