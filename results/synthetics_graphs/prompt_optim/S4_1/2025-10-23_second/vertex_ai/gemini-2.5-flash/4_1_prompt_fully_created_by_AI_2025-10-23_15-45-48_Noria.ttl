foaf:Agent_SecurityTeam noria:agentManagesResource noria:Resource_FirewallDMZ01 .

# Link applications to resources
noria:Application_CorpInternetAccess seas:subSystem noria:Resource_DNS01, noria:Resource_RouterCore01, noria:Resource_FirewallDMZ01 .
noria:Application_CorpWebsite seas:subSystem noria:Resource_WebSrv01, noria:Resource_DNS01 .
noria:Application_CRMSystem seas:subSystem noria:Resource_VirtualDB01 .
noria:Application_MonitoringPlatform seas:subSystem noria:Resource_DNS01, noria:Resource_RouterCore01, noria:Resource_FirewallDMZ01, noria:Resource_WebSrv01, noria:Resource_VirtualDB01 .

# Link application modules to resources (indirectly via application, or directly if module specific)
noria:ApplicationModule_CIA_Prod seas:subSystem noria:Resource_DNS01, noria:Resource_RouterCore01, noria:Resource_FirewallDMZ01 .
noria:ApplicationModule_CWEB_Prod seas:subSystem noria:Resource_WebSrv01 .
noria:ApplicationModule_CRM_Dev seas:subSystem noria:Resource_VirtualDB01 .

# Link trouble tickets to more related parties
noria:TroubleTicket_DNSOutageTT noria:troubleTicketRelatedParty foaf:Agent_JohnDoe .
noria:TroubleTicket_WebSrvPerformanceTT noria:troubleTicketRelatedParty foaf:Agent_JaneSmith .

# Document status history for trouble tickets
noria:TroubleTicket_DNSOutageTT noria:documentStatusHistory noria:EventRecord_DNSOutageLog .
noria:TroubleTicket_DNSOutageTT noria:documentStatusHistory noria:EventRecord_ConfigChange . # Assuming config change was part of resolution

