# =============================================================================
# SKOS Concept Schemes and Concepts (for properties with restricted ranges)
# =============================================================================

# Application Types
<https://w3id.org/noria/kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .

<https://w3id.org/noria/kos/application/type/infrastructure> a skos:Concept ;
    skos:prefLabel "Infrastructure Application"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

<https://w3id.org/noria/kos/application/type/business> a skos:Concept ;
    skos:prefLabel "Business Application"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

