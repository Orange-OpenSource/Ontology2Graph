    noria:logOriginatingManagementSystem noria:Application/MonitoringPlatform ;
    noria:logOriginatingAgent foaf:Agent/SecurityTeam ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord/ConfigChangeRouter01 a noria:EventRecord ;
