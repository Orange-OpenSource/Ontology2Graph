noria:EventRecord/DNSOutageLog01 a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS01 server became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "Host dns01.corp.example.com (10.0.0.10) is unreachable via ICMP."@en ;
    noria:logOriginatingManagedObject noria:Resource/DNS01 ;
    noria:logOriginatingManagementSystem noria:Application/MonitoringPlatform ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan/RestartDNSService .

noria:EventRecord/RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a critical interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T09:01:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/0 on core-rtr01.corp.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource/RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application/MonitoringPlatform ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan/CheckFiberLink .

noria:EventRecord/AppServerHighCPU a noria:EventRecord ;
    rdfs:label "Application Server High CPU Warning"@en ;
    rdfs:comment "Warning for high CPU utilization on AppServer01."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on app-srv01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource/AppServer01 ;
    noria:logOriginatingManagementSystem noria:Application/MonitoringPlatform ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord/UserLoginFailure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
