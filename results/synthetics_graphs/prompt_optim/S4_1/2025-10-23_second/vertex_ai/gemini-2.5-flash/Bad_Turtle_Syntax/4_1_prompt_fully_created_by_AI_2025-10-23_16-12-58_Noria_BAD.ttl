    rdfs:comment "Configuration change applied to Core Router 01 by an administrator."@en ;
    noria:loggingTime "2024-04-19T16:00:00Z"^^xsd:dateTime ;
    noria:logText "Configuration changed by John Doe from 10.0.0.100. Added static route."@en ;
    noria:logOriginatingManagedObject noria:Resource/RouterCore01 ;
    noria:logOriginatingAgent foaf:Agent/JohnDoe ;
    noria:logOriginatingManagementSystem noria:Application/MonitoringPlatform .

