# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OperationPlan_RestartWebServer a noria:OperationPlan ;
    rdfs:label "Standard Web Server Restart Procedure"@en ;
    rdfs:comment "Procedure for safely restarting an Apache web server instance."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_WebServerOffline ;
    noria:operationPlanPostCondition noria:ActionPostCondition_WebServerOnline .

noria:OperationPlan_DiagnoseFiberCut a noria:OperationPlan ;
    rdfs:label "Fiber Cut Diagnosis Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and escalating fiber optic cable cuts."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_OpticalLinkDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_ISPContacted .

noria:OperationPlan_ApplyFirewallRules a noria:OperationPlan ;
    rdfs:label "Firewall Rule Application Procedure"@en ;
    rdfs:comment "Standard procedure for applying new firewall rules."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_FirewallConfigReady ;
    noria:operationPlanPostCondition noria:ActionPostCondition_FirewallRulesActive .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:ActionPreCondition_WebServerOffline a noria:ActionPreCondition ;
    rdfs:label "Web Server Offline Pre-condition"@en ;
    rdfs:comment "Condition: The web server process is not running or is unresponsive."@en .

noria:ActionPostCondition_WebServerOnline a noria:ActionPostCondition ;
    rdfs:label "Web Server Online Post-condition"@en ;
    rdfs:comment "Condition: The web server process is running and responding to requests."@en .

noria:ActionPreCondition_OpticalLinkDown a noria:ActionPreCondition ;
    rdfs:label "Optical Link Down Pre-condition"@en ;
    rdfs:comment "Condition: Optical power levels on a network interface are below operational thresholds."@en .

noria:ActionPostCondition_ISPContacted a noria:ActionPostCondition ;
    rdfs:label "ISP Contacted Post-condition"@en ;
    rdfs:comment "Condition: Internet Service Provider has been notified and a repair ticket opened."@en .

noria:ActionPreCondition_FirewallConfigReady a noria:ActionPreCondition ;
    rdfs:label "Firewall Configuration Ready Pre-condition"@en ;
    rdfs:comment "Condition: New firewall rules have been reviewed and approved."@en .

noria:ActionPostCondition_FirewallRulesActive a noria:ActionPostCondition ;
    rdfs:label "Firewall Rules Active Post-condition"@en ;
    rdfs:comment "Condition: New firewall rules are successfully applied and traffic flows as expected."@en .

# =============================================================================
# Connections between Dynamic and Procedural Elements
# =============================================================================

noria:TroubleTicket_WebServerOutage
    noria:troubleTicketCharacteristic noria:OperationPlan_RestartWebServer . # Example of linking a TT to a potential operation plan

noria:TroubleTicket_NetworkOutage
    noria:troubleTicketCharacteristic noria:OperationPlan_DiagnoseFiberCut .

noria:ChangeRequest_WebServerUpgrade
    noria:changeRequestSpecification noria:OperationPlan_RestartWebServer . # The upgrade might involve a restart procedure

noria:ChangeRequest_FirewallRuleUpdate
    noria:changeRequestSpecification noria:OperationPlan_ApplyFirewallRules .

noria:EventRecord_WebServer01_Down
    noria:alarmProposedRepairAction noria:OperationPlan_RestartWebServer .

noria:EventRecord_WebOps_RestartWebServer
    noria:alarmMitigatedBy noria:TroubleTicket_WebServerOutage . # The action taken in the event record is part of mitigating the TT.

# Example of a more complex correlation:
# A procedure execution container for the web server restart action
<https://w3id.org/noria/pep/ProcedureExecutionContainer_WebServerRestart> a pep:ProcedureExecutionContainer ;
    rdfs:label "Web Server Restart Execution"@en ;
    dcterms:description "Container for the execution of the web server restart procedure related to the outage."@en ;
    pep:hasProcedure noria:OperationPlan_RestartWebServer ;
    pep:member noria:EventRecord_WebOps_RestartWebServer .

noria:TroubleTicketNote_WebServerOutage_Note2
    noria:troubleTicketNoteCorrelatedExecution <https://w3id.org/noria/pep/ProcedureExecutionContainer_WebServerRestart> .

