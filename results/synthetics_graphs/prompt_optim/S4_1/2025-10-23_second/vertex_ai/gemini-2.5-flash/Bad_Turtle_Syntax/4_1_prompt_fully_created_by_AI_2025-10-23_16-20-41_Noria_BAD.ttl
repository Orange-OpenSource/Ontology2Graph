# Base URI for NORIA ontology
<https://w3id.org/noria/ontology/>
    a voaf:Vocabulary, owl:Ontology ;
    dcterms:title "The NORIA Ontology"@en ;
    dcterms:description """The NORIA-O project is a data model for IT networks, events and operations information.
The ontology is developed using web technologies (e.g. RDF, OWL, SKOS) and is intended as a structure for realizing an IT Service Management (ITSM) Knowledge Graph (KG) for Anomaly Detection (AD) and Risk Management applications.
The model has been developed in collaboration with operational teams, and in connection with third parties linked vocabularies.
"""@en ;
    vann:preferredNamespacePrefix "noria" ;
    vann:preferredNamespaceUri "https://w3id.org/noria/ontology/" ;
    dcterms:issued "2022-05-10"^^xsd:date ;
    dcterms:modified "2024-03-15"^^xsd:date ;
    owl:versionInfo "v0.3" ;
    .

# =============================================================================
# SKOS Concept Schemes and Concepts (for properties with restricted ranges)
# =============================================================================

# Application Types
<kos/application/type> a skos:ConceptScheme ; rdfs:label "Application Type Scheme"@en .
<kos/application/type/infrastructure> a skos:Concept ; skos:prefLabel "Infrastructure"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/business-application> a skos:Concept ; skos:prefLabel "Business Application"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/monitoring> a skos:Concept ; skos:prefLabel "Monitoring System"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/database> a skos:Concept ; skos:prefLabel "Database System"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/email> a skos:Concept ; skos:prefLabel "Email Service"@en ; skos:inScheme <kos/application/type> .

# Application Business Importance
<kos/application/business-importance> a skos:ConceptScheme ; rdfs:label "Application Business Importance Scheme"@en .
<kos/application/business-importance/high> a skos:Concept ; skos:prefLabel "High"@en ; skos:inScheme <kos/application/business-importance> .
<kos/application/business-importance/medium> a skos:Concept ; skos:prefLabel "Medium"@en ; skos:inScheme <kos/application/business-importance> .
<kos/application/business-importance/low> a skos:Concept ; skos:prefLabel "Low"@en ; skos:inScheme <kos/application/business-importance> .

# Application Module Status
<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ; rdfs:label "Application Module Status Scheme"@en .
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; skos:prefLabel "Development"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Staging> a skos:Concept ; skos:prefLabel "Staging"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ; skos:prefLabel "Maintenance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .

# Resource Types
<kos/Resource/type> a skos:ConceptScheme ; rdfs:label "Resource Type Scheme"@en .
<kos/Resource/type/server> a skos:Concept ; skos:prefLabel "Server"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/router> a skos:Concept ; skos:prefLabel "Router"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/firewall> a skos:Concept ; skos:prefLabel "Firewall"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/load-balancer> a skos:Concept ; skos:prefLabel "Load Balancer"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/virtual-machine> a skos:Concept ; skos:prefLabel "Virtual Machine"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/storage-array> a skos:Concept ; skos:prefLabel "Storage Array"@en ; skos:inScheme <kos/Resource/type> .

# Resource Lifecycle State
<kos/Resource/LifecycleState> a skos:ConceptScheme ; rdfs:label "Resource Lifecycle State Scheme"@en .
<kos/Resource/LifecycleState/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en ; skos:inScheme <kos/Resource/LifecycleState> .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; skos:prefLabel "Decommissioned"@en ; skos:inScheme <kos/Resource/LifecycleState> .
<kos/Resource/LifecycleState/Testing> a skos:Concept ; skos:prefLabel "Testing"@en ; skos:inScheme <kos/Resource/LifecycleState> .

# Resource Operational State
<kos/Resource/OperationalState> a skos:ConceptScheme ; rdfs:label "Resource Operational State Scheme"@en .
<kos/Resource/OperationalState/Up> a skos:Concept ; skos:prefLabel "Up"@en ; skos:inScheme <kos/Resource/OperationalState> .
<kos/Resource/OperationalState/Down> a skos:Concept ; skos:prefLabel "Down"@en ; skos:inScheme <kos/Resource/OperationalState> .
<kos/Resource/OperationalState/Degraded> a skos:Concept ; skos:prefLabel "Degraded"@en ; skos:inScheme <kos/Resource/OperationalState> .

# Resource Administrative State
<kos/Resource/AdministrativeState> a skos:ConceptScheme ; rdfs:label "Resource Administrative State Scheme"@en .
<kos/Resource/AdministrativeState/Enabled> a skos:Concept ; skos:prefLabel "Enabled"@en ; skos:inScheme <kos/Resource/AdministrativeState> .
<kos/Resource/AdministrativeState/Disabled> a skos:Concept ; skos:prefLabel "Disabled"@en ; skos:inScheme <kos/Resource/AdministrativeState> .

# Service Types
<kos/service/type> a skos:ConceptScheme ; rdfs:label "Service Type Scheme"@en .
<kos/service/type/CustomerFacingService> a skos:Concept ; skos:prefLabel "Customer Facing Service"@en ; skos:inScheme <kos/service/type> .
<kos/service/type/ResourceFacingService> a skos:Concept ; skos:prefLabel "Resource Facing Service"@en ; skos:inScheme <kos/service/type> .

# Trouble Ticket Severity
<kos/TroubleTicket/severity> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Severity Scheme"@en .
<kos/TroubleTicket/severity/Critical> a skos:Concept ; skos:prefLabel "Critical"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Major> a skos:Concept ; skos:prefLabel "Major"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; skos:prefLabel "Minor"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Warning> a skos:Concept ; skos:prefLabel "Warning"@en ; skos:inScheme <kos/TroubleTicket/severity> .

# Trouble Ticket Type
<kos/TroubleTicket/type> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Type Scheme"@en .
<kos/TroubleTicket/type/Failure> a skos:Concept ; skos:prefLabel "Failure"@en ; skos:inScheme <kos/TroubleTicket/type> .
