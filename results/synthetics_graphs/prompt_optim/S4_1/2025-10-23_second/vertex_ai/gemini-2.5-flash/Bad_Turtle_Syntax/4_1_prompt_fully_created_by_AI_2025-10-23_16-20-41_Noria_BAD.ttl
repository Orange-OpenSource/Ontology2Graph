# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

foaf:Agent_WebOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Web Operations Team"@en ;
    rdfs:comment "Team responsible for the corporate website and related infrastructure."@en ;
    noria:agentWorkingHours "9:00 AM - 6:00 PM (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "For critical issues, open a P1 ticket and call the hotline."@en .

foaf:Agent_DBAdmins a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Database Administrators"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always escalate database performance issues to P1."@en .

foaf:Agent_NetworkTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure, including routers, switches, and firewalls."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Use dedicated network monitoring tools for initial diagnosis."@en .

foaf:Agent_Helpdesk a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Helpdesk"@en ;
    rdfs:comment "First-line support for all internal IT issues."@en ;
    noria:agentWorkingHours "8:00 AM - 7:00 PM (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Triage all incoming requests and escalate to specialized teams as needed."@en .

foaf:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Monitors and responds to security incidents."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "All security alerts must be investigated within 15 minutes."@en .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Engineer for Web Operations."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Database Administrator."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_AutomatedMonitoringSystem a foaf:Agent ;
    rdfs:label "Automated Monitoring System"@en ;
    rdfs:comment "Automated system responsible for generating alerts and events."@en .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:Site_DC1 a bot:Site ;
    rdfs:label "Main Data Center 1"@en ;
    noria:siteId "DC1-FRA-01"@en ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Frankfurt"@en ;
    noria:sitePrincipalAddressPostalCode "60313"@en ;
    noria:sitePrincipalAddressCountry "DE"@en .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Primary server room within Data Center 1."@en ;
    bot:hasSpace noria:Locus_Rack1, noria:Locus_Rack2 ;
    bot:hasBuilding bot:Site_DC1 .

noria:Locus_Rack1 a noria:Locus ;
    rdfs:label "Rack 1, Server Room A"@en ;
    rdfs:comment "Location for critical web servers and load balancers."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en .

noria:Locus_Rack2 a noria:Locus ;
    rdfs:label "Rack 2, Server Room A"@en ;
    rdfs:comment "Location for database servers and storage arrays."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "2"@en .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Room dedicated to network equipment within Data Center 1."@en ;
    bot:hasSpace noria:Locus_NetworkRack1 ;
    bot:hasBuilding bot:Site_DC1 .

noria:Locus_NetworkRack1 a noria:Locus ;
    rdfs:label "Network Rack 1, Network Room B"@en ;
    rdfs:comment "Location for core routers and firewalls."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "1"@en .

