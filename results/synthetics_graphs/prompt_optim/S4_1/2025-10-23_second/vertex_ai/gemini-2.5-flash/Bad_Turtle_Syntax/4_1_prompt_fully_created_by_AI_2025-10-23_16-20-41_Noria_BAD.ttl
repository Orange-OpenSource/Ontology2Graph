# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord_WebServer01_Down a noria:EventRecord ;
    rdfs:label "Web Server 01 Down Alert"@en ;
    rdfs:comment "Automated alert indicating Web Server 01 is unreachable."@en ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:logText "Host web01.corp.example.com is DOWN. Ping failed."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_DBPerformance_Warning a noria:EventRecord ;
    rdfs:label "Database Performance Warning"@en ;
    rdfs:comment "Alert indicating high CPU usage on DB Server 01."@en ;
    noria:loggingTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:logText "DB Server db01.corp.example.com CPU usage > 90% for 15 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_RouterInterface_Down a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating GigabitEthernet0/0/0 on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/0, changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_FirewallLogin_Failed a noria:EventRecord ;
    rdfs:label "Firewall Failed Login Attempt"@en ;
    rdfs:comment "Multiple failed login attempts detected on Firewall 01."@en ;
    noria:loggingTime "2024-04-20T13:15:00Z"^^xsd:dateTime ;
    noria:logText "Failed login attempt for user 'admin' from IP 203.0.113.42 (5 times)."@en ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_WebOps_RestartWebServer a noria:EventRecord ;
    rdfs:label "WebOps Restart Web Server 01"@en ;
    rdfs:comment "Log entry for manual restart of Web Server 01 by WebOps team."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "Executed 'systemctl restart apache2' on web01.corp.example.com."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebServer01 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

