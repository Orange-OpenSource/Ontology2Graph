<kos/TroubleTicket/status/Closed> a skos:Concept ; skos:prefLabel "Closed"@en ; skos:inScheme <kos/TroubleTicket/status> .

# Trouble Ticket Origin
<kos/TroubleTicket/origin> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Origin Scheme"@en .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; skos:prefLabel "Customer"@en ; skos:inScheme <kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin/MonitoringSystem> a skos:Concept ; skos:prefLabel "Monitoring System"@en ; skos:inScheme <kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin/Internal> a skos:Concept ; skos:prefLabel "Internal"@en ; skos:inScheme <kos/TroubleTicket/origin> .

# Trouble Ticket Problem Responsibility
<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Problem Responsibility Scheme"@en .
<kos/TroubleTicket/problemResponsibility/NetworkTeam> a skos:Concept ; skos:prefLabel "Network Team"@en ; skos:inScheme <kos/TroubleTicket/problemResponsibility> .
<kos/TroubleTicket/problemResponsibility/ApplicationTeam> a skos:Concept ; skos:prefLabel "Application Team"@en ; skos:inScheme <kos/TroubleTicket/problemResponsibility> .
<kos/TroubleTicket/problemResponsibility/Vendor> a skos:Concept ; skos:prefLabel "Vendor"@en ; skos:inScheme <kos/TroubleTicket/problemResponsibility> .

# Trouble Ticket Note Comment Type
<kos/TroubleTicket/commentType> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Note Comment Type Scheme"@en .
