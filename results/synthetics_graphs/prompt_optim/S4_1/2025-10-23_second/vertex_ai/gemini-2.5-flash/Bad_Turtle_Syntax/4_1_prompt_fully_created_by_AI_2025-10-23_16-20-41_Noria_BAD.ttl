<kos/TroubleTicket/trouble-category/SecurityIncident> a skos:Concept ; skos:prefLabel "Security Incident"@en ; skos:inScheme <kos/TroubleTicket/trouble-category> .

# Trouble Ticket Status
<kos/TroubleTicket/status> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Status Scheme"@en .
<kos/TroubleTicket/status/Open> a skos:Concept ; skos:prefLabel "Open"@en ; skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; skos:prefLabel "In Progress"@en ; skos:inScheme <kos/TroubleTicket/status> .
