    noria:loggingTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_VirtualMachineWeb01 ;
    noria:logOriginatingManagementSystem noria:Application_LogManagementSystem ;
    noria:logText "Disk usage on /var/log on web01.corp.example.com is 90%."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

# Additional Trouble Ticket
noria:TroubleTicket_SecurityAlertTT a noria:TroubleTicket ;
    rdfs:label "Security Alert: Brute Force Attack"@en ;
    rdfs:comment "Critical security alert triggered by multiple failed login attempts."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T11:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedResource noria:Resource_LogServer01 ;
    noria:troubleTicketRelatedParty foaf:Agent_SecurityTeam ;
    noria:troubleTicketTrigger noria:EventRecord_LoginFailure .

# Additional Change Request
noria:ChangeRequest_WebVMDiskExpansion a noria:ChangeRequest ;
    rdfs:label "Web VM Disk Expansion"@en ;
    rdfs:comment "Expand disk space for Web Server VM 01 due to low disk space warning."@en ;
    noria:changeRequestPlannedStartTime "2024-04-21T00:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-21T00:30:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:Resource_VirtualMachineWeb01 ;
    noria:changeRequestOutageDuration "PT0H15M"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty foaf:Agent_AppDevTeam ;
    noria:changeRequestActorParty foaf:Agent_AppDevTeam ;
    noria:changeRequestIsRegulated false .

# Link EventRecord_DiskSpaceWarning to TroubleTicket_WebVMPerformanceTT
noria:TroubleTicket_WebVMPerformanceTT noria:troubleTicketTrigger noria:EventRecord_DiskSpaceWarning .

# Link ChangeRequest_WebVMDiskExpansion to EventRecord_DiskSpaceWarning as a mitigation
noria:EventRecord_DiskSpaceWarning noria:alarmMitigatedBy noria:ChangeRequest_WebVMDiskExpansion .

# Link ChangeRequest_WebVMDiskExpansion to the Web VM performance TT
noria:TroubleTicket_WebVMPerformanceTT dcterms:relation noria:ChangeRequest_WebVMDiskExpansion .

# Further enrich agents with managed resources
foaf:Agent_JohnDoe noria:agentManagesResource noria:NetworkInterface_DNS01_Eth0 .
foaf:Agent_JaneSmith noria:agentManagesResource noria:NetworkLink_CR01_ISP_A .
foaf:Agent_JaneSmith noria:agentManagesResource noria:NetworkLink_CR01_ISP_B .

# Add more details to existing entities
noria:Resource_DNSServer01 noria:elementDistinguishedName "dns01.corp.example.com" .
noria:Resource_CoreRouter01 noria:elementDistinguishedName "cr01.corp.example.com" .
noria:Application_CorporateInternetAccess noria:functionalElementDistinguishedName "Corporate Internet Access" .
noria:ApplicationModule_CIA_Prod noria:functionalElementDistinguishedName "CIA_PROD" .

# Example of a Corporate User Identifier
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Unique corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    observable:accountLogin "jdoe" ;
    observable:accountIdentifier "EMP-JD-001" ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

# Example of a more complex Operation Plan
noria:OperationPlan_ISP_Failover a noria:OperationPlan ;
    rdfs:label "ISP Failover Procedure"@en ;
    rdfs:comment "Procedure to switch network traffic from primary ISP A to secondary ISP B in case of outage."@en .

noria:ActionPreCondition_ISP_A_Down a noria:ActionPreCondition ;
    rdfs:label "ISP A Link Down"@en ;
    rdfs:comment "Pre-condition: Network Link CR01 to ISP A is down."@en .

noria:ActionPostCondition_ISP_B_Up a noria:ActionPostCondition ;
    rdfs:label "ISP B Link Up and Active"@en ;
    rdfs:comment "Post-condition: Network Link CR01 to ISP B is up and carrying traffic."@en .

noria:OperationPlan_ISP_Failover noria:operationPlanPreCondition noria:ActionPreCondition_ISP_A_Down ;
    noria:operationPlanPostCondition noria:ActionPostCondition_ISP_B_Up .

# Link RouterInterfaceDown TT to ISP Failover plan
noria:TroubleTicket_RouterInterfaceTT noria:troubleTicketCause "ISP A link failure" ;
    noria:troubleTicketCharacteristic noria:OperationPlan_ISP_Failover . # Using characteristic to link to a relevant plan

# Example of Anomaly Pattern
noria:AnomalyPattern_HighCPU_LowDisk a noria:AnomalyPattern ;
    rdfs:label "High CPU and Low Disk Space Anomaly"@en ;
    rdfs:comment "Anomaly pattern indicating potential performance issues or resource exhaustion when both CPU is high and disk space is low."@en ;
    folio:hasFailureMode "Resource Exhaustion" .

# Link EventRecord_WebVMHighCPU and EventRecord_DiskSpaceWarning to this anomaly pattern
noria:EventRecord_WebVMHighCPU dcterms:relation noria:AnomalyPattern_HighCPU_LowDisk .
noria:EventRecord_DiskSpaceWarning dcterms:relation noria:AnomalyPattern_HighCPU_LowDisk .

# Example of a freeze item for a trouble ticket
noria:EventRecord_TT_DNSOutage_Freeze a noria:EventRecord ;
    rdfs:label "DNS Outage TT Freeze Event"@en ;
    rdfs:comment "Trouble ticket put on hold awaiting external vendor response."@en ;
    noria:loggingTime "2024-04-20T08:45:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket DNSOutageTT status changed to 'Frozen' due to vendor dependency."@en .

noria:TroubleTicket_DNSOutageTT noria:troubleTicketFreezeItem noria:EventRecord_TT_DNSOutage_Freeze .

# Example of document external ID and href
noria:TroubleTicket_DNSOutageTT noria:documentExternalId "EXT-TT-12345" ;
    noria:documentHRef "https://ticketing.example.com/ticket/DNSOutageTT"^^xsd:anyURI .

noria:ChangeRequest_RouterOSUpgrade noria:documentExternalId "EXT-CR-67890" ;
    noria:documentHRef "https://changemanagement.example.com/cr/RouterOSUpgrade"^^xsd:anyURI .

# More detailed network interface properties
noria:NetworkInterface_CR01_Gi0_0_0 noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetworkInterface_CR01_Gi0_0_1 noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

