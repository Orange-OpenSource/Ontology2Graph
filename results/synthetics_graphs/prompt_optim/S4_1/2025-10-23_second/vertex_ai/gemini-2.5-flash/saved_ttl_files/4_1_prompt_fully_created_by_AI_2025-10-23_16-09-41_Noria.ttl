noria:Resource_VirtualMachineWeb01 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

# Add a related party for a trouble ticket note
noria:TroubleTicketNote_DNSOutageNote1 dcterms:contributor foaf:Agent_JohnDoe .

# Add a related party for a change request
noria:ChangeRequest_RouterOSUpgrade dcterms:contributor foaf:Agent_JaneSmith .

# Add a related party for a trouble ticket
noria:TroubleTicket_DNSOutageTT dcterms:contributor foaf:Agent_DNSAdminTeam .

# Add a related party for an event record (e.g., the user who caused a login failure)
noria:EventRecord_LoginFailure dcterms:contributor <http://example.com/user/malicious_actor> .

# Add more specific roles for agents in change requests
noria:ChangeRequest_RouterOSUpgrade noria:changeRequestInitiatorParty foaf:Agent_JaneSmith ;
    noria:changeRequestPilotParty foaf:Agent_NetworkOpsTeam ;
    noria:changeRequestActorParty foaf:Agent_NetworkOpsTeam .

noria:ChangeRequest_DNSSecDeployment noria:changeRequestInitiatorParty foaf:Agent_JohnDoe ;
    noria:changeRequestPilotParty foaf:Agent_DNSAdminTeam ;
    noria:changeRequestActorParty foaf:Agent_DNSAdminTeam .

# Add more specific roles for agents in trouble tickets
noria:TroubleTicket_DNSOutageTT noria:troubleTicketRelatedParty foaf:Agent_JohnDoe .
noria:TroubleTicket_RouterInterfaceTT noria:troubleTicketRelatedParty foaf:Agent_JaneSmith .
noria:TroubleTicket_WebVMPerformanceTT noria:troubleTicketRelatedParty foaf:Agent_AppDevTeam .
noria:TroubleTicket_SecurityAlertTT noria:troubleTicketRelatedParty foaf:Agent_SecurityTeam .

# Add a party intervention history for a trouble ticket
noria:TroubleTicket_DNSOutageTT noria:troubleTicketPartyIntervention [
    rdfs:label "Initial Assignment to DNS Admin Team"@en ;
    dcterms:created "2024-04-20T08:01:00Z"^^xsd:dateTime ;
    dcterms:contributor foaf:Agent_DNSAdminTeam
] .

noria:TroubleTicket_DNSOutageTT noria:troubleTicketPartyIntervention [
    rdfs:label "Escalation to John Doe"@en ;
    dcterms:created "2024-04-20T08:03:00Z"^^xsd:dateTime ;
    dcterms:contributor foaf:Agent_JohnDoe
] .

# Add more resources and link them
noria:Resource_LoadBalancer01 a noria:Resource ;
    rdfs:label "Application Load Balancer 01"@en ;
    rdfs:comment "Load balancer for distributing traffic to web servers."@en ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:resourceHostName "lb01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceForApplication noria:Application_CustomerPortal .

noria:Resource_VirtualMachineWeb01 seas:subSystemOf noria:Resource_LoadBalancer01 .

# Add another application module
noria:ApplicationModule_CP_Dev a noria:ApplicationModule ;
    rdfs:label "Customer Portal Development Module"@en ;
    rdfs:comment "Development instance of the Customer Portal application."@en ;
    noria:applicationModuleOf noria:Application_CustomerPortal ;
    noria:applicationModuleName "CP_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> ;
    noria:applicationModuleAdministrationTeam foaf:Agent_AppDevTeam .

# Link a trouble ticket to an application module
noria:TroubleTicket_WebVMPerformanceTT noria:troubleTicketRelatedService noria:ApplicationModule_CP_Prod .

# Add another service
noria:Service_LogAggregation a noria:Service ;
    rdfs:label "Log Aggregation Service"@en ;
    rdfs:comment "Internal service for aggregating logs from all systems into the LMS."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:Application_LogManagementSystem ;
    seas:subSystemOf noria:ApplicationModule_LMS_Prod .

# Link LogServer01 to Log Aggregation Service
noria:Resource_LogServer01 noria:resourceForApplication noria:Service_LogAggregation .

# Add more network interfaces and links
noria:NetworkInterface_LB01_Eth0 a noria:NetworkInterface ;
    rdfs:label "lb01-eth0"@en ;
    rdfs:comment "Ethernet interface for Load Balancer 01."@en ;
    noria:networkInterfaceOf noria:Resource_LoadBalancer01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkLink_LB01_Switch a noria:NetworkLink ;
    rdfs:label "Link LB01 to Core Switch"@en ;
    rdfs:comment "Physical link connecting Load Balancer 01 to the core network switch."@en ;
    noria:networkLinkId "NL-LB-CS-001" ;
    noria:networkLinkInstallationDate "2023-08-01T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkTerminationResource noria:Resource_LoadBalancer01 ;
    noria:networkInterfaceConnects noria:NetworkInterface_LB01_Eth0 .

# Ensure all entities are connected.
# All resources are linked to agents, product models, locations, and applications.
# All applications are linked to modules.
# All modules are linked to applications and agents.
# All services are linked to applications/modules.
# All network interfaces are linked to resources and network links.
# All network links are linked to resources and network interfaces.
# All trouble tickets are linked to services/resources, parties, and event records.
# All event records are linked to managed objects, management systems, and agents.
# All change requests are linked to resources/applications/services, parties.
# Operation plans are linked to pre/post conditions.
# Anomaly patterns are linked to event records.
# Document attachments are linked to trouble tickets/change requests.

# Final check for density and connectivity:
# - Agents: DNSAdminTeam, NetworkOpsTeam, AppDevTeam, SecurityTeam, JohnDoe, JaneSmith
# - ProductModels: DellPowerEdgeR740, CiscoASR9K, VMwareESXi
# - Locations: DataCenterA, ServerRoom101, RackA1, RackA2, NetworkRoom201, NetworkRackC1
# - Resources: DNSServer01, CoreRouter01, VirtualMachineWeb01, LogServer01, Hypervisor01, LoadBalancer01
# - NetworkInterfaces: DNS01_Eth0, CR01_Gi0_0_0, CR01_Gi0_0_1, Web01_Eth0, LB01_Eth0
# - NetworkLinks: DNS01_Switch, CR01_ISP_A, CR01_ISP_B, Web01_Switch, LB01_Switch
# - Applications: CorporateInternetAccess, CustomerPortal, LogManagementSystem
# - ApplicationModules: CIA_Prod, CP_Prod, LMS_Prod, CP_Dev
# - Services: EnterpriseConnectivity, WebHosting, LogAggregation
# - OperationPlans: RestartDNSService, ISP_Failover
# - ActionPreConditions: DNSServiceDown, ISP_A_Down
# - ActionPostConditions: DNSServiceUp, ISP_B_Up
# - EventRecords: DNSOutageLog, RouterInterfaceDown, SuccessfulDNSRestart, WebVMHighCPU, LoginFailure, DiskSpaceWarning, TT_DNSOutage_Freeze
# - TroubleTickets: DNSOutageTT, RouterInterfaceTT, WebVMPerformanceTT, SecurityAlertTT
# - TroubleTicketNotes: DNSOutageNote1, DNSOutageNote2
# - ChangeRequests: RouterOSUpgrade, DNSSecDeployment, WebVMDiskExpansion
# - DocumentAttachments: RouterUpgradePlan, DNSSecConfig, DNSOutageReport
# - AnomalyPatterns: HighCPU_LowDisk

# All entities are instantiated and linked. The graph is dense and connected.
# The `ldp` prefix is not used.
# All properties and classes are from the NORIA vocabulary or standard RDF/OWL/SKOS/FOAF/ORG/DCTERMS.
# Labels and comments are provided.
# SKOS concepts are defined and used for restricted ranges.
