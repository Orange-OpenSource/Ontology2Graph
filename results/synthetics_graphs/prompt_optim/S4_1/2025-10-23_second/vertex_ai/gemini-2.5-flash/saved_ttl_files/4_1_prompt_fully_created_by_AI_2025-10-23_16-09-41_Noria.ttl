# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

foaf:Agent_DNSAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and operations."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use emergency hotline after hours."@en .

foaf:Agent_NetworkOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing core network infrastructure."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always open a P1 ticket for network outages."@en .

foaf:Agent_AppDevTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "8:30 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 Operations"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Engineer for DNS Services."@en ;
    foaf:mbox "mailto:john.doe@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Network Architect."@en ;
    foaf:mbox "mailto:jane.smith@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_DellPowerEdgeR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for high-performance computing and virtualization."@en ;
    noria:productManufacturedBy <https://www.dell.com/en-us> .

noria:ProductModel_CiscoASR9K a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series Router"@en ;
    rdfs:comment "High-end router series for carrier-grade networks."@en ;
    noria:productManufacturedBy <https://www.cisco.com> .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy <https://www.vmware.com> .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:Site_DataCenterA a bot:Site ;
    rdfs:label "Primary Data Center A"@en ;
    rdfs:comment "Main data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC-A-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:Room_ServerRoom101 a noria:Room ;
    rdfs:label "Server Room 101"@en ;
    rdfs:comment "Main server room within Data Center A."@en ;
    bot:hasSpace bot:Site_DataCenterA .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Specific rack location in Server Room 101."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en ;
    bot:hasSpace noria:Room_ServerRoom101 .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Specific rack location in Server Room 101."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "2"@en ;
    bot:hasSpace noria:Room_ServerRoom101 .

noria:Room_NetworkRoom201 a noria:Room ;
    rdfs:label "Network Room 201"@en ;
    rdfs:comment "Dedicated room for network equipment in Data Center A."@en ;
    bot:hasSpace bot:Site_DataCenterA .

noria:Locus_NetworkRackC1 a noria:Locus ;
    rdfs:label "Network Rack C1"@en ;
    rdfs:comment "Specific rack for network devices in Network Room 201."@en ;
    noria:locusLine "C"@en ;
    noria:locusRow "1"@en ;
    bot:hasSpace noria:Room_NetworkRoom201 .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNSServer01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, physical machine."@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellPowerEdgeR740 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

noria:Resource_CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for internal network traffic."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "cr01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR9K ;
    noria:resourceLogisticId "ASSET-CR-001" ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-CR-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_NetworkRackC1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

noria:Resource_VirtualMachineWeb01 a noria:Resource ;
    rdfs:label "Web Server VM 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate website."@en ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The hypervisor model, not the VM itself
    noria:resourceLogisticId "ASSET-VM-WEB-001" ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.10> .

noria:Resource_LogServer01 a noria:Resource ;
    rdfs:label "Log Management Server 01"@en ;
    rdfs:comment "Server dedicated to collecting and processing logs from various systems."@en ;
    noria:resourceManagedBy foaf:Agent_SecurityTeam ;
    noria:resourceHostName "log01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellPowerEdgeR740 ;
    noria:resourceLogisticId "ASSET-LOG-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-LOG-001-PQR" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-02-10T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.20> .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "dns01-eth0"@en ;
    rdfs:comment "Ethernet interface for DNS Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DNSServer01 ;
    noria:networkInterfaceDescription "Primary network interface for management and DNS queries."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_CR01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "cr01-Gi0/0/0"@en ;
    rdfs:comment "GigabitEthernet interface 0/0/0 on Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to ISP A."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

