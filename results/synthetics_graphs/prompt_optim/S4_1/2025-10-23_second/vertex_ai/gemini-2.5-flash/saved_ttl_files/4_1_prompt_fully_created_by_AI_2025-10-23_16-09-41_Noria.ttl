# =============================================================================
# Additional Interconnections for Density
# =============================================================================

# Link resources to applications they support
noria:Resource_DNSServer01 noria:resourceForApplication noria:Application_CorporateInternetAccess .
noria:Resource_CoreRouter01 noria:resourceForApplication noria:Application_CorporateInternetAccess .
noria:Resource_VirtualMachineWeb01 noria:resourceForApplication noria:Application_CustomerPortal .
noria:Resource_LogServer01 noria:resourceForApplication noria:Application_LogManagementSystem .

# Link agents to resources they manage (inverse of resourceManagedBy)
foaf:Agent_DNSAdminTeam noria:agentManagesResource noria:Resource_DNSServer01 .
foaf:Agent_NetworkOpsTeam noria:agentManagesResource noria:Resource_CoreRouter01 .
foaf:Agent_AppDevTeam noria:agentManagesResource noria:Resource_VirtualMachineWeb01 .
foaf:Agent_SecurityTeam noria:agentManagesResource noria:Resource_LogServer01 .

# Link applications to their modules (inverse of applicationModuleOf)
noria:Application_CorporateInternetAccess seas:hasSubSystem noria:ApplicationModule_CIA_Prod .
noria:Application_CustomerPortal seas:hasSubSystem noria:ApplicationModule_CP_Prod .
noria:Application_LogManagementSystem seas:hasSubSystem noria:ApplicationModule_LMS_Prod .

# Link services to their components (inverse of seas:subSystemOf)
noria:Application_CorporateInternetAccess seas:hasSubSystem noria:Service_EnterpriseConnectivity .
noria:Application_CustomerPortal seas:hasSubSystem noria:Service_WebHosting .

# Link network interfaces to network links (inverse of networkInterfaceConnects)
noria:NetworkLink_DNS01_Switch seas:connectsSystemAt noria:NetworkInterface_DNS01_Eth0 .
noria:NetworkLink_CR01_ISP_A seas:connectsSystemAt noria:NetworkInterface_CR01_Gi0_0_0 .
noria:NetworkLink_CR01_ISP_B seas:connectsSystemAt noria:NetworkInterface_CR01_Gi0_0_1 .
noria:NetworkLink_Web01_Switch seas:connectsSystemAt noria:NetworkInterface_Web01_Eth0 .

# Example of a cluster controller
noria:Resource_Hypervisor01 a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical server hosting virtual machines, acting as a cluster controller."@en ;
    noria:resourceHostName "hv01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam .

noria:Resource_VirtualMachineWeb01 noria:clusterController noria:Resource_Hypervisor01 .

# Example of an alarm being mitigated by a procedure execution container (e.g., a trouble ticket)
noria:EventRecord_DNSOutageLog noria:alarmMitigatedBy noria:TroubleTicket_DNSOutageTT .

# Example of an operation plan being correlated to an action (e.g., a change request)
noria:ChangeRequest_RouterOSUpgrade noria:actionCorrelatedOperationPlan noria:OperationPlan_RestartDNSService . # Simplified for example, typically a more complex plan.

