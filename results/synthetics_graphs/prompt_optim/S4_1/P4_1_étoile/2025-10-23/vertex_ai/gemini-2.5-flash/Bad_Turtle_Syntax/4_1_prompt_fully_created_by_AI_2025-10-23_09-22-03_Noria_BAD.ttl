@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@base <https://w3id.org/noria/> .

# =============================================================================
# SKOS Concepts (for properties with skos:inScheme restrictions)
# =============================================================================

<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/service-platform> a skos:Concept ; rdfs:label "Service Platform"@en ; skos:inScheme <kos/application/type> .
<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High"@en ; skos:inScheme <kos/application/business-importance> .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium"@en ; skos:inScheme <kos/application/business-importance> .
<kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<kos/application/status/Maintenance> a skos:Concept ; rdfs:label "In Maintenance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .

<kos/TroubleTicket/severity/Critical> a skos:Concept ; rdfs:label "Critical"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Major> a skos:Concept ; rdfs:label "Major"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/type/Failure> a skos:Concept ; rdfs:label "Failure"@en ; skos:inScheme <kos/TroubleTicket/type> .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; rdfs:label "In Progress"@en ; skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved"@en ; skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal"@en ; skos:inScheme <kos/TroubleTicket/commentType> .
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis"@en ; skos:inScheme <kos/TroubleTicket/operationType> .
<kos/TroubleTicket/trouble-category/TotalBreakdown> a skos:Concept ; rdfs:label "Total Breakdown"@en ; skos:inScheme <kos/TroubleTicket/trouble-category> .
<kos/TroubleTicket/problemResponsibility/ManagedBackbone> a skos:Concept ; rdfs:label "Managed Backbone Networks"@en ; skos:inScheme <kos/TroubleTicket/problemResponsibility> .

<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard Change"@en ; skos:inScheme <kos/ChangeRequest/type> .
<kos/ChangeRequest/status/Approved> a skos:Concept ; rdfs:label "Approved"@en ; skos:inScheme <kos/ChangeRequest/status> .
<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ; rdfs:label "Software Upgrade"@en ; skos:inScheme <kos/ChangeRequest/cause> .

<kos/Resource/type/Server> a skos:Concept ; rdfs:label "Server"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/Router> a skos:Concept ; rdfs:label "Router"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/VirtualMachine> a skos:Concept ; rdfs:label "Virtual Machine"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/LifecycleState/InUse> a skos:Concept ; rdfs:label "In Use"@en ; skos:inScheme <kos/Resource/LifecycleState> .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; rdfs:label "Decommissioned"@en ; skos:inScheme <kos/Resource/LifecycleState> .
<kos/Resource/AdministrativeState/up> a skos:Concept ; rdfs:label "Up"@en ; skos:inScheme <kos/Resource/AdministrativeState> .
<kos/Resource/AdministrativeState/down> a skos:Concept ; rdfs:label "Down"@en ; skos:inScheme <kos/Resource/AdministrativeState> .
<kos/Resource/OperationalState/up> a skos:Concept ; rdfs:label "Up"@en ; skos:inScheme <kos/Resource/OperationalState> .
<kos/Resource/OperationalState/down> a skos:Concept ; rdfs:label "Down"@en ; skos:inScheme <kos/Resource/OperationalState> .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; rdfs:label "Critical"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; rdfs:label "Warning"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<kos/Notification/EventType/stateChange> a skos:Concept ; rdfs:label "State Change"@en ; skos:inScheme <kos/Notification/EventType> .
<kos/Notification/EventType/thresholdExceeded> a skos:Concept ; rdfs:label "Threshold Exceeded"@en ; skos:inScheme <kos/Notification/EventType> .

<kos/service/type/CustomerFacingService> a skos:Concept ; rdfs:label "Customer Facing Service"@en ; skos:inScheme <kos/service/type> .
<kos/service/type/ResourceFacingService> a skos:Concept ; rdfs:label "Resource Facing Service"@en ; skos:inScheme <kos/service/type> .

<kos/org/agent-contact-method/Email> a skos:Concept ; rdfs:label "Email"@en ; skos:inScheme <kos/org/agent-contact-method> .
<kos/org/agent-contact-method/Phone> a skos:Concept ; rdfs:label "Phone"@en ; skos:inScheme <kos/org/agent-contact-method> .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

:Agent_DNSAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:label "Équipe Admin DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email to dns-support@example.com for all inquiries."@en .

:Agent_NetworkOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:label "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for network infrastructure monitoring and maintenance."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call hotline for critical issues, use ticketing system for routine requests."@en .

:Agent_AppSupportTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:label "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing L2 support for critical business applications."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:label "Jean Dupont"@fr ;
    rdfs:comment "Individual member of the Network Operations Team."@en ;
    foaf:mbox "mailto:john.doe@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:label "Jeanne Martin"@fr ;
    rdfs:comment "Lead of the Application Support Team."@en ;
    foaf:mbox "mailto:jane.smith@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

:Org_Dell a org:Organization ;
    rdfs:label "Dell Inc."@en ;
    rdfs:comment "Manufacturer of IT hardware."@en .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

:Site_DC_Paris a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

:Room_ServerRoom_A a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Primary server room within Paris Data Center."@en ;
    bot:hasSpace :Locus_Rack_A1, :Locus_Rack_A2 ;
    bot:hasSubSpace :Site_DC_Paris . # Using bot:hasSubSpace to link room to site

:Locus_Rack_A1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of critical infrastructure servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

:Locus_Rack_A2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of application servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

:ProductModel_Dell_R740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy :Org_Dell .

:ProductModel_Cisco_ASR9K a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series Router"@en ;
    rdfs:comment "Carrier-grade aggregation services router."@en ;
    noria:productManufacturedBy :Org_Cisco . # Assuming Cisco is an org:Organization

:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:label "Serveur DNS d'entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, critical for internet access."@en ;
    noria:resourceManagedBy :Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_Dell_R740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_Rack_A1 ;
    noria:resourceManagementIPAddress "192.168.1.10" .

:Resource_Router_Edge01 a noria:Resource ;
    rdfs:label "Edge Router 01"@en ;
    rdfs:label "Routeur Edge 01"@fr ;
    rdfs:comment "Edge router connecting the corporate network to the internet."@en ;
    noria:resourceManagedBy :Agent_NetworkOpsTeam ;
    noria:resourceHostName "edge01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_Cisco_ASR9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-EDGE-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_Rack_A1 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

:Resource_VM_AppDB a noria:Resource ;
    rdfs:label "Application Database VM"@en ;
    rdfs:label "VM Base de Données Application"@fr ;
    rdfs:comment "Virtual machine hosting the database for the main business application."@en ;
    noria:resourceManagedBy :Agent_AppSupportTeam ;
    noria:resourceHostName "appdb01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-05-01T08:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_Rack_A2 ;
    noria:resourceManagementIPAddress "172.16.0.50" .

:Resource_VM_WebApp a noria:Resource ;
    rdfs:label "Web Application VM"@en ;
    rdfs:label "VM Application Web"@fr ;
    rdfs:comment "Virtual machine hosting the web front-end for the main business application."@en ;
    noria:resourceManagedBy :Agent_AppSupportTeam ;
    noria:resourceHostName "webapp01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-05-01T08:15:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_Rack_A2 ;
    noria:resourceManagementIPAddress "172.16.0.51" ;
    noria:clusterController :Resource_VM_Host01 . # Example of cluster controller

:Resource_VM_Host01 a noria:Resource ;
    rdfs:label "VMware ESXi Host 01"@en ;
    rdfs:comment "Physical host for virtual machines."@en ;
    noria:resourceManagedBy :Agent_NetworkOpsTeam ;
    noria:resourceHostName "esxi01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_Dell_R740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:locatedAtLocus :Locus_Rack_A2 .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

:NI_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "dns01-eth0"@en ;
    rdfs:comment "Ethernet interface for DNS server."@en ;
    noria:networkInterfaceOf :Resource_DNS01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceType "physical" .

:NI_Edge01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "edge01-Gi0/0/0"@en ;
    rdfs:comment "GigabitEthernet interface connecting to ISP."@en ;
    noria:networkInterfaceOf :Resource_Router_Edge01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceType "physical" .

:NI_Edge01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "edge01-Gi0/0/1"@en ;
    rdfs:comment "GigabitEthernet interface connecting to internal network."@en ;
    noria:networkInterfaceOf :Resource_Router_Edge01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 ;
    noria:networkInterfaceType "physical" .

:NI_VMAppDB_Eth0 a noria:NetworkInterface ;
    rdfs:label "appdb01-eth0"@en ;
    rdfs:comment "Virtual Ethernet interface for Application Database VM."@en ;
    noria:networkInterfaceOf :Resource_VM_AppDB ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceType "virtual" .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

:NL_ISP_Edge01 a noria:NetworkLink ;
    rdfs:label "ISP Uplink to Edge01"@en ;
    rdfs:comment "External link from ISP to Edge Router 01."@en ;
    noria:networkLinkId "NL-ISP-EDGE01-001" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2021-03-20T14:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource :Resource_Router_Edge01 ;
    noria:networkInterfaceConnects :NI_Edge01_Gi0_0_0 .

:NL_Edge01_DNS01 a noria:NetworkLink ;
    rdfs:label "Edge01 to DNS01 Link"@en ;
    rdfs:comment "Internal link between Edge Router 01 and DNS Server 01."@en ;
    noria:networkLinkId "NL-EDGE01-DNS01-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-15T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin :Resource_Router_Edge01 ;
    noria:networkLinkTerminationResourceDestination :Resource_DNS01 ;
    noria:networkInterfaceConnects :NI_Edge01_Gi0_0_1, :NI_DNS01_Eth0 .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

:App_CorpInternetAccess a noria:Application ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:label "Accès Internet Entreprise"@fr ;
    rdfs:comment "Provides internet access for all corporate users."@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Internet Gateway" ;
    noria:applicationModelIdentifier "CIA-APP" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CIA" ;
    noria:resourceForApplication :Resource_DNS01, :Resource_Router_Edge01 .

:App_BusinessAppSuite a noria:Application ;
    rdfs:label "Business Application Suite"@en ;
    rdfs:label "Suite d'Applications Métier"@fr ;
    rdfs:comment "Core suite of applications for business operations."@en ;
    noria:applicationType <kos/application/type/service-platform> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Enterprise Resource Planning" ;
    noria:applicationFunctionalSubDomain "Customer Relationship Management" ;
    noria:applicationModelIdentifier "BAS-APP" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "BAS" ;
    noria:resourceForApplication :Resource_VM_AppDB, :Resource_VM_WebApp .

# =============================================================================
# Application Modules (noria:ApplicationModule)
# =============================================================================

:AppModule_CIA_Prod a noria:ApplicationModule ;
    rdfs:label "Corporate Internet Access - Production"@en ;
    rdfs:label "Accès Internet Entreprise - Production"@fr ;
    rdfs:comment "Production instance of the Corporate Internet Access application."@en ;
    noria:applicationModuleOf :App_CorpInternetAccess ;
    noria:applicationModuleName "CIA_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam :Agent_NetworkOpsTeam ;
    noria:applicationModuleSupportTeam :Agent_NetworkOpsTeam ;
    noria:applicationModuleAdministrationLeader :Agent_JohnDoe ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

:AppModule_BAS_Prod a noria:ApplicationModule ;
    rdfs:label "Business App Suite - Production"@en ;
    rdfs:label "Suite App Métier - Production"@fr ;
    rdfs:comment "Production instance of the Business Application Suite."@en ;
    noria:applicationModuleOf :App_BusinessAppSuite ;
    noria:applicationModuleName "BAS_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam :Agent_AppSupportTeam ;
    noria:applicationModuleSupportTeam :Agent_AppSupportTeam ;
    noria:applicationModuleAdministrationLeader :Agent_JaneSmith ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

:AppModule_BAS_Dev a noria:ApplicationModule ;
    rdfs:label "Business App Suite - Development"@en ;
    rdfs:label "Suite App Métier - Développement"@fr ;
    rdfs:comment "Development instance of the Business Application Suite."@en ;
    noria:applicationModuleOf :App_BusinessAppSuite ;
    noria:applicationModuleName "BAS_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleStatus <kos/application/status/Maintenance> ;
    noria:applicationModuleAdministrationTeam :Agent_AppSupportTeam ;
    noria:applicationModuleSupportTeam :Agent_AppSupportTeam ;
    noria:applicationModuleAdministrationLeader :Agent_JaneSmith ;
    noria:applicationModuleHotlineEnabled false .

# =============================================================================
# Services (noria:Service)
# =============================================================================

:Service_CorpConnectivity a noria:Service ;
    rdfs:label "Corporate Connectivity Service"@en ;
    rdfs:label "Service de Connectivité d'Entreprise"@fr ;
    rdfs:comment "End-to-end service providing network connectivity to all corporate sites."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :App_CorpInternetAccess . # Linking service to application as a subsystem

:Service_CRM_Access a noria:Service ;
    rdfs:label "CRM Access Service"@en ;
    rdfs:label "Service d'Accès CRM"@fr ;
    rdfs:comment "Service providing access to the Customer Relationship Management module of the Business App Suite."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :App_BusinessAppSuite . # Linking service to application as a subsystem

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

:Event_DNS_Down a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Event"@en ;
    rdfs:comment "Log entry indicating that the primary DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN" ;
    noria:logOriginatingManagedObject :Resource_DNS01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ; # Assuming a monitoring system application
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    dcterms:type <kos/Notification/EventType/stateChange> .

:App_MonitoringSystem a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:comment "Application responsible for collecting and analyzing system logs and metrics."@en ;
    noria:applicationType <kos/application/type/service-platform> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> .

:Event_Interface_Down a noria:EventRecord ;
    rdfs:label "Edge Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a critical interface on the edge router went down."@en ;
    noria:loggingTime "2024-04-20T08:55:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/0, changed state to down" ;
    noria:logOriginatingManagedObject :Resource_Router_Edge01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    dcterms:type <kos/Notification/EventType/stateChange> .

:Event_CPU_High a noria:EventRecord ;
    rdfs:label "VM CPU Usage High Warning"@en ;
    rdfs:comment "Warning event for high CPU usage on the web application VM."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logText "WARNING: CPU usage on webapp01.corp.example.com exceeded 80% for 5 minutes." ;
    noria:logOriginatingManagedObject :Resource_VM_WebApp ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    dcterms:type <kos/Notification/EventType/thresholdExceeded> .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

:TT_DNS_Outage_001 a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:label "Incident Panne Serveur DNS"@fr ;
    rdfs:comment "Primary DNS server unreachable, impacting corporate internet access."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
