# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

:OP_Router_Firmware_Update a noria:OperationPlan ;
    rdfs:label "Router Firmware Update Procedure"@en ;
    rdfs:comment "Standard operating procedure for updating router firmware."@en ;
    noria:operationPlanPreCondition :APC_Router_Backup ;
    noria:operationPlanPostCondition :APOC_Router_Operational .

:APC_Router_Backup a noria:ActionPreCondition ;
    rdfs:label "Router Configuration Backup Completed"@en ;
    rdfs:comment "Ensure a full configuration backup of the router is completed before starting the update."@en .

:APOC_Router_Operational a noria:ActionPostCondition ;
    rdfs:label "Router Operational After Update"@en ;
    rdfs:comment "Verify router is fully operational, all interfaces up, and routing protocols converged after update."@en .

:OP_DNS_Troubleshooting a noria:OperationPlan ;
    rdfs:label "DNS Server Troubleshooting Guide"@en ;
    rdfs:comment "Procedure for diagnosing and resolving DNS server issues."@en ;
    noria:operationPlanPreCondition :APC_DNS_Connectivity_Check ;
    noria:operationPlanPostCondition :APOC_DNS_Resolution_Restored .

:APC_DNS_Connectivity_Check a noria:ActionPreCondition ;
    rdfs:label "DNS Server Connectivity Check"@en ;
    rdfs:comment "Verify basic network connectivity to the DNS server (ping, traceroute)."@en .

:APOC_DNS_Resolution_Restored a noria:ActionPostCondition ;
    rdfs:label "DNS Resolution Restored"@en ;
    rdfs:comment "Confirm DNS resolution is working correctly from client machines."@en .

# Linking Operation Plan to Change Request
:CR_Router_Upgrade_001 noria:actionCorrelatedOperationPlan :OP_Router_Firmware_Update .

# Linking Operation Plan to Trouble Ticket (as a potential repair action)
:Event_DNS_Down noria:alarmProposedRepairAction :OP_DNS_Troubleshooting .
