    noria:applicationModuleAdministrationTeam foaf:Agent/AppSupportTeam .

# =============================================================================
# Services (noria:Service)
# =============================================================================

noria:Service/EnterpriseConnectivity a noria:Service ;
    rdfs:label "Enterprise Connectivity Service"@en ;
