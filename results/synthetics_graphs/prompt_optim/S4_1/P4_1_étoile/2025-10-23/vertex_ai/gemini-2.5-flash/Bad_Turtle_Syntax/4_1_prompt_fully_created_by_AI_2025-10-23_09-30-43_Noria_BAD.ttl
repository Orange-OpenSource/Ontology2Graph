# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord/DNS01InterfaceDown a noria:EventRecord ;
    rdfs:label "DNS01 Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on DNS01 went down."@en ;
    noria:loggingTime "2024-04-20T08:00:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface Ethernet0 on DNS01, changed state to down"@en ;
    noria:logOriginatingManagedObject noria:Resource/DNS01 ;
    noria:logOriginatingManagementSystem noria:Application/MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord/RouterCore01ConfigChange a noria:EventRecord ;
    rdfs:label "RouterCore01 Configuration Change Event"@en ;
    rdfs:comment "Log entry for a configuration change on RouterCore01."@en ;
    noria:loggingTime "2024-04-19T15:30:00Z"^^xsd:dateTime ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by JohnDoe (10.0.0.50)"@en ;
    noria:logOriginatingManagedObject noria:Resource/RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application/MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent/JohnDoe ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord/DNS01InterfaceUp a noria:EventRecord ;
    rdfs:label "DNS01 Interface Up Event"@en ;
    rdfs:comment "Log entry indicating a network interface on DNS01 came back up."@en ;
    noria:loggingTime "2024-04-20T08:45:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface Ethernet0 on DNS01, changed state to up"@en ;
    noria:logOriginatingManagedObject noria:Resource/DNS01 ;
    noria:logOriginatingManagementSystem noria:Application/MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

noria:TroubleTicket/TT-20240420-001 a noria:TroubleTicket ;
    rdfs:label "DNS Server Interface Down Incident"@en ;
    rdfs:comment "Critical incident: Primary DNS server interface went down, impacting corporate internet access."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketRelatedService noria:Application/CorporateInternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource/DNS01 ;
    noria:troubleTicketRelatedParty foaf:Agent/DNSAdminTeam ;
    noria:troubleTicketRelatedParty foaf:Agent/NetworkOpsTeam ;
    noria:troubleTicketTrigger noria:EventRecord/DNS01InterfaceDown ;
    noria:troubleTicketDescription "DNS server dns01.corp.example.com's primary interface (Ethernet0) reported down at 08:00 UTC. This is causing widespread internet access issues."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-20T08:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:documentHRef "https://ticketing.example.com/TT-20240420-001"^^xsd:anyURI .

# =============================================================================
# Trouble Ticket Notes (noria:TroubleTicketNote)
# =============================================================================

noria:TroubleTicketNote/TT-20240420-001-Note1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis Note for TT-20240420-001"@en ;
    rdfs:comment "Initial investigation shows no physical cable damage. Suspect configuration drift or software issue. Escalated to Network Ops."@en ;
    dcterms:isPartOf noria:TroubleTicket/TT-20240420-001 ;
    dcterms:created "2024-04-20T08:15:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent/JohnDoe ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

noria:TroubleTicketNote/TT-20240420-001-Note2 a noria:TroubleTicketNote ;
    rdfs:label "Resolution Note for TT-20240420-001"@en ;
    rdfs:comment "Interface configuration reloaded. Interface is now up. Monitoring for stability. Root cause analysis pending."@en ;
    dcterms:isPartOf noria:TroubleTicket/TT-20240420-001 ;
    dcterms:created "2024-04-20T08:40:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent/NetworkOpsTeam ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Resolution> ;
    noria:troubleTicketNoteCorrelatedExecution noria:EventRecord/DNS01InterfaceUp .

# Update TroubleTicket status based on notes
noria:TroubleTicket/TT-20240420-001 noria:documentStatusHistory noria:EventRecord/DNS01InterfaceUp .
noria:TroubleTicket/TT-20240420-001 noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> .
noria:TroubleTicket/TT-20240420-001 noria:troubleTicketPlannedRestorationDateTime "2024-04-20T08:45:00Z"^^xsd:dateTime .

# =============================================================================
# Change Requests (noria:ChangeRequest)
# =============================================================================

noria:ChangeRequest/CR-20240422-001 a noria:ChangeRequest ;
    rdfs:label "DNS01 Interface Configuration Hardening"@en ;
    rdfs:comment "Implement persistent configuration for DNS01 Ethernet0 interface to prevent future configuration drift."@en ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:Resource/DNS01 ;
    noria:changeRequestImpact noria:NetworkInterface/DNS01-Eth0 ;
    noria:changeRequestInitiatorParty foaf:Agent/JohnDoe ;
    noria:changeRequestPilotParty foaf:Agent/NetworkOpsTeam ;
    noria:changeRequestActorParty foaf:Agent/NetworkOpsTeam ;
    noria:changeRequestPlannedStartTime "2024-04-22T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-22T23:00:00Z"^^xsd:dateTime ;
    noria:changeRequestOutageDuration "PT15M"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:documentHRef "https://changemanagement.example.com/CR-20240422-001"^^xsd:anyURI .

# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OperationPlan/DNSInterfaceFix a noria:OperationPlan ;
    rdfs:label "DNS Interface Troubleshooting and Fix Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving DNS server network interface issues."@en .

noria:OperationPlan/ConfigHardeningProcedure a noria:OperationPlan ;
    rdfs:label "Configuration Hardening Procedure"@en ;
    rdfs:comment "Procedure for making network device configurations persistent and resilient to reboots."@en .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:ActionPreCondition/InterfaceDownDetected a noria:ActionPreCondition ;
    rdfs:label "Interface Down Detected"@en ;
    rdfs:comment "Pre-condition: An alarm or log indicates a network interface is down."@en .

noria:ActionPostCondition/InterfaceOperational a noria:ActionPostCondition ;
    rdfs:label "Interface Operational"@en ;
    rdfs:comment "Post-condition: Network interface is up and passing traffic."@en .

noria:OperationPlan/DNSInterfaceFix noria:operationPlanPreCondition noria:ActionPreCondition/InterfaceDownDetected ;
    noria:operationPlanPostCondition noria:ActionPostCondition/InterfaceOperational .

noria:ChangeRequest/CR-20240422-001 noria:actionCorrelatedOperationPlan noria:OperationPlan/ConfigHardeningProcedure .

