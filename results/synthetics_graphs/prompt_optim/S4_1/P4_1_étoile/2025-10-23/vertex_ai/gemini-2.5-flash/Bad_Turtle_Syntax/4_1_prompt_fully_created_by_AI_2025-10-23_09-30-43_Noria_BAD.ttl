# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

foaf:Agent/DNSAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for corporate DNS server management."@en ;
    noria:agentWorkingHours "08:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for critical issues."@en .

foaf:Agent/NetworkOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for core network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Use emergency hotline for P1/P2 incidents."@en .

foaf:Agent/AppSupportTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for critical business applications."@en ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent/JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead engineer for DNS infrastructure."@en ;
    foaf:mbox "mailto:john.doe@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent/JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Incident Manager."@en ;
    foaf:mbox "mailto:jane.smith@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:Site/DataCenterA a bot:Site ;
    rdfs:label "Primary Data Center A"@en ;
    noria:siteId "DC-A-01"@en ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddressStreet "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:Room/ServerRoom101 a noria:Room ;
    rdfs:label "Server Room 101"@en ;
    rdfs:comment "Main server room in Data Center A."@en ;
    bot:hasSpace bot:Site/DataCenterA . # bot:hasSpace is inverse of bot:containsZone, so bot:Site/DataCenterA bot:containsZone noria:Room/ServerRoom101

noria:Locus/RackA1L5 a noria:Locus ;
    rdfs:label "Rack A1, Position 5"@en ;
    rdfs:comment "Specific location for critical infrastructure."@en ;
    noria:locusLine "A1"@en ;
    noria:locusRow "5"@en ;
    bot:hasSpace noria:Room/ServerRoom101 . # bot:hasSpace is inverse of bot:containsZone

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel/DellPowerEdgeR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy <https://www.dell.com/en-us> . # Assuming Dell is an org:Organization

noria:ProductModel/CiscoCatalyst9300 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Enterprise-class access layer switch."@en ;
    noria:productManufacturedBy <https://www.cisco.com> . # Assuming Cisco is an org:Organization

noria:ProductModel/JuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480"@en ;
    rdfs:comment "Modular router for service provider and enterprise applications."@en ;
    noria:productManufacturedBy <https://www.juniper.net> . # Assuming Juniper is an org:Organization

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource/DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, critical for internet access."@en ;
    noria:resourceManagedBy foaf:Agent/DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com"@en ;
    noria:resourceProductModel noria:ProductModel/DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ789"@en ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus/RackA1L5 ;
    noria:resourceManagementIPAddress "10.0.0.10" .

noria:Resource/RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate backbone network."@en ;
    noria:resourceManagedBy foaf:Agent/NetworkOpsTeam ;
    noria:resourceHostName "router-core01.corp.example.com"@en ;
    noria:resourceProductModel noria:ProductModel/JuniperMX480 ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR01-ABC123"@en ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-08-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus/RackA1L5 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource/VMWeb01 a noria:Resource ;
    rdfs:label "Web Application VM 01"@en ;
    rdfs:comment "Virtual machine hosting a critical web application."@en ;
    noria:resourceManagedBy foaf:Agent/AppSupportTeam ;
    noria:resourceHostName "web01.app.example.com"@en ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "172.16.1.50" .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetworkInterface/DNS01-Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource/DNS01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface/RouterCore01-Ge000 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Uplink interface from Core Router 01 to external network."@en ;
    noria:networkInterfaceOf noria:Resource/RouterCore01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 .

noria:NetworkInterface/RouterCore01-Ge001 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 01 to internal network segment."@en ;
    noria:networkInterfaceOf noria:Resource/RouterCore01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NetworkLink/CoreToDNSLink a noria:NetworkLink ;
    rdfs:label "Core to DNS Server Link"@en ;
    rdfs:comment "Direct link between Core Router 01 and DNS01 server."@en ;
    noria:networkLinkId "NL-CORE-DNS-001"@en ;
    noria:networkLinkType "Ethernet 10G"@en ;
    noria:networkLinkInstallationDate "2022-03-15T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent/NetworkOpsTeam ;
    noria:networkLinkTerminationResourceOrigin noria:Resource/RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource/DNS01 ;
    noria:networkInterfaceConnects noria:NetworkInterface/RouterCore01-Ge001 ;
    noria:networkInterfaceConnects noria:NetworkInterface/DNS01-Eth0 .

noria:NetworkLink/UplinkToISP a noria:NetworkLink ;
    rdfs:label "Uplink to ISP"@en ;
    rdfs:comment "External uplink from Core Router 01 to Internet Service Provider."@en ;
    noria:networkLinkId "NL-ISP-001"@en ;
    noria:networkLinkType "Fiber Optic 100G"@en ;
    noria:networkLinkInstallationDate "2021-07-20T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent/NetworkOpsTeam ;
    noria:networkLinkTerminationResource noria:Resource/RouterCore01 ;
    noria:networkInterfaceConnects noria:NetworkInterface/RouterCore01-Ge000 .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

noria:Application/CorporateInternetAccess a noria:Application ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users."@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Services"@en ;
    noria:applicationFunctionalSubDomain "DNS Resolution"@en ;
    noria:resourceForApplication noria:Resource/DNS01 ;
    noria:resourceForApplication noria:Resource/RouterCore01 .

noria:Application/MonitoringSystem a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:comment "Collects and analyzes logs and metrics from all IT infrastructure."@en ;
    noria:applicationType <kos/application/type/monitoring> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "IT Operations"@en ;
    noria:applicationFunctionalSubDomain "Event Management"@en .

noria:Application/WebAppPortal a noria:Application ;
    rdfs:label "Internal Web Portal"@en ;
    rdfs:comment "Hosts various internal web applications for employees."@en ;
    noria:applicationType <kos/application/type/business> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Employee Services"@en ;
    noria:applicationFunctionalSubDomain "HR & Finance Access"@en ;
    noria:resourceForApplication noria:Resource/VMWeb01 .

