# =============================================================================
# Services (noria:Service)
# =============================================================================

noria:Service_EnterpriseConnectivity
    a noria:Service ;
    rdfs:label "Enterprise Connectivity Service"@en ;
    rdfs:label "Service de Connectivité d'Entreprise"@fr ;
    rdfs:comment "Overall service providing network connectivity to the enterprise."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:AppMod_CorpInternetAccess_Prod . # A service can group application modules

noria:Service_CustomerFacingWeb
    a noria:Service ;
    rdfs:label "Customer Facing Web Service"@en ;
    rdfs:label "Service Web Client"@fr ;
    rdfs:comment "Service encompassing all customer-facing web applications."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:AppMod_CustomerPortal_Prod .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

noria:TT_DNSOutage
    a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:label "Incident de panne du serveur DNS"@fr ;
    rdfs:comment "Primary DNS server unreachable, causing widespread internet access issues."@en ;
    dcterms:created "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-10T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
