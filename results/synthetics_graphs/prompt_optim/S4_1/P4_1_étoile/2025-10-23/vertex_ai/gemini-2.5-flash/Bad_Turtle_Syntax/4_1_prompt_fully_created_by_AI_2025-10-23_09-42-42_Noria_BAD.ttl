# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot:  <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

foaf:Agent_AdminTeam
    a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:label "Équipe d'administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and configuration."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Use ticketing system for all requests. For critical issues, call the hotline."@en .

foaf:Agent_NetworkOps
    a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:label "Équipe d'opérations réseau"@fr ;
    rdfs:comment "Team managing core network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always open a trouble ticket first, then call the on-call engineer."@en .

foaf:Agent_AppDev
    a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:label "Équipe de développement applicatif"@fr ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> .

foaf:Agent_User1
    a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:label "Jean Dupont"@fr ;
    rdfs:comment "An end-user reporting an issue with the customer portal."@en .

org:OrgUnit_L2Support
    a org:OrganizationalUnit ;
    rdfs:label "L2 Application Support"@en ;
    rdfs:label "Support Applicatif N2"@fr ;
    rdfs:comment "Second-level support for critical business applications."@en ;
    noria:agentWorkingHours "8:00 am - 8:00 pm (Mon-Sun)"@en .

org:OrgUnit_Hotline
    a org:OrganizationalUnit ;
    rdfs:label "Hotline Team"@en ;
    rdfs:label "Équipe d'astreinte"@fr ;
    rdfs:comment "On-call team for urgent incidents outside business hours."@en ;
    noria:agentWorkingHours "24/7"@en .

foaf:Agent_CRInitiator
    a foaf:Agent ;
    rdfs:label "Project Manager Alice"@en ;
    rdfs:comment "Project Manager initiating a change request."@en .

foaf:Agent_CRPilot
    a foaf:Agent ;
    rdfs:label "Technical Lead Bob"@en ;
    rdfs:comment "Technical Lead piloting the execution of a change request."@en .

foaf:Agent_CRActor
    a foaf:Agent ;
    rdfs:label "System Engineer Charlie"@en ;
    rdfs:comment "System Engineer acting on a change request."@en .

foaf:Agent_SecurityTeam
    a foaf:Agent ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:label "Centre d'Opérations de Sécurité"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:Site_ParisDC
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:label "Centre de Données de Paris"@fr ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:label "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace bot:Site_ParisDC .

noria:Locus_Rack12_U24
    a noria:Locus ;
    rdfs:label "Rack 12, Unit 24"@en ;
    rdfs:label "Baie 12, Unité 24"@fr ;
    rdfs:comment "Specific location within Server Room A for equipment installation."@en ;
    noria:locusLine "12" ;
    noria:locusRow "24" ;
    bot:hasZone noria:Room_ServerRoomA .

bot:Site_LyonOffice
    a bot:Site ;
    rdfs:label "Lyon Office"@en ;
    rdfs:label "Bureau de Lyon"@fr ;
    rdfs:comment "Regional office in Lyon."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_NetworkCloset
    a noria:Room ;
    rdfs:label "Network Closet"@en ;
    rdfs:label "Local Réseau"@fr ;
    rdfs:comment "Small room housing network equipment in Lyon office."@en ;
    bot:hasSpace bot:Site_LyonOffice .

noria:Locus_PatchPanel_A
    a noria:Locus ;
    rdfs:label "Patch Panel A"@en ;
    rdfs:label "Panneau de Brassage A"@fr ;
    rdfs:comment "Location of the main patch panel in the network closet."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasZone noria:Room_NetworkCloset .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_DellR740
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for various applications."@en ;
    noria:productManufacturedBy <https://www.dell.com/> .

noria:ProductModel_CiscoNexus9K
    a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "High-performance data center switch series."@en ;
    noria:productManufacturedBy <https://www.cisco.com/> .

noria:ProductModel_VMwareESXi
    a noria:ProductModel ;
    rdfs:label "VMware ESXi Host"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy <https://www.vmware.com/> .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNS01
    a noria:Resource ;
    rdfs:label "Corporate DNS Server"@en ;
    rdfs:label "Serveur DNS d'entreprise"@fr ;
    rdfs:comment "Primary DNS server for corporate network, critical infrastructure."@en ;
    noria:resourceManagedBy foaf:Agent_AdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U24 ;
    noria:resourceManagementIPAddress "192.168.1.10" .

noria:Resource_RouterCore1
    a noria:Resource ;
    rdfs:label "Core Router 1"@en ;
    rdfs:label "Routeur Cœur 1"@fr ;
    rdfs:comment "Main router for internal network traffic and external connectivity."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:resourceHostName "router-core-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U24 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_AppServer01
    a noria:Resource ;
    rdfs:label "Application Server 01"@en ;
    rdfs:label "Serveur Applicatif 01"@fr ;
    rdfs:comment "Server hosting critical business applications."@en ;
    noria:resourceManagedBy foaf:Agent_AppDev ;
    noria:resourceHostName "appserver-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceSerialNumber "SN-APP-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U24 ;
    noria:resourceManagementIPAddress "192.168.1.20" .

noria:Resource_FirewallDMZ
    a noria:Resource ;
    rdfs:label "DMZ Firewall"@en ;
    rdfs:label "Pare-feu DMZ"@fr ;
    rdfs:comment "Firewall protecting the Demilitarized Zone (DMZ)."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:resourceHostName "fw-dmz-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ; # Using a switch model for firewall for example purpose, could be a dedicated firewall model
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-FW-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-08-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U24 ;
    noria:resourceManagementIPAddress "10.0.1.1" .

noria:Resource_DBServer01
    a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:label "Serveur de Base de Données 01"@fr ;
    rdfs:comment "Server hosting the main database for customer applications."@en ;
    noria:resourceManagedBy foaf:Agent_AppDev ;
    noria:resourceHostName "dbserver-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/DatabaseServer> ;
    noria:resourceSerialNumber "SN-DB-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-20T16:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U24 ;
    noria:resourceManagementIPAddress "192.168.1.30" .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetIF_DNS01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to corporate LAN."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetIF_RouterCore1_Gi0_0_1
    a noria:NetworkInterface ;
    rdfs:label "RouterCore1 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 1 to DNS server segment."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore1 ;
    noria:networkInterfaceDescription "Uplink to DNS server."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetIF_RouterCore1_Gi0_0_2
    a noria:NetworkInterface ;
    rdfs:label "RouterCore1 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Interface connecting Core Router 1 to DMZ firewall."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore1 ;
    noria:networkInterfaceDescription "Uplink to DMZ firewall."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 .

noria:NetIF_AppServer01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "AppServer01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for Application Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_AppServer01 ;
    noria:networkInterfaceDescription "Ethernet interface for application traffic."@en ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetIF_FirewallDMZ_Ext
    a noria:NetworkInterface ;
    rdfs:label "Firewall DMZ External"@en ;
    rdfs:comment "External interface of the DMZ firewall, facing the internet."@en ;
    noria:networkInterfaceOf noria:Resource_FirewallDMZ ;
    noria:networkInterfaceDescription "External WAN interface."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetIF_FirewallDMZ_Int
    a noria:NetworkInterface ;
    rdfs:label "Firewall DMZ Internal"@en ;
    rdfs:comment "Internal interface of the DMZ firewall, facing the core router."@en ;
    noria:networkInterfaceOf noria:Resource_FirewallDMZ ;
    noria:networkInterfaceDescription "Internal LAN interface."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NetLink_DNS01_Core1
    a noria:NetworkLink ;
    rdfs:label "Link DNS01 to Core1"@en ;
    rdfs:comment "Physical link between DNS01 server and Core Router 1."@en ;
    noria:networkLinkId "NL-DNS-RTR-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_RouterCore1 ;
    noria:networkLinkInstallationDate "2022-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 1Gbps" ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:NetIF_DNS01_Eth0 noria:networkInterfaceConnects noria:NetLink_DNS01_Core1 ;
    noria:NetIF_RouterCore1_Gi0_0_1 noria:networkInterfaceConnects noria:NetLink_DNS01_Core1 .

noria:NetLink_Core1_Firewall
    a noria:NetworkLink ;
    rdfs:label "Link Core1 to Firewall"@en ;
    rdfs:comment "Physical link between Core Router 1 and DMZ Firewall."@en ;
    noria:networkLinkId "NL-RTR-FW-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore1 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_FirewallDMZ ;
    noria:networkLinkInstallationDate "2021-03-20T14:45:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber 10Gbps" ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:NetIF_RouterCore1_Gi0_0_2 noria:networkInterfaceConnects noria:NetLink_Core1_Firewall ;
    noria:NetIF_FirewallDMZ_Int noria:networkInterfaceConnects noria:NetLink_Core1_Firewall .

noria:NetLink_AppServer_Core1
    a noria:NetworkLink ;
    rdfs:label "Link AppServer to Core1"@en ;
    rdfs:comment "Logical link between Application Server 01 and Core Router 1."@en ;
    noria:networkLinkId "NL-APP-RTR-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_AppServer01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_RouterCore1 ;
    noria:networkLinkInstallationDate "2023-05-10T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Virtual Ethernet" ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:NetIF_AppServer01_Eth0 noria:networkInterfaceConnects noria:NetLink_AppServer_Core1 ;
    noria:NetIF_RouterCore1_Gi0_0_2 noria:networkInterfaceConnects noria:NetLink_AppServer_Core1 .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

noria:App_CorpInternetAccess
    a noria:Application ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:label "Accès Internet d'entreprise"@fr ;
    rdfs:comment "Provides internet access for all corporate users."@en ;
    noria:applicationModelIdentifier "CIA-APP" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CIA" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Internet Gateway" ;
    noria:resourceForApplication noria:Resource_FirewallDMZ .

noria:App_CustomerPortal
    a noria:Application ;
    rdfs:label "Customer Portal"@en ;
    rdfs:label "Portail Client"@fr ;
    rdfs:comment "Web application allowing customers to manage their services."@en ;
    noria:applicationModelIdentifier "CUST-PORTAL" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "CPORT" ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Self-Service Portal" ;
    noria:resourceForApplication noria:Resource_AppServer01 ;
    noria:resourceForApplication noria:Resource_DBServer01 .

noria:App_MonitoringSystem
    a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:label "Système de Supervision Réseau"@fr ;
    rdfs:comment "System for monitoring network devices and services."@en ;
    noria:applicationModelIdentifier "NMS-APP" ;
    noria:applicationNumericalIdentifier 3001 ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationType <kos/application/type/management-tool> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Network Performance Monitoring" ;
    noria:resourceForApplication noria:Resource_DNS01 . # NMS might rely on DNS for name resolution

# =============================================================================
# Application Modules (noria:ApplicationModule)
# =============================================================================

noria:AppMod_CorpInternetAccess_Prod
    a noria:ApplicationModule ;
    rdfs:label "Corporate Internet Access Production"@en ;
