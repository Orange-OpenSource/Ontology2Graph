    noria:applicationModuleSupportTeam org:OrgUnit_L2Support ;
    noria:applicationModuleHotlineGroup org:OrgUnit_Hotline ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime .

noria:AppMod_CustomerPortal_Prod
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production"@en ;
    rdfs:label "Portail Client Production"@fr ;
    rdfs:comment "Production instance of the Customer Portal application."@en ;
    noria:applicationModuleOf noria:App_CustomerPortal ;
    noria:applicationModuleName "CPORT_PROD" ;
