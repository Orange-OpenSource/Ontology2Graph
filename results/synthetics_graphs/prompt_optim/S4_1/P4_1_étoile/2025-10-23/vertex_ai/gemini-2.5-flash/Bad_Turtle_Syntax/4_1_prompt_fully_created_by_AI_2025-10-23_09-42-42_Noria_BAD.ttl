# =============================================================================
# Trouble Ticket Notes (noria:TroubleTicketNote)
# =============================================================================

noria:TTNote_DNSInvestigation
    a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Investigation Note"@en ;
    rdfs:comment "Initial investigation revealed no network connectivity to DNS01. Escalated to L2."@en ;
    dcterms:created "2024-04-10T09:15:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_AdminTeam ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TT_DNSOutage .

noria:TTNote_PortalRestart
    a noria:TroubleTicketNote ;
    rdfs:label "Portal Restart Action Note"@en ;
    rdfs:comment "Application server restarted. Performance restored to normal levels. Monitoring for stability."@en ;
    dcterms:created "2024-04-09T15:30:00Z"^^xsd:dateTime ;
    dcterms:creator org:OrgUnit_L2Support ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:isPartOf noria:TT_PortalSlow .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:Event_DNSFailure
    a noria:EventRecord ;
    rdfs:label "DNS Service Failure Log"@en ;
    rdfs:comment "Log entry indicating DNS service failure on dns01.corp.example.com."@en ;
    noria:loggingTime "2024-04-10T08:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "CRITICAL: DNS service on dns01 is down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_HighLoad
    a noria:EventRecord ;
    rdfs:label "Application High Load Alert"@en ;
    rdfs:comment "Alert triggered due to high CPU utilization on appserver-01."@en ;
    noria:loggingTime "2024-04-09T13:40:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_AppServer01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "WARNING: CPU usage on appserver-01 exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:Event_InterfaceDown
    a noria:EventRecord ;
    rdfs:label "Router Interface Down"@en ;
    rdfs:comment "Log entry indicating a network interface went down on router-core-01."@en ;
    noria:loggingTime "2024-04-08T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore1 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "Interface GigabitEthernet0/0/1 on router-core-01 changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction noria:OpPlan_RouterFirmwareUpdate . # Example of linking to a procedure

noria:Event_ConfigChange
    a noria:EventRecord ;
    rdfs:label "Router Configuration Change"@en ;
    rdfs:comment "Configuration change detected on router-core-01 by Network Operations Team."@en ;
    noria:loggingTime "2024-04-07T15:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore1 ;
    noria:logOriginatingAgent foaf:Agent_NetworkOps ;
    noria:logText "Configuration changed by 'admin' from 10.0.0.5."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:Event_SecurityAlert
    a noria:EventRecord ;
    rdfs:label "DMZ Firewall Security Alert"@en ;
    rdfs:comment "High severity security alert from DMZ firewall."@en ;
    noria:loggingTime "2024-04-11T07:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_FirewallDMZ ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent_SecurityTeam ;
    noria:logText "Multiple failed login attempts detected on external interface."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

# =============================================================================
# Change Requests (noria:ChangeRequest)
# =============================================================================

noria:CR_RouterUpgrade
    a noria:ChangeRequest ;
    rdfs:label "Core Router Software Upgrade"@en ;
    rdfs:label "Mise à jour logicielle du routeur cœur"@fr ;
    rdfs:comment "Planned software upgrade for Core Router 1 to enhance security and performance."@en ;
    dcterms:created "2024-03-25T10:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-05T16:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-15T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-15T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-04-15T02:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-04-15T03:45:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_RouterCore1 ;
    noria:changeRequestOutageDuration "PT1H30M"^^xsd:duration ; # 1 hour 30 minutes
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Implemented> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/NetworkDeviceFirmwareUpdate> ;
    noria:changeRequestInitiatorParty foaf:Agent_CRInitiator ;
    noria:changeRequestPilotParty foaf:Agent_CRPilot ;
    noria:changeRequestActorParty foaf:Agent_CRActor ;
    noria:changeRequestIsRegulated false ;
    noria:documentExternalId "CR-2024-03-25-001" ;
    noria:documentHRef "https://itsm.example.com/change/CR-2024-03-25-001" .

noria:CR_DBMigration
    a noria:ChangeRequest ;
    rdfs:label "Database Migration"@en ;
    rdfs:label "Migration de Base de Données"@fr ;
    rdfs:comment "Migration of Customer Portal database to a new, more powerful server."@en ;
    dcterms:created "2024-04-01T11:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-20T00:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-20T06:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Major> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/NetworkExtension> ; # Using NetworkExtension as an example, could be "InfrastructureUpgrade"
    noria:changeRequestImpact noria:Resource_DBServer01 ;
    noria:changeRequestImpact noria:App_CustomerPortal ;
    noria:changeRequestOutageDuration "PT3H"^^xsd:duration ; # 3 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Planned> ;
    noria:changeRequestInitiatorParty foaf:Agent_CRInitiator ;
    noria:changeRequestPilotParty foaf:Agent_AppDev ;
    noria:changeRequestIsRegulated true ;
    noria:documentExternalId "CR-2024-04-01-002" .

# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OpPlan_RouterFirmwareUpdate
    a noria:OperationPlan ;
    rdfs:label "Router Firmware Update Procedure"@en ;
    rdfs:label "Procédure de mise à jour du firmware du routeur"@fr ;
    rdfs:comment "Standard operating procedure for updating router firmware."@en ;
    noria:operationPlanPreCondition noria:PreCond_RouterConnectivity ;
    noria:operationPlanPostCondition noria:PostCond_RouterOperational .

noria:OpPlan_DBBackup
    a noria:OperationPlan ;
    rdfs:label "Database Backup Procedure"@en ;
    rdfs:label "Procédure de sauvegarde de base de données"@fr ;
    rdfs:comment "Procedure for performing a full backup of the production database."@en ;
    noria:operationPlanPreCondition noria:PreCond_DBConsistent ;
    noria:operationPlanPostCondition noria:PostCond_BackupComplete .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:PreCond_RouterConnectivity
    a noria:ActionPreCondition ;
    rdfs:label "Router Connectivity Check"@en ;
    rdfs:comment "Verify network connectivity to the router before starting the update."@en ;
    skos:example "Ping management IP, check BGP neighbor status."@en .

noria:PostCond_RouterOperational
    a noria:ActionPostCondition ;
    rdfs:label "Router Operational Status"@en ;
    rdfs:comment "Confirm router is fully operational and routing traffic correctly after update."@en ;
    skos:example "Verify all interfaces are up, BGP sessions established, traffic flowing."@en .

noria:PreCond_DBConsistent
    a noria:ActionPreCondition ;
    rdfs:label "Database Consistency Check"@en ;
    rdfs:comment "Ensure database is in a consistent state before initiating backup."@en ;
    skos:example "Run DB consistency checks, stop write operations."@en .

noria:PostCond_BackupComplete
    a noria:ActionPostCondition ;
    rdfs:label "Backup Completion Confirmation"@en ;
    rdfs:comment "Confirm the database backup process has completed successfully."@en ;
    skos:example "Check backup logs, verify backup file integrity."@en .

# =============================================================================
# Additional connections for density
# =============================================================================

# Link Application Modules to Services (already done, but adding more explicit connections)
noria:Service_EnterpriseConnectivity
    seas:subSystemOf noria:AppMod_CorpInternetAccess_Prod .

noria:Service_CustomerFacingWeb
    seas:subSystemOf noria:AppMod_CustomerPortal_Prod .

# Link Resources to Applications (already done, but adding more explicit connections)
noria:Resource_FirewallDMZ
    noria:resourceForApplication noria:App_CorpInternetAccess .

noria:Resource_AppServer01
    noria:resourceForApplication noria:App_CustomerPortal .

noria:Resource_DBServer01
    noria:resourceForApplication noria:App_CustomerPortal .

noria:Resource_DNS01
    noria:resourceForApplication noria:App_MonitoringSystem .

# Link Agents to resources they manage (inverse of resourceManagedBy)
foaf:Agent_AdminTeam
    noria:agentManagesResource noria:Resource_DNS01 .

foaf:Agent_NetworkOps
    noria:agentManagesResource noria:Resource_RouterCore1 ;
    noria:agentManagesResource noria:Resource_FirewallDMZ ;
    noria:agentManagesResource noria:NetLink_DNS01_Core1 ;
    noria:agentManagesResource noria:NetLink_Core1_Firewall ;
    noria:agentManagesResource noria:NetLink_AppServer_Core1 .

foaf:Agent_AppDev
    noria:agentManagesResource noria:Resource_AppServer01 ;
    noria:agentManagesResource noria:Resource_DBServer01 .

# Link Trouble Tickets to impacted entities
noria:TT_DNSOutage
    noria:troubleTicketImpacts noria:Resource_DNS01 ;
    noria:troubleTicketImpacts noria:App_CorpInternetAccess .

noria:TT_PortalSlow
    noria:troubleTicketImpacts noria:Resource_AppServer01 ;
    noria:troubleTicketImpacts noria:App_CustomerPortal .

# Link Change Requests to impacted entities
noria:CR_RouterUpgrade
    noria:changeRequestImpact noria:Resource_RouterCore1 .

noria:CR_DBMigration
    noria:changeRequestImpact noria:Resource_DBServer01 ;
    noria:changeRequestImpact noria:App_CustomerPortal .

# Link Event Records to related parties (if applicable)
noria:Event_DNSFailure
    noria:eventRelatedParty foaf:Agent_AdminTeam .

noria:Event_HighLoad
    noria:eventRelatedParty foaf:Agent_AppDev .

noria:Event_InterfaceDown
    noria:eventRelatedParty foaf:Agent_NetworkOps .

noria:Event_SecurityAlert
    noria:eventRelatedParty foaf:Agent_SecurityTeam .

# Link Operation Plans to relevant agents (e.g., who executes them)
noria:OpPlan_RouterFirmwareUpdate
    noria:elementManagedBy foaf:Agent_NetworkOps .

noria:OpPlan_DBBackup
    noria:elementManagedBy foaf:Agent_AppDev .

# Example of document status history for a TroubleTicket
noria:TT_DNSOutage
    noria:documentStatusHistory noria:Event_DNSStatusChangeToInProgress ;
    noria:documentStatusHistory noria:Event_DNSStatusChangeToResolved .

noria:Event_DNSStatusChangeToInProgress
    a noria:EventRecord ;
    rdfs:label "DNS TT Status InProgress"@en ;
    rdfs:comment "Trouble Ticket DNSOutage moved to InProgress status."@en ;
    noria:loggingTime "2024-04-10T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent_AdminTeam ;
    noria:logText "Status changed to InProgress by Admin Team."@en ;
    dcterms:references noria:TT_DNSOutage .

noria:Event_DNSStatusChangeToResolved
    a noria:EventRecord ;
    rdfs:label "DNS TT Status Resolved"@en ;
    rdfs:comment "Trouble Ticket DNSOutage moved to Resolved status."@en ;
    noria:loggingTime "2024-04-10T11:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent_AdminTeam ;
    noria:logText "Status changed to Resolved after server restart."@en ;
    dcterms:references noria:TT_DNSOutage .

# Example of a TroubleTicketNote correlated execution
noria:TTNote_PortalRestart
    noria:troubleTicketNoteCorrelatedExecution noria:ProcExecContainer_PortalRestart .

noria:ProcExecContainer_PortalRestart
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Procedure Execution for Portal Restart"@en ;
    rdfs:comment "Container for events related to the portal restart action."@en ;
    dcterms:created "2024-04-09T15:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-09T15:30:00Z"^^xsd:dateTime ;
    dcterms:member noria:Event_PortalRestartCommand ;
    dcterms:member noria:Event_PortalRestartSuccess .

noria:Event_PortalRestartCommand
    a noria:EventRecord ;
    rdfs:label "Portal Restart Command Issued"@en ;
    rdfs:comment "Command issued to restart the Customer Portal application."@en ;
    noria:loggingTime "2024-04-09T15:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_AppServer01 ;
    noria:logOriginatingAgent org:OrgUnit_L2Support ;
    noria:logText "Command 'systemctl restart customer-portal' executed."@en .

noria:Event_PortalRestartSuccess
    a noria:EventRecord ;
    rdfs:label "Portal Restart Successful"@en ;
    rdfs:comment "Log entry confirming successful restart of Customer Portal."@en ;
    noria:loggingTime "2024-04-09T15:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_AppServer01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "Customer Portal application started successfully."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

