    noria:applicationModuleOf :Application_Corporate_Website ;
    noria:applicationModuleName "CORPWEB_PROD" ;
    noria:applicationModuleIdentifier "PROD-CW-01" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam :Agent_IT_Ops_Team ;
    noria:applicationModuleSupportTeam :Agent_App_Support_L2 ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

:ApplicationModule_CRM_Dev a noria:ApplicationModule ;
    rdfs:label "Internal CRM Development Module"@en ;
    rdfs:comment "Development instance of the Internal CRM System."@en ;
    noria:applicationModuleOf :Application_Internal_CRM ;
    noria:applicationModuleName "CRMINT_DEV" ;
    noria:applicationModuleIdentifier "DEV-CRM-01" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> ;
    noria:applicationModuleAdministrationTeam :Agent_IT_Ops_Team ;
    noria:applicationModuleSupportTeam :Agent_App_Support_L2 ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Bronze> ;
    noria:applicationModuleSlaLevelDate "2023-03-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled false .

# --- Services ---
:Service_Public_Web_Access a noria:Service ;
    rdfs:label "Public Web Access Service"@en ;
    rdfs:comment "End-to-end service providing public access to corporate web resources."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :ApplicationModule_CorpWeb_Prod . # Linking service to its primary application module

:Service_Internal_Data_Processing a noria:Service ;
    rdfs:label "Internal Data Processing Service"@en ;
    rdfs:comment "Service for internal data processing and analytics."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf :ApplicationModule_CRM_Dev .

# --- Event Records ---
:EventRecord_Web01_Down a noria:EventRecord ;
    rdfs:label "Web Server 01 Down Alert"@en ;
    rdfs:comment "Alert indicating Web Server 01 is unreachable."@en ;
    noria:loggingTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Web_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:logText "Host web01.corp.example.com is DOWN."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

:EventRecord_DB01_HighCPU a noria:EventRecord ;
    rdfs:label "DB Server 01 High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on DB Server 01."@en ;
    noria:loggingTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_DB_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:logText "CPU utilization on db01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

:EventRecord_Firewall_Config_Change a noria:EventRecord ;
    rdfs:label "Firewall Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on Firewall 01."@en ;
