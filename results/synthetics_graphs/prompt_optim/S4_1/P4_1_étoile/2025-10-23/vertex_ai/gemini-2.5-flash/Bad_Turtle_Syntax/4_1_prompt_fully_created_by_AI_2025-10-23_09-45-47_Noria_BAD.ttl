# --- Operation Plans, Pre/Post Conditions ---
:OperationPlan_Web_Restart a noria:OperationPlan ;
    rdfs:label "Web Server Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a web server."@en ;
    skos:example "Steps include checking logs, attempting graceful restart, forced restart if necessary, and verifying service."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_Web_Service_Down ;
    noria:operationPlanPostCondition :ActionPostCondition_Web_Service_Up .

:ActionPreCondition_Web_Service_Down a noria:ActionPreCondition ;
    rdfs:label "Web Service Down"@en ;
    rdfs:comment "Condition: The web service is not responding or is unreachable."@en .

:ActionPostCondition_Web_Service_Up a noria:ActionPostCondition ;
    rdfs:label "Web Service Up and Responding"@en ;
    rdfs:comment "Expected outcome: The web service is running and accessible, responding to requests."@en .

:OperationPlan_Firewall_ACL_Update a noria:OperationPlan ;
    rdfs:label "Firewall ACL Update Procedure"@en ;
    rdfs:comment "Procedure for safely updating Access Control Lists on perimeter firewalls."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_Firewall_Access_Granted ;
    noria:operationPlanPostCondition :ActionPostCondition_Firewall_Rules_Applied .

:ActionPreCondition_Firewall_Access_Granted a noria:ActionPreCondition ;
    rdfs:label "Firewall Management Access Granted"@en ;
    rdfs:comment "Condition: Administrator has authenticated access to the firewall management interface."@en .

:ActionPostCondition_Firewall_Rules_Applied a noria:ActionPostCondition ;
    rdfs:label "Firewall Rules Applied and Verified"@en ;
    rdfs:comment "Expected outcome: New ACL rules are active and verified to allow intended traffic without unintended side effects."@en .

# --- Additional Connectivity ---
# Link agents to resources they manage
:Agent_IT_Ops_Team noria:agentManagesResource :Resource_Web_Server_01, :Resource_DB_Server_01 .
:Agent_Network_Admin noria:agentManagesResource :Resource_Core_Switch_01, :Resource_Firewall_01 .
:Agent_Security_Team noria:agentManagesResource :Resource_Firewall_01 .

# Link applications to resources they use (beyond noria:resourceForApplication)
:Application_Corporate_Website seas:subSystemOf :Resource_Web_Server_01, :Resource_DB_Server_01 .
:Application_Internal_CRM seas:subSystemOf :Resource_DB_Server_01 .

# Link trouble tickets to event records that are part of their status history
:TroubleTicket_WebOutage_001 noria:documentStatusHistory :EventRecord_Web01_Down, :EventRecord_Web01_Restart_Success .

# Link change requests to event records (e.g., for audit trails)
:ChangeRequest_Firewall_Update_001 noria:documentStatusHistory :EventRecord_Firewall_Config_Change .

# Example of a Corporate User Identifier
:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for John Doe, a member of the IT Operations Team."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount :Agent_IT_Ops_Team . # Assuming John Doe is represented by the team for simplicity, or a specific foaf:Person instance.

# Example of a Network Interface Observable
:NetworkInterface_CS01_Eth1_RxPower a noria:NetworkInterface ;
    rdfs:label "CS01 Ethernet 1 Rx Power"@en ;
    rdfs:comment "Received optical power on CS01 Ethernet 1 interface."@en ;
    noria:networkInterfaceOf :Resource_Core_Switch_01 ;
    noria:networkInterfaceLaserRxOpticalPower -10 ; # Example value in dBm
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -20 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 .

