    noria:networkLinkTerminationResourceDestination :Resource_Core_Switch_01 ;
    noria:resourceManagedBy :Agent_Network_Admin .

:NetworkLink_DB01_CoreSwitch a noria:NetworkLink ;
    rdfs:label "Link DB01-CoreSwitch"@en ;
    rdfs:comment "Physical link between DB Server 01 and Core Switch 01."@en ;
    noria:networkLinkId "NL-DB01-CS01" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2023-01-15T11:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin :Resource_DB_Server_01 ;
    noria:networkLinkTerminationResourceDestination :Resource_Core_Switch_01 ;
    noria:resourceManagedBy :Agent_Network_Admin .

:NetworkLink_CoreSwitch_Firewall a noria:NetworkLink ;
    rdfs:label "Link CoreSwitch-Firewall"@en ;
    rdfs:comment "Physical link between Core Switch 01 and Firewall 01."@en ;
    noria:networkLinkId "NL-CS01-FW01" ;
