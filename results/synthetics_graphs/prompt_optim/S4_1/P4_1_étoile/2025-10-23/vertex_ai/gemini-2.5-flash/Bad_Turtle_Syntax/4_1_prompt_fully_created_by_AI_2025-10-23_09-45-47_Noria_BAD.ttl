    noria:resourceManagedBy :Agent_Network_Admin .

# --- Applications ---
:Application_Corporate_Website a noria:Application ;
    rdfs:label "Corporate Website"@en ;
    rdfs:comment "The main public-facing website for the corporation."@en ;
    rdfs:label "Site Web Corporatif"@fr ;
    noria:applicationModelIdentifier "CORPWEB" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CW" ;
    noria:applicationType <kos/application/type/CustomerFacing> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Marketing and Sales" ;
    noria:applicationFunctionalSubDomain "Online Presence Management" .

:Application_Internal_CRM a noria:Application ;
    rdfs:label "Internal CRM System"@en ;
    rdfs:comment "Customer Relationship Management system for internal use."@en ;
    rdfs:label "Système CRM Interne"@fr ;
    noria:applicationModelIdentifier "CRMINT" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType <kos/application/type/InternalBusiness> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical> ;
    noria:applicationFunctionalDomain "Customer Service" ;
    noria:applicationFunctionalSubDomain "Customer Data Management" .

:Application_Monitoring_System a noria:Application ;
    rdfs:label "Monitoring System"@en ;
    rdfs:comment "System responsible for collecting and analyzing IT infrastructure metrics and logs."@en ;
    rdfs:label "Système de Supervision"@fr ;
    noria:applicationModelIdentifier "MONSYS" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "MON" ;
    noria:applicationType <kos/application/type/Infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "IT Operations" ;
    noria:applicationFunctionalSubDomain "Performance Monitoring" .

