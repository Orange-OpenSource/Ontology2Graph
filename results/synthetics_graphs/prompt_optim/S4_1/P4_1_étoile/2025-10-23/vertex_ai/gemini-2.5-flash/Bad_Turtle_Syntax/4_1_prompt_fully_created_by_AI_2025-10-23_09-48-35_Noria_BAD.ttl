    noria:logText "Trouble Ticket TT002 status changed from New to InProgress."@en ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    dcterms:references <troubleticket/TT002> .

# --- Change Requests (noria:ChangeRequest) ---
<changerequest/CR001> a noria:ChangeRequest ;
    rdfs:label "Web App Server Upgrade"@en ;
    rdfs:comment "Upgrade RAM and CPU for Web Application Server 01 to improve performance."@en ;
    dcterms:created "2024-04-15T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-18T15:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-25T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-26T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact <resource/Server01> ;
    noria:changeRequestImpact <application/WebApp> ;
    noria:changeRequestOutageDuration "PT4H"^^xsd:duration ; # 4 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty <agent/JaneSmith> ;
    noria:changeRequestPilotParty <agent/JaneSmith> ;
    noria:changeRequestActorParty <agent/TeamB> ;
    noria:changeRequestIsRegulated "false"^^xsd:boolean ;
    noria:documentStatusHistory <eventrecord/CR001StatusChange1> .

<changerequest/CR002> a noria:ChangeRequest ;
    rdfs:label "Core Router Firmware Update"@en ;
    rdfs:comment "Apply critical security patch to Core Router 01 firmware."@en ;
    dcterms:created "2024-04-10T11:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-12T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-27T01:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-27T03:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Normal> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact <resource/RouterCore01> ;
    noria:changeRequestImpact <application/CoreNetwork> ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ; # 2 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty <agent/JohnDoe> ;
    noria:changeRequestPilotParty <agent/JohnDoe> ;
    noria:changeRequestActorParty <agent/TeamA> ;
    noria:changeRequestIsRegulated "true"^^xsd:boolean ;
    noria:documentStatusHistory <eventrecord/CR002StatusChange1> .

# --- Event Records for Change Request Status History ---
<eventrecord/CR001StatusChange1> a noria:EventRecord ;
    rdfs:label "CR001 Status Change to Approved"@en ;
    noria:loggingTime "2024-04-18T15:00:00Z"^^xsd:dateTime ;
    noria:logText "Change Request CR001 status changed from Pending Approval to Approved."@en ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    dcterms:references <changerequest/CR001> .

<eventrecord/CR002StatusChange1> a noria:EventRecord ;
    rdfs:label "CR002 Status Change to Scheduled"@en ;
    noria:loggingTime "2024-04-12T10:00:00Z"^^xsd:dateTime ;
    noria:logText "Change Request CR002 status changed from Approved to Scheduled."@en ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    dcterms:references <changerequest/CR002> .

# --- Operation Plans, Pre/Post Conditions ---
<operationplan/WebAppRestart> a noria:OperationPlan ;
    rdfs:label "Web Application Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the corporate web application."@en ;
    skos:example "Steps include stopping services, checking logs, starting services, and verifying access."@en ;
    noria:operationPlanPreCondition <actionprecondition/WebAppDegraded> ;
    noria:operationPlanPostCondition <actionpostcondition/WebAppRestored> .

<actionprecondition/WebAppDegraded> a noria:ActionPreCondition ;
    rdfs:label "Web Application Performance Degraded"@en ;
    rdfs:comment "Condition: Web application response time is above 5 seconds for 10 minutes."@en ;
    skos:example "Monitoring alert for high response time on /index.html" .

<actionpostcondition/WebAppRestored> a noria:ActionPostCondition ;
    rdfs:label "Web Application Performance Restored"@en ;
    rdfs:comment "Condition: Web application response time is below 2 seconds for 15 minutes."@en ;
    skos:example "Monitoring alert for normal response time on /index.html" .

<operationplan/RouterFirmwareUpdate> a noria:OperationPlan ;
    rdfs:label "Core Router Firmware Update Procedure"@en ;
    rdfs:comment "Procedure for safely updating firmware on core network routers."@en ;
    skos:example "Includes backup configuration, upgrade command, and post-check steps."@en ;
    noria:operationPlanPreCondition <actionprecondition/RouterStable> ;
    noria:operationPlanPostCondition <actionpostcondition/RouterUpdated> .

<actionprecondition/RouterStable> a noria:ActionPreCondition ;
    rdfs:label "Router Stable State"@en ;
    rdfs:comment "Condition: Router CPU and memory usage are normal, no active alarms."@en ;
    skos:example "No critical alarms on router-core-01 for 24 hours." .

<actionpostcondition/RouterUpdated> a noria:ActionPostCondition ;
    rdfs:label "Router Firmware Updated and Functional"@en ;
    rdfs:comment "Condition: Router firmware version matches target, all interfaces up, traffic flowing."@en ;
    skos:example "Verify 'show version' output and ping tests to key destinations." .

# Linking Operation Plans to Trouble Tickets (as proposed repair actions)
<troubleticket/TT001> noria:alarmProposedRepairAction <operationplan/WebAppRestart> .
<troubleticket/TT002> noria:alarmProposedRepairAction <operationplan/RouterFirmwareUpdate> . # This is a bit of a stretch, but demonstrates the property usage. In reality, a fiber cut would have a different repair action.

# Linking Change Requests to Operation Plans (as correlated actions)
<changerequest/CR001> noria:changeRequestSpecification <operationplan/WebAppRestart> . # Using specification as a proxy for the plan
<changerequest/CR002> noria:changeRequestSpecification <operationplan/RouterFirmwareUpdate> .

