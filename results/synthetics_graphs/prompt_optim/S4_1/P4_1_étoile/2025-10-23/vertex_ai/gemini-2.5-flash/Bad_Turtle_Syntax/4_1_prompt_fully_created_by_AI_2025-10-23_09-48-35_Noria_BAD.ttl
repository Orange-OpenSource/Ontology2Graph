# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot:  <https://w3id.org/bot#> .
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix pep: <https://w3id.org/pep/>.
@prefix seas: <https://w3id.org/seas/>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# NORIA Ontology Metadata (as provided in the schema, not to be modified)
# =============================================================================

<https://w3id.org/noria/ontology/>
	a voaf:Vocabulary, owl:Ontology ;
	dcterms:title "The NORIA Ontology"@en ;
    dcterms:description """The NORIA-O project is a data model for IT networks, events and operations information.
The ontology is developed using web technologies (e.g. RDF, OWL, SKOS) and is intended as a structure for realizing an IT Service Management (ITSM) Knowledge Graph (KG) for Anomaly Detection (AD) and Risk Management applications.
The model has been developed in collaboration with operational teams, and in connection with third parties linked vocabularies.

Alignment with third parties vocabularies is implemented on a per class or per property basis when relevant (e.g. with `rdfs:subClassOf`, `owl:equivalentClass`).
Directions for direct instanciation of these vocabularies are provided for cases where implementing a class/property alignment is redundant.
Alignment holds for the following vocabulary releases:
- [BBO](https://hal.archives-ouvertes.fr/hal-02365012/) 1.0.0
- [BOT](https://w3id.org/bot/) 0.3.2
- [DevOps-Infra](https://oeg-upm.github.io/devops-infra/) 1.0.0
- [FOLIO](https://github.com/IBCNServices/Folio-Ontology) 1.0.0
- [ORG](https://www.w3.org/TR/vocab-org/) 0.8
- [PEP](https://w3id.org/pep/) 1.1
- [SEAS](https://w3id.org/seas/) 1.1
- [SLOGERT](https://sepses.ifs.tuwien.ac.at/ns/log/index-en.html) 1.1.0
- [UCO](https://unifiedcyberontology.org/ontology/uco) Release-0.8.0
"""@en ;
    foaf:depiction <https://github.com/Orange-OpenSource/noria-ontology/raw/master/dataset/noria-0.2/noria-ontology-UC.png> ;
    bibo:status <http://purl.org/ontology/bibo/status/accepted> ;
	dcterms:creator "Lionel Tailhardat (https://orcid.org/0000-0001-5887-899X)" ;
	dcterms:creator "Yoan Chabot (https://orcid.org/0000-0001-5639-1504)" ;
	dcterms:creator "Raphaël Troncy (https://orcid.org/0000-0003-0457-1436)" ;
    dcterms:publisher <https://www.orange.com/> ;
    dcterms:license <https://spdx.org/licenses/BSD-4-Clause> ;
    vann:preferredNamespacePrefix "noria" ;
    vann:preferredNamespaceUri "https://w3id.org/noria/ontology/" ;
    dcterms:issued "2022-05-10"^^xsd:date ;
	dcterms:modified "2024-03-15"^^xsd:date ;
	skos:changeNote """Changes in v0.3:

- Changed the ontology architecture from micro-architecture to single file.
- Removed owl:imports for NORIA foundations.

2024-03-15:

- Changed bibo:status
"""@en ;
	owl:versionInfo "v0.3" ;
	owl:versionIRI <ontology/noria-0.3> ;
	owl:priorVersion <ontology/noria-0.2> ;
    rdfs:seeAlso <https://w3id.org/noria/doc/> ;
.

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents (foaf:Agent, org:OrganizationalUnit) ---
<agent/TeamA> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center Team A"@en ;
    rdfs:label "Équipe du Centre d'Opérations Réseau A"@fr ;
    rdfs:comment "Team responsible for monitoring and managing core network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Contact via dedicated incident management hotline for critical issues."@en .

<agent/TeamB> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team B"@en ;
    rdfs:label "Équipe de Support Applicatif B"@fr ;
    rdfs:comment "Team responsible for supporting critical business applications."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Submit a ticket via the ITSM portal for all requests."@en .

<agent/JohnDoe> a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer, Team A."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+33123456789" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

<agent/JaneSmith> a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Developer, Team B."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:phone "+33198765432" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

<agent/CustomerService> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Customer Service Department"@en ;
    rdfs:comment "First line of contact for customer inquiries and issues."@en ;
    noria:agentWorkingHours "8:00 am - 8:00 pm (Mon-Sat)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/portal> .

# --- Locations (bot:Site, noria:Room, noria:Locus) ---
<location/SiteParis> a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center facility located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" ;
    wgs84_pos:lat "48.867"^^xsd:float ;
    wgs84_pos:long "2.333"^^xsd:float .

<location/RoomServer1> a noria:Room ;
    rdfs:label "Server Room 1"@en ;
    rdfs:comment "Primary server room within the Paris Data Center."@en ;
    bot:hasSpace <location/SiteParis> .

<location/LocusRackA1> a noria:Locus ;
    rdfs:label "Rack A1, Server Room 1"@en ;
    rdfs:comment "Specific location for Rack A1 in Server Room 1."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace <location/RoomServer1> .

<location/LocusRackB2> a noria:Locus ;
    rdfs:label "Rack B2, Server Room 1"@en ;
    rdfs:comment "Specific location for Rack B2 in Server Room 1."@en ;
    noria:locusLine "B" ;
    noria:locusRow "2" ;
    bot:hasSpace <location/RoomServer1> .

# --- Product Models (noria:ProductModel) ---
<productmodel/DellR740> a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy <org/Dell> .

<productmodel/CiscoNexus9K> a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Data center switch for high-density deployments."@en ;
    noria:productManufacturedBy <org/Cisco> .

<productmodel/VMwareESXi> a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy <org/VMware> .

<org/Dell> a org:Organization ;
    rdfs:label "Dell Technologies"@en .

<org/Cisco> a org:Organization ;
    rdfs:label "Cisco Systems"@en .

<org/VMware> a org:Organization ;
    rdfs:label "VMware Inc."@en .

# --- Resources (noria:Resource) ---
<resource/Server01> a noria:Resource ;
    rdfs:label "Web Application Server 01"@en ;
    rdfs:comment "Primary server hosting the corporate web application."@en ;
    noria:resourceManagedBy <agent/TeamB> ;
    noria:resourceHostName "web-app-01.corp.example.com" ;
    noria:resourceLogisticId "LOG-WEB-001" ;
    noria:resourceProductModel <productmodel/DellR740> ;
    noria:resourceType <kos/Resource/type/physical-server> ;
    noria:resourceSerialNumber "SN-WEB-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <application/WebApp> ;
    noria:locatedAtLocus <location/LocusRackA1> ;
    noria:resourceManagementIPAddress <observable/IPAddress1> .

<resource/RouterCore01> a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the data center network."@en ;
    noria:resourceManagedBy <agent/TeamA> ;
    noria:resourceHostName "core-rtr-01.dc.example.com" ;
    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:resourceProductModel <productmodel/CiscoNexus9K> ;
    noria:resourceType <kos/Resource/type/network-router> ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <application/CoreNetwork> ;
    noria:locatedAtLocus <location/LocusRackB2> ;
    noria:resourceManagementIPAddress <observable/IPAddress2> .

<resource/VMDB01> a noria:Resource ;
    rdfs:label "Database Virtual Machine 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate database."@en ;
    noria:resourceManagedBy <agent/TeamB> ;
    noria:resourceHostName "db-vm-01.corp.example.com" ;
    noria:resourceLogisticId "LOG-VM-001" ;
    noria:resourceProductModel <productmodel/VMwareESXi> ; # The hypervisor model, not the VM itself
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceSerialNumber "VM-ID-DB-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-10T09:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <application/WebApp> ;
    noria:clusterController <resource/Hypervisor01> ;
    noria:resourceManagementIPAddress <observable/IPAddress3> .

<resource/Hypervisor01> a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical server hosting virtual machines, including VMDB01."@en ;
    noria:resourceManagedBy <agent/TeamB> ;
    noria:resourceHostName "hypervisor-01.corp.example.com" ;
    noria:resourceProductModel <productmodel/DellR740> ;
    noria:resourceType <kos/Resource/type/hypervisor> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:locatedAtLocus <location/LocusRackA1> .

<observable/IPAddress1> a observable:IPAddress ;
    rdfs:label "192.168.10.100"@en ;
    observable:ipAddressValue "192.168.10.100" .

<observable/IPAddress2> a observable:IPAddress ;
    rdfs:label "10.0.0.1"@en ;
    observable:ipAddressValue "10.0.0.1" .

<observable/IPAddress3> a observable:IPAddress ;
    rdfs:label "192.168.10.101"@en ;
    observable:ipAddressValue "192.168.10.101" .

# --- Network Interfaces (noria:NetworkInterface) ---
<networkinterface/Server01Eth0> a noria:NetworkInterface ;
    rdfs:label "Server01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Web Application Server 01."@en ;
    noria:networkInterfaceOf <resource/Server01> ;
    noria:networkInterfaceDescription "Uplink to corporate LAN" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects <networklink/Server01ToSwitch01> .

<networkinterface/RouterCore01Gi01> a noria:NetworkInterface ;
    rdfs:label "Core Router 01 GigabitEthernet 0/1"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the internet uplink."@en ;
    noria:networkInterfaceOf <resource/RouterCore01> ;
    noria:networkInterfaceDescription "Internet Uplink" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceConnects <networklink/RouterCore01ToISP> .

<networkinterface/RouterCore01Gi02> a noria:NetworkInterface ;
    rdfs:label "Core Router 01 GigabitEthernet 0/2"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the internal data center network."@en ;
    noria:networkInterfaceOf <resource/RouterCore01> ;
    noria:networkInterfaceDescription "Internal DC Network" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric "50"^^xsd:int ;
    noria:networkInterfaceConnects <networklink/RouterCore01ToSwitch01> .

# --- Network Links (noria:NetworkLink) ---
<networklink/Server01ToSwitch01> a noria:NetworkLink ;
    rdfs:label "Link Server01 to Switch01"@en ;
    rdfs:comment "Ethernet link between Web Application Server 01 and a data center switch."@en ;
    noria:networkLinkId "NL-S01-SW01" ;
    noria:networkLinkTerminationResourceOrigin <resource/Server01> ;
    noria:networkLinkTerminationResourceDestination <resource/Switch01> ; # Assuming Switch01 exists
    noria:networkLinkInstallationDate "2023-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:resourceManagedBy <agent/TeamA> .

<networklink/RouterCore01ToISP> a noria:NetworkLink ;
    rdfs:label "Link Core Router 01 to ISP"@en ;
    rdfs:comment "Fiber optic link connecting Core Router 01 to the Internet Service Provider."@en ;
    noria:networkLinkId "NL-R01-ISP" ;
    noria:networkLinkTerminationResourceOrigin <resource/RouterCore01> ;
    noria:networkLinkInstallationDate "2022-05-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic 100Gbps" ;
    noria:resourceManagedBy <agent/TeamA> .

<networklink/RouterCore01ToSwitch01> a noria:NetworkLink ;
    rdfs:label "Link Core Router 01 to Switch01"@en ;
    rdfs:comment "Internal link between Core Router 01 and a data center switch."@en ;
    noria:networkLinkId "NL-R01-SW01" ;
    noria:networkLinkTerminationResourceOrigin <resource/RouterCore01> ;
    noria:networkLinkTerminationResourceDestination <resource/Switch01> ; # Assuming Switch01 exists
    noria:networkLinkInstallationDate "2022-05-20T15:10:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 40Gbps" ;
    noria:resourceManagedBy <agent/TeamA> .

<resource/Switch01> a noria:Resource ;
    rdfs:label "Data Center Switch 01"@en ;
    rdfs:comment "Core switch for the data center network."@en ;
    noria:resourceManagedBy <agent/TeamA> ;
    noria:resourceHostName "dc-sw-01.dc.example.com" ;
    noria:resourceType <kos/Resource/type/network-switch> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:locatedAtLocus <location/LocusRackB2> .

# --- Applications (noria:Application) ---
<application/WebApp> a noria:Application ;
    rdfs:label "Corporate Web Application"@en ;
    rdfs:label "Application Web d'Entreprise"@fr ;
    rdfs:comment "The main web application used by employees and customers."@en ;
    noria:applicationModelIdentifier "CWA-V2" ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CWA" ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Online Services" ;
    noria:elementManagedBy <agent/TeamB> .

<application/CoreNetwork> a noria:Application ;
    rdfs:label "Core Network Infrastructure"@en ;
    rdfs:label "Infrastructure Réseau Cœur"@fr ;
    rdfs:comment "The underlying network infrastructure supporting all IT services."@en ;
    noria:applicationModelIdentifier "CNI-V1" ;
    noria:applicationNumericalIdentifier "2001"^^xsd:int ;
    noria:applicationShortIdentifier "CNI" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Network Operations" ;
    noria:applicationFunctionalSubDomain "Data Transport" ;
    noria:elementManagedBy <agent/TeamA> .

<application/MonitoringSystem> a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:label "Système de Supervision Centralisé"@fr ;
    rdfs:comment "System responsible for collecting and analyzing logs and metrics from all IT components."@en ;
    noria:applicationModelIdentifier "CMS-V3" ;
    noria:applicationNumericalIdentifier "3001"^^xsd:int ;
    noria:applicationShortIdentifier "CMS" ;
    noria:applicationType <kos/application/type/monitoring> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Event Management" ;
    noria:elementManagedBy <agent/TeamA> .

# --- Application Modules (noria:ApplicationModule) ---
<applicationmodule/WebAppProd> a noria:ApplicationModule ;
    rdfs:label "Corporate Web Application Production Module"@en ;
    rdfs:comment "Production instance of the Corporate Web Application."@en ;
    noria:applicationModuleOf <application/WebApp> ;
    noria:applicationModuleName "CWA_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled "true"^^xsd:boolean ;
    noria:applicationModuleAdministrationTeam <agent/TeamB> ;
    noria:applicationModuleAdministrationLeader <agent/JaneSmith> ;
    noria:applicationModuleSupportTeam <agent/TeamB> ;
    noria:applicationModuleHotlineGroup <agent/TeamB> .

<applicationmodule/WebAppDev> a noria:ApplicationModule ;
    rdfs:label "Corporate Web Application Development Module"@en ;
    rdfs:comment "Development instance of the Corporate Web Application."@en ;
    noria:applicationModuleOf <application/WebApp> ;
    noria:applicationModuleName "CWA_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Bronze> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled "false"^^xsd:boolean ;
    noria:applicationModuleAdministrationTeam <agent/TeamB> .

# --- Services (noria:Service) ---
<service/CustomerFacingWebPortal> a noria:Service ;
    rdfs:label "Customer Facing Web Portal Service"@en ;
    rdfs:comment "End-to-end service providing customer access to their accounts and information."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <applicationmodule/WebAppProd> ; # A service can be composed of application modules
    noria:elementManagedBy <agent/TeamB> .

<service/InternalDataExchange> a noria:Service ;
    rdfs:label "Internal Data Exchange Service"@en ;
    rdfs:comment "Service for secure data exchange between internal systems."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf <application/CoreNetwork> ;
    noria:elementManagedBy <agent/TeamA> .

# --- Event Records (noria:EventRecord) ---
<eventrecord/LogServer01CPUHigh> a noria:EventRecord ;
    rdfs:label "Server01 CPU High Alert"@en ;
    rdfs:comment "Log entry indicating high CPU utilization on Web Application Server 01."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU usage on web-app-01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject <resource/Server01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

<eventrecord/LogRouterCore01InterfaceDown> a noria:EventRecord ;
    rdfs:label "Core Router 01 Interface Down"@en ;
    rdfs:comment "Log entry indicating an interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet 0/1 on core-rtr-01.dc.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject <resource/RouterCore01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<eventrecord/LogUserLoginFailure> a noria:EventRecord ;
    rdfs:label "User Login Failure"@en ;
    rdfs:comment "Log entry for a failed login attempt on the web application."@en ;
    noria:loggingTime "2024-04-20T10:12:00Z"^^xsd:dateTime ;
    noria:logText "Failed login attempt for user 'baduser' from IP 203.0.113.42."@en ;
    noria:logOriginatingManagedObject <application/WebApp> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:logOriginatingAgent <agent/ExternalUser> ; # Assuming an external user agent
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

<agent/ExternalUser> a foaf:Agent ;
    rdfs:label "External User"@en ;
    rdfs:comment "Represents an external user attempting to log in."@en .

# --- Trouble Tickets (noria:TroubleTicket) ---
<troubleticket/TT001> a noria:TroubleTicket ;
    rdfs:label "Web App Performance Degradation"@en ;
    rdfs:comment "Users report slow response times for the corporate web application."@en ;
    dcterms:created "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/PerformanceDegradation> ;
    noria:troubleTicketCause "High CPU on application server" ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService <application/WebApp> ;
    noria:troubleTicketRelatedResource <resource/Server01> ;
    noria:troubleTicketRelatedParty <agent/CustomerService>, <agent/TeamB> ;
    noria:troubleTicketTrigger <eventrecord/LogServer01CPUHigh> ;
    noria:documentStatusHistory <eventrecord/TT001StatusChange1> .

<troubleticket/TT002> a noria:TroubleTicket ;
    rdfs:label "Core Network Outage"@en ;
    rdfs:comment "Critical outage affecting internet connectivity for the data center."@en ;
    dcterms:created "2024-04-20T10:20:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/Emergency> ;
    noria:troubleTicketSupervisionTool "Zabbix" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Fiber cut on ISP uplink" ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService <application/CoreNetwork> ;
    noria:troubleTicketRelatedResource <resource/RouterCore01> ;
    noria:troubleTicketRelatedParty <agent/TeamA>, <agent/JohnDoe> ;
    noria:troubleTicketTrigger <eventrecord/LogRouterCore01InterfaceDown> ;
    noria:documentStatusHistory <eventrecord/TT002StatusChange1> .

# --- Trouble Ticket Notes (noria:TroubleTicketNote) ---
<troubleticketnote/TT001Note1> a noria:TroubleTicketNote ;
    rdfs:label "Initial diagnosis for TT001"@en ;
    rdfs:comment "Initial check shows high CPU on web-app-01. Investigating root cause."@en ;
