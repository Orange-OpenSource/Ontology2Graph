# Add a new trouble ticket for a network interface going down
:TroubleTicket_Network_Interface_Down_006 a noria:TroubleTicket ;
    rdfs:label "Network Interface Down Incident"@en ;
    rdfs:comment "A critical network interface on a core router went down unexpectedly."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger :EventRecord_CR01_Interface_Down ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedResource :Resource_Core_Router_01 ;
    noria:troubleTicketRelatedParty :Agent_Network_Admin .

# Add a new trouble ticket note for the network interface issue
:TroubleTicketNote_Network_Interface_Down_006_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Interface Down Initial Assessment"@en ;
    rdfs:comment "Confirmed interface Gi0/0/1 on CR01 is down. No physical damage observed. Attempting to bring up administratively."@en ;
    dcterms:created "2024-04-23T10:08:00Z"^^xsd:dateTime ;
    dcterms:creator :Agent_Alice_Smith ;
    dcterms:isPartOf :TroubleTicket_Network_Interface_Down_006 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

