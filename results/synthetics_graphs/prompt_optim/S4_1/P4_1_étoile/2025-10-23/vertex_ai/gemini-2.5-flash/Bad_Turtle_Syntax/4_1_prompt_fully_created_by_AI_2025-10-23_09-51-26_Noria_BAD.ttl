# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# NORIA Ontology Metadata (as provided in the schema)
# =============================================================================

<https://w3id.org/noria/ontology/>
	a owl:Ontology ;
	dcterms:title "The NORIA Ontology"@en ;
	dcterms:description """The NORIA-O project is a data model for IT networks, events and operations information.
The ontology is developed using web technologies (e.g. RDF, OWL, SKOS) and is intended as a structure for realizing an IT Service Management (ITSM) Knowledge Graph (KG) for Anomaly Detection (AD) and Risk Management applications.
The model has been developed in collaboration with operational teams, and in connection with third parties linked vocabularies.
"""@en ;
	dcterms:issued "2022-05-10"^^xsd:date ;
	dcterms:modified "2024-03-15"^^xsd:date ;
	owl:versionInfo "v0.3" ;
.

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

:Agent_IT_Operations a foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:label "Équipe Opérations IT"@fr ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "For critical incidents, call the hotline immediately. For non-critical, use the ticketing system."@en .

:Agent_Network_Admin a foaf:Agent ;
    rdfs:label "Network Administration Team"@en ;
    rdfs:label "Équipe Administration Réseau"@fr ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Open a ticket for all requests. For urgent issues, escalate via the IT Operations Team."@en .

:Agent_App_Support_L2 a foaf:Agent ;
    rdfs:label "Application Support L2"@en ;
    rdfs:label "Support Applicatif N2"@fr ;
    rdfs:comment "Second-level support for business applications."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> .

:Agent_Security_Team a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:label "Centre des Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

:Agent_John_Doe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual IT technician, member of the IT Operations Team."@en ;
    foaf:mbox <mailto:john.doe@example.com> .

:OrgUnit_IT_Dept a org:OrganizationalUnit ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "Overall IT department of the company."@en .

:OrgUnit_Network_Ops a org:OrganizationalUnit ;
    rdfs:label "Network Operations"@en ;
    rdfs:comment "Sub-unit within IT Department focusing on network operations."@en ;
    org:unitOf :OrgUnit_IT_Dept .

