# Add a new resource type for storage
:Resource_SAN_Storage_01 a noria:Resource ;
    rdfs:label "SAN Storage Array 01"@en ;
    rdfs:comment "Storage Area Network array providing block storage to servers."@en ;
    noria:resourceManagedBy :Agent_IT_Operations ;
    noria:resourceHostName "san01.prod.example.com" ;
    noria:resourceType <kos/Resource/type/storage> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> .

# Link the DB server to the SAN storage
:Resource_DB_Server_01 seas:subSystemOf :Resource_SAN_Storage_01 . # DB server uses SAN storage

# Add a trouble ticket for storage issue
:TroubleTicket_SAN_Perf_005 a noria:TroubleTicket ;
    rdfs:label "SAN Storage Performance Degradation"@en ;
    rdfs:comment "Slow I/O operations reported on SAN storage array."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Initialised> ;
    noria:troubleTicketRelatedResource :Resource_SAN_Storage_01 ;
    noria:troubleTicketRelatedParty :Agent_IT_Operations .

# Add an event record for SAN performance
:EventRecord_SAN_IO_Latency a noria:EventRecord ;
    rdfs:label "SAN I/O Latency Alert"@en ;
    rdfs:comment "Alert indicating high I/O latency on SAN Storage Array 01."@en ;
    noria:loggingTime "2024-04-24T10:00:00Z"^^xsd:dateTime ;
    noria:logText "Average I/O latency on san01.prod.example.com exceeded 50ms."@en ;
    noria:logOriginatingManagedObject :Resource_SAN_Storage_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

:TroubleTicket_SAN_Perf_005 noria:troubleTicketTrigger :EventRecord_SAN_IO_Latency .

# Add a change request for SAN maintenance
:ChangeRequest_SAN_Firmware_Upgrade a noria:ChangeRequest ;
    rdfs:label "SAN Firmware Upgrade"@en ;
    rdfs:comment "Planned firmware upgrade for SAN Storage Array 01."@en ;
    dcterms:created "2024-04-18T14:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-15T00:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-15T03:00:00Z"^^xsd:dateTime ;
    noria:changeRequestType <kos/ChangeRequest/type/Major> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/PreventativeMaintenance> ;
    noria:changeRequestImpact :Resource_SAN_Storage_01 ;
    noria:changeRequestOutageDuration "PT3H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty :Agent_IT_Operations .

# Add a new operation plan for SAN firmware upgrade
:OperationPlan_SAN_Firmware_Upgrade a noria:OperationPlan ;
    rdfs:label "SAN Firmware Upgrade Procedure"@en ;
    rdfs:comment "Detailed procedure for upgrading firmware on SAN storage arrays."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_SAN_Maintenance_Window ;
    noria:operationPlanPostCondition :ActionPostCondition_SAN_Firmware_Updated .

:ActionPreCondition_SAN_Maintenance_Window a noria:ActionPreCondition ;
    rdfs:label "SAN Maintenance Window Available"@en ;
    rdfs:comment "Condition: A scheduled maintenance window must be available for SAN operations."@en .

:ActionPostCondition_SAN_Firmware_Updated a noria:ActionPostCondition ;
    rdfs:label "SAN Firmware Updated and Verified"@en ;
    rdfs:comment "Expected outcome: SAN firmware is successfully updated, and all storage services are verified."@en .

:ChangeRequest_SAN_Firmware_Upgrade noria:changeRequestSpecification :OperationPlan_SAN_Firmware_Upgrade .

# Add a new organizational unit for a specific team
:OrgUnit_Storage_Team a org:OrganizationalUnit ;
    rdfs:label "Storage Team"@en ;
    rdfs:comment "Specialized team managing storage infrastructure."@en ;
    org:unitOf :OrgUnit_IT_Dept .

:Agent_IT_Operations noria:agentManagesResource :Resource_SAN_Storage_01 .
:ChangeRequest_SAN_Firmware_Upgrade noria:changeRequestActorParty :Agent_IT_Operations .

# Add a new locus for a different room
:Room_Storage_Hall_B a noria:Room ;
    rdfs:label "Storage Hall B"@en ;
    rdfs:comment "Dedicated hall for storage systems."@en ;
    bot:hasSpace :Site_Paris_DC .

:Locus_Storage_Rack_S01_U01 a noria:Locus ;
    rdfs:label "Storage Rack S01, Unit 01"@en ;
    noria:locusLine "S01" ;
    noria:locusRow "01" ;
    bot:hasSpace :Room_Storage_Hall_B .

:Resource_SAN_Storage_01 noria:locatedAtLocus :Locus_Storage_Rack_S01_U01 .

# Add a new application module for a different environment
:ApplicationModule_CMS_Alert_Engine a noria:ApplicationModule ;
    rdfs:label "CMS Alert Engine Module"@en ;
    rdfs:comment "Module within the Central Monitoring System responsible for alert generation and routing."@en ;
    noria:applicationModuleOf :Application_Monitoring_System ;
    noria:applicationModuleName "MONSYS_ALERT_ENGINE" ;
    noria:applicationModuleIdentifier "ALRT" ;
    noria:applicationModuleAdministrationTeam :OrgUnit_IT_Dept ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

# Link the alert engine to the web server down event
:EventRecord_Web01_Down noria:logOriginatingManagementSystem :ApplicationModule_CMS_Alert_Engine .

