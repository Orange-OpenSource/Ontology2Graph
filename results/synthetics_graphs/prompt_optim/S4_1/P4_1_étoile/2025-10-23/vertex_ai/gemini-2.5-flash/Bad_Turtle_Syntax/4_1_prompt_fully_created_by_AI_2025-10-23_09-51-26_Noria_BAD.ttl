# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

:OperationPlan_Router_Reboot a noria:OperationPlan ;
    rdfs:label "Standard Router Reboot Procedure"@en ;
    rdfs:comment "A documented procedure for safely rebooting a network router."@en ;
    skos:example "Steps include: notify stakeholders, save configuration, execute reboot command, verify connectivity."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_Router_Accessible ;
    noria:operationPlanPostCondition :ActionPostCondition_Router_Online .

:OperationPlan_DB_Query_Optimization a noria:OperationPlan ;
    rdfs:label "Database Query Optimization Procedure"@en ;
    rdfs:comment "Procedure for identifying and optimizing slow database queries."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_DB_High_Load ;
    noria:operationPlanPostCondition :ActionPostCondition_DB_Load_Reduced .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

:ActionPreCondition_Router_Accessible a noria:ActionPreCondition ;
    rdfs:label "Router Accessible via SSH"@en ;
    rdfs:comment "Condition: The router must be reachable via SSH for remote management."@en .

:ActionPostCondition_Router_Online a noria:ActionPostCondition ;
    rdfs:label "Router Online and Interfaces Up"@en ;
    rdfs:comment "Expected outcome: Router is fully booted, all critical interfaces are up, and routing protocols are converged."@en .

:ActionPreCondition_DB_High_Load a noria:ActionPreCondition ;
    rdfs:label "Database High Load Detected"@en ;
    rdfs:comment "Condition: Monitoring system reports sustained high CPU or I/O load on the database server."@en .

:ActionPostCondition_DB_Load_Reduced a noria:ActionPostCondition ;
    rdfs:label "Database Load Reduced to Normal"@en ;
    rdfs:comment "Expected outcome: Database server CPU and I/O utilization return to normal operating levels."@en .

