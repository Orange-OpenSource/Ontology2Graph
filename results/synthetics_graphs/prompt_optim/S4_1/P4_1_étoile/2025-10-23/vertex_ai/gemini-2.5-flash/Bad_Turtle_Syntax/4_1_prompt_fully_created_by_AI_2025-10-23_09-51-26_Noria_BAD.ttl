    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Data" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" .

:Room_Server_Hall_A a noria:Room ;
    rdfs:label "Server Hall A"@en ;
    rdfs:label "Salle Serveurs A"@fr ;
    rdfs:comment "Primary server hall within the Paris Data Center."@en ;
    bot:hasSpace :Site_Paris_DC .

:Locus_Rack_A12_U24 a noria:Locus ;
    rdfs:label "Rack A12, Unit 24"@en ;
    rdfs:comment "Specific location within Server Hall A for a server rack and unit."@en ;
    noria:locusLine "A12" ;
    noria:locusRow "24" ;
    bot:hasSpace :Room_Server_Hall_A .

:Locus_Rack_B05_U10 a noria:Locus ;
    rdfs:label "Rack B05, Unit 10"@en ;
    rdfs:comment "Specific location within Server Hall A for another server rack and unit."@en ;
    noria:locusLine "B05" ;
    noria:locusRow "10" ;
    bot:hasSpace :Room_Server_Hall_A .

