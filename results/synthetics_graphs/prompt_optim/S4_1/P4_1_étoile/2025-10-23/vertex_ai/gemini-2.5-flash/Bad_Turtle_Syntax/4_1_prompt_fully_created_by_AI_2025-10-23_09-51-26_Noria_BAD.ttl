:EventRecord_CR01_Interface_Up a noria:EventRecord ;
    rdfs:label "Core Router Interface Up Log"@en ;
    rdfs:comment "Log entry for a network interface being brought up on Core Router 01."@en ;
    noria:loggingTime "2024-04-23T10:25:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/1 on dc-par-cr01.example.com changed state to up."@en ;
