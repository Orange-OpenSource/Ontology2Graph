    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects :NetworkLink_DB01_Core01 .

:NetworkInterface_CR01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "CR01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface on Core Router 01 connected to web servers."@en ;
