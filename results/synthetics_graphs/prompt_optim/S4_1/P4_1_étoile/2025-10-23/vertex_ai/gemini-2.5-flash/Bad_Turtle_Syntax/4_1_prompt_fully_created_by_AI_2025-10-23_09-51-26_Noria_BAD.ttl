:Service_Public_Web_Access a noria:Service ;
    rdfs:label "Public Web Access Service"@en ;
    rdfs:comment "End-to-end service providing public access to corporate web resources."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :ApplicationModule_CorpWeb_Prod . # A service can group application modules

:Service_Internal_Monitoring a noria:Service ;
    rdfs:label "Internal Monitoring Service"@en ;
    rdfs:comment "Service for internal IT infrastructure monitoring and alerting."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf :ApplicationModule_CMS_Log_Collector .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

:EventRecord_Web01_Down a noria:EventRecord ;
    rdfs:label "Web Server 01 Down Alert"@en ;
    rdfs:comment "Alert indicating that Web Server 01 is unreachable."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "Host web01.prod.example.com is DOWN. Ping failed."@en ;
    noria:logOriginatingManagedObject :Resource_Web_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

:EventRecord_CR01_Interface_Down a noria:EventRecord ;
    rdfs:label "Core Router Interface Down"@en ;
    rdfs:comment "Log entry for a network interface going down on Core Router 01."@en ;
    noria:loggingTime "2024-04-23T10:04:30Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/1 on dc-par-cr01.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject :Resource_Core_Router_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

:EventRecord_Security_Login_Fail a noria:EventRecord ;
    rdfs:label "Failed Login Attempt Alert"@en ;
    rdfs:comment "Alert for multiple failed login attempts on a critical server."@en ;
    noria:loggingTime "2024-04-23T09:55:10Z"^^xsd:dateTime ;
    noria:logText "Multiple failed login attempts for user 'admin' on db01.prod.example.com from IP 192.168.1.50."@en ;
    noria:logOriginatingManagedObject :Resource_DB_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:logOriginatingAgent :Agent_Security_Team ; # The SOC might be the 'agent' that detected/generated this specific alert from raw logs
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

:TroubleTicket_Web_Outage_001 a noria:TroubleTicket ;
    rdfs:label "Corporate Website Outage Incident"@en ;
    rdfs:label "Incident Panne Site Web Entreprise"@fr ;
    rdfs:comment "Critical incident: Corporate Website is completely inaccessible."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger :EventRecord_Web01_Down ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Network connectivity issue to web server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty :Agent_IT_Operations ;
    noria:troubleTicketRelatedService :Service_Public_Web_Access ;
    noria:troubleTicketRelatedResource :Resource_Web_Server_01 ;
    noria:troubleTicketImpacts :Resource_Web_Server_01, :Application_Corporate_Website, :Service_Public_Web_Access .

:TroubleTicket_DB_Perf_002 a noria:TroubleTicket ;
    rdfs:label "Database Performance Degradation"@en ;
    rdfs:comment "Incident: Database server experiencing high load and slow queries."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/CorruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Internal> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "Prometheus" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/DowngradingEquipment> ;
    noria:troubleTicketCause "High CPU utilization on DB server due to unoptimized queries."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T14:10:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Initialised> ;
    noria:troubleTicketRelatedParty :Agent_App_Support_L2 ;
    noria:troubleTicketRelatedResource :Resource_DB_Server_01 .

# =============================================================================
# Trouble Ticket Notes (noria:TroubleTicketNote)
# =============================================================================

:TroubleTicketNote_Web_Outage_001_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis Note"@en ;
    rdfs:comment "Initial check shows web server is not responding to pings. Network team engaged."@en ;
    dcterms:created "2024-04-23T10:07:00Z"^^xsd:dateTime ;
    dcterms:creator :Agent_John_Doe ;
    dcterms:isPartOf :TroubleTicket_Web_Outage_001 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

:TroubleTicketNote_Web_Outage_001_Note2 a noria:TroubleTicketNote ;
    rdfs:label "Network Team Update"@en ;
    rdfs:comment "Core router interface Gi0/0/1 was found to be administratively down. Bringing it up now."@en ;
    dcterms:created "2024-04-23T10:20:00Z"^^xsd:dateTime ;
    dcterms:creator :Agent_Network_Admin ;
    dcterms:isPartOf :TroubleTicket_Web_Outage_001 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Group> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    noria:troubleTicketNoteCorrelatedExecution :EventRecord_CR01_Interface_Down .

# =============================================================================
# Change Requests (noria:ChangeRequest)
# =============================================================================

:ChangeRequest_CR001_Router_Upgrade a noria:ChangeRequest ;
    rdfs:label "Core Router Software Upgrade"@en ;
    rdfs:comment "Planned software upgrade for Core Router DC-PAR-01-CR01 to enhance security and performance."@en ;
    dcterms:created "2024-04-10T09:00:00Z"^^xsd:dateTime ;
