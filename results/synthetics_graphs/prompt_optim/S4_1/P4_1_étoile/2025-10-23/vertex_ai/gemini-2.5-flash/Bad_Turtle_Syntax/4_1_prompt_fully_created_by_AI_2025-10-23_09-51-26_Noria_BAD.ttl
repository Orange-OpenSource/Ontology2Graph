    noria:operationPlanPreCondition :ActionPreCondition_DB_Maintenance_Window ;
    noria:operationPlanPostCondition :ActionPostCondition_DB_Health_Verified .

:ActionPreCondition_DB_Maintenance_Window a noria:ActionPreCondition ;
