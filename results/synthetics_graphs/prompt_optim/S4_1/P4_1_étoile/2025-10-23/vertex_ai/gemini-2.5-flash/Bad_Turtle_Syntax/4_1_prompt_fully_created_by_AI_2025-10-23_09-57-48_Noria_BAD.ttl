# --- Operation Plans (noria:OperationPlan) ---
:OperationPlan_RestartInterface a noria:OperationPlan ;
    rdfs:label "Network Interface Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure to restart a network interface on a router."@en ;
    skos:example "CLI commands: 'interface GigabitEthernet0/0/0', 'shutdown', 'no shutdown'."@en ;
    noria:operationPlanPreCondition :PreCondition_InterfaceDown ;
    noria:operationPlanPostCondition :PostCondition_InterfaceUp .

:OperationPlan_DB_Optimization a noria:OperationPlan ;
    rdfs:label "Database Query Optimization"@en ;
    rdfs:comment "Procedure for identifying and optimizing slow database queries."@en ;
    noria:operationPlanPreCondition :PreCondition_DB_HighLoad ;
    noria:operationPlanPostCondition :PostCondition_DB_NormalLoad .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
:PreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: The network interface's operational status is 'down'."@en .

:PostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Expected outcome: The network interface's operational status is 'up' and traffic is flowing."@en .

:PreCondition_DB_HighLoad a noria:ActionPreCondition ;
    rdfs:label "Database High Load Detected"@en ;
    rdfs:comment "Condition: Database server CPU or I/O utilization is consistently high."@en .

:PostCondition_DB_NormalLoad a noria:ActionPostCondition ;
    rdfs:label "Database Load Normalized"@en ;
    rdfs:comment "Expected outcome: Database server CPU and I/O utilization returned to normal levels."@en .

