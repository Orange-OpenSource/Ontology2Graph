# --- Event Records (noria:EventRecord) ---
:Event_WebSrv01_CPU_High a noria:EventRecord ;
    rdfs:label "WebSrv01 High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on websrv01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject :Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

:Event_NetIF_Down a noria:EventRecord ;
    rdfs:label "Network Interface Down Alert"@en ;
    rdfs:comment "Critical alert: Edge Router 1's WAN interface went down."@en ;
    noria:loggingTime "2024-04-23T10:10:15Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down on edge-rtr01."@en ;
    noria:logOriginatingManagedObject :Resource_Router_Edge1 ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction :OperationPlan_RestartInterface .

:Event_DB_Error a noria:EventRecord ;
    rdfs:label "Database Connection Error"@en ;
    rdfs:comment "Application reported database connection issues."@en ;
    noria:loggingTime "2024-04-23T10:12:30Z"^^xsd:dateTime ;
    noria:logText "SQLSTATE[HY000]: General error: 2006 MySQL server has gone away."@en ;
    noria:logOriginatingManagedObject :Application_CustomerPortal ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

:Event_User_Login_Failure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Multiple failed login attempts detected for a user account."@en ;
    noria:loggingTime "2024-04-23T09:45:00Z"^^xsd:dateTime ;
