# --- Operation Plans (noria:OperationPlan) ---
:OperationPlan_Restart_WebServer a noria:OperationPlan ;
    rdfs:label "Restart Web Server Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a web server."@en ;
    skos:example "Steps: 1. Check logs. 2. Attempt graceful shutdown. 3. Force shutdown if necessary. 4. Verify service."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_WebServer_Unresponsive ;
    noria:operationPlanPostCondition :ActionPostCondition_WebServer_Service_Restored ;
.

:OperationPlan_Check_Network_Link a noria:OperationPlan ;
    rdfs:label "Check Network Link Procedure"@en ;
    rdfs:comment "Procedure to diagnose and verify network link status."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_Network_Interface_Down ;
    noria:operationPlanPostCondition :ActionPostCondition_Network_Link_Status_Verified ;
.

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
:ActionPreCondition_WebServer_Unresponsive a noria:ActionPreCondition ;
    rdfs:label "Web Server Unresponsive"@en ;
    rdfs:comment "Condition: Web server is not responding to HTTP requests."@en ;
.

:ActionPostCondition_WebServer_Service_Restored a noria:ActionPostCondition ;
    rdfs:label "Web Server Service Restored"@en ;
    rdfs:comment "Outcome: Web server is responding to HTTP requests and corporate website is accessible."@en ;
.

:ActionPreCondition_Network_Interface_Down a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down"@en ;
    rdfs:comment "Condition: Monitoring system reports a network interface as down."@en ;
.

:ActionPostCondition_Network_Link_Status_Verified a noria:ActionPostCondition ;
    rdfs:label "Network Link Status Verified"@en ;
    rdfs:comment "Outcome: Network link status (up/down) has been confirmed and root cause identified."@en ;
.

# --- Connecting more entities ---
# Link EventRecord to a ProcedureExecutionContainer (TroubleTicket)
# The schema states that TroubleTicket and TroubleTicketNote are subclasses of pep:ProcedureExecutionContainer.
# And EventRecord is a specialization of pep:ProcedureExecution.
# So, we can link EventRecord to TroubleTicket via pep:member.
:TroubleTicket_Web_Outage_001 pep:member :EventRecord_CR01_Interface_Down ;
    pep:member :TroubleTicketNote_TT001_Note1 ;
    pep:member :TroubleTicketNote_TT001_Note2 ;
.

:TroubleTicket_CRM_Performance_002 pep:member :EventRecord_DB01_Disk_Full ;
.

# Link ChangeRequest to EventRecords (e.g., for audit trail)
:ChangeRequest_CR001_Router_Upgrade pep:member :EventRecord_CR01_Interface_Down ; # Example: if the CR was to fix the interface, or if the interface went down during the CR.
.

# Link EventRecord to the procedure that mitigated it
:EventRecord_CR01_Interface_Down noria:alarmMitigatedBy :TroubleTicket_Web_Outage_001 ; # The TT is the container for the mitigation actions
.

# Link OperationPlan to ChangeRequest (as a specification)
:ChangeRequest_CR001_Router_Upgrade noria:changeRequestSpecification <kos/ChangeRequest/specification/NetworkOSUpgrade> ; # This is a concept, not an instance of OperationPlan.
# If we want to link to an actual OperationPlan:
# :ChangeRequest_CR001_Router_Upgrade noria:changeRequestSpecification :OperationPlan_Router_OS_Upgrade ; # This would require defining OperationPlan_Router_OS_Upgrade
.

# Let's add a hypothetical OperationPlan for the router upgrade
:OperationPlan_Router_OS_Upgrade a noria:OperationPlan ;
    rdfs:label "Router OS Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading the operating system of a core router."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_Router_Ready_For_Upgrade ;
    noria:operationPlanPostCondition :ActionPostCondition_Router_Upgrade_Successful ;
.

:ActionPreCondition_Router_Ready_For_Upgrade a noria:ActionPreCondition ;
    rdfs:label "Router Ready for Upgrade"@en ;
    rdfs:comment "Condition: Router configuration backed up, maintenance window approved, and necessary files downloaded."@en ;
.

:ActionPostCondition_Router_Upgrade_Successful a noria:ActionPostCondition ;
    rdfs:label "Router Upgrade Successful"@en ;
    rdfs:comment "Outcome: Router OS upgraded, all interfaces up, and routing protocols converged."@en ;
.

# Now link the ChangeRequest to this OperationPlan
# The property noria:changeRequestSpecification expects a SKOS Concept, not an OperationPlan instance.
# However, we can use dcterms:conformsTo or a custom property if needed, but sticking to NORIA:
# noria:changeRequestSpecification is defined as an ObjectProperty with range a SKOS Concept.
# So, we can't directly link to an OperationPlan instance using this property.
# We can imply that the OperationPlan is related to the ChangeRequest's specification.
# For now, I'll stick to the SKOS concept for noria:changeRequestSpecification.

# Add a document attachment to a TroubleTicket
:DocumentAttachment_NetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Network Diagram for DC-PAR-01"@en ;
    rdfs:comment "Diagram showing the network topology of the Paris Data Center."@en ;
    dcterms:isPartOf :TroubleTicket_Web_Outage_001 ;
    dcterms:format "image/png"^^xsd:string ;
    dcterms:source <http://docs.example.com/network_diagram_dcpar01.png> ;
.

# Add a document attachment to a ChangeRequest
:DocumentAttachment_UpgradePlan a noria:DocumentAttachment ;
    rdfs:label "Router OS Upgrade Plan"@en ;
    rdfs:comment "Detailed plan for the Core Router OS upgrade."@en ;
    dcterms:isPartOf :ChangeRequest_CR001_Router_Upgrade ;
    dcterms:format "application/pdf"^^xsd:string ;
    dcterms:source <http://docs.example.com/cr001_upgrade_plan.pdf> ;
.

# Add more connections to existing entities to increase density
:Agent_IT_Operations_Team noria:agentManagesResource :Resource_Web_Server_01, :Resource_DB_Server_01 ;
.

:Agent_Network_Admin_Team noria:agentManagesResource :Resource_Core_Router_01, :NetworkLink_Web01_CR001, :NetworkLink_DB01_CR01 ;
.

:Application_Corporate_Website seas:subSystemOf :Service_Public_Facing_Services ;
.

:Application_CRM_System seas:subSystemOf :Service_Internal_Business_Services ;
.

# Example of a virtual server status
:Resource_Web_Server_01 noria:virtualServerStatus <kos/Resource/OperationalState/running> ;
.

# Example of optical power metrics for a network interface (if it were optical)
# Assuming CR01_Eth1 is an optical interface for this example
:NetworkInterface_CR01_Eth1 noria:networkInterfaceLaserTxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int ;
.

# Example of document status history for a TroubleTicket
:EventRecord_TT001_Status_InProgress a noria:EventRecord ;
    rdfs:label "TT-20240423-001 Status Change to InProgress"@en ;
    noria:loggingTime "2024-04-23T10:35:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:logText "Trouble Ticket TT-20240423-001 status changed to InProgress."@en ;
.

:TroubleTicket_Web_Outage_001 noria:documentStatusHistory :EventRecord_TT001_Status_InProgress ;
.

# Example of a ChangeRequest being related to an EventRecord (e.g., a log of the change execution)
:EventRecord_CR001_Execution_Log a noria:EventRecord ;
    rdfs:label "CR-20240501-001 Execution Log"@en ;
    noria:loggingTime "2024-05-01T02:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Core_Router_01 ;
    noria:logOriginatingAgent :Agent_John_Doe ;
    noria:logText "Started OS upgrade on cr01.dc-par.example.com."@en ;
.

:ChangeRequest_CR001_Router_Upgrade pep:member :EventRecord_CR001_Execution_Log ;
.
