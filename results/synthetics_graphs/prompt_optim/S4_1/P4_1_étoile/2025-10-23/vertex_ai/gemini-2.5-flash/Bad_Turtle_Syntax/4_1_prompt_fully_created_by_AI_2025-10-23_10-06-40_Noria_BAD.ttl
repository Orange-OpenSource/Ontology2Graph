# --- Services (noria:Service) ---
:Service_Public_Facing_Services a noria:Service ;
    rdfs:label "Public Facing Services"@en ;
    rdfs:comment "Aggregates all services directly accessible by external customers."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :ApplicationModule_Corporate_Website_Prod ; # Example of service composition
.

:Service_Internal_Business_Services a noria:Service ;
    rdfs:label "Internal Business Services"@en ;
    rdfs:comment "Aggregates all services used internally by the organization."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf :ApplicationModule_CRM_Prod ;
.

# --- Event Records (noria:EventRecord) ---
:EventRecord_Web01_CPU_High a noria:EventRecord ;
    rdfs:label "Web01 CPU High Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Web_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:logText "CPU usage on web01.prod.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:alarmProposedRepairAction :OperationPlan_Restart_WebServer ;
.

:EventRecord_CR01_Interface_Down a noria:EventRecord ;
    rdfs:label "CR01 Interface Down Alert"@en ;
    rdfs:comment "Alert indicating that an interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Core_Router_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:logText "Interface CR01_Eth1 on cr01.dc-par.example.com changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logOriginatingAgent :Agent_Network_Admin_Team ; # Could be an automated script or a human action
.

:EventRecord_DB01_Disk_Full a noria:EventRecord ;
    rdfs:label "DB01 Disk Full Alert"@en ;
    rdfs:comment "Alert indicating that a disk on Database Server 01 is nearly full."@en ;
    noria:loggingTime "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_DB_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:logText "Disk usage on db01.prod.example.com reached 95%."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
.

# --- Trouble Tickets (noria:TroubleTicket) ---
:TroubleTicket_Web_Outage_001 a noria:TroubleTicket ;
    rdfs:label "Corporate Website Outage"@en ;
    rdfs:label "Panne Site Web Corporate"@fr ;
    rdfs:comment "Incident reported by customers regarding the corporate website being unreachable."@en ;
    dcterms:identifier "TT-20240423-001"^^xsd:string ;
    dcterms:created "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"^^xsd:string ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/InaccessibleDestination> ;
    noria:troubleTicketCause "Network link failure between web server and core router."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T11:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService :Application_Corporate_Website ;
    noria:troubleTicketRelatedResource :Resource_Web_Server_01, :Resource_Core_Router_01 ;
    noria:troubleTicketRelatedParty :Agent_IT_Operations_Team, :Agent_Network_Admin_Team ;
    noria:troubleTicketTrigger :EventRecord_CR01_Interface_Down ;
    noria:documentHRef <http://ticketing.example.com/TT-20240423-001> ;
    noria:troubleTicketImpacts :Application_Corporate_Website, :Service_Public_Facing_Services ;
.

:TroubleTicket_CRM_Performance_002 a noria:TroubleTicket ;
