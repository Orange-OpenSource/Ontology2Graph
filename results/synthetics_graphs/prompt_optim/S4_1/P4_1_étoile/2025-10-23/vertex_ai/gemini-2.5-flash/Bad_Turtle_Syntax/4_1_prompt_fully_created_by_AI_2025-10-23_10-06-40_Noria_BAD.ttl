    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to corporate network."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects :NetworkLink_Web01_CR01 ;
.

:NetworkInterface_CR01_Eth1 a noria:NetworkInterface ;
    rdfs:label "CR01 Ethernet 1"@en ;
    rdfs:comment "Interface on Core Router 01 connected to Web Server 01."@en ;
    noria:networkInterfaceOf :Resource_Core_Router_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Connection to Web Server VLAN."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects :NetworkLink_Web01_CR01 ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
.

:NetworkInterface_CR01_Eth2 a noria:NetworkInterface ;
    rdfs:label "CR01 Ethernet 2"@en ;
    rdfs:comment "Interface on Core Router 01 connected to DB Server 01."@en ;
    noria:networkInterfaceOf :Resource_Core_Router_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Connection to Database Server VLAN."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects :NetworkLink_DB01_CR01 ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
.

:NetworkInterface_DB01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DB01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Database Server 01."@en ;
    noria:networkInterfaceOf :Resource_DB_Server_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to corporate network."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects :NetworkLink_DB01_CR01 ;
.

# --- Network Links (noria:NetworkLink) ---
:NetworkLink_Web01_CR01 a noria:NetworkLink ;
    rdfs:label "Link Web01 to CR01"@en ;
    rdfs:comment "Physical Ethernet link between Web Server 01 and Core Router 01."@en ;
    noria:networkLinkId "NL-WEB01-CR01"^^xsd:string ;
    noria:networkLinkType "Ethernet 10Gbps"^^xsd:string ;
    noria:networkLinkInstallationDate "2023-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin :Resource_Web_Server_01 ;
    noria:networkLinkTerminationResourceDestination :Resource_Core_Router_01 ;
    noria:resourceManagedBy :Agent_Network_Admin_Team ;
.

:NetworkLink_DB01_CR01 a noria:NetworkLink ;
    rdfs:label "Link DB01 to CR01"@en ;
    rdfs:comment "Physical Ethernet link between DB Server 01 and Core Router 01."@en ;
    noria:networkLinkId "NL-DB01-CR01"^^xsd:string ;
    noria:networkLinkType "Ethernet 10Gbps"^^xsd:string ;
    noria:networkLinkInstallationDate "2023-01-15T10:20:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin :Resource_DB_Server_01 ;
    noria:networkLinkTerminationResourceDestination :Resource_Core_Router_01 ;
    noria:resourceManagedBy :Agent_Network_Admin_Team ;
.

