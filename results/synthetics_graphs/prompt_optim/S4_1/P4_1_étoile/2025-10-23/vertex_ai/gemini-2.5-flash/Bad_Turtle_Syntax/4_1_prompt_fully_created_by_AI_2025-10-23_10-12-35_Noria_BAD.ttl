# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot:  <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents (foaf:Agent, org:OrganizationalUnit) ---
noria:Agent_AdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en, "Équipe d'administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and related infrastructure."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentInstructions "Contact via ticketing system for non-critical issues, phone for critical outages."@en .

noria:Agent_NetworkOps a foaf:Agent ;
    rdfs:label "Network Operations Team"@en, "Équipe d'opérations réseau"@fr ;
    rdfs:comment "Team managing core network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentInstructions "Escalate critical network incidents directly to their hotline."@en .

noria:Agent_AppDev a foaf:Agent ;
    rdfs:label "Application Development Team"@en, "Équipe de développement applicatif"@fr ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en .

noria:Agent_SecurityAnalyst a foaf:Agent ;
    rdfs:label "Security Analyst John Doe"@en, "Analyste Sécurité John Doe"@fr ;
    rdfs:comment "Individual security analyst monitoring system logs and alerts."@en ;
    foaf:mbox <mailto:john.doe@example.com> .

noria:OrgUnit_L1Support a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Level 1 Support"@en, "Support de Niveau 1"@fr ;
    rdfs:comment "First line of support for user and application issues."@en ;
    noria:agentWorkingHours "24/7"@en .

noria:OrgUnit_L2Support a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Level 2 Support"@en, "Support de Niveau 2"@fr ;
    rdfs:comment "Second line of support, handling more complex technical issues."@en ;
    noria:agentWorkingHours "8:00 am - 8:00 pm (Mon-Sun)"@en .

noria:OrgUnit_Hotline a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Hotline Team"@en, "Équipe d'astreinte"@fr ;
    rdfs:comment "Dedicated team for urgent incident response outside business hours."@en ;
    noria:agentWorkingHours "On-call outside business hours"@en .

noria:Agent_CustomerA a foaf:Agent ;
    rdfs:label "Customer A Representative"@en, "Représentant Client A"@fr ;
    rdfs:comment "Key contact person for Customer A regarding service issues."@en ;
    foaf:phone "+1-555-123-4567" .

noria:Agent_ChangeManager a foaf:Agent ;
    rdfs:label "Change Manager Jane Smith"@en, "Responsable des changements Jane Smith"@fr ;
    rdfs:comment "Manages the change management process for IT infrastructure."@en ;
    foaf:mbox <mailto:jane.smith@example.com> .

# --- Locations (bot:Site, noria:Room, noria:Locus) ---
noria:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en, "Centre de Données de Paris"@fr ;
    rdfs:comment "Primary data center location for corporate services."@en ;
    noria:siteId "PARIS-DC-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002"@en ;
    noria:sitePrincipalAddressCountry "FR"@en .

