# --- Services (noria:Service) ---
:Service_Customer_Facing_Web a noria:Service ;
    rdfs:label "Customer Facing Web Service"@en ;
    rdfs:comment "Aggregates all modules related to customer-facing web presence."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystem :ApplicationModule_Corporate_Website_Prod .

:Service_Internal_Business_Ops a noria:Service ;
    rdfs:label "Internal Business Operations Service"@en ;
    rdfs:comment "Service supporting core internal business processes."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystem :ApplicationModule_Inventory_Management_Prod .

# --- Event Records (noria:EventRecord) ---
:EventRecord_Web_Server_CPU_Spike a noria:EventRecord ;
    rdfs:label "Web Server CPU Spike Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on the web server."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Web_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:logText "CPU usage on srv-web-01.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

:EventRecord_Router_Interface_Down a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Critical alert: Core Router 01's external uplink interface went down."@en ;
    noria:loggingTime "2024-04-23T10:10:15Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Core_Router_01 ;
    noria:logOriginatingManagementSystem :Application_Network_Monitoring ;
    noria:logText "Interface GigabitEthernet0/0/0 on rtr-core-01.example.com changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction :OperationPlan_Interface_Troubleshooting .

:EventRecord_DB_Login_Failure a noria:EventRecord ;
    rdfs:label "Database Login Failure"@en ;
    rdfs:comment "Log entry for a failed login attempt on the database server."@en ;
    noria:loggingTime "2024-04-23T10:12:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_DB_Server_01 ;
