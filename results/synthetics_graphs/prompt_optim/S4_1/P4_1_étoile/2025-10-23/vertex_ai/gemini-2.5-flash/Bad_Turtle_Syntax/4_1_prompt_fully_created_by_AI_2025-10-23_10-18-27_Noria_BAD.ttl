# --- Network Interfaces (noria:NetworkInterface) ---
:NetworkInterface_Web_Server_Eth0 a noria:NetworkInterface ;
    rdfs:label "eth0 on Web Server 01"@en ;
    rdfs:comment "Primary network interface for Web Server 01."@en ;
    noria:networkInterfaceOf :Resource_Web_Server_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects :NetworkLink_Web_Switch_Uplink .

:NetworkInterface_Router_GE0_0_0 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/0 on Core Router 01"@en ;
    rdfs:comment "Uplink interface from Core Router 01 to external network."@en ;
    noria:networkInterfaceOf :Resource_Core_Router_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects :NetworkLink_Core_External_Uplink ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

:NetworkInterface_Router_GE0_0_1 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on Core Router 01"@en ;
    rdfs:comment "Interface connecting Core Router 01 to internal data center network."@en ;
    noria:networkInterfaceOf :Resource_Core_Router_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects :NetworkLink_Core_Internal_Link ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

# --- Network Links (noria:NetworkLink) ---
:NetworkLink_Web_Switch_Uplink a noria:NetworkLink ;
    rdfs:label "Web Server Uplink to Switch"@en ;
    rdfs:comment "Physical Ethernet link between Web Server 01 and a data center switch."@en ;
    noria:networkLinkId "NL-WEB-SW-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Agent_Network_Admin ;
    noria:networkLinkTerminationResourceOrigin :Resource_Web_Server_01 ;
    noria:networkLinkTerminationResourceDestination :Resource_Core_Router_01 . # Simplified, assuming switch is part of router's domain

:NetworkLink_Core_External_Uplink a noria:NetworkLink ;
    rdfs:label "Core Router External Uplink"@en ;
    rdfs:comment "High-capacity fiber link connecting the data center to the internet backbone."@en ;
    noria:networkLinkId "NL-CORE-EXT-001" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2022-09-30T14:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Agent_Network_Admin ;
    noria:networkLinkTerminationResource :Resource_Core_Router_01 .

:NetworkLink_Core_Internal_Link a noria:NetworkLink ;
    rdfs:label "Core Router Internal Link"@en ;
    rdfs:comment "Internal link within the data center network."@en ;
    noria:networkLinkId "NL-CORE-INT-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-10-01T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Agent_Network_Admin ;
    noria:networkLinkTerminationResource :Resource_Core_Router_01 .

