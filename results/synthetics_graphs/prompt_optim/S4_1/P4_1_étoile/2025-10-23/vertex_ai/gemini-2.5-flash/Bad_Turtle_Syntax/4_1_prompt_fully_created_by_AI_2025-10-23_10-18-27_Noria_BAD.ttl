# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
:ActionPreCondition_Interface_Down a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: A network interface reports an operational status of 'down'."@en .

:ActionPostCondition_Interface_Up a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Expected outcome: The network interface reports an operational status of 'up' and traffic flows."@en .

:ActionPreCondition_DB_Backup_Complete a noria:ActionPreCondition ;
    rdfs:label "Database Backup Complete"@en ;
    rdfs:comment "Condition: A full backup of the database has been successfully completed."@en .

:ActionPostCondition_DB_Service_Restored a noria:ActionPostCondition ;
    rdfs:label "Database Service Restored"@en ;
    rdfs:comment "Expected outcome: Database service is running, accessible, and data integrity is verified."@en .

