# --- Services ---
noria:Service_InternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en, "Service Accès Internet d'entreprise"@fr ;
    rdfs:comment "End-to-end service providing internet access to corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:ApplicationModule_CorpDNS_Prod ; # Example of service composition
    seas:subSystemOf noria:Resource_FirewallDMZ .

noria:Service_CustomerPortal a noria:Service ;
    rdfs:label "External Customer Portal Service"@en, "Service Portail Client Externe"@fr ;
    rdfs:comment "Service providing access to customer-facing applications."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:ApplicationModule_WebAppPortal_Prod .

# --- Trouble Tickets ---
noria:TroubleTicket_DNSOutage a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en, "Incident Panne Serveur DNS"@fr ;
    rdfs:comment "Primary DNS server unreachable, impacting all corporate services."@en ;
    dcterms:identifier "TT-20240423-001" ;
    dcterms:created "2024-04-23T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Hardware failure on primary DNS server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T08:55:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty noria:Agent_DNSAdminTeam ;
    noria:troubleTicketRelatedService noria:Application_CorpDNS ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketImpacts noria:Service_InternetAccess ;
    noria:troubleTicketTrigger noria:EventRecord_DNSDownLog .

noria:TroubleTicket_WebPerfIssue a noria:TroubleTicket ;
    rdfs:label "WebApp Portal Performance Degradation"@en, "Dégradation Performance Portail Web"@fr ;
    rdfs:comment "Users report slow response times on the corporate web portal."@en ;
    dcterms:identifier "TT-20240423-002" ;
    dcterms:created "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/User> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Initialised> ;
    noria:troubleTicketRelatedParty noria:Agent_AppDevTeam ;
    noria:troubleTicketRelatedService noria:ApplicationModule_WebAppPortal_Prod ;
    noria:troubleTicketRelatedResource noria:Resource_VMWeb01 ;
    noria:troubleTicketImpacts noria:Service_CustomerPortal ;
    noria:troubleTicketTrigger noria:EventRecord_WebServerError .

noria:TroubleTicket_RouterPortDown a noria:TroubleTicket ;
    rdfs:label "Core Router Port Down"@en, "Port Routeur Cœur Hors Service"@fr ;
    rdfs:comment "GigabitEthernet0/0/1 on Core Router 01 went down unexpectedly."@en ;
    dcterms:identifier "TT-20240423-003" ;
    dcterms:created "2024-04-23T11:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty noria:Agent_NetworkOpsTeam ;
    noria:troubleTicketRelatedResource noria:Resource_RouterCore01 ;
    noria:troubleTicketImpacts noria:NetworkLink_CoreToDNS ;
    noria:troubleTicketTrigger noria:EventRecord_RouterPortStatusChange .

# --- Trouble Ticket Notes ---
noria:TroubleTicketNote_DNSOutage_Initial a noria:TroubleTicketNote ;
    rdfs:label "Initial DNS Outage Note"@en ;
    rdfs:comment "Initial assessment: DNS server is not responding to pings. Investigating hardware status."@en ;
    dcterms:created "2024-04-23T09:05:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_DNSAdminTeam ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage .

noria:TroubleTicketNote_DNSOutage_Resolution a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Resolution Note"@en ;
    rdfs:comment "Replaced faulty power supply unit. Server is back online and responding. Monitoring for stability."@en ;
    dcterms:created "2024-04-23T11:45:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_JohnDoe ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage ;
    noria:troubleTicketNoteCorrelatedExecution noria:EventRecord_ConfigChange .

# --- Event Records ---
noria:EventRecord_DNSDownLog a noria:EventRecord ;
    rdfs:label "DNS Server Down Log"@en ;
    rdfs:comment "Log entry indicating DNS service failure."@en ;
    noria:loggingTime "2024-04-23T08:55:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: DNS service on dns01.corp.example.com is down."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_RouterPortStatusChange a noria:EventRecord ;
    rdfs:label "Router Port Status Change Log"@en ;
    rdfs:comment "Log entry for network interface status change on Core Router 01."@en ;
    noria:loggingTime "2024-04-23T11:10:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/1, changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction noria:OperationPlan_RouterFirmwareUpdate .

noria:EventRecord_WebServerError a noria:EventRecord ;
    rdfs:label "Web Server Error Log"@en ;
    rdfs:comment "Application error log from WebApp Portal VM."@en ;
    noria:loggingTime "2024-04-23T10:25:00Z"^^xsd:dateTime ;
    noria:logText "ERROR: Database connection pool exhausted for WebAppPortal."@en ;
    noria:logOriginatingManagedObject noria:Resource_VMWeb01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_ConfigChange a noria:EventRecord ;
    rdfs:label "Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on DNS01."@en ;
    noria:loggingTime "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by John Doe (192.168.1.50)."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingAgent noria:Agent_JohnDoe ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

# --- Change Requests ---
noria:ChangeRequest_RouterUpgrade a noria:ChangeRequest ;
    rdfs:label "Core Router Firmware Upgrade"@en, "Mise à jour Firmware Routeur Cœur"@fr ;
    rdfs:comment "Planned firmware upgrade for Core Router 01 to enhance security and performance."@en ;
    dcterms:identifier "CR-20240501-001" ;
    dcterms:created "2024-04-15T14:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_RouterCore01 ;
    noria:changeRequestImpact noria:Service_InternetAccess ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/NetworkDeviceFirmwareUpdate> ;
    noria:changeRequestInitiatorParty noria:Agent_NetworkOpsTeam ;
    noria:changeRequestPilotParty noria:Agent_NetworkOpsTeam ;
    noria:changeRequestActorParty noria:Agent_JohnDoe ;
    noria:changeRequestIsRegulated true .

noria:ChangeRequest_WebAppDeploy a noria:ChangeRequest ;
    rdfs:label "WebApp Portal New Feature Deployment"@en, "Déploiement Nouvelle Fonctionnalité Portail Web"@fr ;
    rdfs:comment "Deployment of new features for the Corporate WebApp Portal."@en ;
    dcterms:identifier "CR-20240510-002" ;
    dcterms:created "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-10T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-10T23:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Normal> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:ApplicationModule_WebAppPortal_Prod ;
    noria:changeRequestImpact noria:Resource_VMWeb01 ;
    noria:changeRequestOutageDuration "PT30M"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty noria:Agent_AppDevTeam ;
    noria:changeRequestPilotParty noria:Agent_AppDevTeam .

# --- Operation Plans ---
noria:OperationPlan_RouterFirmwareUpdate a noria:OperationPlan ;
    rdfs:label "Router Firmware Update Procedure"@en, "Procédure de Mise à Jour Firmware Routeur"@fr ;
    rdfs:comment "Standard operating procedure for updating router firmware."@en ;
    skos:example "Steps include backup configuration, download firmware, apply update, verify connectivity."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_RouterConnectivityOK ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterFirmwareUpdated .

noria:OperationPlan_WebAppRollback a noria:OperationPlan ;
    rdfs:label "WebApp Rollback Procedure"@en, "Procédure de Retour Arrière Application Web"@fr ;
    rdfs:comment "Procedure to revert WebApp Portal to a previous stable version in case of deployment issues."@en ;
    skos:example "Steps include stopping services, restoring previous code, restarting services, functional testing."@en ;
    noria:operationPlanPostCondition noria:ActionPostCondition_WebAppFunctional .

# --- Action Pre/Post Conditions ---
noria:ActionPreCondition_RouterConnectivityOK a noria:ActionPreCondition ;
    rdfs:label "Router Connectivity OK Pre-condition"@en ;
    rdfs:comment "Verify full network connectivity to the router before starting any maintenance."@en ;
    skos:example "Ping tests to management IP and adjacent devices must pass."@en .

noria:ActionPostCondition_RouterFirmwareUpdated a noria:ActionPostCondition ;
    rdfs:label "Router Firmware Updated Post-condition"@en ;
    rdfs:comment "Confirm that the router firmware version has been successfully updated and all interfaces are up."@en ;
    skos:example "Check 'show version' output and interface status."@en .

noria:ActionPostCondition_WebAppFunctional a noria:ActionPostCondition ;
    rdfs:label "WebApp Functional Post-condition"@en ;
    rdfs:comment "Verify that the web application is fully functional and accessible after deployment or rollback."@en ;
    skos:example "Access main page, login, perform a key transaction."@en .

# --- KOS Concepts (defined inline as per example) ---
# These are not instances of noria:Class but skos:Concept used as values for ObjectProperties.
# They are typically defined in separate SKOS vocabularies, but for this exercise,
# they are represented as URIs that would point to such concepts.
# The example shows how to use them in the graph, so I'll just reference them.
# For completeness, I'll add a few as skos:Concept instances.

<kos/application/type/infrastructure> a skos:Concept ;
    rdfs:label "Infrastructure Application"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

