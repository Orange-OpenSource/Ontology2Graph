# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents (foaf:Agent, org:OrganizationalUnit) ---
noria:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en, "Équipe d'administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentInstructions "Contact via ticketing system for non-critical issues, direct phone for critical outages."@en .

noria:Agent_NetworkOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team managing network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

noria:Agent_AppDevTeam a foaf:Agent ;
    rdfs:label "Application Development Team"@en, "Équipe Développement Applicatif"@fr ;
    rdfs:comment "Team responsible for developing and maintaining the WebApp Portal."@en .

noria:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center"@en, "Centre Opérations Sécurité"@fr ;
    rdfs:comment "Monitors and responds to security incidents."@en .

noria:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Individual IT Administrator, specialized in Linux systems."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en .

noria:OrgUnit_L2Support a org:OrganizationalUnit ;
    rdfs:label "L2 Application Support"@en, "Support Applicatif N2"@fr ;
    rdfs:comment "Second-level support for critical business applications."@en ;
    noria:agentWorkingHours "24/7"@en .

noria:OrgUnit_Hotline a org:OrganizationalUnit ;
    rdfs:label "IT Hotline"@en, "Hotline Informatique"@fr ;
    rdfs:comment "First point of contact for all IT-related issues."@en .

# --- Locations ---
noria:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en, "Centre de Données de Paris"@fr ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace noria:Site_ParisDC .

noria:Locus_Rack12_U23 a noria:Locus ;
    rdfs:label "Rack 12, Unit 23"@en, "Baie 12, Unité 23"@fr ;
    rdfs:comment "Specific location for DNS01 server."@en ;
    noria:locusLine "12" ;
    noria:locusRow "23" ;
    bot:hasZone noria:Room_ServerRoomA .

noria:Locus_Rack15_U10 a noria:Locus ;
    rdfs:label "Rack 15, Unit 10"@en, "Baie 15, Unité 10"@fr ;
    rdfs:comment "Location for RouterCore01."@en ;
    noria:locusLine "15" ;
    noria:locusRow "10" ;
    bot:hasZone noria:Room_ServerRoomA .

# --- Product Models ---
noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Server model for critical applications."@en ;
    noria:productManufacturedBy noria:Org_Dell .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "High-performance data center switch."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform software."@en ;
    noria:productManufacturedBy noria:Org_VMware .

noria:Org_Dell a org:Organization ;
    rdfs:label "Dell Inc."@en .

noria:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems, Inc."@en .

noria:Org_VMware a org:Organization ;
    rdfs:label "VMware, Inc."@en .

# --- Resources ---
noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en, "Serveur DNS d'entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for the corporate network, physical machine."@en ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceManagedBy noria:Agent_DNSAdminTeam ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U23 ;
    noria:resourceManagementIPAddress "192.168.1.10" .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en, "Routeur Cœur 01"@fr ;
    rdfs:comment "Main router for internal network traffic."@en ;
    noria:resourceHostName "router-core01.corp.example.com" ;
    noria:resourceLogisticId "ASSET-RTR-001" ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack15_U10 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_VMWeb01 a noria:Resource ;
    rdfs:label "Web Application VM 01"@en, "VM Application Web 01"@fr ;
    rdfs:comment "Virtual machine hosting the corporate web portal."@en ;
    noria:resourceHostName "web01.app.example.com" ;
    noria:resourceManagedBy noria:Agent_AppDevTeam ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The hypervisor model, not the VM itself
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-01T08:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_WebAppPortal ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Running> .

noria:Resource_FirewallDMZ a noria:Resource ;
    rdfs:label "DMZ Firewall"@en, "Pare-feu DMZ"@fr ;
    rdfs:comment "Firewall protecting the DMZ network segment."@en ;
    noria:resourceHostName "fw-dmz01.corp.example.com" ;
    noria:resourceManagedBy noria:Agent_SecurityTeam ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceManagementIPAddress "172.16.0.1" .

noria:Resource_StorageSAN01 a noria:Resource ;
    rdfs:label "SAN Storage Array 01"@en, "Baie de Stockage SAN 01"@fr ;
    rdfs:comment "Shared storage array for virtual machines and databases."@en ;
    noria:resourceHostName "san01.corp.example.com" ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam ;
    noria:resourceType <kos/Resource/type/Storage> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> .

# --- Network Interfaces ---
noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_RouterCore01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 01 to internal network segment."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_RouterCore01_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet0/0/2"@en ;
    rdfs:comment "Interface connecting Core Router 01 to DMZ Firewall."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_VMWeb01_vNIC0 a noria:NetworkInterface ;
    rdfs:label "VMWeb01 Virtual NIC 0"@en ;
    rdfs:comment "Virtual network interface for Web Application VM 01."@en ;
    noria:networkInterfaceOf noria:Resource_VMWeb01 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# --- Network Links ---
noria:NetworkLink_CoreToDNS a noria:NetworkLink ;
    rdfs:label "Link Core Router to DNS Server"@en ;
    rdfs:comment "Physical link between Core Router 01 and DNS Server 01."@en ;
    noria:networkLinkId "NL-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore01_Gi0_0_1 ;
    noria:networkInterfaceConnects noria:NetworkInterface_DNS01_Eth0 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_DNS01 .

noria:NetworkLink_CoreToVM a noria:NetworkLink ;
    rdfs:label "Link Core Router to WebApp VM"@en ;
    rdfs:comment "Logical link between Core Router 01 and WebApp VM 01 (via hypervisor)."@en ;
    noria:networkLinkId "NL-002" ;
    noria:networkLinkType "Virtual Network" ;
    noria:networkLinkInstallationDate "2023-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore01_Gi0_0_2 ;
    noria:networkInterfaceConnects noria:NetworkInterface_VMWeb01_vNIC0 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_VMWeb01 .

# --- Applications ---
noria:Application_CorpDNS a noria:Application ;
    rdfs:label "Corporate DNS Service"@en, "Service DNS d'entreprise"@fr ;
