@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Agents and Organizational Units
# =============================================================================

foaf:Agent_AdminTeam
    a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:label "Équipe d'administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and operations."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for non-critical issues, phone for critical outages."@en .

foaf:Agent_NetworkOps
    a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:label "Équipe d'opérations réseau"@fr ;
    rdfs:comment "Team managing core network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always call the hotline for network incidents."@en .

foaf:Agent_AppDev
    a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:label "Équipe de développement d'applications"@fr ;
    rdfs:comment "Team responsible for developing and maintaining corporate applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> .

foaf:Agent_SecurityTeam
    a foaf:Agent ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:label "Centre d'opérations de sécurité"@fr ;
    rdfs:comment "Monitors and responds to security threats."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_User1
    a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An end-user reporting an issue."@en .

org:OrgUnit_L2Support
    a org:OrganizationalUnit ;
    rdfs:label "Level 2 Application Support"@en ;
    rdfs:label "Support Applicatif N2"@fr ;
    rdfs:comment "Second-line support for critical applications."@en ;
    noria:agentWorkingHours "8:00 am - 8:00 pm (Mon-Sun)"@en .

org:OrgUnit_Hotline
    a org:OrganizationalUnit ;
    rdfs:label "Hotline Support Group"@en ;
    rdfs:label "Groupe de support d'astreinte"@fr ;
    rdfs:comment "On-call team for urgent issues."@en ;
    noria:agentWorkingHours "24/7"@en .

foaf:Agent_CRInitiator
    a foaf:Agent ;
    rdfs:label "Project Manager Alice"@en ;
    rdfs:comment "Initiator of change requests."@en .

foaf:Agent_CRPilot
    a foaf:Agent ;
    rdfs:label "Technical Lead Bob"@en ;
    rdfs:comment "Pilot of change requests."@en .

foaf:Agent_CRActor
    a foaf:Agent ;
    rdfs:label "System Engineer Charlie"@en ;
    rdfs:comment "Actor implementing change requests."@en .

# =============================================================================
# Locations
# =============================================================================

bot:Site_ParisDC
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:label "Centre de données de Paris"@fr ;
    rdfs:comment "Main data center for corporate services."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:label "Salle des serveurs A"@fr ;
    rdfs:comment "Primary server room within Paris Data Center."@en ;
    bot:hasSpace bot:Site_ParisDC .

noria:Locus_Rack12_U24
    a noria:Locus ;
    rdfs:label "Rack 12, Unit 24"@en ;
    rdfs:comment "Specific location within Server Room A."@en ;
    noria:locusLine "Rack 12" ;
    noria:locusRow "U24" ;
    bot:hasSpace noria:Room_ServerRoomA .

bot:Site_LyonOffice
    a bot:Site ;
    rdfs:label "Lyon Office"@en ;
    rdfs:label "Bureau de Lyon"@fr ;
    rdfs:comment "Regional office with local IT infrastructure."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_CommsRoomB
    a noria:Room ;
    rdfs:label "Communications Room B"@en ;
    rdfs:label "Salle de communication B"@fr ;
    rdfs:comment "Network equipment room in Lyon Office."@en ;
    bot:hasSpace bot:Site_LyonOffice .

noria:Locus_Cabinet05_Shelf3
    a noria:Locus ;
    rdfs:label "Cabinet 05, Shelf 3"@en ;
    rdfs:comment "Location for network devices in Communications Room B."@en ;
    noria:locusLine "Cabinet 05" ;
    noria:locusRow "Shelf 3" ;
    bot:hasSpace noria:Room_CommsRoomB .

