# =============================================================================
# Resources
# =============================================================================

noria:Resource_DNS01
    a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:label "Serveur DNS d'entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, located in Paris DC."@en ;
    noria:resourceManagedBy foaf:Agent_AdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U24 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

noria:Resource_RouterCore01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:label "Routeur Cœur 01"@fr ;
    rdfs:comment "Main router for internal network traffic, located in Paris DC."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:resourceHostName "router-core01.corp.example.com" ;
    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2020-07-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U24 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

noria:Resource_AppServer01
    a noria:Resource ;
    rdfs:label "Application Server 01"@en ;
    rdfs:label "Serveur d'applications 01"@fr ;
    rdfs:comment "Server hosting various corporate applications, located in Lyon Office."@en ;
    noria:resourceManagedBy foaf:Agent_AppDev ;
    noria:resourceHostName "appserver01.corp.example.com" ;
    noria:resourceLogisticId "LOG-APP-001" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceSerialNumber "SN-APP-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Cabinet05_Shelf3 ;
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.50> .

noria:Resource_FirewallDMZ
    a noria:Resource ;
    rdfs:label "DMZ Firewall"@en ;
    rdfs:label "Pare-feu DMZ"@fr ;
    rdfs:comment "Firewall protecting the DMZ segment, located in Paris DC."@en ;
    noria:resourceManagedBy foaf:Agent_SecurityTeam ;
    noria:resourceHostName "fw-dmz.corp.example.com" ;
    noria:resourceLogisticId "LOG-FW-001" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ; # Re-using product model for density
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-FW-001-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-06-10T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U24 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.100.1> .

# =============================================================================
# Network Interfaces
# =============================================================================

noria:NetworkInterface_DNS01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to corporate LAN."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_RouterCore01_Gi0_0_1
    a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 01 to DNS server segment."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Uplink to DNS segment."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_RouterCore01_Gi0_0_2
    a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Interface connecting Core Router 01 to Application server segment."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Uplink to Application segment."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_AppServer01_vNIC0
    a noria:NetworkInterface ;
    rdfs:label "AppServer01 Virtual NIC 0"@en ;
    rdfs:comment "Virtual network interface for Application Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_AppServer01 ;
    noria:networkInterfaceDescription "Virtual NIC for application traffic."@en ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_FirewallDMZ_Ext
    a noria:NetworkInterface ;
    rdfs:label "FirewallDMZ External Interface"@en ;
    rdfs:comment "External facing interface of the DMZ Firewall."@en ;
    noria:networkInterfaceOf noria:Resource_FirewallDMZ ;
    noria:networkInterfaceDescription "Interface connected to external network."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# =============================================================================
# Network Links
# =============================================================================

noria:NetworkLink_CoreToDNS
    a noria:NetworkLink ;
    rdfs:label "Core Router to DNS Server Link"@en ;
    rdfs:comment "Physical link between Core Router 01 and DNS Server 01."@en ;
    noria:networkLinkId "NL-CR01-DNS01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_DNS01 ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore01_Gi0_0_1 ;
    noria:networkInterfaceConnects noria:NetworkInterface_DNS01_Eth0 ;
    noria:networkLinkInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:resourceManagedBy foaf:Agent_NetworkOps .

noria:NetworkLink_CoreToApp
    a noria:NetworkLink ;
    rdfs:label "Core Router to App Server Link"@en ;
    rdfs:comment "Logical link between Core Router 01 and Application Server 01."@en ;
    noria:networkLinkId "NL-CR01-APP01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_AppServer01 ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore01_Gi0_0_2 ;
    noria:networkInterfaceConnects noria:NetworkInterface_AppServer01_vNIC0 ;
    noria:networkLinkInstallationDate "2022-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "VLAN Trunk" ;
    noria:resourceManagedBy foaf:Agent_NetworkOps .

noria:NetworkLink_FirewallToCore
    a noria:NetworkLink ;
    rdfs:label "DMZ Firewall to Core Router Link"@en ;
    rdfs:comment "Link connecting the DMZ Firewall to the Core Router."@en ;
    noria:networkLinkId "NL-FWDMZ-CR01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_FirewallDMZ ;
    noria:networkLinkTerminationResourceDestination noria:Resource_RouterCore01 ;
    noria:networkInterfaceConnects noria:NetworkInterface_FirewallDMZ_Ext ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore01_Gi0_0_1 ; # Sharing interface for density
    noria:networkLinkInstallationDate "2021-06-10T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 1Gbps" ;
    noria:resourceManagedBy foaf:Agent_SecurityTeam .

# =============================================================================
# Applications
# =============================================================================

noria:Application_CorpDNS
    a noria:Application ;
    rdfs:label "Corporate DNS Service"@en ;
    rdfs:label "Service DNS d'entreprise"@fr ;
    rdfs:comment "Provides name resolution for all internal corporate systems."@en ;
    noria:applicationModelIdentifier "CORP-DNS-V1" ;
    noria:applicationNumericalIdentifier 101 ;
    noria:applicationShortIdentifier "CorpDNS" ;
    noria:applicationType <kos/application/type/Infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Name Resolution" ;
    noria:resourceForApplication noria:Resource_DNS01 .

noria:Application_WebPortal
    a noria:Application ;
    rdfs:label "Corporate Web Portal"@en ;
    rdfs:label "Portail Web d'entreprise"@fr ;
    rdfs:comment "Internal web portal for employee services."@en ;
    noria:applicationModelIdentifier "WEB-PORTAL-V2" ;
    noria:applicationNumericalIdentifier 202 ;
    noria:applicationShortIdentifier "WebPortal" ;
    noria:applicationType <kos/application/type/BusinessApplication> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Medium> ;
    noria:applicationFunctionalDomain "Employee Services" ;
    noria:applicationFunctionalSubDomain "Human Resources" ;
    noria:resourceForApplication noria:Resource_AppServer01 .

noria:Application_MonitoringSystem
    a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:label "Système de surveillance réseau"@fr ;
    rdfs:comment "Monitors the health and performance of network devices and applications."@en ;
    noria:applicationModelIdentifier "NMS-PROD-V3" ;
    noria:applicationNumericalIdentifier 303 ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationType <kos/application/type/ManagementTool> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "IT Operations" ;
    noria:applicationFunctionalSubDomain "Monitoring and Alerting" ;
    noria:resourceManagedBy foaf:Agent_NetworkOps .

