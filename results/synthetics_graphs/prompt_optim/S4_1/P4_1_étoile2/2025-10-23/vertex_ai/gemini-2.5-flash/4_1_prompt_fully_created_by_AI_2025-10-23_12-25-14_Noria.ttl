    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

# =============================================================================
# Services
# =============================================================================

noria:Service_InternetAccess
    a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:label "Service d'accès Internet d'entreprise"@fr ;
    rdfs:comment "End-to-end service providing internet access to corporate users, relying on DNS and Web Portal."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystem noria:ApplicationModule_CorpDNS_Prod ;
    seas:subSystem noria:ApplicationModule_WebPortal_Prod ;
    noria:elementManagedBy foaf:Agent_NetworkOps .

# =============================================================================
# Trouble Tickets
# =============================================================================

noria:TroubleTicket_DNSOutage
    a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:label "Incident de panne du serveur DNS"@fr ;
    rdfs:comment "Primary DNS server became unreachable, impacting all corporate services."@en ;
    dcterms:identifier "TT-20240423-001" ;
    dcterms:created "2024-04-23T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/NetworkFailure> ;
    noria:troubleTicketCause "Network connectivity loss to DNS server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T08:55:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ;
    noria:troubleTicketRelatedParty foaf:Agent_AdminTeam ;
    noria:troubleTicketRelatedParty foaf:Agent_NetworkOps ;
    noria:troubleTicketRelatedService noria:Application_CorpDNS ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketImpacts noria:Service_InternetAccess ;
    noria:troubleTicketTrigger noria:EventRecord_DNSDown .

noria:TroubleTicket_WebSlow
    a noria:TroubleTicket ;
    rdfs:label "Web Portal Slow Performance"@en ;
    rdfs:label "Performance lente du portail Web"@fr ;
    rdfs:comment "Users report slow loading times for the corporate web portal."@en ;
    dcterms:identifier "TT-20240423-002" ;
