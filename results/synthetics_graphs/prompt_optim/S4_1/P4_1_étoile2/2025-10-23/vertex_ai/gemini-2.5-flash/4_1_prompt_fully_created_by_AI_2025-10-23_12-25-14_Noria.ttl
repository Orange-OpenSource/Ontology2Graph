# =============================================================================
# Operation Plans and Conditions
# =============================================================================

noria:OperationPlan_RouterOSUpgrade
    a noria:OperationPlan ;
    rdfs:label "Router OS Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router operating systems."@en ;
    skos:example "Steps include backup configuration, load new image, reboot, verify connectivity."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_RouterHealthCheck ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterOnline .

noria:OperationPlan_DNSFailover
    a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:comment "Procedure to switch to a secondary DNS server in case of primary server failure."@en ;
    skos:example "Steps include verifying primary server status, activating secondary, updating network configurations, verifying resolution."@en ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSResolving .

noria:ActionPreCondition_RouterHealthCheck
    a noria:ActionPreCondition ;
    rdfs:label "Router Health Check Pre-condition"@en ;
    rdfs:comment "Verify router health, CPU, memory, and interface status before upgrade."@en ;
    skos:example "All interfaces up, CPU < 50%, Memory < 70%."@en .

noria:ActionPostCondition_RouterOnline
    a noria:ActionPostCondition ;
    rdfs:label "Router Online Post-condition"@en ;
    rdfs:comment "Verify router is online, all critical interfaces are up, and routing protocols are converged after upgrade."@en ;
    skos:example "Ping to default gateway successful, BGP neighbors up, traffic flowing."@en .

noria:ActionPostCondition_DNSResolving
    a noria:ActionPostCondition ;
    rdfs:label "DNS Resolving Post-condition"@en ;
    rdfs:comment "Verify that DNS queries are successfully resolved after failover."@en ;
    skos:example "nslookup for internal and external domains returns correct IPs."@en .

# =============================================================================
# Connections for density
# =============================================================================

# Link Change Request to Operation Plan
noria:ChangeRequest_RouterUpgrade
    pep:usedProcedure noria:OperationPlan_RouterOSUpgrade .

# Link Trouble Ticket to potential corrective actions (Operation Plan)
noria:TroubleTicket_DNSOutage
    noria:alarmProposedRepairAction noria:OperationPlan_DNSFailover .

# Link Event Record to Trouble Ticket for status history
noria:TroubleTicket_DNSOutage
    noria:documentStatusHistory noria:EventRecord_DNSOutage_StatusChange .

# Link Application Modules to Services (already done via seas:subSystem)
# Link Resources to Applications (already done via noria:resourceForApplication)
