# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot:  <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents (foaf:Agent, org:OrganizationalUnit) ---
noria:Agent_IT_Ops_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:label "Équipe Opérations IT"@fr ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations and incident response, ensuring system availability and performance."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for non-critical issues, use dedicated hotline for critical alerts (P1/P2)."@en .

noria:Agent_Network_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:label "Équipe Ingénierie Réseau"@fr ;
    rdfs:comment "Team responsible for network design, implementation, and advanced troubleshooting of the core and access networks."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Escalate network-related critical incidents to this team after initial L1/L2 assessment."@en .

noria:Agent_App_Support_L2 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support L2"@en ;
    rdfs:label "Support Applicatif N2"@fr ;
    rdfs:comment "Second-level support team for critical business applications, handling complex issues and escalations."@en ;
    noria:agentWorkingHours "8:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing> ;
    noria:agentInstructions "All application-related incidents must be logged in the ITSM system before contacting this team."@en .

noria:Agent_John_Doe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer, specializing in core routing and switching technologies."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    org:memberOf noria:Agent_Network_Team .

noria:Agent_Jane_Smith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Administrator for the Customer Portal, responsible for its operational health."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    org:memberOf noria:Agent_App_Support_L2 .

noria:Agent_Alice_Brown a foaf:Agent ;
    rdfs:label "Alice Brown"@en ;
    rdfs:comment "IT Operations Technician, focusing on server and virtualization management."@en ;
    foaf:mbox <mailto:alice.brown@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    org:memberOf noria:Agent_IT_Ops_Team .

# --- Corporate User Identifiers (noria:CorporateUserIdentifier) ---
noria:CUid_Jane_Smith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    rdfs:comment "Corporate User Identifier for Jane Smith, used for system access and authentication."@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount noria:Agent_Jane_Smith .

noria:CUid_John_Doe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "Corporate User Identifier for John Doe, granting access to network management tools."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount noria:Agent_John_Doe .

# --- Locations (bot:Site, noria:Room, noria:Locus) ---
noria:Site_DC_Paris a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center facility located in Paris, housing critical IT infrastructure."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" ;
    bot:hasSpace noria:Room_Server_Hall_A .

noria:Room_Server_Hall_A a noria:Room ;
    rdfs:label "Server Hall A"@en ;
    rdfs:comment "Primary server hall within the Paris Data Center, containing racks of servers and network equipment."@en ;
    bot:containsZone noria:Locus_Rack_A12 .

noria:Locus_Rack_A12 a noria:Locus ;
    rdfs:label "Rack A12"@en ;
    rdfs:comment "Specific rack location A12 in Server Hall A, designated for web and database servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "12" .

noria:Locus_Rack_B05 a noria:Locus ;
    rdfs:label "Rack B05"@en ;
    rdfs:comment "Specific rack location B05 in Server Hall A, designated for core network equipment."@en ;
    noria:locusLine "B" ;
    noria:locusRow "05" ;
    bot:containsZone noria:Room_Server_Hall_A .

# --- Product Models (noria:ProductModel) ---
noria:ProductModel_Dell_R740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model from Dell, commonly used for virtualization and demanding applications."@en ;
    noria:productManufacturedBy <https://www.dell.com/en-us> .

noria:ProductModel_Cisco_ASR9K a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series Router"@en ;
    rdfs:comment "Carrier-grade aggregation services router from Cisco, deployed in core network infrastructure."@en ;
    noria:productManufacturedBy <https://www.cisco.com> .

noria:ProductModel_VMware_ESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Virtualization Platform"@en ;
    rdfs:comment "Industry-leading bare-metal hypervisor for creating and running virtual machines."@en ;
    noria:productManufacturedBy <https://www.vmware.com> .

# --- Resources (noria:Resource) ---
noria:Resource_Web_Server_01 a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Primary web server hosting customer-facing applications, part of the Customer Portal infrastructure."@en ;
    noria:resourceManagedBy noria:Agent_IT_Ops_Team ;
    noria:resourceHostName "web01.example.com" ;
    noria:resourceProductModel noria:ProductModel_Dell_R740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_A12 ;
    noria:resourceForApplication noria:Application_Customer_Portal ;
    noria:resourceLogisticId "ASSET-WEB-001" ;
    noria:resourceSerialNumber "SN-WEB-001-XYZ" ;
    noria:resourceManagementIPAddress "192.168.1.10" .

noria:Resource_Core_Router_01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the data center network backbone, providing connectivity to internal and external networks."@en ;
    noria:resourceManagedBy noria:Agent_Network_Team ;
    noria:resourceHostName "cr01.dc-par.example.com" ;
    noria:resourceProductModel noria:ProductModel_Cisco_ASR9K ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_B05 ;
    noria:resourceManagementIPAddress "10.0.0.1" ;
    noria:resourceLogisticId "ASSET-CR-001" ;
    noria:resourceSerialNumber "SN-CR-001-ABC" ;
    noria:resourceForApplication noria:Application_Customer_Portal . # Essential for portal access.

noria:Resource_Virtual_DB_01 a noria:Resource ;
    rdfs:label "Virtual Database Server 01"@en ;
    rdfs:comment "Virtual machine hosting the main application database for the Customer Portal."@en ;
    noria:resourceManagedBy noria:Agent_IT_Ops_Team ;
    noria:resourceHostName "db01-vm.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMware_ESXi ; # Represents the underlying hypervisor platform.
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceForApplication noria:Application_Customer_Portal ;
    noria:resourceManagementIPAddress "192.168.1.20" .

noria:Resource_Hypervisor_01 a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical server hosting virtual machines, including Virtual_DB_01, managed by VMware vCenter."@en ;
    noria:resourceManagedBy noria:Agent_IT_Ops_Team ;
    noria:resourceHostName "hv01.dc-par.example.com" ;
    noria:resourceProductModel noria:ProductModel_Dell_R740 ;
    noria:resourceType <kos/Resource/type/hypervisor> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:locatedAtLocus noria:Locus_Rack_A12 ;
    noria:clusterController noria:Resource_vCenter_Cluster_01 ;
    noria:resourceForApplication noria:Application_Monitoring_System . # Monitoring agents run on hypervisors.

noria:Resource_vCenter_Cluster_01 a noria:Resource ;
    rdfs:label "vCenter Cluster 01"@en ;
    rdfs:comment "VMware vCenter cluster managing multiple hypervisors and virtual machines."@en ;
    noria:resourceManagedBy noria:Agent_IT_Ops_Team ;
    noria:resourceHostName "vcenter01.example.com" ;
    noria:resourceType <kos/Resource/type/virtualization-manager> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceManagementIPAddress "10.0.0.50" .

# --- Network Interfaces (noria:NetworkInterface) ---
noria:NetworkInterface_Web01_Eth0 a noria:NetworkInterface ;
    rdfs:label "Web01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Web Server 01, connecting it to the internal network."@en ;
    noria:networkInterfaceOf noria:Resource_Web_Server_01 ;
    noria:networkInterfaceDescription "Uplink to core switch in Server Hall A" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceType "physical" .

noria:NetworkInterface_CR01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "CR01 GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Uplink interface on Core Router 01, connecting to ISP A."@en ;
    noria:networkInterfaceOf noria:Resource_Core_Router_01 ;
    noria:networkInterfaceDescription "External link to ISP A" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceType "physical" .

noria:NetworkInterface_CR01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "CR01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Internal interface on Core Router 01, connecting to Server Hall A switch."@en ;
    noria:networkInterfaceOf noria:Resource_Core_Router_01 ;
    noria:networkInterfaceDescription "Internal link to Server Hall A" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 110 ;
    noria:networkInterfaceType "physical" .

# --- Network Links (noria:NetworkLink) ---
noria:NetworkLink_Web01_CR01_Internal a noria:NetworkLink ;
    rdfs:label "Web01 to CR01 Internal Link"@en ;
    rdfs:comment "Ethernet link connecting Web Server 01 to Core Router 01 within the data center."@en ;
    noria:networkLinkId "NL-WEB01-CR01-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_Web_Server_01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Core_Router_01 ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2023-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent_Network_Team .

noria:NetworkInterface_Web01_Eth0 noria:networkInterfaceConnects noria:NetworkLink_Web01_CR01_Internal .
noria:NetworkInterface_CR01_Gi0_0_1 noria:networkInterfaceConnects noria:NetworkLink_Web01_CR01_Internal .

noria:NetworkLink_CR01_ISP_Link a noria:NetworkLink ;
    rdfs:label "CR01 to ISP A Link"@en ;
    rdfs:comment "External fiber optic link connecting Core Router 01 to Internet Service Provider A."@en ;
    noria:networkLinkId "NL-CR01-ISP-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_Core_Router_01 ;
    noria:networkLinkType "Fiber Optic 100Gbps" ;
    noria:networkLinkInstallationDate "2022-05-20T15:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent_Network_Team .

noria:NetworkInterface_CR01_Gi0_0_0 noria:networkInterfaceConnects noria:NetworkLink_CR01_ISP_Link .

# --- Applications (noria:Application) ---
noria:Application_Customer_Portal a noria:Application ;
    rdfs:label "Customer Portal"@en ;
    rdfs:label "Portail Client"@fr ;
    rdfs:comment "Web application allowing customers to manage their services, view bills, and access support."@en ;
    noria:applicationModelIdentifier "CP-V2" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CUSTPORT" ;
    noria:applicationType <kos/application/type/customer-facing> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Customer Self-Service" ;
    noria:elementManagedBy noria:Agent_App_Support_L2 .

noria:Application_Monitoring_System a noria:Application ;
    rdfs:label "Monitoring System"@en ;
    rdfs:label "Système de Supervision"@fr ;
    rdfs:comment "Internal application for infrastructure and application monitoring, collecting metrics and logs."@en ;
    noria:applicationModelIdentifier "MON-V3" ;
    noria:applicationNumericalIdentifier 2002 ;
    noria:applicationShortIdentifier "MONSYS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Event Management" ;
    noria:elementManagedBy noria:Agent_IT_Ops_Team .

# --- Application Modules (noria:ApplicationModule) ---
noria:ApplicationModule_CP_Prod a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module"@en ;
    rdfs:comment "Production instance of the Customer Portal application, serving live customer traffic."@en ;
    noria:applicationModuleOf noria:Application_Customer_Portal ;
    noria:applicationModuleName "CUSTPORT_PROD" ;
    noria:applicationModuleIdentifier "CP-PROD-01" ;
    noria:applicationModuleAdministrationTeam noria:Agent_App_Support_L2 ;
    noria:applicationModuleAdministrationLeader noria:Agent_Jane_Smith ;
    noria:applicationModuleSupportTeam noria:Agent_App_Support_L2 ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

noria:ApplicationModule_MON_Alerting a noria:ApplicationModule ;
    rdfs:label "Monitoring Alerting Module"@en ;
    rdfs:comment "Module responsible for processing monitoring data and generating alerts based on predefined thresholds."@en ;
    noria:applicationModuleOf noria:Application_Monitoring_System ;
    noria:applicationModuleName "MONSYS_ALERT" ;
    noria:applicationModuleIdentifier "MON-ALERT-01" ;
    noria:applicationModuleSupportTeam noria:Agent_IT_Ops_Team ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

# --- Services (noria:Service) ---
noria:Service_Customer_Access a noria:Service ;
    rdfs:label "Customer Access Service"@en ;
    rdfs:comment "End-to-end service providing customer access to online resources, including the Customer Portal."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:ApplicationModule_CP_Prod .

noria:Service_Internal_IT_Platform a noria:Service ;
    rdfs:label "Internal IT Platform Service"@en ;
    rdfs:comment "Service providing core IT functionalities for internal users, including monitoring and virtualization."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:ApplicationModule_MON_Alerting ;
    seas:subSystemOf noria:Resource_Hypervisor_01 .

# --- Event Records (noria:EventRecord) ---
noria:EventRecord_Web01_CPU_High a noria:EventRecord ;
    rdfs:label "Web01 High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01, potentially impacting application performance."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU usage on web01.example.com exceeded 90% for 5 minutes. Threshold: 85%."@en ;
    noria:logOriginatingManagedObject noria:Resource_Web_Server_01 ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_System ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_CR01_Interface_Down a noria:EventRecord ;
    rdfs:label "CR01 Interface Down Log"@en ;
    rdfs:comment "Log entry for a critical network interface going down on Core Router 01, causing connectivity loss."@en ;
    noria:loggingTime "2024-04-23T10:10:15Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/0 on cr01.dc-par.example.com changed state to down. Link to ISP A lost."@en ;
    noria:logOriginatingManagedObject noria:Resource_Core_Router_01 ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_System ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_DB01_Login_Failure a noria:EventRecord ;
    rdfs:label "DB01 Login Failure Log"@en ;
    rdfs:comment "Log entry for repeated failed login attempts on Virtual DB 01, indicating potential security breach or misconfiguration."@en ;
    noria:loggingTime "2024-04-23T10:12:30Z"^^xsd:dateTime ;
    noria:logText "Multiple failed login attempts for user 'admin' on db01-vm.example.com from IP 10.0.0.100."@en ;
    noria:logOriginatingManagedObject noria:Resource_Virtual_DB_01 ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_System ;
    noria:logOriginatingAgent noria:Agent_John_Doe ; # Example: John Doe might have tried to log in with wrong credentials.
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_CR01_Firmware_Start a noria:EventRecord ;
    rdfs:label "CR01 Firmware Upgrade Start Log"@en ;
    rdfs:comment "Log entry indicating the start of the firmware upgrade procedure on Core Router 01."@en ;
    noria:loggingTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:logText "Firmware upgrade initiated on cr01.dc-par.example.com by John Doe via SSH."@en ;
    noria:logOriginatingManagedObject noria:Resource_Core_Router_01 ;
    noria:logOriginatingAgent noria:Agent_John_Doe ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_System ;
    dcterms:relation noria:ChangeRequest_CR01_Firmware_Upgrade .

noria:EventRecord_CR01_Firmware_End a noria:EventRecord ;
    rdfs:label "CR01 Firmware Upgrade End Log"@en ;
    rdfs:comment "Log entry indicating the successful completion of the firmware upgrade on Core Router 01."@en ;
    noria:loggingTime "2024-05-01T03:45:00Z"^^xsd:dateTime ;
    noria:logText "Firmware upgrade completed successfully on cr01.dc-par.example.com. System rebooted."@en ;
    noria:logOriginatingManagedObject noria:Resource_Core_Router_01 ;
    noria:logOriginatingAgent noria:Agent_John_Doe ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_System ;
    dcterms:relation noria:ChangeRequest_CR01_Firmware_Upgrade .

noria:EventRecord_TT_CP_Status_InProgress a noria:EventRecord ;
    rdfs:label "TT CP Outage Status InProgress"@en ;
    rdfs:comment "Event record for status change of Customer Portal Outage ticket to InProgress, indicating active investigation."@en ;
    noria:loggingTime "2024-04-23T10:25:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket noria:TroubleTicket_CP_Outage status changed to InProgress by Jane Smith."@en ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_System ; # Assuming monitoring system logs ticket status changes
    noria:logOriginatingAgent noria:Agent_Jane_Smith ;
    dcterms:references noria:TroubleTicket_CP_Outage .

# --- Trouble Tickets (noria:TroubleTicket) ---
noria:TroubleTicket_CP_Outage a noria:TroubleTicket ;
    rdfs:label "Customer Portal Outage"@en ;
    rdfs:comment "Critical incident affecting the Customer Portal application, leading to service unavailability for users."@en ;
    dcterms:created "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketTrigger noria:EventRecord_Web01_CPU_High ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "High CPU on web server leading to unresponsiveness and service outage."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty noria:Agent_IT_Ops_Team, noria:Agent_Jane_Smith ;
    noria:troubleTicketRelatedService noria:Application_Customer_Portal, noria:Service_Customer_Access ;
    noria:troubleTicketRelatedResource noria:Resource_Web_Server_01 ;
    noria:troubleTicketImpacts noria:Application_Customer_Portal, noria:Resource_Web_Server_01 ;
    noria:documentStatusHistory noria:EventRecord_TT_CP_Status_InProgress ;
    noria:troubleTicketCharacteristic [
        rdfs:label "Impacted Customer Segment"@en ;
        rdfs:comment "All customers in Europe are affected by this outage."@en
    ] .

noria:TroubleTicket_Network_Issue a noria:TroubleTicket ;
    rdfs:label "Core Router Interface Down"@en ;
    rdfs:comment "Incident regarding a critical network interface on the core router, impacting external connectivity."@en ;
    dcterms:created "2024-04-23T10:18:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_CR01_Interface_Down ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Zabbix" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/InaccessibleDestination> ;
    noria:troubleTicketCause "Physical link failure on Gi0/0/0 of CR01, requiring hardware replacement."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:10:15Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Initialised> ;
    noria:troubleTicketRelatedParty noria:Agent_Network_Team, noria:Agent_John_Doe ;
    noria:troubleTicketRelatedResource noria:Resource_Core_Router_01 ;
    noria:troubleTicketImpacts noria:Resource_Core_Router_01, noria:NetworkLink_CR01_ISP_Link .

# --- Trouble Ticket Notes (noria:TroubleTicketNote) ---
noria:TroubleTicketNote_CP_Outage_Update1 a noria:TroubleTicketNote ;
    rdfs:label "CP Outage Update 1"@en ;
    rdfs:comment "Initial assessment: high CPU on web server. Investigating root cause and potential impact on other services."@en ;
    dcterms:created "2024-04-23T10:20:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_Jane_Smith ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket_CP_Outage .

noria:TroubleTicketNote_CP_Outage_Update2 a noria:TroubleTicketNote ;
    rdfs:label "CP Outage Update 2"@en ;
    rdfs:comment "Identified a runaway process on web01. Restarting service to restore functionality. Customer notified of progress."@en ;
    dcterms:created "2024-04-23T10:45:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_Jane_Smith ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:isPartOf noria:TroubleTicket_CP_Outage .

# --- Document Attachments (noria:DocumentAttachment) ---
noria:DocumentAttachment_Web01_Screenshot a noria:DocumentAttachment ;
    rdfs:label "Web01 Error Screenshot"@en ;
    rdfs:comment "Screenshot of the error page displayed to users during the Customer Portal outage, showing a 503 Service Unavailable message."@en ;
    dcterms:isPartOf noria:TroubleTicket_CP_Outage ;
    dcterms:format "image/png" ;
    dcterms:identifier "screenshot-cp-outage-20240423.png" .

# --- Change Requests (noria:ChangeRequest) ---
noria:ChangeRequest_CR01_Firmware_Upgrade a noria:ChangeRequest ;
    rdfs:label "CR01 Firmware Upgrade"@en ;
    rdfs:comment "Planned firmware upgrade for Core Router 01 to enhance security, fix known bugs, and improve performance."@en ;
    dcterms:created "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T15:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_Core_Router_01 ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty noria:Agent_John_Doe ;
    noria:changeRequestPilotParty noria:Agent_Network_Team ;
    noria:changeRequestActorParty noria:Agent_John_Doe ;
    noria:changeRequestIsRegulated true .

# --- Operation Plans (noria:OperationPlan) ---
noria:OperationPlan_Router_Firmware_Update a noria:OperationPlan ;
    rdfs:label "Router Firmware Update Procedure"@en ;
    rdfs:comment "Standard operating procedure for updating router firmware, including pre-checks, execution, and post-verification steps."@en ;
    skos:example "Steps include: 1. Backup configuration. 2. Download firmware. 3. Install firmware. 4. Reboot device. 5. Verify operational status."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_Router_Backup_Complete ;
    noria:operationPlanPostCondition noria:ActionPostCondition_Router_Operational .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
noria:ActionPreCondition_Router_Backup_Complete a noria:ActionPreCondition ;
    rdfs:label "Router Configuration Backup Complete"@en ;
    rdfs:comment "Ensures that a full configuration backup of the router has been successfully performed and verified before proceeding with any changes."@en .

noria:ActionPostCondition_Router_Operational a noria:ActionPostCondition ;
    rdfs:label "Router Operational and Verified"@en ;
    rdfs:comment "Confirms that the router is fully operational, services are restored, and all post-update checks (e.g., routing protocols, interface status) have passed."@en ;
    skos:example "Ping tests successful to key destinations, BGP neighbors up, traffic flowing as expected, no critical alarms."@en .

