# -----------------------------------------------------------------------------
# 17. Operation Plans, Pre/Post Conditions, and Actions
# -----------------------------------------------------------------------------

<OperationPlan/db-upgrade-procedure> a noria:OperationPlan ;
    rdfs:label "Database Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading database software, including backup, installation, and verification steps."@en ;
    noria:operationPlanPreCondition <ActionPreCondition/db-backup-complete> ;
    noria:operationPlanPostCondition <ActionPostCondition/db-service-restored> .

<ActionPreCondition/db-backup-complete> a noria:ActionPreCondition ;
    rdfs:label "Database Backup Complete"@en ;
    rdfs:comment "Ensures a full and verified backup of the database is completed before starting the upgrade process."@en ;
    skos:example "Verify backup logs and integrity checks, confirm storage availability."@en .

<ActionPostCondition/db-service-restored> a noria:ActionPostCondition ;
    rdfs:label "Database Service Restored and Verified"@en ;
    rdfs:comment "Confirms that the database service is running, accessible, and data integrity is maintained after the upgrade."@en ;
    skos:example "Run application health checks, query sample data, monitor database logs for errors, check performance metrics."@en .

<OperationPlan/sfp-replacement-procedure> a noria:OperationPlan ;
    rdfs:label "SFP Module Replacement Procedure"@en ;
    rdfs:comment "Procedure for safely replacing a Small Form-Factor Pluggable (SFP) module in a network device with minimal service disruption."@en ;
    noria:operationPlanPreCondition <ActionPreCondition/sfp-replacement-precheck> ;
    noria:operationPlanPostCondition <ActionPostCondition/interface-operational> .

<ActionPreCondition/sfp-replacement-precheck> a noria:ActionPreCondition ;
    rdfs:label "SFP Replacement Pre-check"@en ;
    rdfs:comment "Verify link redundancy, identify affected services, and prepare replacement SFP module before intervention."@en ;
    skos:example "Check routing tables, verify redundant paths are active, confirm SFP compatibility and availability."@en .

<ActionPostCondition/interface-operational> a noria:ActionPostCondition ;
    rdfs:label "Interface Operational and Traffic Restored"@en ;
    rdfs:comment "Confirm the replaced interface is up, operational, and traffic is flowing as expected without errors."@en ;
    skos:example "Check interface status (admin/oper), ping connected devices, monitor traffic counters and error rates."@en .

<ChangeAction/CR-20240325-001-action> a pep:ChangeAction ;
    rdfs:label "Execute DB Upgrade for CR-20240325-001"@en ;
    rdfs:comment "The actual execution of the database upgrade procedure as part of Change Request CR-20240325-001."@en ;
    pep:isExecutedIn <ChangeRequest/CR-20240325-001> ;
    noria:actionCorrelatedOperationPlan <OperationPlan/db-upgrade-procedure> ;
    dcterms:creator <Agent/team-dev> ;
    dcterms:created "2024-03-25T22:00:00Z"^^xsd:dateTime .

<ChangeAction/CR-20240326-002-action> a pep:ChangeAction ;
    rdfs:label "Execute SFP Replacement for CR-20240326-002"@en ;
    rdfs:comment "The actual execution of the SFP module replacement procedure as part of Change Request CR-20240326-002."@en ;
    pep:isExecutedIn <ChangeRequest/CR-20240326-002> ;
    noria:actionCorrelatedOperationPlan <OperationPlan/sfp-replacement-procedure> ;
    dcterms:creator <Agent/john-doe> ;
    dcterms:created "2024-03-26T01:00:00Z"^^xsd:dateTime .
