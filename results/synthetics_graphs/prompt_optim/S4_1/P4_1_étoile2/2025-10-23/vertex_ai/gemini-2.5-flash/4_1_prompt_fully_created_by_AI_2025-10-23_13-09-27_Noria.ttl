# -----------------------------------------------------------------------------
# 12. Services (noria:Service)
# -----------------------------------------------------------------------------

<Service/internet-access> a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:label "Service Accès Internet Entreprise"@fr ;
    rdfs:comment "Provides internet connectivity for all corporate users and applications, underpinned by the Internet Gateway application."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <Application/internet-gateway> .

<Service/customer-facing-web> a noria:Service ;
    rdfs:label "Customer Facing Web Service"@en ;
    rdfs:label "Service Web Client"@fr ;
    rdfs:comment "Aggregates all web-based services directly accessible by customers, primarily the Customer Portal."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <ApplicationModule/customer-portal-prod> .

