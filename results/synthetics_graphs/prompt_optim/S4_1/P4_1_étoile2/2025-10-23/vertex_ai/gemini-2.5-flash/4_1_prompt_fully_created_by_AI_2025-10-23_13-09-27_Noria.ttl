# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix org: <http://www.w3.org/ns/org#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot:  <https://w3id.org/bot#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/instance/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Agents (foaf:Agent, org:OrganizationalUnit)
# -----------------------------------------------------------------------------

<Agent/team-ops> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Operations Team"@en ;
    rdfs:label "Équipe Opérations"@fr ;
    rdfs:comment "Team responsible for day-to-day IT operations and incident response, including network and server management."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

<Agent/team-dev> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Development Team"@en ;
    rdfs:label "Équipe Développement"@fr ;
    rdfs:comment "Team responsible for application development, deployment, and maintenance."@en ;
    noria:agentWorkingHours "10:00-18:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Chat> .

<Agent/john-doe> a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:label "Jean Dupont"@fr ;
    rdfs:comment "Lead Network Engineer, member of the Operations Team, specializing in core network infrastructure."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+33123456789" ;
    noria:agentWorkingHours "8:30-17:30 (Mon-Fri)" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    foaf:holdsAccount <CorporateUserIdentifier/jdoe> .

<Agent/jane-smith> a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:label "Jeanne Martin"@fr ;
    rdfs:comment "Application Support Specialist, member of the Development Team, focusing on customer-facing applications."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)" ;
    foaf:holdsAccount <CorporateUserIdentifier/jsmith> .

<Agent/customer-support> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Customer Support Team"@en ;
    rdfs:label "Équipe Support Client"@fr ;
    rdfs:comment "First line support for external customers, handling initial inquiries and incident reporting."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> .

<Agent/security-team> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:label "Centre des Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Team responsible for monitoring, detecting, and responding to security incidents and threats."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/SIEMAlerts> .

# -----------------------------------------------------------------------------
# 2. Corporate User Identifiers (noria:CorporateUserIdentifier)
# -----------------------------------------------------------------------------

<CorporateUserIdentifier/jdoe> a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for John Doe, used for system access."@en ;
    foaf:accountName "jdoe" ;
    observable:accountLogin "jdoe" ;
    observable:accountIdentifier "EMP-JD-001" .

<CorporateUserIdentifier/jsmith> a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for Jane Smith, used for system access."@en ;
    foaf:accountName "jsmith" ;
    observable:accountLogin "jsmith" ;
    observable:accountIdentifier "EMP-JS-002" .

# -----------------------------------------------------------------------------
# 3. Organizations (org:Organization)
# -----------------------------------------------------------------------------

<Org/dell> a org:Organization ;
    rdfs:label "Dell Inc."@en ;
    rdfs:comment "Manufacturer of computer hardware, including servers and storage solutions."@en .

<Org/cisco> a org:Organization ;
    rdfs:label "Cisco Systems, Inc."@en ;
    rdfs:comment "Manufacturer of networking hardware, including routers, switches, and security devices."@en .

<Org/vmware> a org:Organization ;
    rdfs:label "VMware, Inc."@en ;
    rdfs:comment "Provider of cloud computing and virtualization software and services."@en .

# -----------------------------------------------------------------------------
# 4. Locations (bot:Site, noria:Room, noria:Locus)
# -----------------------------------------------------------------------------

<Location/site-paris> a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:label "Centre de Données de Paris"@fr ;
    noria:siteId "PDC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

<Location/room-server-a> a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:label "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room in the Paris Data Center, housing critical infrastructure."@en ;
    bot:hasSpace <Location/site-paris> .

<Location/locus-a-r1-c5> a noria:Locus ;
    rdfs:label "Rack 1, Column 5"@en ;
    rdfs:label "Baie 1, Colonne 5"@fr ;
    rdfs:comment "Specific location within Server Room A, where physical servers are installed."@en ;
    noria:locusLine "R1" ;
    noria:locusRow "C5" ;
    bot:containsZone <Location/room-server-a> .

<Location/site-london> a bot:Site ;
    rdfs:label "London Office"@en ;
    rdfs:label "Bureau de Londres"@fr ;
    noria:siteId "LON01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Baker Street" ;
    noria:sitePrincipalAddressCityName "London" ;
    noria:sitePrincipalAddressPostalCode "NW1 6XE" ;
    noria:sitePrincipalAddressCountry "GB" .

<Location/room-network-b> a noria:Room ;
    rdfs:label "Network Equipment Room B"@en ;
    rdfs:label "Salle Équipements Réseau B"@fr ;
    rdfs:comment "Network equipment room in the London Office, hosting core network devices."@en ;
    bot:hasSpace <Location/site-london> .

<Location/locus-b-r2-c3> a noria:Locus ;
    rdfs:label "Rack 2, Column 3"@en ;
    rdfs:label "Baie 2, Colonne 3"@fr ;
    rdfs:comment "Specific location within Network Equipment Room B, for network devices."@en ;
    noria:locusLine "R2" ;
    noria:locusRow "C3" ;
    bot:containsZone <Location/room-network-b> .

# -----------------------------------------------------------------------------
# 5. Product Models (noria:ProductModel)
# -----------------------------------------------------------------------------

<ProductModel/dell-r740> a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance 2U rack server, commonly used for virtualization and demanding applications."@en ;
    noria:productManufacturedBy <Org/dell> .

<ProductModel/cisco-asr1000> a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router"@en ;
    rdfs:comment "Enterprise-class aggregation services router, suitable for WAN edge and data center interconnect."@en ;
    noria:productManufacturedBy <Org/cisco> .

<ProductModel/vmware-esxi> a noria:ProductModel ;
    rdfs:label "VMware ESXi Virtualization Host"@en ;
    rdfs:comment "Industry-leading bare-metal hypervisor for creating and running virtual machines."@en ;
    noria:productManufacturedBy <Org/vmware> .

# -----------------------------------------------------------------------------
# 6. Resources (noria:Resource)
# -----------------------------------------------------------------------------

<Resource/server-web-01> a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:label "Serveur Web 01"@fr ;
    rdfs:comment "Primary web server hosting customer-facing applications, part of the production environment."@en ;
    noria:resourceManagedBy <Agent/team-ops> ;
    noria:resourceHostName "web01.example.com" ;
    noria:resourceLogisticId "LOG-WEB-001" ;
    noria:resourceProductModel <ProductModel/dell-r740> ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/PhysicalServer> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <Location/locus-a-r1-c5> ;
    noria:resourceManagementIPAddress <IPAddress/192.168.1.10> ;
    noria:resourceForApplication <Application/customer-portal> .

<Resource/router-core-01> a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:label "Routeur Coeur 01"@fr ;
    rdfs:comment "Main router for the data center network, providing connectivity to external networks and internal segments."@en ;
    noria:resourceManagedBy <Agent/john-doe> ;
    noria:resourceHostName "cr01.example.com" ;
    noria:resourceLogisticId "LOG-CR-001" ;
    noria:resourceProductModel <ProductModel/cisco-asr1000> ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/NetworkRouter> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <Location/locus-b-r2-c3> ;
    noria:resourceManagementIPAddress <IPAddress/10.0.0.1> ;
    noria:resourceForApplication <Application/internet-gateway> .

<Resource/vm-db-01> a noria:Resource ;
    rdfs:label "Database VM 01"@en ;
    rdfs:label "VM Base de Données 01"@fr ;
    rdfs:comment "Virtual machine hosting the main application database for the customer portal."@en ;
    noria:resourceManagedBy <Agent/team-dev> ;
    noria:resourceHostName "db01.app.example.com" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceForApplication <Application/customer-portal> ;
    noria:clusterController <Resource/hypervisor-01> ;
    noria:resourceManagementIPAddress <IPAddress/172.16.0.5> .

<Resource/hypervisor-01> a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:label "Hôte Hyperviseur 01"@fr ;
    rdfs:comment "Physical server running VMware ESXi, hosting multiple virtual machines including critical application components."@en ;
    noria:resourceManagedBy <Agent/team-ops> ;
    noria:resourceHostName "hv01.example.com" ;
    noria:resourceProductModel <ProductModel/dell-r740> ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/PhysicalServer> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:locatedAtLocus <Location/locus-a-r1-c5> ;
    noria:resourceManagementIPAddress <IPAddress/192.168.1.11> .

<Resource/isp-router-external> a noria:Resource ;
    rdfs:label "ISP Edge Router"@en ;
    rdfs:comment "External router managed by the Internet Service Provider, serving as the demarcation point for our WAN link."@en ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/NetworkRouter> ;
    noria:resourceHostName "isp-edge-01.isp.com" ;
    noria:resourceManagedBy <Agent/team-ops> . # Managed by our team in terms of interface configuration.

# -----------------------------------------------------------------------------
# 7. IP Addresses (observable:IPAddress)
# -----------------------------------------------------------------------------

<IPAddress/192.168.1.10> a observable:IPAddress ;
    rdfs:label "192.168.1.10"@en ;
    rdfs:comment "Management IP address for Web Server 01."@en .

<IPAddress/10.0.0.1> a observable:IPAddress ;
    rdfs:label "10.0.0.1"@en ;
    rdfs:comment "Management IP address for Core Router 01."@en .

<IPAddress/192.168.1.11> a observable:IPAddress ;
    rdfs:label "192.168.1.11"@en ;
    rdfs:comment "Management IP address for Hypervisor Host 01."@en .

<IPAddress/172.16.0.5> a observable:IPAddress ;
    rdfs:label "172.16.0.5"@en ;
    rdfs:comment "Management IP address for Database VM 01."@en .

# -----------------------------------------------------------------------------
# 8. Network Interfaces (noria:NetworkInterface)
# -----------------------------------------------------------------------------

<NetworkInterface/web01-eth0> a noria:NetworkInterface ;
    rdfs:label "eth0 on Web Server 01"@en ;
    rdfs:comment "Primary network interface for Web Server 01, connected to the internal LAN segment A."@en ;
    noria:networkInterfaceOf <Resource/server-web-01> ;
    noria:networkInterfaceDescription "Ethernet interface connected to LAN segment A."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

<NetworkInterface/cr01-ge0-0-0> a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/0 on Core Router 01"@en ;
    rdfs:comment "Uplink interface for Core Router 01 to the external ISP network."@en ;
    noria:networkInterfaceOf <Resource/router-core-01> ;
    noria:networkInterfaceDescription "WAN uplink to ISP."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

<NetworkInterface/cr01-ge0-0-1> a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on Core Router 01"@en ;
    rdfs:comment "LAN interface for Core Router 01, connecting to internal LAN segment A."@en ;
    noria:networkInterfaceOf <Resource/router-core-01> ;
    noria:networkInterfaceDescription "LAN segment A connection."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 .

<NetworkInterface/hv01-vmnic0> a noria:NetworkInterface ;
    rdfs:label "vmnic0 on Hypervisor Host 01"@en ;
    rdfs:comment "Physical network adapter for Hypervisor Host 01, handling VM network traffic."@en ;
    noria:networkInterfaceOf <Resource/hypervisor-01> ;
    noria:networkInterfaceDescription "Physical NIC for VM traffic."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

<NetworkInterface/vmdb01-eth0> a noria:NetworkInterface ;
    rdfs:label "eth0 on Database VM 01"@en ;
    rdfs:comment "Virtual network interface for Database VM 01, connected to the internal VM network."@en ;
    noria:networkInterfaceOf <Resource/vm-db-01> ;
    noria:networkInterfaceDescription "Virtual NIC connected to internal VM network."@en ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

# -----------------------------------------------------------------------------
# 9. Network Links (noria:NetworkLink)
# -----------------------------------------------------------------------------

<NetworkLink/lan-segment-a> a noria:NetworkLink ;
    rdfs:label "LAN Segment A"@en ;
    rdfs:comment "Local Area Network segment connecting web servers, hypervisors, and internal router interface within the data center."@en ;
    noria:networkLinkId "LAN-A-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-10T08:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <Agent/team-ops> ;
    noria:networkInterfaceConnects <NetworkInterface/web01-eth0> ;
    noria:networkInterfaceConnects <NetworkInterface/cr01-ge0-0-1> ;
    noria:networkInterfaceConnects <NetworkInterface/hv01-vmnic0> .

<NetworkLink/wan-isp-link> a noria:NetworkLink ;
    rdfs:label "WAN ISP Uplink"@en ;
    rdfs:comment "Wide Area Network link to the Internet Service Provider, providing external connectivity."@en ;
    noria:networkLinkId "WAN-ISP-001" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2021-03-15T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <Agent/john-doe> ;
    noria:networkInterfaceConnects <NetworkInterface/cr01-ge0-0-0> ;
    noria:networkLinkTerminationResourceOrigin <Resource/router-core-01> ;
    noria:networkLinkTerminationResourceDestination <Resource/isp-router-external> .

# -----------------------------------------------------------------------------
# 10. Applications (noria:Application)
# -----------------------------------------------------------------------------

<Application/customer-portal> a noria:Application ;
    rdfs:label "Customer Portal"@en ;
    rdfs:label "Portail Client"@fr ;
    rdfs:comment "Web application allowing customers to manage their services, view billing, and access support."@en ;
    noria:applicationModelIdentifier "CP-V2" ;
    noria:applicationNumericalIdentifier 101 ;
    noria:applicationShortIdentifier "CUSTPORT" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/CustomerFacing> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Customer Self-Service" .

<Application/monitoring-system> a noria:Application ;
    rdfs:label "Monitoring System"@en ;
    rdfs:label "Système de Supervision"@fr ;
    rdfs:comment "Internal application for monitoring IT infrastructure, services, and application performance."@en ;
    noria:applicationModelIdentifier "MON-V3" ;
    noria:applicationNumericalIdentifier 202 ;
    noria:applicationShortIdentifier "MONSYS" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/Infrastructure> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/Critical> ;
    noria:applicationFunctionalDomain "Service Development, Management and Operations" ;
    noria:applicationFunctionalSubDomain "Resource Performance Management" .

<Application/ticketing-system> a noria:Application ;
    rdfs:label "Ticketing System"@en ;
    rdfs:label "Système de Billetterie"@fr ;
    rdfs:comment "System used for managing incidents, problems, and change requests across all IT services."@en ;
    noria:applicationModelIdentifier "TKS-V1" ;
    noria:applicationNumericalIdentifier 303 ;
    noria:applicationShortIdentifier "TKSYS" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/ITSM> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/Critical> ;
    noria:applicationFunctionalDomain "Service Development, Management and Operations" ;
    noria:applicationFunctionalSubDomain "Incident Management" .

<Application/internet-gateway> a noria:Application ;
    rdfs:label "Internet Gateway Service"@en ;
    rdfs:label "Service Passerelle Internet"@fr ;
    rdfs:comment "Provides secure and managed internet access for the entire corporate network."@en ;
    noria:applicationModelIdentifier "IGW-V1" ;
    noria:applicationNumericalIdentifier 404 ;
    noria:applicationShortIdentifier "IGW" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/Infrastructure> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/Critical> ;
    noria:applicationFunctionalDomain "Resource Development, Management and Operations" ;
    noria:applicationFunctionalSubDomain "Network Management" .

