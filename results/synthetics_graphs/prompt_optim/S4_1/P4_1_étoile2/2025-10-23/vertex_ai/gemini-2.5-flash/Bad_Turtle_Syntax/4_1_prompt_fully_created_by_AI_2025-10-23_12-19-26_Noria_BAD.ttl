:Site_HQ_Datacenter a bot:Site ;
    rdfs:label "Headquarters Datacenter"@en ;
    rdfs:comment "Main datacenter facility for corporate services."@en ;
    noria:siteId "DC-HQ-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Main Street"@en ;
    noria:sitePrincipalAddressCityName "Anytown"@en ;
    noria:sitePrincipalAddressPostalCode "12345" ;
    noria:sitePrincipalAddressCountry "US" .

:Room_Server_Hall_A a noria:Room ;
    rdfs:label "Server Hall A"@en ;
    rdfs:comment "Primary server hall within the HQ Datacenter."@en ;
    bot:hasSpace :Locus_Rack_A1, :Locus_Rack_A2 ;
    bot:hasBuilding :Site_HQ_Datacenter .

:Locus_Rack_A1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of servers in Rack A1, Server Hall A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

:Locus_Rack_A2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of network equipment in Rack A2, Server Hall A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" .

