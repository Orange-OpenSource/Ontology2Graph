# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

:OperationPlan_Router_Upgrade a noria:OperationPlan ;
    rdfs:label "Router Software Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router software."@en ;
    skos:example "Steps include backup configuration, load new image, reboot, verify connectivity."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_Router_Backup_Complete ;
    noria:operationPlanPostCondition :ActionPostCondition_Router_Connectivity_Verified .

:OperationPlan_App_Deployment a noria:OperationPlan ;
    rdfs:label "Application Deployment Procedure"@en ;
    rdfs:comment "Procedure for deploying new versions of applications to production."@en ;
    skos:example "Steps include code deployment, database migration, smoke testing, rollback plan."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_Code_Review_Approved ;
    noria:operationPlanPostCondition :ActionPostCondition_App_Functionality_Verified .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

:ActionPreCondition_Router_Backup_Complete a noria:ActionPreCondition ;
    rdfs:label "Router Configuration Backup Complete"@en ;
    rdfs:comment "Ensures that a full backup of the router configuration has been successfully performed before starting the upgrade."@en .

:ActionPostCondition_Router_Connectivity_Verified a noria:ActionPostCondition ;
    rdfs:label "Router Connectivity Verified"@en ;
    rdfs:comment "Confirms that all critical network interfaces and routing protocols are operational after the router upgrade."@en ;
    skos:example "Ping tests to core services, BGP neighbor status check."@en .

:ActionPreCondition_Code_Review_Approved a noria:ActionPreCondition ;
    rdfs:label "Code Review Approved"@en ;
    rdfs:comment "Requires that the new application code has passed all code review and testing stages."@en .

:ActionPostCondition_App_Functionality_Verified a noria:ActionPostCondition ;
    rdfs:label "Application Functionality Verified"@en ;
    rdfs:comment "Verifies that all key functionalities of the application are working correctly post-deployment."@en ;
    skos:example "User login, data retrieval, transaction processing."@en .

