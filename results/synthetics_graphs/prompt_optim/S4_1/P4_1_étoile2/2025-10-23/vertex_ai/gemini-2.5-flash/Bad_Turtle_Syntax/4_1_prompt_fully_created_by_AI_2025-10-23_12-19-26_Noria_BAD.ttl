# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

:TroubleTicket_001 a noria:TroubleTicket ;
    rdfs:label "Customer Portal Unreachable"@en ;
    rdfs:comment "Customers are reporting inability to access the Customer Portal."@en ;
    dcterms:created "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketTrigger :EventRecord_CR01_Interface_Down ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Monitoring System v3.0" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Network link failure between core router and ISP."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:10:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty :Agent_Customer_Service, :Agent_IT_Ops_Team, :Agent_Network_Team ;
    noria:troubleTicketRelatedService :Service_E2E_Customer_Access, :Application_Customer_Portal ;
    noria:troubleTicketRelatedResource :Resource_Core_Router_01 ;
    noria:troubleTicketImpacts :NetworkLink_CR01_Internet_Uplink, :ApplicationModule_CP_Prod ;
    noria:documentExternalId "CUST-INC-2024-001" ;
    noria:documentHRef <https://ticketing.example.com/ticket/001> .

:TroubleTicket_002 a noria:TroubleTicket ;
    rdfs:label "Web Server CPU Spike"@en ;
    rdfs:comment "Investigate intermittent high CPU usage on Web Server 01."@en ;
    dcterms:created "2024-04-23T10:20:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Minor> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P3> ;
