    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Account Management"@en ;
    noria:elementManagedBy :Agent_App_Support_L2 .

:Application_Monitoring_System a noria:Application ;
    rdfs:label "Monitoring System"@en ;
    rdfs:comment "Internal application for monitoring IT infrastructure and services."@en ;
    noria:applicationModelIdentifier "MON-V3" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "MonitorSys" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations Management"@en ;
    noria:applicationFunctionalSubDomain "Performance Monitoring"@en ;
    noria:elementManagedBy :Agent_IT_Ops_Team .

