    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:resourceManagedBy :Agent_Network_Team .

:NetworkLink_CR01_Internet_Uplink a noria:NetworkLink ;
    rdfs:label "CR01 Internet Uplink"@en ;
    rdfs:comment "Uplink from Core Router 01 to the Internet Service Provider."@en ;
    noria:networkLinkId "NL-CR01-ISP-001" ;
    noria:networkLinkTerminationResourceOrigin :Resource_Core_Router_01 ;
    noria:networkLinkInstallationDate "2022-05-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic 100Gbps" ;
    noria:resourceManagedBy :Agent_Network_Team .

