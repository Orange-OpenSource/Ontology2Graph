# =============================================================================
# Services (noria:Service)
# =============================================================================

:Service_E2E_Customer_Access a noria:Service ;
    rdfs:label "End-to-End Customer Access Service"@en ;
    rdfs:comment "Service providing complete customer access, including portal and underlying infrastructure."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :ApplicationModule_CP_Prod ; # A service can be composed of application modules
    seas:subSystemOf :NetworkLink_CR01_Internet_Uplink ; # And network links
    noria:elementManagedBy :Agent_IT_Ops_Team .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

:EventRecord_Web01_CPU_High a noria:EventRecord ;
    rdfs:label "Web01 CPU High Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU usage on web01.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject :Resource_Web_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

:EventRecord_CR01_Interface_Down a noria:EventRecord ;
    rdfs:label "CR01 Interface Down"@en ;
    rdfs:comment "Log entry for network interface going down on Core Router 01."@en ;
    noria:loggingTime "2024-04-23T10:10:15Z"^^xsd:dateTime ;
    noria:logText "Interface CR01_Eth2 changed state to down."@en ;
    noria:logOriginatingManagedObject :Resource_Core_Router_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logOriginatingAgent :Agent_Network_Team . # Could be an automated script or manual action

:EventRecord_CP_Prod_Login_Failure a noria:EventRecord ;
    rdfs:label "Customer Portal Login Failure"@en ;
    rdfs:comment "Log entry for multiple failed login attempts on Customer Portal."@en ;
    noria:loggingTime "2024-04-23T10:12:30Z"^^xsd:dateTime ;
    noria:logText "Multiple failed login attempts detected for user 'baduser' on Customer Portal Production Module."@en ;
    noria:logOriginatingManagedObject :ApplicationModule_CP_Prod ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

