# =============================================================================
# Services (noria:Service)
# =============================================================================

:Service_Corporate_Internet_Access a noria:Service ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users and applications."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :ApplicationModule_Monitoring_Prod_Instance . # Example of linking a service to a monitoring module

:Service_CRM_Data_Access a noria:Service ;
    rdfs:label "CRM Data Access Service"@en ;
    rdfs:comment "Enables secure access to CRM data for internal and external users."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf :ApplicationModule_CRM_Prod_Instance .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

:EventRecord_DNS_Down_Log a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: DNS service on dns01.corp.example.com is unreachable via port 53."@en ;
    noria:logOriginatingManagedObject :Resource_DNS_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_Platform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

:EventRecord_Interface_Down_Log a noria:EventRecord ;
    rdfs:label "Network Interface Down Log"@en ;
    rdfs:comment "Log entry indicating a network interface went down on the core router."@en ;
    noria:loggingTime "2024-04-20T09:03:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down."@en ;
    noria:logOriginatingManagedObject :Resource_Core_Router_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_Platform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

:EventRecord_CRM_Error_Log a noria:EventRecord ;
    rdfs:label "CRM Database Connection Error"@en ;
    rdfs:comment "Application log indicating a failure to connect to the CRM database."@en ;
    noria:loggingTime "2024-04-20T09:10:00Z"^^xsd:dateTime ;
    noria:logText "ERROR: Database connection failed for CRM_PROD_01. Check database server status."@en ;
    noria:logOriginatingManagedObject :Application_CRM_System ;
    noria:logOriginatingManagementSystem :ApplicationModule_Monitoring_Prod_Instance ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

:EventRecord_User_Login_Failure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Security log entry for a failed login attempt on a critical system."@en ;
    noria:loggingTime "2024-04-20T08:55:00Z"^^xsd:dateTime ;
    noria:logText "Failed login for user 'baduser' from IP 1.2.3.4 on server 'auth-server-01'."@en ;
    noria:logOriginatingManagedObject :Resource_DNS_Server_01 ; # Example, could be any resource
    noria:logOriginatingAgent :Agent_IT_Ops_Team ; # Assuming IT Ops team is monitoring this
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

:TroubleTicket_DNS_Outage a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:comment "Critical incident: Corporate DNS server is unreachable, impacting all services."@en ;
    dcterms:created "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger :EventRecord_DNS_Down_Log ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Network connectivity issue to DNS server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
