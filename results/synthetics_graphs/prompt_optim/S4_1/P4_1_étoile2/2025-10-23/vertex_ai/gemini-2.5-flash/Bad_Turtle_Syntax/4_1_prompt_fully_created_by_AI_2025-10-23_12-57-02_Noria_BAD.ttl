# =============================================================================
# Resources (noria:Resource)
# =============================================================================

:Resource_DNS_Server_01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for the corporate network, hosted on a physical machine."@en ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceProductModel :ProductModel_Dell_R740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Agent_IT_Ops_Team ;
    noria:locatedAtLocus :Locus_Rack_A1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

:Resource_Core_Router_01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate network, handling internal and external traffic."@en ;
    noria:resourceHostName "cr01.corp.example.com" ;
    noria:resourceLogisticId "LOG-CR-001" ;
    noria:resourceSerialNumber "SN-CR-001-ABC" ;
    noria:resourceProductModel :ProductModel_Cisco_Nexus_9K ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2020-08-01T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Agent_Network_Team ;
    noria:locatedAtLocus :Locus_Rack_A2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

:Resource_CRM_VM_01 a noria:Resource ;
    rdfs:label "CRM Application VM 01"@en ;
    rdfs:comment "Virtual machine hosting a component of the CRM application."@en ;
    noria:resourceHostName "crm-app-vm01.corp.example.com" ;
    noria:resourceLogisticId "LOG-CRM-VM-001" ;
    noria:resourceProductModel :ProductModel_VMware_ESXi ; # The hypervisor model, not the VM itself
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Agent_App_Support_L2 ;
    noria:resourceForApplication :Application_CRM_System ;
    noria:clusterController :Resource_VMware_Cluster_01 .

:Resource_VMware_Cluster_01 a noria:Resource ;
    rdfs:label "VMware Cluster 01"@en ;
    rdfs:comment "VMware vCenter managing a cluster of ESXi hosts."@en ;
    noria:resourceHostName "vcenter01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/virtualization-manager> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceManagedBy :Agent_IT_Ops_Team .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
