# =============================================================================
# Operation Plans (noria:OperationPlan) and Conditions
# =============================================================================

:OperationPlan_Router_Restart a noria:OperationPlan ;
    rdfs:label "Standard Router Restart Procedure"@en ;
    rdfs:comment "A documented procedure for safely restarting a network router."@en ;
    skos:example "Steps include notifying stakeholders, checking network redundancy, executing restart command, verifying connectivity."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_Network_Redundancy_Check ;
    noria:operationPlanPostCondition :ActionPostCondition_Network_Connectivity_Verified .

:ActionPreCondition_Network_Redundancy_Check a noria:ActionPreCondition ;
    rdfs:label "Network Redundancy Check"@en ;
    rdfs:comment "Verify that redundant network paths are active and healthy before proceeding with a router restart."@en .

:ActionPostCondition_Network_Connectivity_Verified a noria:ActionPostCondition ;
    rdfs:label "Network Connectivity Verified"@en ;
    rdfs:comment "Confirm that all critical network services and links are operational after a router restart."@en ;
    skos:example "Ping critical hosts, check BGP/OSPF neighbor status, verify traffic flow."@en .

:OperationPlan_SFP_Module_Replacement a noria:OperationPlan ;
    rdfs:label "SFP Module Replacement Procedure"@en ;
    rdfs:comment "Procedure for replacing a Small Form-Factor Pluggable (SFP) module in a network device."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_SFP_Module_Available ;
    noria:operationPlanPostCondition :ActionPostCondition_Interface_Operational .

:ActionPreCondition_SFP_Module_Available a noria:ActionPreCondition ;
    rdfs:label "SFP Module Available"@en ;
    rdfs:comment "Ensure a compatible spare SFP module is available on site."@en .

:ActionPostCondition_Interface_Operational a noria:ActionPostCondition ;
    rdfs:label "Interface Operational"@en ;
    rdfs:comment "Verify that the network interface with the new SFP module is up and passing traffic."@en .

# Linking an EventRecord to a proposed repair action (OperationPlan)
:EventRecord_Interface_Down_Log noria:alarmProposedRepairAction :OperationPlan_SFP_Module_Replacement .

# Linking a TroubleTicket to its status history (EventRecords)
:TroubleTicket_DNS_Outage noria:documentStatusHistory :EventRecord_DNS_Down_Log .
# In a real scenario, there would be multiple EventRecords for status changes.
# For example, an EventRecord for "InProgress" status, another for "Resolved", etc.
# For density, let's add a hypothetical status change event.
:EventRecord_DNS_TT_Status_InProgress a noria:EventRecord ;
    rdfs:label "DNS TT Status InProgress"@en ;
    noria:loggingTime "2024-04-20T09:20:00Z"^^xsd:dateTime ;
