    noria:logOriginatingManagementSystem :Application_Monitoring_Platform ;
    noria:logOriginatingAgent :Agent_IT_Ops_Team ;
    dcterms:references :TroubleTicket_DNS_Outage .

:TroubleTicket_DNS_Outage noria:documentStatusHistory :EventRecord_DNS_TT_Status_InProgress .

