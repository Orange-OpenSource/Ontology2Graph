    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Sales & Marketing" .

:Application_Monitoring_Platform a noria:Application ;
    rdfs:label "IT Monitoring Platform"@en ;
    rdfs:comment "Platform for collecting, analyzing, and visualizing IT infrastructure metrics and logs."@en ;
    noria:applicationModelIdentifier "MON-PROD" ;
    noria:applicationNumericalIdentifier "2001"^^xsd:int ;
    noria:applicationShortIdentifier "MON" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Monitoring & Alerting" .

