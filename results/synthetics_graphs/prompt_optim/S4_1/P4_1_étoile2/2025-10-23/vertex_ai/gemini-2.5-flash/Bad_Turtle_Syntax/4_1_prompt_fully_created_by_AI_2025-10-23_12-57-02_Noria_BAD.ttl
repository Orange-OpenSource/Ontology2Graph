:NetworkInterface_DNS_Eth0 a noria:NetworkInterface ;
    rdfs:label "Ethernet 0 on DNS Server 01"@en ;
    rdfs:comment "Primary network interface for DNS Server 01."@en ;
    noria:networkInterfaceOf :Resource_DNS_Server_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects :NetworkLink_DNS_Core_01 .

:NetworkInterface_CR01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet 0/0/1 on Core Router 01"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the internal network segment."@en ;
    noria:networkInterfaceOf :Resource_Core_Router_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceConnects :NetworkLink_DNS_Core_01 .

:NetworkInterface_CR01_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet 0/0/2 on Core Router 01"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the external network/ISP."@en ;
    noria:networkInterfaceOf :Resource_Core_Router_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects :NetworkLink_CR01_ISP .

# =============================================================================
# Network Links (noria:NetworkLink)
