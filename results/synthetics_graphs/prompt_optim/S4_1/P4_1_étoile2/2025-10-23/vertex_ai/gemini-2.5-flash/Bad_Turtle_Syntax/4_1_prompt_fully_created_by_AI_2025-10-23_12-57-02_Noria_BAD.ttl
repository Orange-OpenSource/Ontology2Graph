:Site_HQ_Paris a bot:Site ;
    rdfs:label "Headquarters Paris"@en ;
    rdfs:comment "Main corporate headquarters located in Paris."@en ;
    noria:siteId "HQ-PAR-01" ;
    noria:siteType "building" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" ;
    wgs84_pos:lat "48.8718"^^xsd:float ;
    wgs84_pos:long "2.3314"^^xsd:float .

:Room_Server_HQ_A a noria:Room ;
    rdfs:label "Server Room HQ-A"@en ;
    rdfs:comment "Primary server room at Paris HQ."@en ;
    bot:hasSpace :Locus_Rack_A1, :Locus_Rack_A2 ;
    bot:hasBuilding :Site_HQ_Paris .

:Locus_Rack_A1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of servers in Rack A1 within Server Room HQ-A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasZone :Room_Server_HQ_A .

:Locus_Rack_A2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of network equipment in Rack A2 within Server Room HQ-A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
    bot:hasZone :Room_Server_HQ_A .

