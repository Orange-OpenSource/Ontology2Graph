    noria:networkLinkId "NL-DNS-CR-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin :Resource_DNS_Server_01 ;
    noria:networkLinkTerminationResourceDestination :Resource_Core_Router_01 ;
    noria:resourceManagedBy :Agent_Network_Team .

:NetworkLink_CR01_ISP a noria:NetworkLink ;
    rdfs:label "Link from Core Router 01 to ISP"@en ;
    rdfs:comment "External network link providing internet access."@en ;
    noria:networkLinkId "NL-CR-ISP-001" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2020-08-01T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin :Resource_Core_Router_01 ;
    noria:resourceManagedBy :Agent_Network_Team .

