# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OpPlan_RouterOSUpdate a noria:OperationPlan ;
    rdfs:label "Router OS Update Procedure"@en ;
    rdfs:comment "Standard operating procedure for updating router operating systems."@en ;
    skos:example "Steps include backup, pre-checks, upgrade, post-checks, and rollback plan."@en ;
    noria:operationPlanPreCondition noria:PreCond_RouterReach ;
    noria:operationPlanPostCondition noria:PostCond_RouterUp .

noria:PreCond_RouterReach a noria:ActionPreCondition ;
    rdfs:label "Router Reachable Pre-Condition"@en ;
    rdfs:comment "Condition: Core Router 01 must be reachable via management interface."@en ;
    skos:example "Ping to 10.0.0.1 must succeed."@en .

noria:PostCond_RouterUp a noria:ActionPostCondition ;
    rdfs:label "Router Operational Post-Condition"@en ;
    rdfs:comment "Condition: Core Router 01 must be fully operational after upgrade."@en ;
    skos:example "All interfaces up, routing protocols converged, no critical alarms."@en .

noria:OpPlan_DNS_Troubleshoot a noria:OperationPlan ;
    rdfs:label "DNS Troubleshooting Guide"@en ;
    rdfs:comment "Procedure for diagnosing and resolving DNS service outages."@en ;
    skos:example "Steps include checking server status, network connectivity, DNS configuration, and service restart."@en ;
    noria:operationPlanPreCondition noria:PreCond_DNS_PingFail ;
    noria:operationPlanPostCondition noria:PostCond_DNS_Resolve .

noria:PreCond_DNS_PingFail a noria:ActionPreCondition ;
    rdfs:label "DNS Ping Failure Pre-Condition"@en ;
    rdfs:comment "Condition: DNS server IP address is not reachable."@en ;
    skos:example "Ping to 192.168.1.10 fails."@en .

noria:PostCond_DNS_Resolve a noria:ActionPostCondition ;
    rdfs:label "DNS Resolution Restored Post-Condition"@en ;
    rdfs:comment "Condition: DNS resolution is working correctly."@en ;
    skos:example "DNS queries for internal and external domains resolve successfully."@en .

# =============================================================================
# Connections and Relationships
# =============================================================================

# Link Event Records to Trouble Tickets (documentStatusHistory)
noria:TT_DNSOutage noria:documentStatusHistory noria:Event_DNS_Down .
noria:TT_WebPerformance noria:documentStatusHistory noria:Event_WebSrv_HighCPU .

# Link Change Request to Operation Plan
noria:CR_RouterUpgrade pep:usedProcedure noria:OpPlan_RouterOSUpdate .
noria:CR_DBMigration pep:usedProcedure noria:OpPlan_DNS_Troubleshoot . # Example, might not be a direct fit but shows connection

# Link Application Modules to Resources (indirectly via seas:subSystem)
noria:AppMod_CorpDNS_Prod seas:subSystem noria:Resource_DNS01 .
noria:AppMod_WebPortal_Prod seas:subSystem noria:Resource_WebSrv01 .
noria:AppMod_WebPortal_Prod seas:subSystem noria:Resource_DB01 .

# Link Services to Application Modules (already done, but reinforcing)
noria:Service_InternetAccess seas:subSystem noria:AppMod_CorpDNS_Prod .
noria:Service_InternetAccess seas:subSystem noria:AppMod_WebPortal_Prod .
noria:Service_InternalDB seas:subSystem noria:Resource_DB01 .

# Example of a resource being managed by an agent
noria:Resource_DNS01 noria:resourceManagedBy foaf:Agent_AdminTeam .
noria:Resource_RouterCore01 noria:resourceManagedBy foaf:Agent_NetworkOps .
noria:Resource_WebSrv01 noria:resourceManagedBy foaf:Agent_AppDev .

# Example of an agent managing a resource (inverse property)
foaf:Agent_AdminTeam noria:agentManagesResource noria:Resource_DNS01 .
foaf:Agent_NetworkOps noria:agentManagesResource noria:Resource_RouterCore01 .
foaf:Agent_AppDev noria:agentManagesResource noria:Resource_WebSrv01 .

# Example of a resource being part of an application
noria:Resource_DNS01 noria:resourceForApplication noria:App_CorpDNS .
noria:Resource_WebSrv01 noria:resourceForApplication noria:App_WebPortal .
noria:Resource_DB01 noria:resourceForApplication noria:App_WebPortal .

# Example of a resource being a cluster controller for another resource
noria:Resource_VMHost01 a noria:Resource ;
    rdfs:label "VMware ESXi Host 01"@en ;
    noria:resourceHostName "vmhost01.corp.example.com" ;
    noria:resourceManagedBy foaf:Agent_AdminTeam ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:locatedAtLocus noria:Locus_Rack12_U23 .

noria:Resource_vCenter a noria:Resource ;
    rdfs:label "VMware vCenter Server"@en ;
    noria:resourceHostName "vcenter.corp.example.com" ;
    noria:resourceManagedBy foaf:Agent_AdminTeam ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:locatedAtLocus noria:Locus_Rack12_U23 ;
    noria:clusterController noria:Resource_VMHost01 .

noria:Resource_VMHost01 noria:clusterController noria:Resource_vCenter . # Inverse relationship for density

# Example of a TroubleTicketImpacts
noria:TT_DNSOutage noria:troubleTicketImpacts noria:App_CorpDNS ;
    noria:troubleTicketImpacts noria:Resource_DNS01 .

noria:TT_WebPerformance noria:troubleTicketImpacts noria:App_WebPortal ;
    noria:troubleTicketImpacts noria:Resource_WebSrv01 ;
    noria:troubleTicketImpacts noria:Resource_DB01 .

# Example of a ChangeRequestImpact
noria:CR_RouterUpgrade noria:changeRequestImpact noria:Resource_RouterCore01 ;
    noria:changeRequestImpact noria:Service_InternetAccess .

noria:CR_DBMigration noria:changeRequestImpact noria:Resource_DB01 ;
    noria:changeRequestImpact noria:Service_InternalDB .

# Example of a CorporateUserIdentifier
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe" ;
    rdfs:comment "Corporate User ID for John Doe, a security analyst."@en .

foaf:Agent_SecurityAnalyst foaf:holdsAccount noria:CUid_JohnDoe .

# Example of an EventRecord being mitigated by a ProcedureExecutionContainer (TroubleTicket)
noria:Event_DNS_Down noria:alarmMitigatedBy noria:TT_DNSOutage .
noria:Event_WebSrv_HighCPU noria:alarmMitigatedBy noria:TT_WebPerformance .

# Example of a TroubleTicketNoteCorrelatedExecution (linking a note to a procedure execution container)
# This is a bit abstract without actual pep:ProcedureExecution instances, but we can link it to the TT itself as a container.
noria:TTNote_DNS_Diag noria:troubleTicketNoteCorrelatedExecution noria:TT_DNSOutage .
noria:TTNote_Web_Fix noria:troubleTicketNoteCorrelatedExecution noria:TT_WebPerformance .

# Example of DocumentAttachment
noria:DocAttach_DNSDiagReport a noria:DocumentAttachment ;
    rdfs:label "DNS Diagnostic Report"@en ;
    rdfs:comment "Detailed report of DNS outage diagnosis."@en ;
    dcterms:isPartOf noria:TT_DNSOutage ;
    dcterms:format "application/pdf" ;
    dcterms:title "DNS_Outage_Report_20240423.pdf" .

noria:DocAttach_RouterUpgradePlan a noria:DocumentAttachment ;
    rdfs:label "Router Upgrade Plan"@en ;
    rdfs:comment "Detailed plan for Core Router OS upgrade."@en ;
    dcterms:isPartOf noria:CR_RouterUpgrade ;
    dcterms:format "application/vnd.openxmlformats-officedocument.wordprocessingml.document" ;
    dcterms:title "CR_RouterUpgrade_Plan_v1.0.docx" .

