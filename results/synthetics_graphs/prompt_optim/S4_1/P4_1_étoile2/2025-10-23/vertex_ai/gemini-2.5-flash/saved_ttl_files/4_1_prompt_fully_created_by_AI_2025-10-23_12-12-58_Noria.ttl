noria:Event_DNS_Down a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating that the corporate DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service unreachable."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_Interface_Flap a noria:EventRecord ;
    rdfs:label "Router Interface Flap Event"@en ;
    rdfs:comment "Event indicating a network interface on Core Router 01 flapped (went down and up)."@en ;
    noria:loggingTime "2024-04-23T10:03:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logText "Interface GigabitEthernet0/0/1 on router-core-ldn01 changed state to down, then up."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:Event_WebSrv_HighCPU a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on the customer web server."@en ;
    noria:loggingTime "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logText "ALERT: CPU utilization on web01.customer.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_ConfigChange_Router a noria:EventRecord ;
    rdfs:label "Router Configuration Change Log"@en ;
    rdfs:comment "Log entry detailing a configuration change on Core Router 01."@en ;
    noria:loggingTime "2024-04-22T18:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent foaf:Agent_NetworkOps ;
    noria:logText "Configuration changed by NetworkOps team: added new static route."@en .

