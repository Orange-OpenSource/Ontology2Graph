# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# --- Domain specific ---
@prefix bot:  <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix time: <http://www.w3.org/2006/time#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS Concepts (Knowledge Organization System)
# These are required by various noria properties for their ranges.
# =============================================================================

# Application Types
<kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .

<kos/application/type/infrastructure> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "An application providing core infrastructure services."@en .

<kos/application/type/business-critical> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Business Critical Application"@en ;
    rdfs:comment "An application essential for core business operations."@en .

<kos/application/type/monitoring> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Monitoring Application"@en ;
    rdfs:comment "An application used for monitoring IT systems."@en .

# Application Business Importance
<kos/application/business-importance> a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A scheme for classifying the business importance of applications."@en .

<kos/application/business-importance/high> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Application with high impact on business operations."@en .

<kos/application/business-importance/medium> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Application with medium impact on business operations."@en .

# Application Module Status
<kos/application/status> a skos:ConceptScheme ;
    rdfs:label "Application Module Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational status of application modules."@en .

<kos/application/status/InProduction> a skos:Concept ;
    skos:inScheme <kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently in production."@en .

<kos/application/status/Development> a skos:Concept ;
    skos:inScheme <kos/application/status> ;
    rdfs:label "Development"@en ;
    rdfs:comment "The application module is currently under development."@en .

# Resource Types
<kos/Resource/type> a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of IT resources."@en .

<kos/Resource/type/server> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server"@en ;
    rdfs:comment "A computing server resource."@en .

<kos/Resource/type/router> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network router resource."@en .

<kos/Resource/type/firewall> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Firewall"@en ;
    rdfs:comment "A network firewall resource."@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState> a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    rdfs:comment "A scheme for classifying the lifecycle state of resources."@en .

<kos/Resource/LifecycleState/InUse> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "In Use"@en ;
    rdfs:comment "The resource is currently in active use."@en .

<kos/Resource/LifecycleState/Maintenance> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "In Maintenance"@en ;
    rdfs:comment "The resource is currently undergoing maintenance."@en .

# Resource Operational State
<kos/Resource/OperationalState> a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational state of resources."@en .

<kos/Resource/OperationalState/Up> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "The resource is operational."@en .

<kos/Resource/OperationalState/Down> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "The resource is not operational."@en .

# Resource Administrative State
<kos/Resource/AdministrativeState> a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    rdfs:comment "A scheme for classifying the administrative state of resources."@en .

<kos/Resource/AdministrativeState/Enabled> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Enabled"@en ;
    rdfs:comment "The resource is administratively enabled."@en .

<kos/Resource/AdministrativeState/Disabled> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Disabled"@en ;
    rdfs:comment "The resource is administratively disabled."@en .

# Trouble Ticket Severity
<kos/TroubleTicket/severity> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the severity of trouble tickets."@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Critical impact, service down."@en .

<kos/TroubleTicket/severity/Major> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major"@en ;
    rdfs:comment "Major impact, degraded service."@en .

<kos/TroubleTicket/severity/Minor> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Minor"@en ;
    rdfs:comment "Minor impact, cosmetic issue."@en .

# Trouble Ticket Type
<kos/TroubleTicket/type> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of trouble tickets."@en .

<kos/TroubleTicket/type/Failure> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Failure"@en ;
    rdfs:comment "Ticket related to a system failure."@en .

<kos/TroubleTicket/type/Assistance> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Assistance"@en ;
    rdfs:comment "Ticket for user assistance."@en .

# Trouble Ticket Status
<kos/TroubleTicket/status> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the status of trouble tickets."@en .

<kos/TroubleTicket/status/InProgress> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "The trouble ticket is currently being worked on."@en .

<kos/TroubleTicket/status/Resolved> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "Resolved"@en ;
    rdfs:comment "The issue described in the trouble ticket has been resolved."@en .

# Trouble Ticket Origin
<kos/TroubleTicket/origin> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "A scheme for classifying the origin of trouble tickets."@en .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Supervision System"@en ;
    rdfs:comment "Ticket originated from a monitoring or supervision system."@en .

<kos/TroubleTicket/origin/Customer> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Customer Report"@en ;
    rdfs:comment "Ticket reported by a customer."@en .

# Trouble Ticket Category
<kos/TroubleTicket/trouble-category> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Category Scheme"@en ;
    rdfs:comment "A scheme for classifying the category of trouble tickets."@en .

<kos/TroubleTicket/trouble-category/ServiceOutage> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Service Outage"@en ;
    rdfs:comment "Complete service interruption."@en .

<kos/TroubleTicket/trouble-category/PerformanceDegradation> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Performance Degradation"@en ;
    rdfs:comment "Service is slow or degraded."@en .

# Problem Responsibility
<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ;
    rdfs:label "Problem Responsibility Scheme"@en ;
    rdfs:comment "A scheme for classifying the responsibility for a problem."@en .

<kos/TroubleTicket/problemResponsibility/InternalIT> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Internal IT"@en ;
    rdfs:comment "Responsibility lies with internal IT teams."@en .

<kos/TroubleTicket/problemResponsibility/Vendor> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Vendor"@en ;
    rdfs:comment "Responsibility lies with a third-party vendor."@en .

# Trouble Ticket Comment Type
<kos/TroubleTicket/commentType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Comment Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of comments on trouble tickets."@en .

<kos/TroubleTicket/commentType/Internal> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment visible only to internal teams."@en .

<kos/TroubleTicket/commentType/Customer> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Customer Comment"@en ;
    rdfs:comment "Comment visible to the customer."@en .

# Trouble Ticket Operation Type
<kos/TroubleTicket/operationType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Operation Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of operations performed on trouble tickets."@en .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis"@en ;
    rdfs:comment "Operation related to diagnosing the issue."@en .

<kos/TroubleTicket/operationType/Resolution> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Resolution"@en ;
    rdfs:comment "Operation related to resolving the issue."@en .

# Change Request Category
<kos/ChangeRequest/category> a skos:ConceptScheme ;
    rdfs:label "Change Request Category Scheme"@en ;
    rdfs:comment "A scheme for classifying categories of change requests."@en .

<kos/ChangeRequest/category/InfrastructureChange> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Infrastructure Change"@en ;
    rdfs:comment "Change related to IT infrastructure."@en .

<kos/ChangeRequest/category/ApplicationUpdate> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Application Update"@en ;
    rdfs:comment "Change related to application updates."@en .

# Change Request Type
<kos/ChangeRequest/type> a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of change requests."@en .

<kos/ChangeRequest/type/Standard> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "A pre-approved, low-risk change."@en .

<kos/ChangeRequest/type/Normal> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Normal Change"@en ;
    rdfs:comment "A planned change requiring assessment and authorization."@en .

# Change Request Cause
<kos/ChangeRequest/cause> a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A scheme for classifying causes of change requests."@en .

<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change due to software upgrade."@en .

<kos/ChangeRequest/cause/PerformanceImprovement> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Performance Improvement"@en ;
    rdfs:comment "Change to improve system performance."@en .

# Change Request Status
<kos/ChangeRequest/status> a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the status of change requests."@en .

<kos/ChangeRequest/status/Approved> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Approved"@en ;
    rdfs:comment "The change request has been approved."@en .

<kos/ChangeRequest/status/Implemented> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Implemented"@en ;
    rdfs:comment "The change request has been implemented."@en .

# Notification Severity
<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ;
    rdfs:label "Perceived Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the perceived severity of notifications."@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Critical severity notification."@en .

<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning"@en ;
    rdfs:comment "Warning severity notification."@en .

# Agent Contact Method
<kos/org/agent-contact-method> a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents."@en .

<kos/org/agent-contact-method/Email> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method is email."@en .

<kos/org/agent-contact-method/Phone> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

# =============================================================================
# Agents and Organizational Units
# =============================================================================

foaf:Agent_AdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

foaf:Agent_NetworkOps a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call directly for any network-related incident."@en .

foaf:Agent_AppDev a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit a ticket for application bugs or feature requests."@en .

foaf:Agent_SecurityAnalyst a foaf:Agent ;
    rdfs:label "Security Analyst John Doe"@en ;
    rdfs:comment "Individual security analyst."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

org:OrgUnit_L1Support a org:OrganizationalUnit ;
    rdfs:label "Level 1 Support"@en ;
    rdfs:comment "First line of support for user issues."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

org:OrgUnit_L2Support a org:OrganizationalUnit ;
    rdfs:label "Level 2 Support"@en ;
    rdfs:comment "Second line of support for technical issues."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

org:OrgUnit_Hotline a org:OrganizationalUnit ;
    rdfs:label "Hotline Team"@en ;
    rdfs:comment "Emergency contact team for critical incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_CustomerA a foaf:Agent ;
    rdfs:label "Customer A Representative"@en ;
    rdfs:comment "Representative from a key customer."@en .

foaf:Agent_ChangeManager a foaf:Agent ;
    rdfs:label "Change Manager Jane Smith"@en ;
    rdfs:comment "Manager responsible for IT change processes."@en .

# =============================================================================
# Locations
# =============================================================================

bot:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace bot:Site_ParisDC .

noria:Locus_Rack12_U23 a noria:Locus ;
    rdfs:label "Rack 12, Unit 23"@en ;
    rdfs:comment "Specific location within Server Room A for Rack 12, Unit 23."@en ;
    noria:locusLine "Rack 12" ;
    noria:locusRow "U23" ;
    bot:hasSpace noria:Room_ServerRoomA .

bot:Site_LondonOffice a bot:Site ;
    rdfs:label "London Office"@en ;
    rdfs:comment "Regional office in London."@en ;
    noria:siteId "OFF-LDN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Baker Street"@en ;
    noria:sitePrincipalAddressCityName "London"@en ;
    noria:sitePrincipalAddressPostalCode "NW1 6XE" ;
    noria:sitePrincipalAddressCountry "UK" .

noria:Room_NetworkCloset a noria:Room ;
    rdfs:label "Network Closet"@en ;
    rdfs:comment "Small network equipment room in London Office."@en ;
    bot:hasSpace bot:Site_LondonOffice .

noria:Locus_PatchPanel_A1 a noria:Locus ;
    rdfs:label "Patch Panel A1"@en ;
    rdfs:comment "Location of Patch Panel A1 in the Network Closet."@en ;
    noria:locusLine "Panel A" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_NetworkCloset .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for various services."@en ;
    noria:productManufacturedBy <http://www.dell.com/organization> . # Assuming a URI for Dell organization

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Cisco high-performance data center switch/router."@en ;
    noria:productManufacturedBy <http://www.cisco.com/organization> . # Assuming a URI for Cisco organization

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Host"@en ;
    rdfs:comment "Virtualization hypervisor host."@en ;
    noria:productManufacturedBy <http://www.vmware.com/organization> . # Assuming a URI for VMware organization

# =============================================================================
# Resources
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, located in Paris DC."@en ;
    noria:resourceManagedBy foaf:Agent_AdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U23 ;
    noria:resourceManagementIPAddress "192.168.1.10" .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate backbone, located in London Office."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:resourceHostName "router-core-ldn01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_PatchPanel_A1 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Customer Web Server 01"@en ;
    rdfs:comment "Server hosting the customer-facing web portal."@en ;
    noria:resourceManagedBy foaf:Agent_AppDev ;
    noria:resourceHostName "web01.customer.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U23 ;
    noria:resourceForApplication noria:App_WebPortal ;
    noria:resourceManagementIPAddress "172.16.0.10" .

noria:Resource_DB01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Database server for critical applications."@en ;
