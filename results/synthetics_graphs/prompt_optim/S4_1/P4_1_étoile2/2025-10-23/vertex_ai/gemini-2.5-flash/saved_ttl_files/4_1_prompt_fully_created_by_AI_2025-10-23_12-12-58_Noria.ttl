    dcterms:created "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_AppDev ;
    dcterms:description "Identified runaway process consuming CPU. Terminated process. Performance restored. Monitoring."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
