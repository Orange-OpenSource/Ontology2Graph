# =============================================================================
# Operation Plans and Conditions
# =============================================================================

noria:ActionPreCondition_PrimaryDNSUnreachable
    a noria:ActionPreCondition ;
    rdfs:label "Primary DNS Unreachable"@en ;
    rdfs:comment "Condition: The primary DNS server is not responding to queries."@en ;
    skos:example "Ping to dns01.corp.example.com fails, DNS queries timeout."@en .

noria:ActionPostCondition_SecondaryDNSActive
    a noria:ActionPostCondition ;
    rdfs:label "Secondary DNS Active"@en ;
    rdfs:comment "Expected outcome: The secondary DNS server is actively serving requests."@en ;
    skos:example "DNS queries are successfully resolved by secondary DNS, services restored."@en .

noria:OperationPlan_DNSFailover
    a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure to activate secondary DNS in case of primary failure."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_PrimaryDNSUnreachable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_SecondaryDNSActive .

noria:ActionPreCondition_MaintenanceWindow
    a noria:ActionPreCondition ;
    rdfs:label "Maintenance Window Active"@en ;
    rdfs:comment "Condition: The scheduled maintenance window is currently active."@en ;
    skos:example "Current time is within the approved maintenance schedule for the firewall."@en .

noria:ActionPostCondition_FirmwareUpdated
    a noria:ActionPostCondition ;
    rdfs:label "Firmware Updated Successfully"@en ;
    rdfs:comment "Expected outcome: The firewall firmware has been updated to the target version without errors."@en ;
    skos:example "Firewall reports new firmware version, all services are operational."@en .

noria:OperationPlan_FirewallUpdate
    a noria:OperationPlan ;
    rdfs:label "Firewall Firmware Update Procedure"@en ;
    rdfs:comment "Procedure for safely upgrading the firmware of a perimeter firewall."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:ActionPostCondition_FirmwareUpdated .

# =============================================================================
# Connecting Event Records to Procedures (pep:ProcedureExecutionContainer)
# =============================================================================

# Example of an EventRecord being part of a ProcedureExecutionContainer (TroubleTicket)
# This is implicitly handled by noria:TroubleTicket being a subClassOf pep:ProcedureExecutionContainer
# and noria:EventRecord being a subClassOf pep:ProcedureExecution.
# The connection is usually made via ldp:member, but since ldp is forbidden, we can imply it or use dcterms:relation.
# For this exercise, we'll use dcterms:relation to link EventRecords to the TroubleTicket that contains them.

noria:TroubleTicket_DNSOutage
    dcterms:relation noria:EventRecord_DNSOutageLog, noria:EventRecord_DNSLinkDown .

noria:TroubleTicket_WebAppPerf
    dcterms:relation noria:EventRecord_WebSrvHighCPU .

# Example of an EventRecord being mitigated by a ProcedureExecutionContainer (TroubleTicket)
noria:EventRecord_DNSOutageLog
    noria:alarmMitigatedBy noria:TroubleTicket_DNSOutage .

noria:EventRecord_WebSrvHighCPU
    noria:alarmMitigatedBy noria:TroubleTicket_WebAppPerf .

# Example of a ChangeRequest being related to an OperationPlan
noria:ChangeRequest_FirewallUpgrade
    noria:changeRequestSpecification noria:OperationPlan_FirewallUpdate .

# Example of an EventRecord being a status history for a TroubleTicket
noria:TroubleTicket_DNSOutage
    noria:documentStatusHistory noria:EventRecord_DNSOutageLog . # Simplified, in reality, this would be a specific status change event.

# Example of a Resource contributing to an Application
noria:Resource_DNS01 noria:resourceForApplication noria:Application_CorpDNS .
noria:Resource_WebSrv01 noria:resourceForApplication noria:Application_WebApp .
noria:Resource_DB01 noria:resourceForApplication noria:Application_WebApp .
noria:Resource_RouterCore01 noria:resourceForApplication noria:Application_CorpDNS, noria:Application_WebApp, noria:Application_Monitoring .
noria:Resource_Firewall01 noria:resourceForApplication noria:Application_CorpDNS, noria:Application_WebApp, noria:Application_Monitoring .

# Example of an Agent managing a Resource
foaf:Agent_AdminTeam noria:agentManagesResource noria:Resource_DNS01 .
foaf:Agent_NetworkOps noria:agentManagesResource noria:Resource_RouterCore01 .
foaf:Agent_SecurityAnalyst noria:agentManagesResource noria:Resource_Firewall01 .
foaf:Agent_AppDev noria:agentManagesResource noria:Resource_WebSrv01, noria:Resource_DB01 .

# Example of an Application Module being related to a Resource
# This is typically inferred or modeled through the application's underlying resources.
# For density, we can add a direct link if the schema allows, but noria:resourceForApplication is more direct.
# Let's add a conceptual link for density.
noria:ApplicationModule_CorpDNS_Prod seas:subSystemOf noria:Resource_DNS01 .
noria:ApplicationModule_WebApp_Prod seas:subSystemOf noria:Resource_WebSrv01, noria:Resource_DB01 .

# Example of a cluster controller
noria:Resource_WebSrv01 noria:clusterController <http://example.com/resource/VMwareVCenter01> .
<http://example.com/resource/VMwareVCenter01>
    a noria:Resource ;
    rdfs:label "VMware vCenter 01"@en ;
    rdfs:comment "Virtualization management platform."@en ;
    noria:resourceType <kos/Resource/type/management-server> ;
    noria:resourceHostName "vcenter01.corp.example.com" ;
    noria:resourceManagedBy foaf:Agent_AdminTeam .

