# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot:  <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Agents and Organizational Units
# =============================================================================

foaf:Agent_AdminTeam
    a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:label "Équipe d'administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and operations."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for non-urgent issues, direct call for critical outages."@en .

foaf:Agent_NetworkOps
    a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:label "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team managing core network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Always use the dedicated hotline for network incidents."@en .

foaf:Agent_AppDev
    a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:label "Équipe Développement Applicatif"@fr ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> .

foaf:Agent_SecurityAnalyst
    a foaf:Agent ;
    rdfs:label "John Doe (Security Analyst)"@en ;
    rdfs:label "John Doe (Analyste Sécurité)"@fr ;
    rdfs:comment "Individual security analyst responsible for firewall and security systems."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

foaf:Agent_CustomerA
    a foaf:Agent ;
    rdfs:label "Customer A Representative"@en ;
    rdfs:label "Représentant Client A"@fr ;
    rdfs:comment "Key contact person for Customer A, reporting service issues."@en .

foaf:Agent_ExternalVendor
    a foaf:Agent ;
    rdfs:label "External ISP Vendor"@en ;
    rdfs:label "Fournisseur FAI Externe"@fr ;
    rdfs:comment "Third-party internet service provider."@en .

org:OrgUnit_L1Support
    a org:OrganizationalUnit ;
    rdfs:label "Level 1 Support Team"@en ;
    rdfs:label "Équipe Support Niveau 1"@fr ;
    rdfs:comment "First line of support for user and application issues."@en ;
    noria:agentWorkingHours "24/7"@en .

org:OrgUnit_L2Support
    a org:OrganizationalUnit ;
    rdfs:label "Level 2 Support Team"@en ;
    rdfs:label "Équipe Support Niveau 2"@fr ;
    rdfs:comment "Second line of support, handling more complex application issues."@en ;
    noria:agentWorkingHours "8:00 am - 8:00 pm (Mon-Sun)"@en .

org:OrgUnit_Hotline
    a org:OrganizationalUnit ;
    rdfs:label "Application Hotline Team"@en ;
    rdfs:label "Équipe Astreinte Applicative"@fr ;
    rdfs:comment "On-call team for critical application incidents outside business hours."@en ;
    noria:agentWorkingHours "On-call 24/7"@en .

# =============================================================================
# Locations
# =============================================================================

bot:Site_ParisDC
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:label "Centre de Données de Paris"@fr ;
    rdfs:comment "Main data center facility located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:label "Salle Serveurs A"@fr ;
    rdfs:comment "Primary server room within the Paris Data Center."@en ;
    bot:hasSpace bot:Site_ParisDC .

noria:Locus_RackA1
    a noria:Locus ;
    rdfs:label "Rack A1 in Server Room A"@en ;
    rdfs:label "Baie A1 en Salle Serveurs A"@fr ;
    rdfs:comment "Specific rack location for servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackA2
    a noria:Locus ;
    rdfs:label "Rack A2 in Server Room A"@en ;
    rdfs:label "Baie A2 en Salle Serveurs A"@fr ;
    rdfs:comment "Specific rack location for network equipment."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
    bot:hasSpace noria:Room_ServerRoomA .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellR740
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model from Dell."@en ;
    noria:productManufacturedBy <http://www.dell.com/organization> . # Assuming a URI for Dell

noria:ProductModel_CiscoNexus9K
    a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Data center switch series from Cisco."@en ;
    noria:productManufacturedBy <http://www.cisco.com/organization> . # Assuming a URI for Cisco

noria:ProductModel_VMwareESXi
    a noria:ProductModel ;
    rdfs:label "VMware ESXi Host"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy <http://www.vmware.com/organization> . # Assuming a URI for VMware

# =============================================================================
# Resources
# =============================================================================

noria:Resource_DNS01
    a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:label "Serveur DNS d'Entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for the corporate network, hosted on a physical machine."@en ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_AdminTeam ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> . # Example IP URI

noria:Resource_RouterCore01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:label "Routeur Cœur 01"@fr ;
    rdfs:comment "Main router for internal network traffic and external connectivity."@en ;
    noria:resourceHostName "router-core01.corp.example.com" ;
    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2020-08-01T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

noria:Resource_WebSrv01
    a noria:Resource ;
    rdfs:label "Web Server 01 (Virtual)"@en ;
    rdfs:label "Serveur Web 01 (Virtuel)"@fr ;
    rdfs:comment "Virtual machine hosting the customer-facing web application."@en ;
    noria:resourceHostName "webapp-srv01.corp.example.com" ;
    noria:resourceLogisticId "LOG-VMS-001" ;
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_AppDev ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The host is ESXi, the VM is on it. Simplified for this graph.
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.20> ;
    noria:virtualServerStatus <kos/Resource/OperationalState/up> .

noria:Resource_Firewall01
    a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:label "Pare-feu Périphérique 01"@fr ;
    rdfs:comment "Hardware firewall protecting the corporate network from external threats."@en ;
    noria:resourceHostName "fw01.corp.example.com" ;
    noria:resourceLogisticId "LOG-FW-001" ;
    noria:resourceSerialNumber "SN-FW-001-DEF" ;
    noria:resourceType <kos/Resource/type/firewall> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2019-11-01T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_SecurityAnalyst ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ; # Placeholder, assuming Cisco makes firewalls
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.254> .

noria:Resource_DB01
    a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:label "Serveur de Base de Données 01"@fr ;
    rdfs:comment "Server hosting the main database for the customer web application."@en ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceLogisticId "LOG-DB-001" ;
    noria:resourceSerialNumber "SN-DB-001-GHI" ;
    noria:resourceType <kos/Resource/type/database-server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-01T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_AppDev ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.30> .

# =============================================================================
# Network Interfaces
# =============================================================================

noria:NetworkInterface_DNS01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for DNS Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to internal network."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_RouterCore01_Ge0_0_1
    a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Internal network interface for Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Gigabit Ethernet interface connecting to server segment."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_RouterCore01_Ge0_0_2
    a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "External network interface for Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Gigabit Ethernet interface connecting to firewall."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

noria:NetworkInterface_WebSrv01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceDescription "Virtual Ethernet interface for web application."@en ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_Firewall01_Ext
    a noria:NetworkInterface ;
    rdfs:label "Firewall01 External Interface"@en ;
    rdfs:comment "Interface connecting Firewall 01 to the internet."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall01 ;
    noria:networkInterfaceDescription "External facing interface."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceLaserTxOpticalPower -5 ;
    noria:networkInterfaceLaserRxOpticalPower -8 .

noria:NetworkInterface_Firewall01_Int
    a noria:NetworkInterface ;
    rdfs:label "Firewall01 Internal Interface"@en ;
    rdfs:comment "Interface connecting Firewall 01 to the internal network."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall01 ;
    noria:networkInterfaceDescription "Internal facing interface."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# =============================================================================
# Network Links
# =============================================================================

noria:NetworkLink_DNS01_Core01
    a noria:NetworkLink ;
    rdfs:label "Link DNS01 to Core01"@en ;
    rdfs:comment "Network link between DNS Server 01 and Core Router 01."@en ;
    noria:networkLinkId "NL-DNS-RTR-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_DNS01_Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore01_Ge0_0_1 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_RouterCore01 ;
    noria:resourceManagedBy foaf:Agent_NetworkOps .

noria:NetworkLink_WebSrv01_Core01
    a noria:NetworkLink ;
    rdfs:label "Link WebSrv01 to Core01"@en ;
    rdfs:comment "Network link between Web Server 01 and Core Router 01."@en ;
    noria:networkLinkId "NL-WEB-RTR-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_WebSrv01_Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore01_Ge0_0_1 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_WebSrv01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_RouterCore01 ;
    noria:resourceManagedBy foaf:Agent_NetworkOps .

noria:NetworkLink_Firewall_Internet
    a noria:NetworkLink ;
    rdfs:label "Link Firewall to Internet"@en ;
    rdfs:comment "External network link from Firewall 01 to the Internet via ISP."@en ;
    noria:networkLinkId "NL-FW-ISP-001" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2019-11-01T11:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_Firewall01_Ext ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_Firewall01 ;
    noria:networkLinkTerminationResourceDestination foaf:Agent_ExternalVendor ; # Representing external entity
    noria:resourceManagedBy foaf:Agent_NetworkOps .

# =============================================================================
# Applications
# =============================================================================

noria:Application_CorpDNS
    a noria:Application ;
    rdfs:label "Corporate DNS Service"@en ;
    rdfs:label "Service DNS d'Entreprise"@fr ;
    rdfs:comment "Critical infrastructure application providing name resolution for the corporate network."@en ;
    noria:applicationModelIdentifier "CORP-DNS-V2" ;
    noria:applicationNumericalIdentifier 101 ;
    noria:applicationShortIdentifier "CORPDNS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Name Resolution" .

noria:Application_WebApp
    a noria:Application ;
    rdfs:label "Customer Web Application"@en ;
    rdfs:label "Application Web Client"@fr ;
    rdfs:comment "Primary customer-facing web application, critical for business operations."@en ;
    noria:applicationModelIdentifier "CUST-WEBAPP-V1" ;
    noria:applicationNumericalIdentifier 201 ;
    noria:applicationShortIdentifier "CUSTWEB" ;
    noria:applicationType <kos/application/type/business> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Online Services" .

noria:Application_Monitoring
    a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:label "Système de Supervision Réseau"@fr ;
    rdfs:comment "Application responsible for collecting and analyzing network and server metrics."@en ;
    noria:applicationModelIdentifier "NMS-PRO-V3" ;
    noria:applicationNumericalIdentifier 301 ;
    noria:applicationShortIdentifier "NMSPRO" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Performance Monitoring" .

# =============================================================================
# Application Modules
# =============================================================================

noria:ApplicationModule_CorpDNS_Prod
    a noria:ApplicationModule ;
    rdfs:label "Corporate DNS Production Module"@en ;
    rdfs:label "Module de Production DNS d'Entreprise"@fr ;
    rdfs:comment "Production instance of the Corporate DNS Service."@en ;
    noria:applicationModuleOf noria:Application_CorpDNS ;
    noria:applicationModuleName "CORPDNS_PROD" ;
    noria:applicationModuleIdentifier "PROD-001" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam foaf:Agent_AdminTeam ;
    noria:applicationModuleSupportTeam org:OrgUnit_L2Support ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

noria:ApplicationModule_WebApp_Prod
    a noria:ApplicationModule ;
    rdfs:label "Customer Web App Production Module"@en ;
    rdfs:label "Module de Production Application Web Client"@fr ;
    rdfs:comment "Production instance of the Customer Web Application."@en ;
    noria:applicationModuleOf noria:Application_WebApp ;
    noria:applicationModuleName "CUSTWEB_PROD" ;
    noria:applicationModuleIdentifier "PROD-002" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam foaf:Agent_AppDev ;
    noria:applicationModuleSupportTeam org:OrgUnit_L2Support ;
    noria:applicationModuleSupportGroup org:OrgUnit_L1Support ;
    noria:applicationModuleHotlineGroup org:OrgUnit_Hotline ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-02-15T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

noria:ApplicationModule_Monitoring_Prod
    a noria:ApplicationModule ;
    rdfs:label "Monitoring System Production Module"@en ;
    rdfs:label "Module de Production Système de Supervision"@fr ;
    rdfs:comment "Production instance of the Network Monitoring System."@en ;
    noria:applicationModuleOf noria:Application_Monitoring ;
    noria:applicationModuleName "NMSPRO_PROD" ;
    noria:applicationModuleIdentifier "PROD-003" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam foaf:Agent_NetworkOps ;
    noria:applicationModuleSupportTeam org:OrgUnit_L2Support ;
