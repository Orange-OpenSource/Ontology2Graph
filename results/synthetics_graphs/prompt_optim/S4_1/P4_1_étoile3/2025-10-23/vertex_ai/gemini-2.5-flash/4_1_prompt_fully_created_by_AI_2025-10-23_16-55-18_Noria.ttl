    noria:applicationModuleHotlineEnabled false .

# =============================================================================
# Services
# =============================================================================

noria:Service_InternetAccess
    a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:label "Service d'Accès Internet d'Entreprise"@fr ;
    rdfs:comment "End-to-end service providing internet access to corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:ApplicationModule_CorpDNS_Prod ; # Simplified, in reality many modules
    seas:subSystemOf noria:ApplicationModule_WebApp_Prod ; # Simplified, in reality many modules
    seas:subSystemOf noria:Resource_Firewall01 ;
    seas:subSystemOf noria:Resource_RouterCore01 .

noria:Service_CustomerFacing
    a noria:Service ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:label "Service Client"@fr ;
    rdfs:comment "Service directly consumed by external customers."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:ApplicationModule_WebApp_Prod .

# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_DNSOutageLog
    a noria:EventRecord ;
    rdfs:label "DNS Server Outage Log"@en ;
    rdfs:comment "Log entry indicating that the primary DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-10T09:05:12Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN. Ping failed."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_WebSrvHighCPU
    a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert indicating sustained high CPU utilization on the web server."@en ;
    noria:loggingTime "2024-04-10T14:20:00Z"^^xsd:dateTime ;
    noria:logText "WARNING: CPU utilization on webapp-srv01.corp.example.com exceeded 90% for 15 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_FirewallConfigChange
    a noria:EventRecord ;
    rdfs:label "Firewall Configuration Change Log"@en ;
    rdfs:comment "Log entry detailing a configuration change applied to the perimeter firewall."@en ;
    noria:loggingTime "2024-04-09T16:45:30Z"^^xsd:dateTime ;
    noria:logText "INFO: Configuration changed by John Doe (Security Analyst) on fw01.corp.example.com. Rule added: allow_ssh_from_mgmt_subnet."@en ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingAgent foaf:Agent_SecurityAnalyst ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord_DNSLinkDown
    a noria:EventRecord ;
    rdfs:label "DNS Server Network Link Down"@en ;
    rdfs:comment "Log entry indicating the network interface on DNS01 went down."@en ;
    noria:loggingTime "2024-04-10T09:04:50Z"^^xsd:dateTime ;
    noria:logText "Interface Ethernet0 on dns01.corp.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject noria:NetworkInterface_DNS01_Eth0 ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

# =============================================================================
# Trouble Tickets
# =============================================================================

noria:TroubleTicket_DNSOutage
    a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:label "Incident Panne Serveur DNS"@fr ;
    rdfs:comment "Critical incident reported due to primary DNS server being unreachable, impacting all internal services."@en ;
    dcterms:identifier "TT-20240410-001" ;
    dcterms:created "2024-04-10T09:10:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_DNSOutageLog ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:Application_CorpDNS ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketRelatedParty foaf:Agent_AdminTeam ;
    noria:troubleTicketDetectionDateTime "2024-04-10T09:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-10T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCause "Network connectivity issue to primary DNS server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketImpacts noria:Application_CorpDNS, noria:Service_InternetAccess .

noria:TroubleTicket_WebAppPerf
    a noria:TroubleTicket ;
    rdfs:label "Web App Performance Degradation"@en ;
    rdfs:label "Dégradation Performance Application Web"@fr ;
    rdfs:comment "Customer reported slow response times on the main web application."@en ;
    dcterms:identifier "TT-20240410-002" ;
    dcterms:created "2024-04-10T14:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketTrigger noria:EventRecord_WebSrvHighCPU ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:Application_WebApp ;
    noria:troubleTicketRelatedResource noria:Resource_WebSrv01 ;
    noria:troubleTicketRelatedParty foaf:Agent_CustomerA ;
    noria:troubleTicketRelatedParty org:OrgUnit_L1Support ;
    noria:troubleTicketDetectionDateTime "2024-04-10T14:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketCause "Suspected high CPU load on web server due to increased traffic."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> ;
    noria:troubleTicketImpacts noria:Application_WebApp, noria:Service_CustomerFacing .

# =============================================================================
# Trouble Ticket Notes
# =============================================================================

noria:TroubleTicketNote_DNSFixAttempt
    a noria:TroubleTicketNote ;
    rdfs:label "DNS Fix Attempt Note"@en ;
    rdfs:comment "Note detailing the attempt to restart the DNS service and check network connectivity."@en ;
    dcterms:created "2024-04-10T09:20:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_AdminTeam ;
    dcterms:description "Attempted to restart DNS service on dns01.corp.example.com. Service failed to start. Checked network link status, found interface down."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage .

noria:TroubleTicketNote_WebAppDiag
    a noria:TroubleTicketNote ;
    rdfs:label "Web App Diagnosis Note"@en ;
    rdfs:comment "Initial diagnosis steps for web application performance issue."@en ;
    dcterms:created "2024-04-10T14:45:00Z"^^xsd:dateTime ;
    dcterms:creator org:OrgUnit_L1Support ;
    dcterms:description "Confirmed high CPU on webapp-srv01.corp.example.com. Escalated to L2 for further investigation. Customer informed of ongoing investigation."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket_WebAppPerf .

