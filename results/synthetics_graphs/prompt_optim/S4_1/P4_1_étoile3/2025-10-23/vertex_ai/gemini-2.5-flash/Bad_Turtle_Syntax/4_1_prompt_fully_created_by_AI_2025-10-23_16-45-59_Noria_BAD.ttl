# --- Trouble Ticket Notes (noria:TroubleTicketNote) ---
:TroubleTicketNote_DB_Investigation a noria:TroubleTicketNote ;
    rdfs:label "DB Performance Investigation Note"@en ;
    rdfs:comment "Initial investigation findings for DB performance issue."@en ;
