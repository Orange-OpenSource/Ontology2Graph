# --- Operation Plans (noria:OperationPlan) ---
:OperationPlan_DB_Restart_Procedure a noria:OperationPlan ;
    rdfs:label "Database Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the production database service."@en ;
    skos:example "Steps include: 1. Notify stakeholders. 2. Stop application services. 3. Stop DB service. 4. Start DB service. 5. Start application services. 6. Verify."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_DB_Issue_Confirmed ;
    noria:operationPlanPostCondition :ActionPostCondition_DB_Service_Restored .

:OperationPlan_Router_Firmware_Procedure a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Detailed procedure for upgrading firmware on core network routers."@en ;
    skos:example "Steps include: 1. Backup configuration. 2. Download firmware. 3. Schedule maintenance window. 4. Upgrade. 5. Verify connectivity."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_Maintenance_Window ;
    noria:operationPlanPostCondition :ActionPostCondition_Router_Operational .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
:ActionPreCondition_DB_Issue_Confirmed a noria:ActionPreCondition ;
    rdfs:label "Database Issue Confirmed"@en ;
    rdfs:comment "Pre-condition: A critical database performance issue has been confirmed by monitoring and initial diagnostics."@en .

:ActionPostCondition_DB_Service_Restored a noria:ActionPostCondition ;
    rdfs:label "Database Service Restored"@en ;
    rdfs:comment "Post-condition: Database service is running, accessible, and performance metrics are within normal thresholds."@en .

:ActionPreCondition_Maintenance_Window a noria:ActionPreCondition ;
    rdfs:label "Approved Maintenance Window"@en ;
    rdfs:comment "Pre-condition: An approved maintenance window is active, minimizing impact on production services."@en .

:ActionPostCondition_Router_Operational a noria:ActionPostCondition ;
    rdfs:label "Router Fully Operational"@en ;
    rdfs:comment "Post-condition: Router firmware upgrade completed successfully, all interfaces are up, and network traffic is flowing as expected."@en .

:TroubleTicket_DB_Performance noria:alarmProposedRepairAction :OperationPlan_DB_Restart_Procedure .
:ChangeRequest_Router_Firmware_Upgrade noria:changeRequestSpecification :OperationPlan_Router_Firmware_Procedure .

