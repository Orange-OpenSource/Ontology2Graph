:TroubleTicket_Network_Outage noria:troubleTicketPartyIntervention :Agent_Network_Admin .

:EventRecord_DB_CPU_High dcterms:relation :TroubleTicket_DB_Performance .
:EventRecord_Router_Interface_Down dcterms:relation :TroubleTicket_Network_Outage .

:TroubleTicketNote_DB_Resolution noria:troubleTicketNoteCorrelatedExecution :EventRecord_DB_Restart_Log .

