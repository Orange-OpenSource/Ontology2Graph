    noria:troubleTicketImpacts :Application_CRM_System, :Service_Customer_Facing_CRM ;
    noria:troubleTicketTrigger :EventRecord_DB_CPU_High ;
    noria:documentExternalId "INC-DB-20240423-001" ;
    noria:documentHRef "https://itsm.example.com/ticket/INC-DB-20240423-001" .

:TroubleTicket_Network_Outage a noria:TroubleTicket ;
