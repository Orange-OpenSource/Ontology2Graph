    noria:resourceProductModel :ProductModel_Cisco_Nexus_9K ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "SN-CR01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_Rack_A2_U5 ;
    noria:resourceManagementIPAddress "10.0.0.254" .

:Resource_Virtual_Host_01 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:comment "Physical server hosting multiple virtual machines."@en ;
    noria:resourceManagedBy :Agent_IT_Ops_Team ;
    noria:resourceHostName "vhost01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_Dell_R740 ;
    noria:resourceType <kos/Resource/type/hypervisor> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
