    noria:resourceInstallationDate "2023-06-10T11:00:00Z"^^xsd:dateTime ;
    noria:clusterController :Resource_Virtual_Host_01 ;
    noria:resourceManagementIPAddress "10.0.1.100" .

# --- Network Interfaces (noria:NetworkInterface) ---
:NetworkInterface_DB_Server_Eth0 a noria:NetworkInterface ;
    rdfs:label "dbprod01-eth0"@en ;
    rdfs:comment "Ethernet interface for DB Server 01."@en ;
    noria:networkInterfaceOf :Resource_DB_Server_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

:NetworkInterface_Router_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "router-core-01-Gi0/0/1"@en ;
    rdfs:comment "GigabitEthernet interface on Core Router R01."@en ;
    noria:networkInterfaceOf :Resource_Core_Router_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

:NetworkInterface_Router_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "router-core-01-Gi0/0/2"@en ;
    rdfs:comment "Second GigabitEthernet interface on Core Router R01."@en ;
    noria:networkInterfaceOf :Resource_Core_Router_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/down> . # Example of a down interface

:NetworkInterface_VM_Eth0 a noria:NetworkInterface ;
    rdfs:label "webapp-vm01-eth0"@en ;
    rdfs:comment "Virtual Ethernet interface for Web Application VM 01."@en ;
    noria:networkInterfaceOf :Resource_Web_App_VM_01 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# --- Network Links (noria:NetworkLink) ---
:NetworkLink_DB_Router a noria:NetworkLink ;
    rdfs:label "Link DB Server to Core Router"@en ;
    rdfs:comment "Physical link connecting the DB server to the core router."@en ;
    noria:networkLinkId "NL-DB-RTR-01" ;
    noria:networkLinkTerminationResourceOrigin :Resource_DB_Server_01 ;
    noria:networkLinkTerminationResourceDestination :Resource_Core_Router_01 ;
    noria:networkLinkInstallationDate "2023-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:resourceManagedBy :Agent_Network_Admin .

:NetworkLink_Router_VM_Host a noria:NetworkLink ;
    rdfs:label "Link Core Router to Virtual Host"@en ;
    rdfs:comment "Link from core router to the virtualization host."@en ;
    noria:networkLinkId "NL-RTR-VHOST-01" ;
    noria:networkLinkTerminationResourceOrigin :Resource_Core_Router_01 ;
    noria:networkLinkTerminationResourceDestination :Resource_Virtual_Host_01 ;
    noria:networkLinkInstallationDate "2023-03-01T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic 40Gbps" ;
    noria:resourceManagedBy :Agent_Network_Admin .

:NetworkInterface_DB_Server_Eth0 noria:networkInterfaceConnects :NetworkLink_DB_Router .
:NetworkInterface_Router_Gi0_0_1 noria:networkInterfaceConnects :NetworkLink_DB_Router .
:NetworkInterface_Router_Gi0_0_2 noria:networkInterfaceConnects :NetworkLink_Router_VM_Host .
:NetworkInterface_VM_Host_Eth0 a noria:NetworkInterface ;
    rdfs:label "vhost01-eth0"@en ;
    rdfs:comment "Ethernet interface for Virtual Host 01."@en ;
    noria:networkInterfaceOf :Resource_Virtual_Host_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects :NetworkLink_Router_VM_Host .

# --- Applications (noria:Application) ---
:Application_CRM_System a noria:Application ;
    rdfs:label "Customer Relationship Management System"@en ;
    rdfs:label "Système de Gestion de la Relation Client"@fr ;
    rdfs:comment "Core application for managing customer interactions."@en ;
    noria:applicationModelIdentifier "CRM-PROD" ;
    noria:applicationNumericalIdentifier 101 ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Management" ;
    noria:applicationFunctionalSubDomain "Sales & Support" .

:Application_Monitoring_Platform a noria:Application ;
    rdfs:label "Infrastructure Monitoring Platform"@en ;
    rdfs:label "Plateforme de Supervision d'Infrastructure"@fr ;
    rdfs:comment "System for monitoring the health and performance of IT infrastructure."@en ;
    noria:applicationModelIdentifier "MON-PLAT" ;
    noria:applicationNumericalIdentifier 202 ;
    noria:applicationShortIdentifier "MON" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "IT Operations" ;
    noria:applicationFunctionalSubDomain "Monitoring & Alerting" .

:Resource_DB_Server_01 noria:resourceForApplication :Application_CRM_System .
:Resource_Web_App_VM_01 noria:resourceForApplication :Application_CRM_System .
:Resource_Core_Router_01 noria:resourceForApplication :Application_Monitoring_Platform .

# --- Application Modules (noria:ApplicationModule) ---
:ApplicationModule_CRM_Prod a noria:ApplicationModule ;
    rdfs:label "CRM Production Module"@en ;
    rdfs:comment "The production instance of the CRM system."@en ;
    noria:applicationModuleOf :Application_CRM_System ;
    noria:applicationModuleName "CRM_PROD_INSTANCE" ;
    noria:applicationModuleIdentifier "PROD-001" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam :Agent_App_Support_L2 ;
    noria:applicationModuleSupportTeam :Agent_App_Support_L2 ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

:ApplicationModule_CRM_Dev a noria:ApplicationModule ;
    rdfs:label "CRM Development Module"@en ;
    rdfs:comment "The development instance of the CRM system."@en ;
    noria:applicationModuleOf :Application_CRM_System ;
    noria:applicationModuleName "CRM_DEV_INSTANCE" ;
    noria:applicationModuleIdentifier "DEV-001" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InDevelopment> ;
    noria:applicationModuleAdministrationTeam :Agent_App_Support_L2 ;
    noria:applicationModuleSupportTeam :Agent_App_Support_L2 ;
    noria:applicationModuleHotlineEnabled false .

# --- Services (noria:Service) ---
:Service_Customer_Facing_CRM a noria:Service ;
    rdfs:label "Customer Facing CRM Service"@en ;
    rdfs:comment "End-to-end service for customer interactions, built on the CRM application."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :ApplicationModule_CRM_Prod . # A service can be composed of application modules

:Service_Internal_Monitoring a noria:Service ;
    rdfs:label "Internal Infrastructure Monitoring Service"@en ;
    rdfs:comment "Service providing monitoring capabilities for internal IT infrastructure."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf :Application_Monitoring_Platform .

# --- Event Records (noria:EventRecord) ---
:EventRecord_DB_CPU_High a noria:EventRecord ;
    rdfs:label "High CPU Alert on DB Server"@en ;
    rdfs:comment "Alert indicating high CPU utilization on the production database server."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_DB_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_Platform ;
    noria:logText "CPU usage on dbprod01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

:EventRecord_Router_Interface_Down a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating that a network interface on the core router went down."@en ;
    noria:loggingTime "2024-04-23T10:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Core_Router_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_Platform ;
    noria:logText "Interface Gi0/0/2 on router-core-01.corp.example.com changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

:EventRecord_User_Login_Failed a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Log entry for a failed login attempt on a web application."@en ;
    noria:loggingTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Web_App_VM_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_Platform ;
    noria:logOriginatingAgent :Agent_Customer_Service ; # Example of a user (agent) causing an event
    noria:logText "User 'jdoe' failed to log in to CRM application from IP 192.168.1.50."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

:EventRecord_DB_Restart_Log a noria:EventRecord ;
    rdfs:label "Database Service Restarted"@en ;
    rdfs:comment "Log entry indicating a database service restart."@en ;
    noria:loggingTime "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_DB_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_Platform ;
    noria:logOriginatingAgent :Agent_Database_Team ;
    noria:logText "Database service 'PostgreSQL' restarted by 'dbadmin'."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

# --- Trouble Tickets (noria:TroubleTicket) ---
