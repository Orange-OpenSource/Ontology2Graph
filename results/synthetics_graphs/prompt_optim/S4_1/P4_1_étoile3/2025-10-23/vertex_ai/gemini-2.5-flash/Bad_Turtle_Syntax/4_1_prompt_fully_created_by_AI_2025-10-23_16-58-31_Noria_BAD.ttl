    noria:operationPlanPreCondition :APC_DB_HighCPU ;
    noria:operationPlanPostCondition :APOC_DB_CPU_Normal .

### Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)

:APC_WebServer_Unresponsive a noria:ActionPreCondition ;
    rdfs:label "Web Server Unresponsive"@en ;
    rdfs:comment "Condition: Web server is not responding to HTTP requests or ping."@en ;
    skos:example "HTTP 503 error, ping timeout."@en .

:APOC_WebServer_Running a noria:ActionPostCondition ;
    rdfs:label "Web Server Running"@en ;
    rdfs:comment "Expected outcome: Web server is running and responding to requests."@en ;
    skos:example "HTTP 200 OK, ping successful."@en .

:APC_DB_HighCPU a noria:ActionPreCondition ;
    rdfs:label "Database High CPU Usage"@en ;
    rdfs:comment "Condition: Database server CPU usage is consistently above 80%."@en ;
    skos:example "Monitoring system reports CPU > 80% for 15 minutes."@en .

:APOC_DB_CPU_Normal a noria:ActionPostCondition ;
    rdfs:label "Database CPU Normal"@en ;
    rdfs:comment "Expected outcome: Database server CPU usage returns to normal levels (e.g., below 50%)."@en ;
    skos:example "Monitoring system reports CPU < 50% for 30 minutes."@en .

