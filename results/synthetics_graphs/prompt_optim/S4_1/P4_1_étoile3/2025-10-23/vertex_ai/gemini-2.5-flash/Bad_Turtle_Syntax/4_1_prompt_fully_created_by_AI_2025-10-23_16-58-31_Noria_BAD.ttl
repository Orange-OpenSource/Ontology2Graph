    noria:operationPlanPostCondition :APOC_WebServer_Running .

:OP_Optimize_DB_Query a noria:OperationPlan ;
    rdfs:label "Database Query Optimization Procedure"@en ;
    rdfs:comment "Procedure for deploying and validating optimized database queries."@en ;
