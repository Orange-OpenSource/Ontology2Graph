# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix time: <http://www.w3.org/2006/time#> .

# --- Domain specific ---
@prefix bot: <https://w3id.org/bot#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# NORIA Ontology Metadata (as provided in the schema)
# =============================================================================

<https://w3id.org/noria/ontology/>
	a voaf:Vocabulary, owl:Ontology ;
	dcterms:title "The NORIA Ontology"@en ;
    dcterms:description """The NORIA-O project is a data model for IT networks, events and operations information.
The ontology is developed using web technologies (e.g. RDF, OWL, SKOS) and is intended as a structure for realizing an IT Service Management (ITSM) Knowledge Graph (KG) for Anomaly Detection (AD) and Risk Management applications.
The model has been developed in collaboration with operational teams, and in connection with third parties linked vocabularies.
"""@en ;
    dcterms:issued "2022-05-10"^^xsd:date ;
	dcterms:modified "2024-03-15"^^xsd:date ;
	owl:versionInfo "v0.3" ;
.

# =============================================================================
# Graphe de Connaissances NORIA
# =============================================================================

### Agents (foaf:Agent & org:OrganizationalUnit)

:Agent_IT_Ops a foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:label "Équipe Opérations IT"@fr ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations and incident response."@en ;
    noria:agentWorkingHours "24/7 (Mon-Sun)" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

:Agent_Network_Admin a foaf:Agent ;
    rdfs:label "Network Administration Team"@en ;
    rdfs:label "Équipe Administration Réseau"@fr ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For network-related incidents, open a ticket and call the L2 support line."@en .

:Agent_App_Dev a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:label "Équipe Développement Applicatif"@fr ;
    rdfs:comment "Team responsible for developing and maintaining core business applications."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Chat> ;
    noria:agentInstructions "Use internal chat for non-critical inquiries. For production issues, follow incident management process."@en .

:Agent_Security_Ops a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:label "Centre d'Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Monitors and responds to security incidents."@en ;
    noria:agentWorkingHours "24/7 (Mon-Sun)" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Report all suspected security incidents immediately via dedicated channel."@en .

:Agent_Customer_Support a foaf:Agent ;
    rdfs:label "Customer Support Tier 1"@en ;
    rdfs:label "Support Client Niveau 1"@fr ;
    rdfs:comment "First line of contact for customer issues."@en ;
    noria:agentWorkingHours "8:00 am - 8:00 pm (Mon-Sat)" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> .

:Org_IT_Department a org:OrganizationalUnit ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "Overall IT department responsible for all IT services."@en ;
    org:hasMember :Agent_IT_Ops, :Agent_Network_Admin, :Agent_App_Dev, :Agent_Security_Ops .

### Locations (bot:Site, noria:Room, noria:Locus)

:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center Site"@en ;
    rdfs:comment "Primary data center facility for all critical services."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

:Room_ServerHall_A a noria:Room ;
    rdfs:label "Server Hall A"@en ;
    rdfs:comment "Main server hall within the primary data center."@en ;
    bot:hasSpace :Site_MainDC .

:Locus_Rack_A12 a noria:Locus ;
    rdfs:label "Rack A12, Server Hall A"@en ;
    rdfs:comment "Specific rack location for critical infrastructure."@en ;
    noria:locusLine "A" ;
    noria:locusRow "12" ;
    bot:hasSpace :Room_ServerHall_A .

:Site_DR_DC a bot:Site ;
    rdfs:label "Disaster Recovery Data Center Site"@en ;
    rdfs:comment "Secondary data center for disaster recovery purposes."@en ;
    noria:siteId "DR01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Backup Road" ;
    noria:sitePrincipalAddressCityName "Safetown" ;
    noria:sitePrincipalAddressPostalCode "20002" ;
    noria:sitePrincipalAddressCountry "US" .

:Room_DR_Hall_B a noria:Room ;
    rdfs:label "DR Server Hall B"@en ;
    rdfs:comment "Server hall in the disaster recovery data center."@en ;
    bot:hasSpace :Site_DR_DC .

:Locus_Rack_B05 a noria:Locus ;
    rdfs:label "Rack B05, DR Server Hall B"@en ;
    rdfs:comment "Specific rack location for DR infrastructure."@en ;
    noria:locusLine "B" ;
    noria:locusRow "05" ;
    bot:hasSpace :Room_DR_Hall_B .

### Product Models (noria:ProductModel)

:ProductModel_Dell_R740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy :Org_Dell .

:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

:ProductModel_Cisco_Nexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Data center network switch series."@en ;
    noria:productManufacturedBy :Org_Cisco .

:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking equipment."@en .

:ProductModel_VMware_ESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform software."@en ;
    noria:productManufacturedBy :Org_VMware .

:Org_VMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Provider of cloud computing and virtualization software."@en .

### Resources (noria:Resource)

:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Primary web server hosting customer-facing applications."@en ;
    noria:resourceManagedBy :Agent_IT_Ops ;
    noria:resourceLogisticId "ASSET-WEB-001" ;
    noria:resourceHostName "websrv01.example.com" ;
    noria:resourceProductModel :ProductModel_Dell_R740 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB-001-XYZ" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_Rack_A12 ;
    noria:resourceManagementIPAddress "192.168.10.101" .

:Resource_DB01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Primary database server for critical application data."@en ;
    noria:resourceManagedBy :Agent_IT_Ops ;
    noria:resourceLogisticId "ASSET-DB-001" ;
    noria:resourceHostName "db01.example.com" ;
    noria:resourceProductModel :ProductModel_Dell_R740 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DB-001-ABC" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_Rack_A12 ;
    noria:resourceManagementIPAddress "192.168.10.102" .

:Resource_Router_Core1 a noria:Resource ;
    rdfs:label "Core Router 1"@en ;
    rdfs:comment "Main router for data center network core."@en ;
    noria:resourceManagedBy :Agent_Network_Admin ;
    noria:resourceLogisticId "ASSET-RTR-001" ;
    noria:resourceHostName "core-rtr01.example.com" ;
    noria:resourceProductModel :ProductModel_Cisco_Nexus9K ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR-001-DEF" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_Rack_A12 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

:Resource_VM_App01 a noria:Resource ;
    rdfs:label "Virtual Machine for App01"@en ;
    rdfs:comment "Virtual machine hosting a component of Application A."@en ;
    noria:resourceManagedBy :Agent_IT_Ops ;
    noria:resourceHostName "vm-app01.example.com" ;
    noria:resourceProductModel :ProductModel_VMware_ESXi ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceForApplication :Application_CustomerPortal .

:Resource_DR_DB01 a noria:Resource ;
    rdfs:label "DR Database Server 01"@en ;
    rdfs:comment "Disaster recovery database server, replica of DB01."@en ;
    noria:resourceManagedBy :Agent_IT_Ops ;
    noria:resourceLogisticId "ASSET-DRDB-001" ;
    noria:resourceHostName "dr-db01.example.com" ;
    noria:resourceProductModel :ProductModel_Dell_R740 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DRDB-001-GHI" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-01T14:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_Rack_B05 ;
    noria:resourceManagementIPAddress "10.1.0.102" .

### Network Interfaces (noria:NetworkInterface)

:NetIF_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Web Server 01."@en ;
    noria:networkInterfaceOf :Resource_WebSrv01 ;
    noria:networkInterfaceDescription "Uplink to core switch" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

:NetIF_DB01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DB01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Database Server 01."@en ;
    noria:networkInterfaceOf :Resource_DB01 ;
    noria:networkInterfaceDescription "Uplink to core switch" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

:NetIF_Router_Core1_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "Core Router 1 Gi0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 1 to Web Server segment."@en ;
    noria:networkInterfaceOf :Resource_Router_Core1 ;
    noria:networkInterfaceDescription "Link to Web/App VLAN" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

:NetIF_Router_Core1_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "Core Router 1 Gi0/0/2"@en ;
    rdfs:comment "Interface connecting Core Router 1 to Database segment."@en ;
    noria:networkInterfaceOf :Resource_Router_Core1 ;
    noria:networkInterfaceDescription "Link to DB VLAN" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

### Network Links (noria:NetworkLink)

:NetLink_WebSrv_CoreRtr a noria:NetworkLink ;
    rdfs:label "WebSrv01 to Core Router Link"@en ;
    rdfs:comment "Physical link between Web Server 01 and Core Router 1."@en ;
    noria:resourceManagedBy :Agent_Network_Admin ;
    noria:networkLinkId "NL-WS01-CR01" ;
    noria:networkLinkTerminationResourceOrigin :Resource_WebSrv01 ;
    noria:networkLinkTerminationResourceDestination :Resource_Router_Core1 ;
    noria:networkLinkInstallationDate "2023-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkInterfaceConnects :NetIF_WebSrv01_Eth0, :NetIF_Router_Core1_Gi0_0_1 .

:NetLink_DB_CoreRtr a noria:NetworkLink ;
    rdfs:label "DB01 to Core Router Link"@en ;
    rdfs:comment "Physical link between Database Server 01 and Core Router 1."@en ;
    noria:resourceManagedBy :Agent_Network_Admin ;
    noria:networkLinkId "NL-DB01-CR01" ;
    noria:networkLinkTerminationResourceOrigin :Resource_DB01 ;
    noria:networkLinkTerminationResourceDestination :Resource_Router_Core1 ;
    noria:networkLinkInstallationDate "2023-01-15T11:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkInterfaceConnects :NetIF_DB01_Eth0, :NetIF_Router_Core1_Gi0_0_2 .

### Applications (noria:Application)

:Application_CustomerPortal a noria:Application ;
    rdfs:label "Customer Portal Application"@en ;
    rdfs:comment "Web application allowing customers to manage their accounts and services."@en ;
    noria:applicationModelIdentifier "CP-APP" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CustPortal" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/customer-facing> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Customer Account Management" .

:Application_InternalMonitoring a noria:Application ;
    rdfs:label "Internal Monitoring System"@en ;
    rdfs:comment "Application for monitoring IT infrastructure and services."@en ;
    noria:applicationModelIdentifier "MON-SYS" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "Monitor" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Performance and Availability Monitoring" .

### Application Modules (noria:ApplicationModule)

:AppModule_CustomerPortal_Prod a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module"@en ;
    rdfs:comment "Production instance of the Customer Portal application."@en ;
    noria:applicationModuleOf :Application_CustomerPortal ;
    noria:applicationModuleName "CP-APP_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam :Agent_IT_Ops ;
    noria:applicationModuleSupportTeam :Agent_IT_Ops ;
    noria:applicationModuleSupportLeader :Agent_IT_Ops ; # Assuming Agent_IT_Ops is also a leader for simplicity
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

:AppModule_CustomerPortal_Dev a noria:ApplicationModule ;
    rdfs:label "Customer Portal Development Module"@en ;
    rdfs:comment "Development instance of the Customer Portal application."@en ;
    noria:applicationModuleOf :Application_CustomerPortal ;
    noria:applicationModuleName "CP-APP_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InDevelopment> ;
    noria:applicationModuleAdministrationTeam :Agent_App_Dev ;
    noria:applicationModuleSupportTeam :Agent_App_Dev ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Bronze> ;
    noria:applicationModuleSlaLevelDate "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled false .

### Services (noria:Service)

:Service_ECommerce a noria:Service ;
    rdfs:label "E-Commerce Service"@en ;
    rdfs:comment "End-to-end service for online sales, including customer portal and payment processing."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :AppModule_CustomerPortal_Prod . # Example of linking an application module to a service

:Service_DataReplication a noria:Service ;
    rdfs:label "Database Replication Service"@en ;
    rdfs:comment "Service ensuring data consistency between primary and DR database servers."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/ResourceFacingService> ;
    seas:subSystemOf :Resource_DB01, :Resource_DR_DB01 .

### Event Records (noria:EventRecord)

:Event_WebSrv01_Down a noria:EventRecord ;
    rdfs:label "Web Server 01 Down Alert"@en ;
    rdfs:comment "Automated alert indicating Web Server 01 is unreachable."@en ;
    noria:loggingTime "2024-04-23T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem :Application_InternalMonitoring ;
    noria:logText "Host websrv01.example.com is DOWN. Ping failed."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> .

:Event_DB01_HighCPU a noria:EventRecord ;
    rdfs:label "DB01 High CPU Usage"@en ;
    rdfs:comment "Alert for sustained high CPU usage on Database Server 01."@en ;
    noria:loggingTime "2024-04-23T08:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_DB01 ;
    noria:logOriginatingManagementSystem :Application_InternalMonitoring ;
    noria:logText "CPU usage on db01.example.com exceeded 90% for 15 minutes."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> .

:Event_Router_Interface_Down a noria:EventRecord ;
    rdfs:label "Core Router Interface Down"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 1 went down."@en ;
    noria:loggingTime "2024-04-23T08:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Router_Core1 ;
    noria:logOriginatingManagementSystem :Application_InternalMonitoring ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface Gi0/0/1, changed state to down."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> .

:Event_User_Login_Failure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Security event: multiple failed login attempts on Customer Portal."@en ;
    noria:loggingTime "2024-04-23T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Application_CustomerPortal ;
    noria:logOriginatingManagementSystem :Application_InternalMonitoring ;
    noria:logOriginatingAgent :Agent_Customer_Support ; # Example of an agent being the source of an event (e.g., reporting a customer issue)
    noria:logText "Multiple failed login attempts for user 'jdoe' on Customer Portal."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Warning> .

### Trouble Tickets (noria:TroubleTicket)

:TT_WebSrv_Outage a noria:TroubleTicket ;
    rdfs:label "Web Server Outage Incident"@en ;
    rdfs:comment "Critical incident: Customer Portal web server is down, impacting service availability."@en ;
    dcterms:created "2024-04-23T09:05:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    noria:documentExternalId "INC-2024-04-23-001" ;
    noria:documentHRef "https://itsm.example.com/ticket/INC-2024-04-23-001" ;
    noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <https://w3id.org/noria/kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <https://w3id.org/noria/kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <https://w3id.org/noria/kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <https://w3id.org/noria/kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger :Event_WebSrv01_Down ;
    noria:troubleTicketUrgency <https://w3id.org/noria/kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <https://w3id.org/noria/kos/TroubleTicket/trouble-category/TotalBreakdown> ;
