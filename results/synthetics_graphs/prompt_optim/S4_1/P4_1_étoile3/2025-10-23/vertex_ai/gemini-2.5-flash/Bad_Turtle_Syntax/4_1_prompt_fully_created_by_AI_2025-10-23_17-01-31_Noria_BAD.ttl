# --- Change Requests ---
:CR_DNS_Upgrade_001 a noria:ChangeRequest ;
    rdfs:label "DNS Software Upgrade"@en ;
    rdfs:comment "Upgrade DNS server software to address known stability issues."@en ;
    dcterms:created "2024-04-24T14:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact :Resource_DNS01, :App_CorporateInternetAccess ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Planned> ;
    noria:changeRequestInitiatorParty :Agent_DNSAdminTeam ;
    noria:changeRequestPilotParty :Agent_JohnDoe ;
    noria:changeRequestActorParty :Agent_DNSAdminTeam ;
    noria:changeRequestIsRegulated false ;
    noria:documentHRef "https://changemanagement.example.com/CR_DNS_Upgrade_001" .

# --- Operation Plans and Conditions ---
:OpPlan_DNS_Restart a noria:OperationPlan ;
    rdfs:label "DNS Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the corporate DNS service."@en ;
    skos:example "Steps include checking service status, attempting graceful restart, force restart if necessary, and verifying resolution."@en ;
    noria:operationPlanPreCondition :PreCond_DNS_ServiceDown ;
    noria:operationPlanPostCondition :PostCond_DNS_ServiceUp .

:PreCond_DNS_ServiceDown a noria:ActionPreCondition ;
    rdfs:label "DNS Service is Down"@en ;
    rdfs:comment "Condition: DNS service process is not running or not responding."@en ;
    skos:example "Check 'systemctl status named' or 'dig @localhost example.com'."@en .

:PostCond_DNS_ServiceUp a noria:ActionPostCondition ;
    rdfs:label "DNS Service is Up and Responding"@en ;
    rdfs:comment "Expected outcome: DNS service is running and successfully resolving queries."@en ;
    skos:example "Verify 'systemctl status named' shows active, and 'dig @localhost example.com' returns valid response."@en .

:OpPlan_NetworkInterfaceTroubleshoot a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting"@en ;
    rdfs:comment "Procedure for diagnosing and resolving issues with network interfaces."@en ;
    noria:operationPlanPreCondition :PreCond_NetIF_OperationalDown ;
    noria:operationPlanPostCondition :PostCond_NetIF_OperationalUp .

:PreCond_NetIF_OperationalDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface Operational Down"@en ;
    rdfs:comment "Condition: A network interface's operational status is reported as 'down'."@en .

:PostCond_NetIF_OperationalUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface Operational Up"@en ;
    rdfs:comment "Expected outcome: Network interface operational status is 'up'."@en .

# --- Connecting Dynamic Elements to Procedures ---
# Example of an EventRecord being mitigated by a procedure execution
:Event_DNS_Down
    noria:alarmProposedRepairAction :OpPlan_DNS_Restart .

# Example of a TroubleTicketNote being correlated to a procedure execution (implicitly, as the note describes actions)
# For a more explicit link, one would need an instance of pep:ProcedureExecutionContainer
# For this example, we'll assume the note itself describes the execution.
:TTNote_DNS_001_Update1
    noria:troubleTicketNoteCorrelatedExecution :OpPlan_DNS_Restart . # This is a simplification, ideally it would be a specific execution instance.

# Example of a ChangeRequest having an associated operation plan
:CR_DNS_Upgrade_001
    noria:changeRequestSpecification <kos/ChangeRequest/specification/SoftwarePatchDeployment> . # Assuming a KOS concept for specification

