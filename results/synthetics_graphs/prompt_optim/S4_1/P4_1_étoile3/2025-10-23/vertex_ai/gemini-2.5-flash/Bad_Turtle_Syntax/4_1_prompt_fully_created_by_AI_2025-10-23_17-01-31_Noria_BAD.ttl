# --- Services ---
:Service_ExternalConnectivity a noria:Service ;
    rdfs:label "External Connectivity Service"@en ;
    rdfs:comment "End-to-end service providing external network access, relying on DNS and core routing."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :AppModule_CIA_Prod . # A service can be a subsystem of an application module

# --- Event Records ---
:Event_DNS_Down a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Alert"@en ;
    rdfs:comment "Alert indicating that the primary DNS server is unreachable."@en ;
    noria:loggingTime "2024-04-23T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: DNS server dns01.corp.example.com is unreachable via ICMP."@en ;
    noria:logOriginatingManagedObject :Resource_DNS01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

:Event_Interface_Down a noria:EventRecord ;
    rdfs:label "Network Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface state change to 'down'."@en ;
    noria:loggingTime "2024-04-23T09:01:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface Eth0 on dns01.corp.example.com, changed state to down."@en ;
    noria:logOriginatingManagedObject :Resource_DNS01 ;
    noria:logOriginatingManagementSystem :App_SyslogServer ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

:Event_Config_Change a noria:EventRecord ;
    rdfs:label "Router Configuration Change"@en ;
    rdfs:comment "Log entry for a configuration change on Core Router 01."@en ;
    noria:loggingTime "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by John Doe (10.0.0.5)."@en ;
    noria:logOriginatingManagedObject :Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem :App_SyslogServer ;
    noria:logOriginatingAgent :Agent_JohnDoe ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

:App_MonitoringSystem a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:comment "Application responsible for monitoring network devices and services."@en ;
    noria:applicationType <kos/application/type/infrastructure> .

:App_SyslogServer a noria:Application ;
    rdfs:label "Central Syslog Server"@en ;
    rdfs:comment "Application collecting log messages from various IT systems."@en ;
    noria:applicationType <kos/application/type/infrastructure> .

# --- Trouble Tickets ---
:TT_DNSOutage_001 a noria:TroubleTicket ;
    rdfs:label "Critical DNS Server Outage"@en ;
    rdfs:comment "Primary DNS server dns01.corp.example.com is down, impacting corporate internet access."@en ;
    dcterms:created "2024-04-23T09:05:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger :Event_DNS_Down ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Unidentified software crash on DNS server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty :Agent_DNSAdminTeam, :Agent_NetworkOpsTeam ;
    noria:troubleTicketRelatedService :App_CorporateInternetAccess, :Service_ExternalConnectivity ;
    noria:troubleTicketRelatedResource :Resource_DNS01 ;
    noria:troubleTicketImpacts :Resource_DNS01, :App_CorporateInternetAccess, :Service_ExternalConnectivity ;
    noria:documentHRef "https://ticketing.example.com/TT_DNSOutage_001" .

:TT_WebsiteSlow_002 a noria:TroubleTicket ;
    rdfs:label "Corporate Website Performance Degradation"@en ;
    rdfs:comment "Users report slow loading times for the corporate website."@en ;
    dcterms:created "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Minor> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P3> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/User> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Initialised> ;
    noria:troubleTicketRelatedParty :Agent_AppSupportTeam ;
    noria:troubleTicketRelatedService :App_CorporateWebsite ;
    noria:troubleTicketRelatedResource :Resource_VirtualMachine_Web01 .

# --- Trouble Ticket Notes ---
:TTNote_DNS_001_Update1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis Note"@en ;
    rdfs:comment "Confirmed DNS server is not responding. Attempting restart."@en ;
    dcterms:created "2024-04-23T09:15:00Z"^^xsd:dateTime ;
    dcterms:creator :Agent_JohnDoe ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf :TT_DNSOutage_001 .

:TTNote_DNS_001_Update2 a noria:TroubleTicketNote ;
    rdfs:label "Restart Attempt Failed Note"@en ;
    rdfs:comment "Restart of DNS service failed. Escalating to L2 for deeper investigation."@en ;
    dcterms:created "2024-04-23T09:45:00Z"^^xsd:dateTime ;
    dcterms:creator :Agent_JohnDoe ;
