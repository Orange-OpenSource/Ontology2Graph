# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/instance/> .

# =============================================================================
# Agents
# =============================================================================

<Agent/team-ops> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Operations Team"@en ;
    rdfs:label "Équipe Opérations"@fr ;
    rdfs:comment "Team responsible for day-to-day IT operations and incident response."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for all non-critical issues. For critical issues, use emergency hotline."@en .

<Agent/team-dev> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Development Team"@en ;
    rdfs:label "Équipe Développement"@fr ;
    rdfs:comment "Team responsible for application development and maintenance."@en ;
    noria:agentWorkingHours "10:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/chat> .

<Agent/john-doe> a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/phone> .

<Agent/jane-smith> a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Application Support Specialist."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/email> .

<Agent/customer-support> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Customer Support"@en ;
    rdfs:label "Support Client"@fr ;
    rdfs:comment "First line support for customer inquiries and issues."@en .

<Agent/security-team> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:label "Centre Opérations Sécurité"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en .

# =============================================================================
# Locations
# =============================================================================

<Location/site-paris> a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string .

<Location/room-server-a> a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:label "Salle Serveurs A"@fr ;
    rdfs:comment "Primary server room within the Paris Data Center."@en ;
    bot:hasSpace <Location/locus-a1-r1> ;
    bot:hasSpace <Location/locus-a1-r2> .

<Location/locus-a1-r1> a noria:Locus ;
    rdfs:label "Locus A1-R1"@en ;
    rdfs:comment "Location A1, Rack 1 in Server Room A."@en ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "R1"^^xsd:string .

<Location/locus-a1-r2> a noria:Locus ;
    rdfs:label "Locus A1-R2"@en ;
    rdfs:comment "Location A1, Rack 2 in Server Room A."@en ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "R2" .

# =============================================================================
# Product Models
# =============================================================================

<ProductModel/dell-r740> a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Server model for high-performance computing."@en ;
    noria:productManufacturedBy <Agent/dell-technologies> .

<ProductModel/cisco-nexus-9k> a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "High-density data center switch series."@en ;
    noria:productManufacturedBy <Agent/cisco-systems> .

<ProductModel/vmware-esxi> a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for virtual machines."@en ;
    noria:productManufacturedBy <Agent