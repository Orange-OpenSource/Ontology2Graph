<noria:ApplicationModule/WebPortal-Backend>
    a noria:ApplicationModule ;
    rdfs:label "Web Portal Backend Module"@en ;
    rdfs:comment "Backend component of the Customer Web Portal."@en ;
    noria:applicationModuleOf <noria:Application/WebPortal> ;
    noria:applicationModuleName "CWP_BACKEND" ;
    noria:applicationModuleIdentifier "BE-001" ;
    noria:applicationModuleAdministrationTeam <foaf:Agent/DevOpsTeamB> ;
    noria:applicationModuleSupportTeam <foaf:Agent/CustomerSupport> ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleHotlineEnabled true .

# =============================================================================
# Services (noria:Service)
# =============================================================================

<noria:Service/InternetAccessService>
    a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users and applications."@en ;
    noria:serviceType <kos/service/type/InfrastructureService> ;
    seas:subSystemOf <noria:Application/CorporateDNS> ; # Example of service composition
    seas:subSystemOf <noria:Application/MonitoringSystem> ;
    seas:subSystemOf <noria:ApplicationModule/CorporateDNS-Prod> .

<noria:Service/CustomerWebAccess>
    a noria:Service ;
    rdfs:label "Customer Web Access Service"@en ;
    rdfs:comment "Enables customers to access their accounts and services via the web portal."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <noria:Application/WebPortal> ;
    seas:subSystemOf <noria:ApplicationModule/WebPortal-Frontend> ;
    seas:subSystemOf <noria:ApplicationModule/WebPortal-Backend> .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

<noria:TroubleTicket/TT20240315-001>
    a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:comment "Primary DNS server (DNS01) is unreachable, impacting all services."@en ;
    dcterms:created "2024-03-15T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-03-15T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Network connectivity issue to DNS01."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-03-15T08:55:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty <foaf:Agent/NOCEngineerJohn> ;
    noria:troubleTicketRelatedParty <foaf:Agent/AdminTeamA> ;
    noria:troubleTicketRelatedService <noria:Application/CorporateDNS> ;
    noria:troubleTicketRelatedResource <noria:Resource/DNS01> ;
    noria:troubleTicketImpacts <noria:Application/CorporateDNS> ;
    noria:troubleTicketImpacts <noria:Service/InternetAccessService> ;
    noria:troubleTicketTrigger <noria:EventRecord/ER20240315-001> ;
    noria:documentStatusHistory <noria:EventRecord/ER20240315-004> .

<noria:TroubleTicket/TT20240315-002>
    a noria:TroubleTicket ;
    rdfs:label "Web Portal Slow Performance"@en ;
    rdfs:comment "Customers reporting slow loading times on the web portal."@en ;
    dcterms:created "2024-03-15T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Initialised> ;
