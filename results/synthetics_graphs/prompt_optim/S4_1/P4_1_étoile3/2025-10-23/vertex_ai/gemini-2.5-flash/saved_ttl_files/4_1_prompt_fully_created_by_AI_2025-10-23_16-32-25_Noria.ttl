# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

<foaf:Agent/AdminTeamA>
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Infrastructure Admin Team"@en ;
    rdfs:label "Équipe d'Administration Infrastructure"@fr ;
    rdfs:comment "Team responsible for core infrastructure management."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for non-urgent issues, phone for critical incidents."@en .

<foaf:Agent/NOCEngineerJohn>
    a foaf:Agent ;
    rdfs:label "John Doe (NOC Engineer)"@en ;
    rdfs:label "John Doe (Ingénieur NOC)"@fr ;
    rdfs:comment "Network Operations Center engineer, first line of defense."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

<foaf:Agent/DevOpsTeamB>
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Web Portal DevOps Team"@en ;
    rdfs:label "Équipe DevOps Portail Web"@fr ;
    rdfs:comment "Team responsible for the development and operations of the customer web portal."@en ;
    noria:agentWorkingHours "8:30 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> .

<foaf:Agent/CustomerSupport>
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Customer Support Tier 1"@en ;
    rdfs:label "Support Client Niveau 1"@fr ;
    rdfs:comment "First line customer support for all services."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> .

<foaf:Agent/SecurityTeam>
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Cyber Security Operations Center"@en ;
    rdfs:label "Centre d'Opérations de Cybersécurité"@fr ;
    rdfs:comment "Monitors and responds to security incidents."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlerts> .

<foaf:Agent/NetworkOps>
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:label "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Manages and maintains the corporate network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

<foaf:Agent/IncidentManagerAlice>
    a foaf:Agent ;
    rdfs:label "Alice Smith (Incident Manager)"@en ;
    rdfs:comment "Senior incident manager overseeing critical incidents."@en ;
    foaf:mbox <mailto:alice.smith@example.com> .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

<bot:Site/ParisDC>
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@fr ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

<noria:Room/ServerRoom01>
    a noria:Room ;
    rdfs:label "Server Room 01"@en ;
    rdfs:label "Salle Serveurs 01"@fr ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace <bot:Site/ParisDC> .

<noria:Locus/RackA05>
    a noria:Locus ;
    rdfs:label "Rack A05"@en ;
    rdfs:comment "Specific rack location within Server Room 01."@en ;
    noria:locusLine "A" ;
    noria:locusRow "05" ;
    bot:hasSpace <noria:Room/ServerRoom01> .

<noria:Locus/RackB12>
    a noria:Locus ;
    rdfs:label "Rack B12"@en ;
    rdfs:comment "Another rack location within Server Room 01."@en ;
    noria:locusLine "B" ;
    noria:locusRow "12" ;
    bot:hasSpace <noria:Room/ServerRoom01> .

