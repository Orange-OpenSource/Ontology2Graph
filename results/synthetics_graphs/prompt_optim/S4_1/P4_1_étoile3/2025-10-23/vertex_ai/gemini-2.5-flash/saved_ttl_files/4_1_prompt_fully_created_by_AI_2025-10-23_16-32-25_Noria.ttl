    rdfs:comment "Enterprise-grade network switch model."@en ;
    noria:productManufacturedBy <org:Organization/Cisco> .

<noria:ProductModel/VMwareESXi>
    a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform software."@en ;
    noria:productManufacturedBy <org:Organization/VMware> .

<org:Organization/Dell>
    a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
