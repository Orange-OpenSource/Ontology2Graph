    rdfs:comment "Provider of cloud computing and virtualization software."@en .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

<noria:Resource/DNS01>
    a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for internal and external resolution."@en ;
    noria:resourceManagedBy <foaf:Agent/AdminTeamA> ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel <noria:ProductModel/DellPowerEdgeR740> ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <noria:Locus/RackA05> ;
    noria:resourceManagementIPAddress "192.168.1.10" .

<noria:Resource/RouterCore01>
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate network, handling internet egress."@en ;
    noria:resourceManagedBy <foaf:Agent/NetworkOps> ;
    noria:resourceHostName "router-core01.corp.example.com" ;
    noria:resourceProductModel <noria:ProductModel/CiscoCatalyst9300> ;
    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-05-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <noria:Locus/RackB12> ;
    noria:resourceManagementIPAddress "10.0.0.1" .

<noria:Resource/VMWeb01>
    a noria:Resource ;
    rdfs:label "Web Portal VM 01"@en ;
    rdfs:comment "Virtual machine hosting the frontend of the customer web portal."@en ;
    noria:resourceManagedBy <foaf:Agent/DevOpsTeamB> ;
    noria:resourceHostName "web01.portal.example.com" ;
    noria:resourceProductModel <noria:ProductModel/VMwareESXi> ;
    noria:resourceLogisticId "LOG-VM-001" ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceSerialNumber "SN-VM-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-01T09:00:00Z"^^xsd:dateTime ;
    noria:clusterController <noria:Resource/HypervisorHost01> .

<noria:Resource/HypervisorHost01>
    a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical server hosting virtual machines, including VMWeb01."@en ;
    noria:resourceManagedBy <foaf:Agent/AdminTeamA> ;
    noria:resourceHostName "hypervisor01.corp.example.com" ;
    noria:resourceProductModel <noria:ProductModel/DellPowerEdgeR740> ;
    noria:resourceType <kos/Resource/type/Hypervisor> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:locatedAtLocus <noria:Locus/RackA05> .

<noria:Resource/FirewallFW01>
    a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:comment "Firewall protecting the corporate network perimeter."@en ;
    noria:resourceManagedBy <foaf:Agent/SecurityTeam> ;
    noria:resourceHostName "fw01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:locatedAtLocus <noria:Locus/RackB12> .

<noria:Resource/LoadBalancerLB01>
    a noria:Resource ;
    rdfs:label "Load Balancer 01"@en ;
    rdfs:comment "Distributes traffic to web servers for the customer portal."@en ;
    noria:resourceManagedBy <foaf:Agent/DevOpsTeamB> ;
    noria:resourceHostName "lb01.portal.example.com" ;
    noria:resourceType <kos/Resource/type/LoadBalancer> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:locatedAtLocus <noria:Locus/RackA05> .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

<noria:NetworkInterface/DNS01-Eth0>
    a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf <noria:Resource/DNS01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceDescription "Uplink to core switch."@en .

<noria:NetworkInterface/RouterCore01-Gi0_0_1>
    a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting to internal network segment."@en ;
    noria:networkInterfaceOf <noria:Resource/RouterCore01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceDescription "Internal LAN connection."@en .

<noria:NetworkInterface/RouterCore01-Gi0_0_2>
    a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Interface connecting to external internet provider."@en ;
    noria:networkInterfaceOf <noria:Resource/RouterCore01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 ;
    noria:networkInterfaceDescription "Internet Uplink."@en .

<noria:NetworkInterface/VMWeb01-vNIC0>
    a noria:NetworkInterface ;
    rdfs:label "VMWeb01 Virtual NIC 0"@en ;
    rdfs:comment "Virtual network interface for VMWeb01."@en ;
    noria:networkInterfaceOf <noria:Resource/VMWeb01> ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

<noria:NetworkLink/Link-DNS01-RouterCore01>
    a noria:NetworkLink ;
    rdfs:label "Link DNS01 to RouterCore01"@en ;
    rdfs:comment "Internal network link between DNS server and core router."@en ;
    noria:resourceManagedBy <foaf:Agent/NetworkOps> ;
    noria:networkLinkTerminationResourceOrigin <noria:Resource/DNS01> ;
    noria:networkLinkTerminationResourceDestination <noria:Resource/RouterCore01> ;
    noria:networkLinkInstallationDate "2022-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:networkInterfaceConnects <noria:NetworkInterface/DNS01-Eth0> ;
    noria:networkInterfaceConnects <noria:NetworkInterface/RouterCore01-Gi0_0_1> .

<noria:NetworkLink/Link-RouterCore01-Internet>
    a noria:NetworkLink ;
    rdfs:label "Link RouterCore01 to Internet Provider"@en ;
    rdfs:comment "External network link to the internet service provider."@en ;
    noria:resourceManagedBy <foaf:Agent/NetworkOps> ;
    noria:networkLinkTerminationResourceOrigin <noria:Resource/RouterCore01> ;
    noria:networkLinkInstallationDate "2021-05-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic WAN" ;
    noria:networkInterfaceConnects <noria:NetworkInterface/RouterCore01-Gi0_0_2> .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

<noria:Application/CorporateDNS>
    a noria:Application ;
    rdfs:label "Corporate DNS Service"@en ;
    rdfs:comment "Provides DNS resolution for all corporate services."@en ;
    noria:applicationModelIdentifier "CORP-DNS" ;
    noria:applicationNumericalIdentifier 101 ;
    noria:applicationShortIdentifier "CDNS" ;
    noria:applicationType <kos/application/type/InfrastructureService> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "DNS Resolution" ;
    noria:resourceForApplication <noria:Resource/DNS01> .

<noria:Application/WebPortal>
    a noria:Application ;
    rdfs:label "Customer Web Portal"@en ;
    rdfs:comment "Public-facing web application for customer interactions."@en ;
    noria:applicationModelIdentifier "CUST-PORTAL" ;
    noria:applicationNumericalIdentifier 201 ;
    noria:applicationShortIdentifier "CWP" ;
    noria:applicationType <kos/application/type/CustomerFacingApplication> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Online Self-Service" ;
    noria:resourceForApplication <noria:Resource/VMWeb01> ;
    noria:resourceForApplication <noria:Resource/LoadBalancerLB01> .

<noria:Application/MonitoringSystem>
    a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:comment "Collects and analyzes metrics and logs from all IT infrastructure."@en ;
    noria:applicationModelIdentifier "MON-SYS" ;
    noria:applicationNumericalIdentifier 301 ;
    noria:applicationShortIdentifier "CMS" ;
    noria:applicationType <kos/application/type/ManagementTool> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Performance Monitoring" .

<noria:Application/TicketingSystem>
    a noria:Application ;
    rdfs:label "ITSM Ticketing System"@en ;
    rdfs:comment "System used for managing incidents, problems, and changes."@en ;
    noria:applicationModelIdentifier "ITSM-TKT" ;
    noria:applicationNumericalIdentifier 401 ;
    noria:applicationShortIdentifier "ITSM" ;
    noria:applicationType <kos/application/type/ManagementTool> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical> ;
    noria:applicationFunctionalDomain "IT Service Management" ;
    noria:applicationFunctionalSubDomain "Incident Management" .

