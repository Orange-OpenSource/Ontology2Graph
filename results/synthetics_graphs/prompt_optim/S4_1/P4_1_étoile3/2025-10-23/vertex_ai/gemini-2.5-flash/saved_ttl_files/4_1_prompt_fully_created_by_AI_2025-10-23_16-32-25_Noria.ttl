    noria:troubleTicketRelatedParty <foaf:Agent/DevOpsTeamB> ;
    noria:troubleTicketRelatedService <noria:Application/WebPortal> ;
    noria:troubleTicketRelatedResource <noria:Resource/VMWeb01> ;
    noria:troubleTicketImpacts <noria:Service/CustomerWebAccess> ;
    noria:troubleTicketTrigger <noria:EventRecord/ER20240315-003> .

# =============================================================================
# Trouble Ticket Notes (noria:TroubleTicketNote)
# =============================================================================

<noria:TroubleTicketNote/TTN20240315-001-01>
    a noria:TroubleTicketNote ;
    rdfs:label "Initial diagnosis for TT20240315-001"@en ;
    rdfs:comment "NOC Engineer John Doe confirmed DNS01 is not responding to pings. Escalated to Admin Team A."@en ;
    dcterms:created "2024-03-15T09:15:00Z"^^xsd:dateTime ;
    dcterms:creator <foaf:Agent/NOCEngineerJohn> ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf <noria:TroubleTicket/TT20240315-001> .

<noria:TroubleTicketNote/TTN20240315-001-02>
    a noria:TroubleTicketNote ;
    rdfs:label "Admin Team A investigation for TT20240315-001"@en ;
    rdfs:comment "Admin Team A found that the network interface on DNS01 is administratively down. Attempting to bring it up."@en ;
    dcterms:created "2024-03-15T10:00:00Z"^^xsd:dateTime ;
    dcterms:creator <foaf:Agent/AdminTeamA> ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:isPartOf <noria:TroubleTicket/TT20240315-001> ;
    noria:troubleTicketNoteCorrelatedExecution <noria:EventRecord/ER20240315-002> .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

<noria:EventRecord/ER20240315-001>
    a noria:EventRecord ;
    rdfs:label "DNS01 Host Down Alert"@en ;
    rdfs:comment "Alert: Host dns01.corp.example.com is DOWN."@en ;
    noria:loggingTime "2024-03-15T08:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <noria:Resource/DNS01> ;
    noria:logOriginatingManagementSystem <noria:Application/MonitoringSystem> ;
    noria:logText "CRITICAL - Host Check Command: check_ping - Host Status: DOWN - Output: PING CRITICAL - Packet loss = 100%"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<noria:EventRecord/ER20240315-002>
    a noria:EventRecord ;
    rdfs:label "RouterCore01 Interface Flap"@en ;
    rdfs:comment "Log: Interface GigabitEthernet0/0/1 on RouterCore01 changed state to down/up repeatedly."@en ;
    noria:loggingTime "2024-03-15T09:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <noria:Resource/RouterCore01> ;
    noria:logOriginatingManagementSystem <noria:Application/MonitoringSystem> ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:alarmProposedRepairAction <noria:OperationPlan/RouterInterfaceReset> .

<noria:EventRecord/ER20240315-003>
    a noria:EventRecord ;
    rdfs:label "VMWeb01 High CPU Alert"@en ;
    rdfs:comment "Alert: VMWeb01 CPU utilization above 90% for 10 minutes."@en ;
    noria:loggingTime "2024-03-15T10:25:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <noria:Resource/VMWeb01> ;
    noria:logOriginatingManagementSystem <noria:Application/MonitoringSystem> ;
    noria:logText "CPU utilization on web01.portal.example.com is 95%."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

<noria:EventRecord/ER20240315-004>
    a noria:EventRecord ;
    rdfs:label "Trouble Ticket TT20240315-001 Status Change"@en ;
    rdfs:comment "Status of TT20240315-001 changed from 'Initialised' to 'InProgress'."@en ;
    noria:loggingTime "2024-03-15T09:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <noria:Application/TicketingSystem> ;
    noria:logOriginatingAgent <foaf:Agent/NOCEngineerJohn> ;
    noria:logText "Ticket TT20240315-001 status updated to InProgress by John Doe."@en .

