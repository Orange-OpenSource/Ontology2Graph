    noria:changeRequestPilotParty <foaf:Agent/NOCEngineerJohn> ;
    noria:changeRequestActorParty <foaf:Agent/NetworkOps> ;
    noria:changeRequestIsRegulated true .

<noria:ChangeRequest/CR20240312-002>
    a noria:ChangeRequest ;
    rdfs:label "Web Portal New Feature Deployment"@en ;
    rdfs:comment "Deployment of new customer self-service features on the web portal."@en ;
    dcterms:created "2024-03-12T11:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-03-22T00:00:00Z"^^xsd:dateTime ;
