# Application Modules (noria:ApplicationModule)
# =============================================================================

<noria:ApplicationModule/CorporateDNS-Prod>
    a noria:ApplicationModule ;
    rdfs:label "Corporate DNS Production Module"@en ;
    rdfs:comment "Production instance of the Corporate DNS Service."@en ;
    noria:applicationModuleOf <noria:Application/CorporateDNS> ;
    noria:applicationModuleName "CDNS_PROD" ;
    noria:applicationModuleIdentifier "PROD-001" ;
    noria:applicationModuleAdministrationTeam <foaf:Agent/AdminTeamA> ;
    noria:applicationModuleSupportTeam <foaf:Agent/NetworkOps> ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

<noria:ApplicationModule/WebPortal-Frontend>
    a noria:ApplicationModule ;
    rdfs:label "Web Portal Frontend Module"@en ;
    rdfs:comment "Frontend component of the Customer Web Portal."@en ;
    noria:applicationModuleOf <noria:Application/WebPortal> ;
    noria:applicationModuleName "CWP_FRONTEND" ;
    noria:applicationModuleIdentifier "FE-001" ;
    noria:applicationModuleAdministrationTeam <foaf:Agent/DevOpsTeamB> ;
    noria:applicationModuleSupportTeam <foaf:Agent/CustomerSupport> ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
