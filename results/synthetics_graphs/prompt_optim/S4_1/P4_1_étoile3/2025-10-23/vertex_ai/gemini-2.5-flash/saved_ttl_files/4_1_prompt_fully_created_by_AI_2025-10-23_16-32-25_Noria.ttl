<noria:ChangeRequest/CR20240310-001>
    a noria:ChangeRequest ;
    rdfs:label "Router Core 01 Firmware Upgrade"@en ;
    rdfs:comment "Planned firmware upgrade for RouterCore01 to enhance security and performance."@en ;
    dcterms:created "2024-03-10T14:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-03-20T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-03-20T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact <noria:Resource/RouterCore01> ;
    noria:changeRequestImpact <noria:Service/InternetAccessService> ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/NetworkDeviceFirmwareUpgrade> ;
