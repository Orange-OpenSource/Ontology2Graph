# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

<noria:OperationPlan/RouterFirmwareUpgrade>
    a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router firmware."@en ;
    skos:example "Steps include backup configuration, upload new image, reload, verify connectivity."@en ;
    noria:operationPlanPreCondition <noria:ActionPreCondition/RouterConnectivityCheck> ;
    noria:operationPlanPostCondition <noria:ActionPostCondition/RouterConnectivityRestored> .

<noria:OperationPlan/DNSFailoverProcedure>
    a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:comment "Procedure to activate secondary DNS server in case of primary failure."@en ;
    skos:example "Steps include verifying primary status, activating secondary, updating load balancer, verifying resolution."@en ;
    noria:operationPlanPreCondition <noria:ActionPreCondition/PrimaryDNSDown> ;
    noria:operationPlanPostCondition <noria:ActionPostCondition/DNSResolutionRestored> .

<noria:OperationPlan/RouterInterfaceReset>
    a noria:OperationPlan ;
    rdfs:label "Router Interface Reset Procedure"@en ;
    rdfs:comment "Procedure to administratively shut down and then bring up a router interface."@en ;
    skos:example "Commands: 'shutdown', 'no shutdown'."@en ;
    noria:operationPlanPreCondition <noria:ActionPreCondition/InterfaceFlappingDetected> ;
    noria:operationPlanPostCondition <noria:ActionPostCondition/InterfaceOperationalStatusUp> .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

<noria:ActionPreCondition/RouterConnectivityCheck>
    a noria:ActionPreCondition ;
    rdfs:label "Router Connectivity Check"@en ;
    rdfs:comment "Verify reachability and basic functionality of the router before maintenance."@en ;
    skos:example "Ping management IP, check routing table, verify BGP neighbors."@en .

<noria:ActionPostCondition/RouterConnectivityRestored>
    a noria:ActionPostCondition ;
    rdfs:label "Router Connectivity Restored"@en ;
    rdfs:comment "Confirm full network connectivity and service routing after router maintenance."@en ;
    skos:example "Ping all critical interfaces, verify BGP sessions, test application connectivity."@en .

<noria:ActionPreCondition/PrimaryDNSDown>
    a noria:ActionPreCondition ;
    rdfs:label "Primary DNS Server Down"@en ;
    rdfs:comment "Condition: Primary DNS server is unreachable or not responding to queries."@en .

<noria:ActionPostCondition/DNSResolutionRestored>
    a noria:ActionPostCondition ;
    rdfs:label "DNS Resolution Restored"@en ;
    rdfs:comment "Condition: DNS resolution for critical services is functioning correctly."@en .

<noria:ActionPreCondition/InterfaceFlappingDetected>
    a noria:ActionPreCondition ;
    rdfs:label "Interface Flapping Detected"@en ;
    rdfs:comment "Condition: A network interface is repeatedly changing its operational state (up/down)."@en .

<noria:ActionPostCondition/InterfaceOperationalStatusUp>
    a noria:ActionPostCondition ;
    rdfs:label "Interface Operational Status Up"@en ;
    rdfs:comment "Condition: The network interface's operational status is stable and 'up'."@en .

