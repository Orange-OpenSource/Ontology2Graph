    rdfs:comment "High-performance rack server."@en ;
    noria:productManufacturedBy org:ManufacturerDell .

noria:ProductModel003 a noria:ProductModel ;
    rdfs:label "Juniper MX204"@en ;
    rdfs:comment "Compact universal routing platform."@en ;
    noria:productManufacturedBy org:ManufacturerJuniper .

noria:ProductModel004 a noria:ProductModel ;
