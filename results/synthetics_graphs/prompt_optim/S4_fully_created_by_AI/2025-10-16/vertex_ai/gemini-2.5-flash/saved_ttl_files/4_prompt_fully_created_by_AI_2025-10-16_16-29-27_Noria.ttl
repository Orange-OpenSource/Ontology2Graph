# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent001 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC) Team"@en, "Équipe du Centre d'Opérations Réseau (NOC)"@fr ;
    rdfs:comment "Primary team responsible for monitoring and initial response to network incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call hotline for critical issues, use ticketing system for non-critical."@en .

foaf:Agent002 a foaf:Agent ;
    rdfs:label "Server Administration Team"@en, "Équipe d'Administration Serveurs"@fr ;
    rdfs:comment "Team managing physical and virtual server infrastructure."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Open a ticket in the ITSM system for all requests."@en .

foaf:Agent003 a foaf:Agent ;
    rdfs:label "Database Administration Team"@en, "Équipe d'Administration Bases de Données"@fr ;
    rdfs:comment "Specialized team for database management and support."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent004 a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Individual member of the NOC Team."@en ;
    foaf:member foaf:Agent001 ;
    foaf:mbox <mailto:john.doe@example.com> .

foaf:Agent005 a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Individual member of the Server Administration Team."@en ;
    foaf:member foaf:Agent002 ;
    foaf:mbox <mailto:jane.smith@example.com> .

org:OrgUnit001 a org:OrganizationalUnit ;
    rdfs:label "IT Infrastructure Department"@en, "Département Infrastructure IT"@fr ;
    rdfs:comment "Main department overseeing all IT infrastructure."@en ;
    org:hasMember foaf:Agent001, foaf:Agent002, foaf:Agent003 .

org:OrgUnit002 a org:OrganizationalUnit ;
    rdfs:label "Application Support L2"@en, "Support Applicatif N2"@fr ;
    rdfs:comment "Second level support for business applications."@en .

org:ManufacturerCisco a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en .

org:ManufacturerDell a org:Organization ;
    rdfs:label "Dell Technologies"@en .

org:ManufacturerJuniper a org:Organization ;
    rdfs:label "Juniper Networks"@en .

org:ManufacturerVMware a org:Organization ;
    rdfs:label "VMware Inc."@en .

