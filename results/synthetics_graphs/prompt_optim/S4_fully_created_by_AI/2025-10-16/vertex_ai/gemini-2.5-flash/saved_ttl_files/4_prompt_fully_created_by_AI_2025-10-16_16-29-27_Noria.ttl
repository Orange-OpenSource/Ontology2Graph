# =============================================================================
# Procedural Elements (Operation Plans, Pre/Post Conditions, Anomaly Patterns)
# =============================================================================

noria:OperationPlan001 a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network interface issues."@en ;
    skos:example "Steps include checking cable, port status, configuration, and testing connectivity."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition001 ;
    noria:operationPlanPostCondition noria:ActionPostCondition001 ;
    folio:addressesFailureMode noria:AnomalyPattern001 .

noria:ActionPreCondition001 a noria:ActionPreCondition ;
    rdfs:label "Interface Down Detected"@en ;
    rdfs:comment "Pre-condition: An alert or user report indicates a network interface is down."@en .

noria:ActionPostCondition001 a noria:ActionPostCondition ;
    rdfs:label "Interface Operational"@en ;
    rdfs:comment "Post-condition: The network interface is up and traffic is flowing normally."@en .

noria:OperationPlan002 a noria:OperationPlan ;
    rdfs:label "Application Server CPU Spike Resolution"@en ;
    rdfs:comment "Procedure to investigate and resolve high CPU usage on application servers."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition002 ;
    noria:operationPlanPostCondition noria:ActionPostCondition002 .

noria:ActionPreCondition002 a noria:ActionPreCondition ;
    rdfs:label "High CPU Usage Alert"@en ;
    rdfs:comment "Pre-condition: Monitoring system reports sustained high CPU usage."@en .

noria:ActionPostCondition002 a noria:ActionPostCondition ;
    rdfs:label "CPU Usage Normalized"@en ;
    rdfs:comment "Post-condition: CPU usage returns to normal levels, application performance restored."@en .

noria:OperationPlan003 a noria:OperationPlan ;
    rdfs:label "Router Software Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading router operating system software."@en .

noria:AnomalyPattern001 a noria:AnomalyPattern ;
    rdfs:label "Repeated Interface Flap Pattern"@en ;
    rdfs:comment "Pattern indicating an interface repeatedly goes down and up within a short period, suggesting a physical layer issue."@en ;
    skos:example "Multiple 'Interface Down' and 'Interface Up' events for the same interface within 5 minutes."@en .

noria:ProcedureExecution001 a pep:ProcedureExecutionContainer ;
