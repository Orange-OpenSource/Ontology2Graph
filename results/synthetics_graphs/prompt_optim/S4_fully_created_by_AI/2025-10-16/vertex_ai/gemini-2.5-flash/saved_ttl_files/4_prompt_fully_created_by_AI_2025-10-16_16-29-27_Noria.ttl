    rdfs:comment "Hypervisor for virtual machines."@en ;
    noria:productManufacturedBy org:ManufacturerVMware .

# =============================================================================
# Locations (Site, Room, Locus)
# =============================================================================

bot:Site001 a bot:Site ;
    rdfs:label "Paris Data Center 1"@en, "Centre de Données Paris 1"@fr ;
    noria:siteId "PDC1" ;
    noria:siteType "Data Center"@en ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" ;
    wgs84_pos:lat "48.867"^^xsd:float ;
    wgs84_pos:long "2.333"^^xsd:float .

bot:Site002 a bot:Site ;
    rdfs:label "Lyon Office Building"@en, "Immeuble de Bureaux Lyon"@fr ;
    noria:siteId "LOB1" ;
    noria:siteType "Office Building"@en ;
    noria:sitePrincipalAddressStreet "45 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room001 a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room in Paris Data Center 1."@en ;
    bot:hasSpace bot:Site001 .

noria:Room002 a noria:Room ;
    rdfs:label "Network Equipment Room"@en, "Salle Équipements Réseau"@fr ;
    rdfs:comment "Room dedicated to network devices in Paris Data Center 1."@en ;
    bot:hasSpace bot:Site001 .

noria:Room003 a noria:Room ;
    rdfs:label "IT Closet Lyon"@en, "Local Technique Lyon"@fr ;
    rdfs:comment "IT equipment closet in Lyon Office Building."@en ;
    bot:hasSpace bot:Site002 .

noria:Locus001 a noria:Locus ;
    rdfs:label "Rack A1, Unit 1-5"@en ;
    rdfs:comment "Location for core network router."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "1-5" ;
    bot:hasSpace noria:Room002 .

noria:Locus002 a noria:Locus ;
    rdfs:label "Rack B2, Unit 10-15"@en ;
    rdfs:comment "Location for application server."@en ;
    noria:locusLine "B2" ;
    noria:locusRow "10-15" ;
    bot:hasSpace noria:Room001 .

noria:Locus003 a noria:Locus ;
    rdfs:label "Rack C3, Unit 20-24"@en ;
    rdfs:comment "Location for database server."@en ;
    noria:locusLine "C3" ;
    noria:locusRow "20-24" ;
    bot:hasSpace noria:Room001 .

noria:Locus004 a noria:Locus ;
    rdfs:label "Office Rack 1, Unit 1-2"@en ;
    rdfs:comment "Location for network equipment in Lyon office."@en ;
    noria:locusLine "Office Rack 1" ;
    noria:locusRow "1-2" ;
    bot:hasSpace noria:Room003 .

# =============================================================================
# Resources (Servers, Routers, Switches, VMs)
# =============================================================================

