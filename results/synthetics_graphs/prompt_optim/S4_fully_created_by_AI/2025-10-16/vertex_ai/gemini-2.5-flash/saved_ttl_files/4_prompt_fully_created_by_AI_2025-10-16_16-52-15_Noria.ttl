# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS Concepts (used as values for ObjectProperties)
# =============================================================================

<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure Application"@en .
<kos/application/type/database> a skos:Concept ; rdfs:label "Database Application"@en .
<kos/application/type/web-service> a skos:Concept ; rdfs:label "Web Service Application"@en .
<kos/application/type/monitoring> a skos:Concept ; rdfs:label "Monitoring System"@en .
<kos/application/type/security> a skos:Concept ; rdfs:label "Security Application"@en .
<kos/application/type/messaging> a skos:Concept ; rdfs:label "Messaging System"@en .
<kos/application/type/virtualization> a skos:Concept ; rdfs:label "Virtualization Platform"@en .
<kos/application/type/storage> a skos:Concept ; rdfs:label "Storage Management System"@en .

<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High Business Importance"@en .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium Business Importance"@en .
<kos/application/business-importance/low> a skos:Concept ; rdfs:label "Low Business Importance"@en .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production"@en ; rdfs:label "En Production"@fr .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; rdfs:label "Development"@en ; rdfs:label "En Développement"@fr .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ; rdfs:label "Maintenance"@en .
<https://w3id.org/noria/kos/application/status/Decommissioned> a skos:Concept ; rdfs:label "Decommissioned"@en .

<kos/service/type/CustomerFacingService> a skos:Concept ; rdfs:label "Customer Facing Service"@en .
<kos/service/type/ResourceFacingService> a skos:Concept ; rdfs:label "Resource Facing Service"@en .
<kos/service/type/InternalService> a skos:Concept ; rdfs:label "Internal Service"@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ; rdfs:label "Critical Severity"@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; rdfs:label "Major Severity"@en .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; rdfs:label "Minor Severity"@en .
<kos/TroubleTicket/severity/Warning> a skos:Concept ; rdfs:label "Warning Severity"@en .

<kos/TroubleTicket/type/Failure> a skos:Concept ; rdfs:label "Failure Ticket"@en .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; rdfs:label "Assistance Ticket"@en .
<kos/TroubleTicket/type/Maintenance> a skos:Concept ; rdfs:label "Maintenance Ticket"@en .

<kos/TroubleTicket/category/ServiceInterruption> a skos:Concept ; rdfs:label "Service Interruption"@en .
<kos/TroubleTicket/category/PerformanceDegradation> a skos:Concept ; rdfs:label "Performance Degradation"@en .
<kos/TroubleTicket/category/HardwareFailure> a skos:Concept ; rdfs:label "Hardware Failure"@en .
<kos/TroubleTicket/category/SoftwareBug> a skos:Concept ; rdfs:label "Software Bug"@en .

<kos/TroubleTicket/priority/P1> a skos:Concept ; rdfs:label "Priority 1"@en .
<kos/TroubleTicket/priority/P2> a skos:Concept ; rdfs:label "Priority 2"@en .
<kos/TroubleTicket/priority/P3> a skos:Concept ; rdfs:label "Priority 3"@en .

<kos/TroubleTicket/origin/Customer> a skos:Concept ; rdfs:label "Customer Origin"@en .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; rdfs:label "Supervision System Origin"@en .
<kos/TroubleTicket/origin/Internal> a skos:Concept ; rdfs:label "Internal Origin"@en .

<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; rdfs:label "Immediate Intervention"@en .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; rdfs:label "Deferred Intervention"@en .

<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ; rdfs:label "Managed Backbone Networks Responsibility"@en .
<kos/TroubleTicket/problemResponsibility/CustomerEquipment> a skos:Concept ; rdfs:label "Customer Equipment Responsibility"@en .
<kos/TroubleTicket/problemResponsibility/ApplicationHosting> a skos:Concept ; rdfs:label "Application Hosting Responsibility"@en .

<kos/TroubleTicket/status/InProgress> a skos:Concept ; rdfs:label "In Progress"@en .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved"@en .
<kos/TroubleTicket/status/Closed> a skos:Concept ; rdfs:label "Closed"@en .
<kos/TroubleTicket/status/PendingCustomer> a skos:Concept ; rdfs:label "Pending Customer"@en .

<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal Comment"@en .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; rdfs:label "Customer Comment"@en .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis Operation"@en .
<kos/TroubleTicket/operationType/TestsAndMeasurements> a skos:Concept ; rdfs:label "Tests and Measurements Operation"@en .
<kos/TroubleTicket/operationType/ConfigurationChange> a skos:Concept ; rdfs:label "Configuration Change Operation"@en .

<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; rdfs:label "Internal Intervention"@en .
<kos/ChangeRequest/category/SoftwareUpgrade> a skos:Concept ; rdfs:label "Software Upgrade"@en .
<kos/ChangeRequest/category/NetworkExtension> a skos:Concept ; rdfs:label "Network Extension"@en .

<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard Change"@en .
<kos/ChangeRequest/type/Normal> a skos:Concept ; rdfs:label "Normal Change"@en .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; rdfs:label "Emergency Change"@en .

<kos/ChangeRequest/cause/Configuration> a skos:Concept ; rdfs:label "Configuration Change Cause"@en .
<kos/ChangeRequest/cause/PreventativeMaintenance> a skos:Concept ; rdfs:label "Preventative Maintenance Cause"@en .

<kos/ChangeRequest/status/Approved> a skos:Concept ; rdfs:label "Approved Change"@en .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; rdfs:label "Implemented Change"@en .
<kos/ChangeRequest/status/Scheduled> a skos:Concept ; rdfs:label "Scheduled Change"@en .

<kos/Resource/type/Server> a skos:Concept ; rdfs:label "Server Resource Type"@en .
<kos/Resource/type/Router> a skos:Concept ; rdfs:label "Router Resource Type"@en .
<kos/Resource/type/Switch> a skos:Concept ; rdfs:label "Switch Resource Type"@en .
<kos/Resource/type/Firewall> a skos:Concept ; rdfs:label "Firewall Resource Type"@en .
<kos/Resource/type/VirtualMachine> a skos:Concept ; rdfs:label "Virtual Machine Resource Type"@en .
<kos/Resource/type/LoadBalancer> a skos:Concept ; rdfs:label "Load Balancer Resource Type"@en .
<kos/Resource/type/StorageArray> a skos:Concept ; rdfs:label "Storage Array Resource Type"@en .

<kos/Resource/LifecycleState/InProduction> a skos:Concept ; rdfs:label "In Production Lifecycle State"@en .
<kos/Resource/LifecycleState/Staging> a skos:Concept ; rdfs:label "Staging Lifecycle State"@en .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; rdfs:label "Decommissioned Lifecycle State"@en .

<kos/Resource/OperationalState/Up> a skos:Concept ; rdfs:label "Operational State Up"@en .
<kos/Resource/OperationalState/Down> a skos:Concept ; rdfs:label "Operational State Down"@en .
<kos/Resource/OperationalState/Degraded> a skos:Concept ; rdfs:label "Operational State Degraded"@en .

<kos/Resource/AdministrativeState/Up> a skos:Concept ; rdfs:label "Administrative State Up"@en .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; rdfs:label "Administrative State Down"@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; rdfs:label "Critical Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; rdfs:label "Major Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; rdfs:label "Minor Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; rdfs:label "Warning Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Indeterminate> a skos:Concept ; rdfs:label "Indeterminate Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Cleared> a skos:Concept ; rdfs:label "Cleared Perceived Severity"@en .

<kos/org/agent-contact-method/Email> a skos:Concept ; rdfs:label "Email Contact Method"@en .
<kos/org/agent-contact-method/Phone> a skos:Concept ; rdfs:label "Phone Contact Method"@en .
<kos/org/agent-contact-method/TicketingSystem> a skos:Concept ; rdfs:label "Ticketing System Contact Method"@en .

# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent1 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email dns-admin@example.com for routine requests. For critical issues, use the emergency hotline."@en .

foaf:Agent2 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "24/7 team monitoring network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call the NOC hotline for all network-related incidents."@en .

foaf:Agent3 a foaf:Agent ;
    rdfs:label "Application Support Team A"@en ;
    rdfs:comment "Team managing critical business applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Submit a ticket via the ITSM portal for all application issues."@en .

foaf:Agent4 a foaf:Agent ;
    rdfs:label "Database Admin Team"@en ;
    rdfs:comment "Team responsible for database systems."@en ;
    noria:agentWorkingHours "8:30 am - 5:30 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For database performance issues, open a P2 ticket. For outages, call directly."@en .

foaf:Agent5 a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Report all security incidents immediately to the SOC hotline."@en .

foaf:Person1 a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Engineer, DNS Admin Team."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "tel:+1-555-123-4567" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en .

foaf:Person2 a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Network Engineer, NOC."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "tel:+1-555-987-6543" ;
    noria:agentWorkingHours "Shift A (Mon-Thu)"@en .

org:OrgUnit1 a org:OrganizationalUnit ;
    rdfs:label "IT Infrastructure Department"@en ;
    rdfs:comment "Manages all core IT infrastructure."@en ;
    org:hasMember foaf:Person1, foaf:Person2 .

org:OrgUnit2 a org:OrganizationalUnit ;
    rdfs:label "Business Applications Department"@en ;
    rdfs:comment "Manages all business-critical applications."@en ;
    org:hasMember foaf:Agent3, foaf:Agent4 .

# =============================================================================
# Locations
# =============================================================================

bot:Site1 a bot:Site ;
    rdfs:label "Main Data Center Paris"@en ;
    rdfs:comment "Primary data center facility in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@fr ;
    noria:sitePrincipalAddressCityName "Paris"@fr ;
    noria:sitePrincipalAddressPostalCode "75002"@fr ;
    noria:sitePrincipalAddressCountry "FR"@en ;
    wgs84_pos:lat "48.8699"^^xsd:float ;
    wgs84_pos:long "2.3364"^^xsd:float .

bot:Site2 a bot:Site ;
    rdfs:label "Regional Office Lyon"@en ;
    rdfs:comment "Regional office building in Lyon."@en ;
    noria:siteId "RO-LYO-01" ;
    noria:siteType "office building"@en ;
    noria:sitePrincipalAddress "45 Avenue Jean Jaurès"@fr ;
    noria:sitePrincipalAddressCityName "Lyon"@fr ;
    noria:sitePrincipalAddressPostalCode "69007"@fr ;
    noria:sitePrincipalAddressCountry "FR"@en ;
    wgs84_pos:lat "45.7494"^^xsd:float ;
    wgs84_pos:long "4.8432"^^xsd:float .

noria:Room1 a noria:Room ;
    rdfs:label "Server Room A1"@en ;
    rdfs:comment "Main server room in Data Center Paris."@en ;
    bot:hasSpace bot:Site1 .

noria:Room2 a noria:Room ;
    rdfs:label "Network Equipment Room B2"@en ;
    rdfs:comment "Network core equipment room in Data Center Paris."@en ;
    bot:hasSpace bot:Site1 .

noria:Locus1 a noria:Locus ;
    rdfs:label "Rack R01, Unit 10"@en ;
    rdfs:comment "Location for DNS Server 01."@en ;
    noria:locusLine "R01"@en ;
    noria:locusRow "10"@en ;
    bot:hasSpace noria:Room1 .

noria:Locus2 a noria:Locus ;
    rdfs:label "Rack R02, Unit 5"@en ;
    rdfs:comment "Location for Web Server 01."@en ;
    noria:locusLine "R02"@en ;
    noria:locusRow "5"@en ;
    bot:hasSpace noria:Room1 .

noria:Locus3 a noria:Locus ;
    rdfs:label "Rack N01, Unit 20"@en ;
    rdfs:comment "Location for Core Router 01."@en ;
    noria:locusLine "N01"@en ;
    noria:locusRow "20"@en ;
    bot:hasSpace noria:Room2 .

noria:Locus4 a noria:Locus ;
    rdfs:label "Rack N02, Unit 15"@en ;
    rdfs:comment "Location for Edge Firewall 01."@en ;
    noria:locusLine "N02"@en ;
    noria:locusRow "15"@en ;
    bot:hasSpace noria:Room2 .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel1 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for DNS and web hosting."@en ;
    noria:productManufacturedBy <https://www.dell.com/en-us> . # Assuming Dell is an org:Organization

noria:ProductModel2 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Cisco network switch model."@en ;
    noria:productManufacturedBy <https://www.cisco.com> . # Assuming Cisco is an org:Organization

noria:ProductModel3 a noria:ProductModel ;
    rdfs:label "Juniper MX204"@en ;
    rdfs:comment "Juniper high-performance router model."@en ;
    noria:productManufacturedBy <https://www.juniper.net> . # Assuming Juniper is an org:Organization

noria:ProductModel4 a noria:ProductModel ;
    rdfs:label "VMware ESXi Host"@en ;
    rdfs:comment "Virtualization host software."@en ;
    noria:productManufacturedBy <https://www.vmware.com> . # Assuming VMware is an org:Organization

# =============================================================================
# Resources
# =============================================================================

noria:Resource1 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted in Paris DC."@en ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel1 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-R740-DNS01" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.10> . # Example URI for IP address

noria:Resource2 a noria:Resource ;
    rdfs:label "Web Application Server 01"@en ;
    rdfs:comment "Server hosting the main corporate web application."@en ;
    noria:resourceManagedBy foaf:Agent3 ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel1 ;
    noria:resourceLogisticId "ASSET-WEB-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-R740-WEB01" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-04-01T11:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.11> .

noria:Resource3 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceManagedBy foaf:Agent2 ;
    noria:resourceHostName "cr01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel3 ;
    noria:resourceLogisticId "ASSET-CR-001" ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-MX204-CR01" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus3 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.254> .

noria:Resource4 a noria:Resource ;
    rdfs:label "Edge Firewall 01"@en ;
    rdfs:comment "Perimeter firewall protecting the corporate network."@en ;
    noria:resourceManagedBy foaf:Agent5 ;
    noria:resourceHostName "fw01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel2 ; # Using a switch model for example, could be a dedicated firewall model
    noria:resourceLogisticId "ASSET-FW-001" ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-CAT9300-FW01" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-01T14:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus4 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.253> .

noria:Resource5 a noria:Resource ;
    rdfs:label "Virtual Machine Host 01"@en ;
    rdfs:comment "Physical server hosting multiple virtual machines."@en ;
    noria:resourceManagedBy foaf:Agent3 ;
    noria:resourceHostName "vmhost01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel4 ;
    noria:resourceLogisticId "ASSET-VMH-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-ESXI-VMH01" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-10T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.12> .

noria:Resource6 a noria:Resource ;
    rdfs:label "Database Server VM 01"@en ;
    rdfs:comment "Virtual machine hosting the main corporate database."@en ;
    noria:resourceManagedBy foaf:Agent4 ;
    noria:resourceHostName "dbvm01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
