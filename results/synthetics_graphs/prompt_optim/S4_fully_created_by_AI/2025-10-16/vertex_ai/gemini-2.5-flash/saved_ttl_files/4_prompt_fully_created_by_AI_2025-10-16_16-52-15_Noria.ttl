    noria:documentHRef <http://itsm.example.com/ticket/REQ-20240420-002> ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean .

noria:TroubleTicket3 a noria:TroubleTicket ;
    rdfs:label "DNS Server High CPU"@en ;
    rdfs:comment "Proactive alert for high CPU on primary DNS server."@en ;
