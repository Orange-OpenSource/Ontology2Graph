noria:EventRecord1 a noria:EventRecord ;
    rdfs:label "DNS Server CPU High Alert"@en ;
    rdfs:comment "CPU utilization on dns01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logText "CPU_HIGH: dns01.corp.example.com CPU usage 95% for 5 minutes."@en .

noria:EventRecord2 a noria:EventRecord ;
    rdfs:label "Network Interface Down Alert"@en ;
    rdfs:comment "Interface ge-0/0/0 on cr01.corp.example.com went down."@en ;
    noria:loggingTime "2024-04-20T10:15:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource3 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "INTERFACE_DOWN: ge-0/0/0 on cr01.corp.example.com is down."@en ;
    noria:alarmProposedRepairAction <http://example.com/op/check_fiber_link> . # Example OperationPlan URI

noria:EventRecord3 a noria:EventRecord ;
    rdfs:label "Web Server HTTP 500 Error Spike"@en ;
    rdfs:comment "Detected a sudden increase in HTTP 500 errors on web01.corp.example.com."@en ;
    noria:loggingTime "2024-04-20T10:20:10Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logText "HTTP_ERROR_SPIKE: web01.corp.example.com reporting 500 errors."@en .

noria:EventRecord4 a noria:EventRecord ;
    rdfs:label "Database Connection Pool Exhaustion"@en ;
    rdfs:comment "Application logs show database connection pool exhaustion on dbvm01."@en ;
    noria:loggingTime "2024-04-20T10:25:45Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource6 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "DB_CONN_EXHAUSTION: Connection pool exhausted on dbvm01.corp.example.com."@en .

noria:EventRecord5 a noria:EventRecord ;
    rdfs:label "Firewall Policy Violation Alert"@en ;
    rdfs:comment "Attempted unauthorized access detected by firewall fw01."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource4 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "SECURITY_ALERT: Unauthorized access attempt from 192.168.1.100 blocked by fw01."@en ;
    noria:logOriginatingAgent foaf:Agent5 . # SOC team might be the "agent" if they configured the alert

noria:EventRecord6 a noria:EventRecord ;
    rdfs:label "Configuration Change Log - Core Router 01"@en ;
    rdfs:comment "Configuration change applied to Core Router 01 by Bob Johnson."@en ;
    noria:loggingTime "2024-04-19T14:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource3 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:logOriginatingAgent foaf:Person2 ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by Bob Johnson (10.0.0.50)."@en .

