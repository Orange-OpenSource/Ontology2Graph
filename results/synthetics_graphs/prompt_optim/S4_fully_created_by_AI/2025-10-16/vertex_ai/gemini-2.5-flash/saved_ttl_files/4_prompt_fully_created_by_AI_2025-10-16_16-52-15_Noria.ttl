# =============================================================================
# Operation Plans and Conditions
# =============================================================================

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "Core Router Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for troubleshooting a down network interface on a core router."@en ;
    skos:example "Steps include checking physical cabling, interface status, optical power levels, and bouncing the interface."@en .

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "Interface is Down"@en ;
    rdfs:comment "The network interface reports an operational status of 'down'."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "Interface is Up and Stable"@en ;
    rdfs:comment "The network interface reports an operational status of 'up' and traffic flows normally."@en .

noria:OperationPlan1 noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Database Connection Pool Reset Procedure"@en ;
    rdfs:comment "Procedure to reset the database connection pool for the Corporate Database Service."@en ;
    skos:example "Involves restarting the application server or executing a specific database command."@en .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Connection Pool Exhausted"@en ;
    rdfs:comment "Application logs indicate database connection pool exhaustion."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Database Connections Restored"@en ;
    rdfs:comment "Application can establish new database connections, and error rates return to normal."@en .

noria:OperationPlan2 noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

# Example of an EventRecord being mitigated by a procedure execution
<http://example.com/pep/exec/bounce_interface_cr01> a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of Interface Bounce on CR01"@en ;
    dcterms:created "2024-04-20T10:40:00Z"^^xsd:dateTime ;
    pep:usedProcedure noria:OperationPlan1 ;
    # This container would typically contain multiple EventRecords (ldp:member)
    # For simplicity, we link it to the note that describes the action.
    rdfs:comment "Attempted to bounce ge-0/0/0 on cr01.corp.example.com."@en .

noria:EventRecord2 noria:alarmMitigatedBy <http://example.com/pep/exec/bounce_interface_cr01> .

# Example of an AnomalyPattern
noria:AnomalyPattern1 a noria:AnomalyPattern ;
    rdfs:label "Network Link Flapping"@en ;
    rdfs:comment "A pattern indicating frequent up/down transitions on a network interface, suggesting an unstable physical link or faulty transceiver."@en ;
    skos:example "Repeated EventRecord instances with 'INTERFACE_DOWN' and 'INTERFACE_UP' for the same interface within a short period."@en .

noria:AnomalyPattern2 a noria:AnomalyPattern ;
    rdfs:label "Database Deadlock Storm"@en ;
    rdfs:comment "A pattern characterized by a rapid increase in database deadlock events, often leading to application unresponsiveness."@en ;
    skos:example "Multiple EventRecord instances reporting 'DB_DEADLOCK' errors from the database server within seconds."@en .

# Connecting an OperationPlan to an AnomalyPattern (as a control method)
noria:OperationPlan2 folio:detects noria:AnomalyPattern2 . # Assuming folio:detects is a relevant property for this context.

# Connecting a TroubleTicket to an AnomalyPattern (as a problem category)
noria:TroubleTicket2 noria:problemCategory <kos/TroubleTicket/category/PerformanceDegradation> . # More specific link could be added if a property exists.
# For example, if there was a property like noria:troubleTicketAssociatedAnomalyPattern
# noria:TroubleTicket2 noria:troubleTicketAssociatedAnomalyPattern noria:AnomalyPattern2 .

# Adding more relations to ensure density
foaf:Agent1 noria:agentManagesResource noria:Resource1 .
foaf:Agent2 noria:agentManagesResource noria:Resource3, noria:Resource4 .
foaf:Agent3 noria:agentManagesResource noria:Resource2, noria:Resource5 .
foaf:Agent4 noria:agentManagesResource noria:Resource6 .

noria:Resource1 noria:resourceForApplication noria:Application3 .
noria:Resource2 noria:resourceForApplication noria:Application2 .
noria:Resource3 noria:resourceForApplication noria:Application1 .
noria:Resource4 noria:resourceForApplication noria:Application1 .
noria:Resource5 noria:resourceForApplication noria:Application2, noria:Application4 . # Hosts VMs for both
noria:Resource6 noria:resourceForApplication noria:Application4 .

# Adding more properties to existing entities
noria:Resource1 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .
noria:Resource2 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .
noria:Resource6 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface2 noria:networkInterfaceLaserRxHighPowerWarningThreshold "0"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-20"^^xsd:int .

noria:TroubleTicket1 noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketCause "Physical fiber cut detected on ISP uplink."@en .

noria:TroubleTicket2 noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ApplicationHosting> ;
    noria:troubleTicketCause "Application misconfiguration leading to excessive database connections."@en .

noria:TroubleTicket3 noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ; # DNS is part of infra
    noria:troubleTicketCause "Unidentified process consuming high CPU on DNS server."@en .

noria:ChangeRequest1 noria:changeRequestSpecification <http://example.com/kos/change/spec/router_os_upgrade> . # Example KOS concept
noria:ChangeRequest2 noria:changeRequestSpecification <http://example.com/kos/change/spec/db_schema_update> .

# Adding more EventRecords to show status history
noria:EventRecord7 a noria:EventRecord ;
    rdfs:label "TT1 Status Change: InProgress"@en ;
    noria:loggingTime "2024-04-20T10:18:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <http://itsm.example.com/system/ITSM> ;
    noria:logText "Trouble Ticket INC-20240420-001 status changed to InProgress."@en .

noria:EventRecord8 a noria:EventRecord ;
    rdfs:label "TT1 Status Change: Resolved"@en ;
    noria:loggingTime "2024-04-20T12:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <http://itsm.example.com/system/ITSM> ;
    noria:logText "Trouble Ticket INC-20240420-001 status changed to Resolved."@en .

noria:TroubleTicket1 noria:documentStatusHistory noria:EventRecord7, noria:EventRecord8 .

noria:EventRecord9 a noria:EventRecord ;
    rdfs:label "CR1 Status Change: Approved"@en ;
    noria:loggingTime "2024-04-18T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <http://itsm.example.com/system/ITSM> ;
    noria:logText "Change Request CR-20240415-001 status changed to Approved."@en .

noria:ChangeRequest1 noria:documentStatusHistory noria:EventRecord9 .

# Adding a freeze item to a TroubleTicket
noria:EventRecord10 a noria:EventRecord ;
    rdfs:label "TT2 Freeze Start: Waiting for Vendor"@en ;
    noria:loggingTime "2024-04-20T13:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <http://itsm.example.com/system/ITSM> ;
    noria:logText "Trouble Ticket REQ-20240420-002 frozen, waiting for database vendor support."@en .

noria:TroubleTicket2 noria:troubleTicketFreezeItem noria:EventRecord10 .

# Adding a Corporate User Identifier
noria:CUid1 a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Alice Smith."@en ;
    foaf:accountName "asmith" ;
    observable:accountLogin "asmith" ;
    observable:accountIdentifier "U12345" .
foaf:Person1 foaf:holdsAccount noria:CUid1 .

noria:CUid2 a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson" ;
    observable:accountLogin "bjohnson" ;
    observable:accountIdentifier "U67890" .
foaf:Person2 foaf:holdsAccount noria:CUid2 .

# Adding a DocumentAttachment
noria:DocumentAttachment1 a noria:DocumentAttachment ;
    rdfs:label "Network Diagram for CR1"@en ;
    rdfs:comment "Attachment: Network diagram showing the impact of CR-20240415-001."@en ;
    dcterms:isPartOf noria:ChangeRequest1 ;
    dcterms:format "application/pdf" ;
    dcterms:identifier "net_diagram_cr1.pdf" .

noria:DocumentAttachment2 a noria:DocumentAttachment ;
    rdfs:label "Screenshot of Web Portal Error"@en ;
    rdfs:comment "Screenshot provided by customer for TT2."@en ;
    dcterms:isPartOf noria:TroubleTicket2 ;
    dcterms:format "image/png" ;
    dcterms:identifier "web_portal_error.png" .

# Adding more relationships to ensure density and cover more properties
noria:ApplicationModule1 noria:applicationModuleSupportGroup org:OrgUnit1 ; # L1 support
    noria:applicationModuleHotlineGroup foaf:Agent2 . # NOC acts as hotline

noria:ApplicationModule2 noria:applicationModuleSupportGroup org:OrgUnit2 ;
    noria:applicationModuleHotlineGroup foaf:Agent3 .

noria:ApplicationModule4 noria:applicationModuleSupportGroup org:OrgUnit2 ;
    noria:applicationModuleHotlineGroup foaf:Agent4 .

# Example of a more complex relationship for troubleTicketImpacts
noria:TroubleTicket2 noria:troubleTicketImpacts noria:ApplicationModule2, noria:ApplicationModule4, noria:Resource2, noria:Resource6 .

# Example of a more complex relationship for changeRequestImpact
noria:ChangeRequest2 noria:changeRequestImpact noria:ApplicationModule2, noria:ApplicationModule4, noria:Service2, noria:Resource6 .

# Example of a specific property for a trouble ticket characteristic
# Assuming a KOS for characteristics exists or defining a literal for now
noria:TroubleTicket1 noria:troubleTicketCharacteristic "Requires on-site intervention"@en .
noria:TroubleTicket2 noria:troubleTicketCharacteristic "Impacts critical business function"@en .

# Example of problemCategory and problemResponsibility
noria:TroubleTicket1 noria:problemCategory <kos/TroubleTicket/category/HardwareFailure> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> .

noria:TroubleTicket2 noria:problemCategory <kos/TroubleTicket/category/SoftwareBug> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ApplicationHosting> .

noria:TroubleTicket3 noria:problemCategory <kos/TroubleTicket/category/PerformanceDegradation> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> .

# Final check for connectivity:
# All Resources are managed by Agents, have product models, types, serials, usage states, installation dates, and locations.
# NetworkInterfaces are part of Resources and connect to NetworkLinks.
# NetworkLinks connect Resources and are managed by Agents.
# Applications are managed by Agents and use Resources.
# ApplicationModules are part of Applications and have detailed management info.
# Services are composed of ApplicationModules/Applications and managed by Agents.
# EventRecords originate from Resources/Applications/Agents and have severity, text, time.
# TroubleTickets are triggered by EventRecords, relate to Services/Applications/Resources/Agents, and have detailed status, severity, type, origin, etc.
# TroubleTicketNotes are part of TroubleTickets and have authors, types, operations.
# ChangeRequests impact Services/Applications/Resources, are initiated/piloted/acted by Agents, and have planned times, categories, causes, status.
# OperationPlans have pre/post conditions.
# AnomalyPatterns are defined.
# Locations (Site, Room, Locus) are defined and linked to Resources.
# All entities have labels and comments.
# All KOS concepts are used as URIs.

# This graph is dense and connected, covering a wide range of NORIA vocabulary.
