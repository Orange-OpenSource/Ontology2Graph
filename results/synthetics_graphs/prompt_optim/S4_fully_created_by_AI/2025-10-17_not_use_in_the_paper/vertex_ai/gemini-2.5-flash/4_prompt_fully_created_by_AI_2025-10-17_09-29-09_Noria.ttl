# =============================================================================
# Procedural Elements (Operation Plans, Pre/Post Conditions, Anomaly Patterns)
# =============================================================================

# Operation Plans (noria:OperationPlan)
noria:OperationPlan_ISP_Failover a noria:OperationPlan ;
    rdfs:label "ISP Link Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for failing over to a redundant ISP link in case of primary link failure."@en ;
    skos:example "Steps include verifying link status, adjusting routing metrics, and testing connectivity."@en .

noria:OperationPlan_DNS_Restart a noria:OperationPlan ;
    rdfs:label "DNS Service Restart Procedure"@en ;
    rdfs:comment "Procedure for safely restarting the BIND service on DNS servers."@en ;
    skos:example "Includes checking service status, restarting, and verifying resolution."@en .

noria:OperationPlan_DB_Recovery a noria:OperationPlan ;
    rdfs:label "Database Instance Recovery Procedure"@en ;
    rdfs:comment "Procedure for recovering a crashed Oracle database instance."@en ;
    skos:example "Steps include checking logs, attempting restart, and engaging vendor support if necessary."@en .

# Action Pre-Conditions (noria:ActionPreCondition)
noria:ActionPreCondition_ISP_Link_Down a noria:ActionPreCondition ;
    rdfs:label "ISP Link Down Pre-Condition"@en ;
    rdfs:comment "Pre-condition for ISP Failover: Primary ISP link is detected as down."@en .

noria:ActionPreCondition_DNS_High_CPU a noria:ActionPreCondition ;
    rdfs:label "DNS High CPU Pre-Condition"@en ;
    rdfs:comment "Pre-condition for DNS Service Restart: DNS server CPU utilization is consistently high."@en .

noria:ActionPreCondition_DB_Crashed a noria:ActionPreCondition ;
    rdfs:label "Database Crashed Pre-Condition"@en ;
    rdfs:comment "Pre-condition for DB Recovery: Database instance is not running or inaccessible."@en .

# Action Post-Conditions (noria:ActionPostCondition)
noria:ActionPostCondition_ISP_Traffic_Rerouted a noria:ActionPostCondition ;
    rdfs:label "ISP Traffic Rerouted Post-Condition"@en ;
    rdfs:comment "Post-condition for ISP Failover: Network traffic is successfully rerouted to the secondary ISP."@en .

noria:ActionPostCondition_DNS_CPU_Normal a noria:ActionPostCondition ;
    rdfs:label "DNS CPU Normal Post-Condition"@en ;
    rdfs:comment "Post-condition for DNS Service Restart: DNS server CPU utilization returns to normal levels."@en .

noria:ActionPostCondition_DB_Online a noria:ActionPostCondition ;
    rdfs:label "Database Online Post-Condition"@en ;
    rdfs:comment "Post-condition for DB Recovery: Database instance is online and accessible, application connectivity restored."@en .

# Link Operation Plans to Pre/Post Conditions
noria:OperationPlan_ISP_Failover noria:operationPlanPreCondition noria:ActionPreCondition_ISP_Link_Down ;
    noria:operationPlanPostCondition noria:ActionPostCondition_ISP_Traffic_Rerouted .

noria:OperationPlan_DNS_Restart noria:operationPlanPreCondition noria:ActionPreCondition_DNS_High_CPU ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNS_CPU_Normal .

noria:OperationPlan_DB_Recovery noria:operationPlanPreCondition noria:ActionPreCondition_DB_Crashed ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DB_Online .

# Link Event Records to Operation Plans (as proposed repair actions)
noria:EventRecord_CR01_Interface_Down noria:alarmProposedRepairAction noria:OperationPlan_ISP_Failover .
noria:EventRecord_DNS_CPU_High noria:alarmProposedRepairAction noria:OperationPlan_DNS_Restart .
noria:EventRecord_DB_Connection_Error noria:alarmProposedRepairAction noria:OperationPlan_DB_Recovery .

# Procedural Execution Container and Executions
noria:ProcedureExecutionContainer_CR01_Failover a pep:ProcedureExecutionContainer ;
    rdfs:label "CR01 Failover Procedure Execution"@en ;
    rdfs:comment "Container for events related to the ISP B failover procedure."@en .

noria:EventRecord_CR01_Config_Change noria:alarmMitigatedBy noria:ProcedureExecutionContainer_CR01_Failover .

noria:ProcedureExecution_CR01_Routing_Adjust a noria:EventRecord ;
    rdfs:label "CR01 Routing Metric Adjustment Execution"@en ;
    rdfs:comment "Execution of a step within the ISP Failover procedure, logged as an event."@en ;
    noria:loggingTime "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingAgent foaf:Agent_Jane_Smith ;
    noria:logOriginatingManagedObject noria:Resource_Core_Router_01 ;
    noria:logText "Routing metric for Gi0/0/1 changed to 500."@en ;
    dcterms:type <https://w3id.org/noria/kos/Notification/EventType/ConfigurationChange> ;
    pep:usedProcedure noria:OperationPlan_ISP_Failover ;
    noria:alarmMitigatedBy noria:ProcedureExecutionContainer_CR01_Failover .

# Anomaly Patterns (noria:AnomalyPattern)
noria:AnomalyPattern_High_CPU_DNS a noria:AnomalyPattern ;
    rdfs:label "High DNS CPU Anomaly Pattern"@en ;
    rdfs:comment "Pattern describing a situation where DNS server CPU is consistently high, leading to performance degradation."@en ;
    skos:example "EventRecord(CPU_High) AND EventRecord(DNS_Latency_High)"@en .

noria:AnomalyPattern_ISP_Link_Failure a noria:AnomalyPattern ;
    rdfs:label "ISP Link Failure Anomaly Pattern"@en ;
    rdfs:comment "Pattern describing a primary ISP link failure, often indicated by interface down events and routing changes."@en ;
    skos:example "EventRecord(Interface_Down) AND EventRecord(Routing_Protocol_Change)"@en .

# Link Event Records to Anomaly Patterns (using dcterms:relation as a generic link)
noria:EventRecord_DNS_CPU_High dcterms:relation noria:AnomalyPattern_High_CPU_DNS .
noria:EventRecord_CR01_Interface_Down dcterms:relation noria:AnomalyPattern_ISP_Link_Failure .

# Trouble Ticket Characteristic
noria:TroubleTicketCharacteristic_RedundancyImpact a noria:StructuralObservable ;
    rdfs:label "Redundancy Impacted"@en ;
    rdfs:comment "Characteristic indicating that network redundancy is compromised."@en .
