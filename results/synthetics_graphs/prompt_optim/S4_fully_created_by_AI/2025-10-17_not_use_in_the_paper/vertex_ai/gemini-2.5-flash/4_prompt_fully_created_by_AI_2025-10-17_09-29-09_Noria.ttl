# =============================================================================
# Location related Entities
# =============================================================================

bot:Site_Paris_DC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@fr ;
    noria:sitePrincipalAddressCityName "Paris"@fr ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressStreet "Rue de la Paix" .

noria:Room_ServerRoom_A a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace bot:Site_Paris_DC .

noria:Room_NetworkRoom_B a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Secondary network room within the Paris Data Center."@en ;
    bot:hasSpace bot:Site_Paris_DC .

noria:Locus_Rack_A1_U23 a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific location for a server in Server Room A."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "23" ;
    bot:hasSpace noria:Room_ServerRoom_A .

noria:Locus_Rack_B5_U10 a noria:Locus ;
    rdfs:label "Rack B5, Unit 10"@en ;
    rdfs:comment "Specific location for a network device in Server Room A."@en ;
    noria:locusLine "B5" ;
    noria:locusRow "10" ;
    bot:hasSpace noria:Room_ServerRoom_A .

noria:Locus_Rack_C10_U5 a noria:Locus ;
    rdfs:label "Rack C10, Unit 5"@en ;
    rdfs:comment "Location for a firewall in Network Room B."@en ;
    noria:locusLine "C10" ;
    noria:locusRow "5" ;
    bot:hasSpace noria:Room_NetworkRoom_B .

# =============================================================================
# Structural Elements (Resources, Network Interfaces, Network Links)
# =============================================================================

# Resources (noria:Resource)
noria:Resource_DNS_Server_01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted on physical hardware."@en ;
    noria:resourceManagedBy foaf:Agent_Network_Admin_Team ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_Dell_R740 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/PhysicalServer> ;
    noria:resourceSerialNumber "SN-DNS-01-XYZ" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_A1_U23 ;
    noria:resourceManagementIPAddress observable:IPAddress_DNS01_Mgmt .

observable:IPAddress_DNS01_Mgmt a observable:IPAddress ;
    rdfs:label "DNS01 Management IP"@en ;
    observable:ipAddressValue "192.168.10.10" .

noria:Resource_Core_Router_01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the data center network."@en ;
    noria:resourceManagedBy foaf:Agent_Network_Admin_Team ;
    noria:resourceHostName "cr01.dc-par.example.com" ;
    noria:resourceProductModel noria:ProductModel_Cisco_ASR1K ;
    noria:resourceLogisticId "ASSET-CR-001" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/NetworkRouter> ;
    noria:resourceSerialNumber "SN-CR-01-ABC" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-08-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_B5_U10 ;
    noria:resourceManagementIPAddress observable:IPAddress_CR01_Mgmt .

observable:IPAddress_CR01_Mgmt a observable:IPAddress ;
    rdfs:label "CR01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.1" .

noria:Resource_Virtual_Host_01 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:comment "Physical server running VMware ESXi, hosting multiple virtual machines."@en ;
    noria:resourceManagedBy foaf:Agent_IT_Ops_Team ;
    noria:resourceHostName "vhost01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_Dell_R740 ;
    noria:resourceLogisticId "ASSET-VHOST-001" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Hypervisor> ;
    noria:resourceSerialNumber "SN-VHOST-01-PQR" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_A1_U23 ;
    noria:resourceManagementIPAddress observable:IPAddress_VHOST01_Mgmt .

observable:IPAddress_VHOST01_Mgmt a observable:IPAddress ;
    rdfs:label "VHOST01 Management IP"@en ;
    observable:ipAddressValue "192.168.10.20" .

noria:Resource_VM_App_A_Prod a noria:Resource ;
    rdfs:label "VM for Application A Production"@en ;
    rdfs:comment "Virtual machine hosting production instance of Application A."@en ;
    noria:resourceManagedBy foaf:Agent_DevOps_Team_A ;
    noria:resourceHostName "app-a-prod-vm01.corp.example.com" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-10T11:00:00Z"^^xsd:dateTime ;
    noria:clusterController noria:Resource_Virtual_Host_01 ;
    noria:resourceManagementIPAddress observable:IPAddress_AppA_VM_Mgmt ;
    noria:virtualServerStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

observable:IPAddress_AppA_VM_Mgmt a observable:IPAddress ;
    rdfs:label "App A VM Management IP"@en ;
    observable:ipAddressValue "172.16.1.10" .

noria:Resource_DB_Server_01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Server hosting the production database for Web Portal A."@en ;
    noria:resourceManagedBy foaf:Agent_DevOps_Team_A ;
    noria:resourceHostName "db01.app-a.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_Dell_R740 ;
    noria:resourceLogisticId "ASSET-DB-001" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/PhysicalServer> ;
    noria:resourceSerialNumber "SN-DB-01-UVW" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-02-01T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress observable:IPAddress_DB01_Mgmt .

observable:IPAddress_DB01_Mgmt a observable:IPAddress ;
    rdfs:label "DB01 Management IP"@en ;
    observable:ipAddressValue "172.16.1.20" .

noria:Resource_Firewall_DMZ_01 a noria:Resource ;
    rdfs:label "DMZ Firewall 01"@en ;
    rdfs:comment "Perimeter firewall protecting the DMZ network segment."@en ;
    noria:resourceManagedBy foaf:Agent_Security_Team ;
    noria:resourceHostName "fw-dmz01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_Juniper_EX4600 ;
    noria:resourceLogisticId "ASSET-FW-001" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/NetworkFirewall> ;
    noria:resourceSerialNumber "SN-FW-01-JKL" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-11-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_C10_U5 ;
    noria:resourceManagementIPAddress observable:IPAddress_FW01_Mgmt .

observable:IPAddress_FW01_Mgmt a observable:IPAddress ;
    rdfs:label "FW01 Management IP"@en ;
    observable:ipAddressValue "10.0.1.1" .

# Network Interfaces (noria:NetworkInterface)
noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DNS_Server_01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to corporate LAN."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -4 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -8 .

noria:NetworkInterface_CR01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "CR01 GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Uplink interface for Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_Core_Router_01 ;
    noria:networkInterfaceDescription "Uplink to ISP A."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetworkInterface_CR01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "CR01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Uplink interface for Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_Core_Router_01 ;
    noria:networkInterfaceDescription "Uplink to ISP B."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Down> ;
    noria:networkInterfaceRoutingPriorityMetric 200 ;
    noria:networkInterfaceLaserTxOpticalPower -4 ;
    noria:networkInterfaceLaserRxOpticalPower -30 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetworkInterface_VM_App_A_Eth0 a noria:NetworkInterface ;
    rdfs:label "App A VM Ethernet 0"@en ;
    rdfs:comment "Network interface for Application A production VM."@en ;
    noria:networkInterfaceOf noria:Resource_VM_App_A_Prod ;
    noria:networkInterfaceDescription "Virtual interface for application traffic."@en ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

noria:NetworkInterface_DB01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DB01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Database Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DB_Server_01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to application VLAN."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -1 ;
    noria:networkInterfaceLaserRxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -1.5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -5 .

noria:NetworkInterface_FW01_Eth0 a noria:NetworkInterface ;
    rdfs:label "FW01 Ethernet 0 (External)"@en ;
    rdfs:comment "External facing interface for DMZ Firewall 01."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall_DMZ_01 ;
    noria:networkInterfaceDescription "Interface connected to external network."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

noria:NetworkInterface_FW01_Eth1 a noria:NetworkInterface ;
    rdfs:label "FW01 Ethernet 1 (Internal DMZ)"@en ;
    rdfs:comment "Internal DMZ facing interface for DMZ Firewall 01."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall_DMZ_01 ;
    noria:networkInterfaceDescription "Interface connected to internal DMZ segment."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

# Network Links (noria:NetworkLink)
noria:NetworkLink_DC_Uplink_ISP_A a noria:NetworkLink ;
    rdfs:label "Data Center Uplink to ISP A"@en ;
    rdfs:comment "Primary internet uplink from Paris DC to ISP A."@en ;
    noria:resourceManagedBy foaf:Agent_Network_Admin_Team ;
    noria:networkLinkId "NL-DC-ISP-A-01" ;
    noria:networkLinkTerminationResource noria:Resource_Core_Router_01 ;
    noria:networkLinkInstallationDate "2021-07-25T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic" .

noria:NetworkLink_DC_Uplink_ISP_B a noria:NetworkLink ;
    rdfs:label "Data Center Uplink to ISP B"@en ;
