    noria:troubleTicketTrigger noria:EventRecord_DDoSAttack ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "SIEM System"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/NetworkOutage> ;
    noria:troubleTicketCause "External malicious attack."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ; # Assuming DDoS mitigation is part of network responsibility
    noria:troubleTicketDetectionDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_SecurityTeam, foaf:Agent_NetworkAdminTeam ;
    noria:troubleTicketRelatedService noria:Service_CustomerFacingWeb ;
    noria:troubleTicketRelatedResource noria:Resource_LoadBalancer01, noria:Resource_WebServer01 ;
    noria:documentHRef <http://ticketing.example.com/TT20240420-003> .

noria:TroubleTicketNote_TT20240420_003_Note1 a noria:TroubleTicketNote ;
    rdfs:label "DDoS Mitigation Activated"@en ;
    rdfs:comment "Activated cloud-based DDoS mitigation service. Traffic is being scrubbed. Monitoring effectiveness."@en ;
    dcterms:created "2024-04-20T11:15:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_SecurityTeam ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket_TT20240420_003 .

# Example of a CUid
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    observable:accountIdentifier "jdoe@example.com" .

foaf:Agent_JohnDoe foaf:holdsAccount noria:CUid_JohnDoe .

# Example of a DocumentAttachment
noria:DocumentAttachment_NetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Data Center Network Diagram"@en ;
    rdfs:comment "PDF document showing the logical and physical network topology of the main data center."@en ;
    dcterms:created "2024-01-01T09:00:00Z"^^xsd:dateTime ;
    dcterms:format "application/pdf" ;
    dcterms:title "DC-PAR-01_Network_Diagram_v2.3.pdf"@en ;
    dcterms:isPartOf noria:TroubleTicket_TT20240420_001 . # Attached to a TT for context

# Example of an AnomalyPattern
noria:AnomalyPattern_HighCPULowTraffic a noria:AnomalyPattern ;
    rdfs:label "High CPU, Low Traffic Anomaly Pattern"@en ;
    rdfs:comment "Describes a scenario where a server experiences high CPU utilization but low network traffic, often indicating a local process issue or resource contention rather than external load."@en ;
    skos:example "If (CPU_Usage > 80%) AND (Network_In_Rate < 10Mbps) THEN Anomaly: Local Process Issue."@en .

# Link an EventRecord to a proposed repair action (OperationPlan)
noria:EventRecord_WebServerCPUHigh noria:alarmProposedRepairAction noria:OperationPlan_DBIndexing . # Simplified, but shows the link.

# Link an EventRecord to a mitigated action (ProcedureExecutionContainer)
# Let's assume a hypothetical procedure execution for resolving the DDoS attack
<http://example.com/pep/DDoS_Mitigation_Execution_001> a pep:ProcedureExecutionContainer ;
    rdfs:label "DDoS Mitigation Execution 001"@en ;
    dcterms:created "2024-04-20T11:10:00Z"^^xsd:dateTime ;
    ldp:member noria:TroubleTicketNote_TT20240420_003_Note1 . # The note describes the action

noria:EventRecord_DDoSAttack noria:alarmMitigatedBy <http://example.com/pep/DDoS_Mitigation_Execution_001> .

# Final check for connectivity and density:
# - All core entities (Resource, Application, TroubleTicket, EventRecord, Agent, OrgUnit, Location) have multiple properties and links.
# - Resources are linked to ProductModels, Locations, Agents, Applications, NetworkInterfaces.
# - NetworkInterfaces are linked to Resources and NetworkLinks.
# - Applications are linked to ApplicationModules, Services.
# - ApplicationModules are linked to Applications, Agents/OrgUnits, Resources.
# - Services are linked to Applications/ApplicationModules.
# - EventRecords are linked to Resources, Applications, Agents, and can trigger TroubleTickets.
# - TroubleTickets are linked to Services, Applications, Resources, Agents, EventRecords, TroubleTicketNotes.
# - ChangeRequests are linked to Applications, Resources, Services, Agents, OperationPlans.
# - OperationPlans are linked to Pre/Post Conditions and ChangeRequests/TroubleTickets (via actionCorrelatedOperationPlan/alarmProposedRepairAction).
# - Agents and OrgUnits are linked to Resources, Applications, TroubleTickets, ChangeRequests.
# - Locations (Site, Room, Locus) are linked to Resources.
# - KOS concepts are used consistently.
# - Labels and comments are provided for most entities.

# The graph is dense and connected, covering various aspects of IT infrastructure, operations, and incident/change management.
