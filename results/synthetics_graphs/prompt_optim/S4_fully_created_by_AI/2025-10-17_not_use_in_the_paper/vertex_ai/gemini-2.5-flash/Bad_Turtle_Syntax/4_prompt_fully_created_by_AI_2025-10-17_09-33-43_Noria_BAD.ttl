# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan_DBIndexing a noria:OperationPlan ;
    rdfs:label "Database Indexing Procedure"@en ;
    rdfs:comment "Standard operating procedure for adding new indexes to a production database."@en ;
    skos:example "Steps include: backup database, create index in staging, test performance, apply to production, monitor."@en .

noria:ActionPreCondition_DBIndexing a noria:ActionPreCondition ;
    rdfs:label "Database Indexing Pre-Condition"@en ;
    rdfs:comment "Database backup must be completed and verified. Staging environment tests must pass."@en ;
    noria:operationPlanPreCondition noria:OperationPlan_DBIndexing .

noria:ActionPostCondition_DBIndexing a noria:ActionPostCondition ;
    rdfs:label "Database Indexing Post-Condition"@en ;
    rdfs:comment "Database performance metrics must show improvement. No new errors in application logs."@en ;
    noria:operationPlanPostCondition noria:OperationPlan_DBIndexing .

noria:OperationPlan_RouterOSUpgrade a noria:OperationPlan ;
    rdfs:label "Router OS Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router operating systems."@en ;
    skos:example "Steps include: pre-checks, backup configuration, upload new image, reload, post-checks."@en .

noria:ActionPreCondition_RouterOSUpgrade a noria:ActionPreCondition ;
    rdfs:label "Router OS Upgrade Pre-Condition"@en ;
    rdfs:comment "Router configuration backup must be verified. Network redundancy must be active."@en ;
    noria:operationPlanPreCondition noria:OperationPlan_RouterOSUpgrade .

noria:ActionPostCondition_RouterOSUpgrade a noria:ActionPostCondition ;
    rdfs:label "Router OS Upgrade Post-Condition"@en ;
    rdfs:comment "All network interfaces operational. Routing protocols converged. No packet loss."@en ;
    noria:operationPlanPostCondition noria:OperationPlan_RouterOSUpgrade .

# Link Change Request to Operation Plan
noria:ChangeRequest_CR20240425_001 noria:actionCorrelatedOperationPlan noria:OperationPlan_DBIndexing .
noria:ChangeRequest_CR20240426_002 noria:actionCorrelatedOperationPlan noria:OperationPlan_RouterOSUpgrade .

