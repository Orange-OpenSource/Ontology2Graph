# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns/> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS Concepts (Knowledge Organization System) - Implicitly defined by usage
# =============================================================================

# Application KOS
<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure Application"@en .
<kos/application/type/business-critical> a skos:Concept ; rdfs:label "Business Critical Application"@en .
<kos/application/type/monitoring> a skos:Concept ; rdfs:label "Monitoring System"@en .
<kos/application/type/database> a skos:Concept ; rdfs:label "Database System"@en .
<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High Business Importance"@en .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium Business Importance"@en .
<kos/application/business-importance/low> a skos:Concept ; rdfs:label "Low Business Importance"@en .
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production"@en .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; rdfs:label "Development"@en .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ; rdfs:label "Maintenance"@en .
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; rdfs:label "Gold SLA Level"@en .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ; rdfs:label "Silver SLA Level"@en .

# Service KOS
<kos/service/type/CustomerFacingService> a skos:Concept ; rdfs:label "Customer Facing Service"@en .
<kos/service/type/ResourceFacingService> a skos:Concept ; rdfs:label "Resource Facing Service"@en .

# TroubleTicket KOS
<kos/TroubleTicket/severity/Critical> a skos:Concept ; rdfs:label "Critical Severity"@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; rdfs:label "Major Severity"@en .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; rdfs:label "Minor Severity"@en .
<kos/TroubleTicket/type/Failure> a skos:Concept ; rdfs:label "Failure Ticket Type"@en .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; rdfs:label "Assistance Ticket Type"@en .
<kos/TroubleTicket/category/InterruptedService> a skos:Concept ; rdfs:label "Interrupted Service Category"@en .
<kos/TroubleTicket/category/TotalBreakdown> a skos:Concept ; rdfs:label "Total Breakdown Category"@en .
<kos/TroubleTicket/priority/P1> a skos:Concept ; rdfs:label "Priority 1"@en .
<kos/TroubleTicket/priority/P2> a skos:Concept ; rdfs:label "Priority 2"@en .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; rdfs:label "Customer Origin"@en .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; rdfs:label "Supervision Origin"@en .
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; rdfs:label "Immediate Intervention Urgency"@en .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; rdfs:label "Deferred Intervention Urgency"@en .
<kos/TroubleTicket/trouble-category/NetworkOutage> a skos:Concept ; rdfs:label "Network Outage Trouble Category"@en .
<kos/TroubleTicket/trouble-category/ServerFailure> a skos:Concept ; rdfs:label "Server Failure Trouble Category"@en .
<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ; rdfs:label "Managed Backbone Networks Responsibility"@en .
<kos/TroubleTicket/problemResponsibility/Customer> a skos:Concept ; rdfs:label "Customer Responsibility"@en .
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal Comment Type"@en .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; rdfs:label "Customer Comment Type"@en .
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis Operation Type"@en .
<kos/TroubleTicket/operationType/TestsAndMeasurements> a skos:Concept ; rdfs:label "Tests and Measurements Operation Type"@en .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; rdfs:label "In Progress Status"@en .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved Status"@en .
<kos/TroubleTicket/status/Closed> a skos:Concept ; rdfs:label "Closed Status"@en .

# ChangeRequest KOS
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; rdfs:label "Internal Intervention Category"@en .
<kos/ChangeRequest/category/CustomerIntervention> a skos:Concept ; rdfs:label "Customer Intervention Category"@en .
<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard Change Type"@en .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; rdfs:label "Emergency Change Type"@en .
<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ; rdfs:label "Software Upgrade Cause"@en .
<kos/ChangeRequest/cause/Configuration> a skos:Concept ; rdfs:label "Configuration Change Cause"@en .
<kos/ChangeRequest/status/Approved> a skos:Concept ; rdfs:label "Approved Status"@en .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; rdfs:label "Implemented Status"@en .
<kos/ChangeRequest/specification/NetworkMaintenance> a skos:Concept ; rdfs:label "Network Maintenance Specification"@en .

# Notification KOS
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; rdfs:label "Critical Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; rdfs:label "Major Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; rdfs:label "Minor Perceived Severity"@en .
<kos/Notification/EventType/stateChange> a skos:Concept ; rdfs:label "State Change Event Type"@en .
<kos/Notification/EventType/thresholdCrossing> a skos:Concept ; rdfs:label "Threshold Crossing Event Type"@en .
<kos/Notification/EventType/securityAlert> a skos:Concept ; rdfs:label "Security Alert Event Type"@en .

# Resource KOS
<kos/Resource/type/Server> a skos:Concept ; rdfs:label "Server Resource Type"@en .
<kos/Resource/type/Router> a skos:Concept ; rdfs:label "Router Resource Type"@en .
<kos/Resource/type/Switch> a skos:Concept ; rdfs:label "Switch Resource Type"@en .
<kos/Resource/type/VirtualMachine> a skos:Concept ; rdfs:label "Virtual Machine Resource Type"@en .
<kos/Resource/LifecycleState/InProduction> a skos:Concept ; rdfs:label "In Production Lifecycle State"@en .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; rdfs:label "Decommissioned Lifecycle State"@en .
<kos/Resource/OperationalState/Up> a skos:Concept ; rdfs:label "Up Operational State"@en .
<kos/Resource/OperationalState/Down> a skos:Concept ; rdfs:label "Down Operational State"@en .
<kos/Resource/AdministrativeState/Up> a skos:Concept ; rdfs:label "Up Administrative State"@en .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; rdfs:label "Down Administrative State"@en .

# Agent Contact Method KOS
<kos/org/agent-contact-method/Email> a skos:Concept ; rdfs:label "Email Contact Method"@en .
<kos/org/agent-contact-method/Phone> a skos:Concept ; rdfs:label "Phone Contact Method"@en .
<kos/org/agent-contact-method/TicketingSystem> a skos:Concept ; rdfs:label "Ticketing System Contact Method"@en .

# =============================================================================
# Agents and Organizational Units
# =============================================================================

foaf:Agent_ITOpsTeam a foaf:Agent ;
    rdfs:label "IT Operations Team"@en, "Équipe Opérations IT"@fr ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations and incident response."@en ;
    noria:agentWorkingHours "24/7 (Mon-Sun)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem>, <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical incidents, open a P1 ticket and call the hotline. For non-critical issues, use the ticketing system."@en .

foaf:Agent_NetworkAdminTeam a foaf:Agent ;
    rdfs:label "Network Administration Team"@en, "Équipe Administration Réseau"@fr ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for routine requests, ticketing system for incidents."@en .

foaf:Agent_AppSupportTeam a foaf:Agent ;
    rdfs:label "Application Support Team"@en, "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "All application-related issues must be reported via the dedicated application ticketing system."@en .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en, "Centre Opérations Sécurité (SOC)"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 (Mon-Sun)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem>, <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Report all security incidents immediately via the dedicated security incident platform."@en .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Individual IT Administrator, member of the ITOps Team."@en .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Individual Network Engineer, member of the Network Admin Team."@en .

org:OrgUnit_ITDepartment a org:OrganizationalUnit ;
    rdfs:label "IT Department"@en, "Département IT"@fr ;
    rdfs:comment "Main IT department of the company."@en ;
    org:hasMember foaf:Agent_JohnDoe, foaf:Agent_JaneSmith ;
    org:unitOf org:Org_CompanyX .

org:OrgUnit_NetworkOperations a org:OrganizationalUnit ;
    rdfs:label "Network Operations Unit"@en, "Unité Opérations Réseau"@fr ;
    rdfs:comment "Sub-unit within IT Department focusing on network operations."@en ;
    org:memberOf org:OrgUnit_ITDepartment ;
    org:hasMember foaf:Agent_NetworkAdminTeam .

org:Org_CompanyX a org:Organization ;
    rdfs:label "Company X Inc."@en, "Société X S.A."@fr ;
    rdfs:comment "The main organization."@en .

# =============================================================================
# Location Entities
# =============================================================================

bot:Site_MainDataCenter a bot:Site ;
    rdfs:label "Main Data Center"@en, "Centre de Données Principal"@fr ;
    rdfs:comment "Primary data center facility for critical infrastructure."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Main Street"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" .

bot:Site_BranchOffice a bot:Site ;
    rdfs:label "Branch Office Lyon"@en, "Bureau de Lyon"@fr ;
    rdfs:comment "Regional office with local IT infrastructure."@en ;
    noria:siteId "BO-LYO-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Lyon"@en ;
    noria:sitePrincipalAddressPostalCode "69002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within the Main Data Center."@en ;
    bot:hasSpace bot:Site_MainDataCenter .

noria:Room_NetworkCloset1 a noria:Room ;
    rdfs:label "Network Closet 1"@en, "Local Réseau 1"@fr ;
    rdfs:comment "Network equipment closet in Branch Office Lyon."@en ;
    bot:hasSpace bot:Site_BranchOffice .

noria:Locus_RackA1_U42 a noria:Locus ;
    rdfs:label "Rack A1, Unit 42"@en ;
    rdfs:comment "Specific location for a server in Server Room A."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "42" ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackB2_U1 a noria:Locus ;
    rdfs:label "Rack B2, Unit 1"@en ;
    rdfs:comment "Specific location for a router in Server Room A."@en ;
    noria:locusLine "B2" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_Closet1_Shelf3 a noria:Locus ;
    rdfs:label "Closet 1, Shelf 3"@en ;
    rdfs:comment "Location for a switch in Network Closet 1."@en ;
    noria:locusLine "Shelf 3" ;
    noria:locusRow "N/A" ;
    bot:hasSpace noria:Room_NetworkCloset1 .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy org:Org_Dell .

noria:ProductModel_CiscoASR1000 a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router"@en ;
    rdfs:comment "Enterprise-grade aggregation services router."@en ;
    noria:productManufacturedBy org:Org_Cisco .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Virtualization Platform"@en ;
    rdfs:comment "Hypervisor for virtual machines."@en ;
    noria:productManufacturedBy org:Org_VMware .

org:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en .

org:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

org:Org_VMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Provider of cloud computing and virtualization software."@en .

# =============================================================================
# Resources (Servers, Routers, Virtual Machines)
# =============================================================================

noria:Resource_WebServer01 a noria:Resource ;
    rdfs:label "Production Web Server 01"@en, "Serveur Web Production 01"@fr ;
    rdfs:comment "Primary web server for customer-facing applications."@en ;
    noria:resourceManagedBy foaf:Agent_ITOpsTeam ;
    noria:resourceLogisticId "ASSET-WEB-001" ;
    noria:resourceHostName "web01.prod.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U42 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.10> ;
    noria:clusterController noria:Resource_VirtualCenter01 .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en, "Routeur Coeur 01"@fr ;
    rdfs:comment "Main router for the data center network backbone."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkAdminTeam ;
    noria:resourceLogisticId "ASSET-RTR-001" ;
    noria:resourceHostName "core-rtr01.dc.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1000 ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-08-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackB2_U1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.254> .

noria:Resource_VirtualCenter01 a noria:Resource ;
    rdfs:label "VMware vCenter Server"@en ;
    rdfs:comment "Management server for the VMware virtualization environment."@en ;
    noria:resourceManagedBy foaf:Agent_ITOpsTeam ;
    noria:resourceHostName "vcenter01.prod.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U42 .

noria:Resource_DBServer01 a noria:Resource ;
    rdfs:label "Production Database Server 01"@en ;
    rdfs:comment "Database server for critical business applications."@en ;
    noria:resourceManagedBy foaf:Agent_ITOpsTeam ;
    noria:resourceHostName "db01.prod.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-04-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U42 .

noria:Resource_VirtualMachine_App1_Prod a noria:Resource ;
    rdfs:label "Virtual Machine for App1 Production"@en ;
    rdfs:comment "Virtual machine hosting a production application module."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupportTeam ;
    noria:resourceHostName "vm-app1-prod.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # This is the hypervisor model, not the VM itself, but it's the closest in the vocab.
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-10T15:00:00Z"^^xsd:dateTime ;
    noria:clusterController noria:Resource_VirtualCenter01 .

# =============================================================================
# Network Interfaces
# =============================================================================

noria:NetworkInterface_WebServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "eth0 on WebServer01"@en ;
    rdfs:comment "Primary network interface for WebServer01."@en ;
    noria:networkInterfaceOf noria:Resource_WebServer01 ;
    noria:networkInterfaceDescription "Uplink to production network segment."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_RouterCore01_Gig0_0_0 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/0 on RouterCore01"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the internet uplink."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Internet Uplink Interface"@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_RouterCore01_Gig0_0_1 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on RouterCore01"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the internal data center network."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Internal DC Network Interface"@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

noria:NetworkInterface_DBServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "eth0 on DBServer01"@en ;
    rdfs:comment "Primary network interface for DBServer01."@en ;
    noria:networkInterfaceOf noria:Resource_DBServer01 ;
    noria:networkInterfaceDescription "Uplink to database network segment."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# =============================================================================
# Network Links
# =============================================================================

noria:NetworkLink_DC_InternetUplink a noria:NetworkLink ;
    rdfs:label "Data Center Internet Uplink"@en ;
    rdfs:comment "High-speed fiber link connecting the data center to the internet."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkAdminTeam ;
    noria:networkLinkId "NL-DC-INT-001" ;
