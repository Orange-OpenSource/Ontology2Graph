noria:EventRecord_WebServerCPUHigh a noria:EventRecord ;
    rdfs:label "High CPU Alert on WebServer01"@en ;
    rdfs:comment "Alert indicating sustained high CPU utilization on the production web server."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    dcterms:type <kos/Notification/EventType/thresholdCrossing> ;
    noria:logOriginatingManagedObject noria:Resource_WebServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logText "CPU utilization on web01.prod.example.com exceeded 90% for 5 minutes."@en .

noria:EventRecord_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating that a network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T10:15:30Z"^^xsd:dateTime ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down."@en .

noria:EventRecord_SecurityLoginFailure a noria:EventRecord ;
    rdfs:label "Repeated Login Failures on DBServer01"@en ;
    rdfs:comment "Security alert for multiple failed login attempts on the database server."@en ;
    noria:loggingTime "2024-04-20T10:20:15Z"^^xsd:dateTime ;
    dcterms:type <kos/Notification/EventType/securityAlert> ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logText "Failed login attempt for user 'admin' from IP 192.168.1.5 (5 times in 1 minute)."@en ;
    noria:logOriginatingAgent foaf:Agent_SecurityTeam . # SOC might be the "agent" reporting it, or an external attacker.

noria:EventRecord_ConfigChange_Router a noria:EventRecord ;
    rdfs:label "Router Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change applied to Core Router 01."@en ;
    noria:loggingTime "2024-04-19T14:00:00Z"^^xsd:dateTime ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent_JaneSmith ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by Jane Smith (10.0.0.5)."@en .

