# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent1 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en, "Équipe Admin DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and resolution of related incidents."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for L1, then email for L2/L3. Emergency hotline available 24/7."@en .

foaf:Agent2 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC)"@en, "Centre d'Opérations Réseau (NOC)"@fr ;
    rdfs:comment "24/7 team monitoring network infrastructure and handling initial incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical network issues, call the dedicated hotline. For routine requests, use the service portal."@en .

foaf:Agent3 a foaf:Agent ;
    rdfs:label "Application Support Team A"@en, "Équipe Support Application A"@fr ;
    rdfs:comment "Team responsible for the support and maintenance of critical business applications."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "All requests must be submitted through the ITSM ticketing system."@en .

foaf:Agent4 a foaf:Agent ;
    rdfs:label "Database Administration Team"@en, "Équipe Administration Bases de Données"@fr ;
    rdfs:comment "Specialized team managing all corporate database systems."@en ;
    noria:agentWorkingHours "8:30 am - 5:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For urgent database issues, escalate via NOC. Otherwise, use the internal request system."@en .

foaf:Agent5 a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en, "Centre d'Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Report all suspected security incidents immediately via dedicated security portal or emergency email."@en .

foaf:Agent6 a foaf:Agent ;
    rdfs:label "Storage Team"@en, "Équipe Stockage"@fr ;
    rdfs:comment "Team managing all corporate storage infrastructure."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Submit storage requests and incidents via the dedicated storage portal."@en .

foaf:Person1 a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Dupont"@en, "Alice Dupont"@fr ;
    rdfs:comment "Lead Network Engineer, member of NOC team."@en ;
    foaf:mbox <mailto:alice.dupont@example.com> ;
    foaf:phone "tel:+33123456789" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    foaf:member foaf:Agent2 .

foaf:Person2 a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Martin"@en, "Bob Martin"@fr ;
    rdfs:comment "Senior Application Developer, lead for CRM application."@en ;
    foaf:mbox <mailto:bob.martin@example.com> ;
    foaf:phone "tel:+33198765432" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    foaf:member foaf:Agent3 .

foaf:Person3 a foaf:Person, foaf:Agent ;
    rdfs:label "Carla Rossi"@en, "Carla Rossi"@fr ;
    rdfs:comment "Database Administrator, specialized in Oracle DBs."@en ;
    foaf:mbox <mailto:carla.rossi@example.com> ;
    foaf:phone "tel:+33111223344" ;
    noria:agentWorkingHours "8:30 am - 5:30 pm (Mon-Fri)"^^xsd:string ;
    foaf:member foaf:Agent4 .

noria:CUid1 a noria:CorporateUserIdentifier ;
    rdfs:label "ADupont_IT_Login"@en ;
    rdfs:comment "Corporate User ID for Alice Dupont."@en ;
    foaf:accountName "adupont" ;
    foaf:holdsAccount foaf:Person1 .

noria:CUid2 a noria:CorporateUserIdentifier ;
    rdfs:label "BMartin_Dev_Login"@en ;
    rdfs:comment "Corporate User ID for Bob Martin."@en ;
    foaf:accountName "bmartin" ;
    foaf:holdsAccount foaf:Person2 .

org:OrgUnit1 a org:OrganizationalUnit ;
    rdfs:label "IT Infrastructure Department"@en, "Département Infrastructure IT"@fr ;
    rdfs:comment "Manages all IT infrastructure components."@en ;
    org:hasMember foaf:Person1 ;
    org:hasUnit foaf:Agent1, foaf:Agent2, foaf:Agent6 .

org:OrgUnit2 a org:OrganizationalUnit ;
    rdfs:label "Software Development Department"@en, "Département Développement Logiciel"@fr ;
    rdfs:comment "Develops and maintains corporate applications."@en ;
    org:hasMember foaf:Person2 ;
    org:hasUnit foaf:Agent3, foaf:Agent4 .

org:OrgUnit3 a org:OrganizationalUnit ;
    rdfs:label "Cybersecurity Department"@en, "Département Cybersécurité"@fr ;
    rdfs:comment "Ensures the security of all IT systems and data."@en ;
    org:hasUnit foaf:Agent5 .

