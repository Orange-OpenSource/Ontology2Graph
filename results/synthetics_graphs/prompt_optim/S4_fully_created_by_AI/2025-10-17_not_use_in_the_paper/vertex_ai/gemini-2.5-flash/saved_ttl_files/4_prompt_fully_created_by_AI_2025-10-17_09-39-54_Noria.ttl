noria:ChangeRequest1 a noria:ChangeRequest ;
    rdfs:label "Upgrade Core Router Firmware"@en ;
    rdfs:comment "Planned firmware upgrade for Core Router 01 to address known vulnerabilities and improve performance."@en ;
    dcterms:created "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-18T15:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
