noria:EventRecord1 a noria:EventRecord ;
    rdfs:label "DNS Server CPU High Alert"@en ;
    rdfs:comment "CPU utilization on dns01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logText "CPU usage on dns01.corp.example.com is 95%."@en .

noria:EventRecord2 a noria:EventRecord ;
    rdfs:label "Core Router Interface Down"@en ;
    rdfs:comment "Interface GigabitEthernet0/0/1 on cr01.corp.example.com went down."@en ;
    noria:loggingTime "2024-04-20T10:15:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource3 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down."@en ;
    noria:alarmProposedRepairAction noria:OperationPlan1 .

noria:EventRecord3 a noria:EventRecord ;
    rdfs:label "Database Connection Error"@en ;
    rdfs:comment "Multiple connection errors detected on db01.corp.example.com from app01.corp.example.com."@en ;
    noria:loggingTime "2024-04-20T10:20:10Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource5 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logText "ORA-01034: ORACLE not available. ORA-27101: shared memory realm does not exist."@en ;
    noria:alarmProposedRepairAction noria:OperationPlan2 .

noria:EventRecord4 a noria:EventRecord ;
    rdfs:label "Successful Configuration Change on CR01"@en ;
    rdfs:comment "Configuration change applied to Core Router 01 by Alice Dupont."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource3 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:logOriginatingAgent foaf:Person1 ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by vty0 (10.0.0.5)."@en .

noria:EventRecord5 a noria:EventRecord ;
    rdfs:label "Web Application Error Rate Spike"@en ;
    rdfs:comment "Error rate for WebApp 01 increased by 500% in the last 5 minutes."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource7 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "HTTP 500 errors detected on /api/v1/customers endpoint."@en .

noria:EventRecord6 a noria:EventRecord ;
    rdfs:label "Storage Array Disk Failure"@en ;
    rdfs:comment "Disk 3 in Storage Array 01 reported as failed."@en ;
    noria:loggingTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource8 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logText "Disk failure detected on bay 3, serial XYZ123. Initiating rebuild."@en .

noria:EventRecord7 a noria:EventRecord ;
    rdfs:label "Load Balancer Health Check Failure"@en ;
    rdfs:comment "Health check for WebApp 01 backend server failed on Load Balancer 01."@en ;
    noria:loggingTime "2024-04-20T10:29:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource9 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logText "Backend server 172.16.1.100 (webapp01) health check failed."@en .

noria:EventRecord8 a noria:EventRecord ;
    rdfs:label "Security Alert: Brute Force Attempt"@en ;
    rdfs:comment "Multiple failed login attempts detected on a public-facing service, originating from a suspicious IP."@en ;
    noria:loggingTime "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource9 ; # Load balancer might detect this
    noria:logOriginatingManagementSystem foaf:Agent5 ; # SOC is the management system here
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "Brute force attack detected on SSH service from 203.0.113.42."@en .

