# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "Core Router Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving issues with core router interfaces."@en ;
    skos:example "Steps include checking physical connections, interface status, logs, and attempting soft/hard resets."@en .

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "Interface is down"@en ;
    rdfs:comment "The network interface reports an operational status of 'down'."@en ;
    skos:example "noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/Down>" .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "Interface is up and stable"@en ;
    rdfs:comment "The network interface reports an operational status of 'up' and traffic flows normally."@en ;
    skos:example "noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/Up>" .

noria:OperationPlan1 noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Database Instance Restart Procedure"@en ;
    rdfs:comment "Procedure for safely restarting a critical database instance."@en ;
    skos:example "Includes steps for checking dependencies, notifying stakeholders, performing the restart, and verifying service."@en .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Database unresponsive or high error rate"@en ;
    rdfs:comment "Database server is not responding to queries or is reporting a high rate of errors."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Database operational and accessible"@en ;
    rdfs:comment "Database instance is running, accessible, and applications can connect without errors."@en .

noria:OperationPlan2 noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

noria:OperationPlan3 a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading firmware on Juniper MX series routers."@en ;
    skos:example "Includes pre-checks, backup, upgrade command, post-checks, and rollback plan."@en .

noria:ActionPreCondition3 a noria:ActionPreCondition ;
    rdfs:label "New firmware available and tested"@en ;
    rdfs:comment "A new, validated firmware version is available for deployment."@en .

noria:ActionPostCondition3 a noria:ActionPostCondition ;
    rdfs:label "Router firmware updated and operational"@en ;
    rdfs:comment "Router is running the new firmware version without issues, and all services are restored."@en .

noria:OperationPlan3 noria:operationPlanPreCondition noria:ActionPreCondition3 ;
    noria:operationPlanPostCondition noria:ActionPostCondition3 .

noria:OperationPlan4 a noria:OperationPlan ;
    rdfs:label "Application Feature Deployment Procedure"@en ;
    rdfs:comment "Standard procedure for deploying new features to production application modules."@en ;
    skos:example "Includes code deployment, database schema updates, testing, and rollback plan."@en .

noria:ActionPreCondition4 a noria:ActionPreCondition ;
    rdfs:label "Feature tested in pre-production"@en ;
    rdfs:comment "The new application feature has passed all tests in the pre-production environment."@en .

noria:ActionPostCondition4 a noria:ActionPostCondition ;
    rdfs:label "New feature deployed and functional"@en ;
    rdfs:comment "The new feature is live in production and accessible to users without errors."@en .

noria:OperationPlan4 noria:operationPlanPreCondition noria:ActionPreCondition4 ;
    noria:operationPlanPostCondition noria:ActionPostCondition4 .

noria:OperationPlan5 a noria:OperationPlan ;
    rdfs:label "Storage Capacity Expansion Procedure"@en ;
    rdfs:comment "Procedure for safely expanding storage capacity on enterprise storage arrays."@en ;
    skos:example "Includes adding new disks/shelves, configuring RAID groups, and extending volumes."@en .

noria:ActionPreCondition5 a noria:ActionPreCondition ;
    rdfs:label "New storage hardware available"@en ;
    rdfs:comment "New disk drives or storage shelves are physically available and ready for installation."@en .

noria:ActionPostCondition5 a noria:ActionPostCondition ;
    rdfs:label "Storage capacity expanded and accessible"@en ;
    rdfs:comment "New storage capacity is online, configured, and accessible to connected servers."@en .

noria:OperationPlan5 noria:operationPlanPreCondition noria:ActionPreCondition5 ;
    noria:operationPlanPostCondition noria:ActionPostCondition5 .

# =============================================================================
# Procedure Execution Containers and links
# =============================================================================

<http://example.com/pep/PEC-TT2-Action1> a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of Interface Troubleshooting for TT2"@en ;
    dcterms:isPartOf noria:TroubleTicket2 ;
    dcterms:description "Actions taken to troubleshoot Core Router 01 interface G0/0/1, including reseating module."@en .

noria:TroubleTicketNote2 noria:troubleTicketNoteCorrelatedExecution <http://example.com/pep/PEC-TT2-Action1> .

# EventRecord4 (Successful Configuration Change on CR01) is part of the troubleshooting for TT2
noria:EventRecord4 dcterms:isPartOf <http://example.com/pep/PEC-TT2-Action1> ;
    pep:usedProcedure noria:OperationPlan1 .

<http://example.com/pep/PEC-TT3-Action1> a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of Database Restart for TT3"@en ;
    dcterms:isPartOf noria:TroubleTicket3 ;
    dcterms:description "Attempted restart of Oracle database instance on db01.corp.example.com."@en .

noria:TroubleTicketNote4 noria:troubleTicketNoteCorrelatedExecution <http://example.com/pep/PEC-TT3-Action1> .

# Assuming a specific event record for the restart attempt, or EventRecord3 itself if it captures the failure of the restart.
# Let's create a new event record for the restart attempt.
noria:EventRecord9 a noria:EventRecord ;
    rdfs:label "Database Restart Command Issued"@en ;
    rdfs:comment "Command issued to restart Oracle instance on db01.corp.example.com."@en ;
    noria:loggingTime "2024-04-20T10:48:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource5 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:logOriginatingAgent foaf:Person3 ;
    noria:logText "SQL> shutdown immediate; SQL> startup;"@en ;
    dcterms:isPartOf <http://example.com/pep/PEC-TT3-Action1> ;
    pep:usedProcedure noria:OperationPlan2 .

