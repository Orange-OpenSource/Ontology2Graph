# =============================================================================
# Network Interfaces
# =============================================================================

noria:NetworkInterface1 a noria:NetworkInterface ;
    rdfs:label "eth0 on DNS Server 01"@en ;
    rdfs:comment "Primary network interface for DNS Server 01."@en ;
    noria:networkInterfaceOf noria:Resource1 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface2 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on Core Router 01"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the internal network segment."@en ;
    noria:networkInterfaceOf noria:Resource3 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface3 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/2 on Core Router 01"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the WAN."@en ;
    noria:networkInterfaceOf noria:Resource3 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

noria:NetworkInterface4 a noria:NetworkInterface ;
    rdfs:label "vNIC0 on WebApp 01"@en ;
    rdfs:comment "Virtual network interface for WebApp 01 VM."@en ;
    noria:networkInterfaceOf noria:Resource7 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Virtual> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface5 a noria:NetworkInterface ;
    rdfs:label "eth0 on Application Server 01"@en ;
    rdfs:comment "Primary network interface for Application Server 01."@en ;
    noria:networkInterfaceOf noria:Resource4 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface6 a noria:NetworkInterface ;
    rdfs:label "eth0 on Database Server 01"@en ;
    rdfs:comment "Primary network interface for Database Server 01."@en ;
    noria:networkInterfaceOf noria:Resource5 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface7 a noria:NetworkInterface ;
    rdfs:label "SAN Interface on Storage Array 01"@en ;
    rdfs:comment "Fibre Channel interface for Storage Array 01."@en ;
    noria:networkInterfaceOf noria:Resource8 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/FibreChannel> ; # Assuming a KOS concept for FibreChannel
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

