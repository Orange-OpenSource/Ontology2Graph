# --- Network Links (noria:NetworkLink) ---

<networkLink/DC-CoreLink-01> a noria:NetworkLink ;
    rdfs:label "Datacenter Core Link 01"@en ;
    rdfs:comment "High-speed fiber link between Core Router 01 and another core router (CR02, not modeled here)."@en ;
    noria:networkLinkId "NL-DC-CR-01" ;
    noria:networkLinkType "Optical Fiber" ;
    noria:networkLinkInstallationDate "2020-05-10T12:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects <networkInterface/CR01-Gi0_0_1> ;
    noria:networkLinkTerminationResourceOrigin <resource/CoreRouter01> ;
    noria:networkLinkTerminationResourceDestination <resource/CoreRouter02> . # Assuming CR02 exists for connectivity

<resource/CoreRouter02> a noria:Resource ; # Minimal definition for connectivity
