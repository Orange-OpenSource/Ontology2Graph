    noria:logOriginatingManagedObject <resource/WebFrontend03> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:logOriginatingAgent <agent/ApplicationSupportTeam> .

<changeRequest/CR-20240315-005> noria:documentStatusHistory <eventRecord/Web_Patch_Deployment_20240315_1505> .

# Event record for successful patch deployment
<eventRecord/Web_Patch_Success_20240315_1520> a noria:EventRecord ;
    rdfs:label "Web Frontend Patch Success"@en ;
    rdfs:comment "Log entry for successful completion of emergency security patch deployment."@en ;
    noria:loggingTime "2024-03-15T15:20:00Z"^^xsd:dateTime ;
    noria:logText "Security patch CVE-2024-XXXX successfully applied to web03.corp.example.com. Service restored."@en ;
