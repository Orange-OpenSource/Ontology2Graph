# Add a specific operation plan for incident response
<operationPlan/SecurityIncidentResponsePlan> a noria:OperationPlan ;
    rdfs:label "Security Incident Response Plan"@en ;
    rdfs:comment "Standard operating procedure for responding to detected security incidents."@en ;
    skos:example "Steps include containment, eradication, recovery, and post-incident analysis."@en ;
    noria:operationPlanPreCondition <actionPreCondition/SecurityAlertTriggered> ;
    noria:operationPlanPostCondition <actionPostCondition/IncidentContained> .

<actionPreCondition/SecurityAlertTriggered> a noria:ActionPreCondition ;
    rdfs:label "Security Alert Triggered Pre-Condition"@en ;
    rdfs:comment "Condition: A security alert of Major or Critical severity has been triggered."@en .

<actionPostCondition/IncidentContained> a noria:ActionPostCondition ;
    rdfs:label "Incident Contained Post-Condition"@en ;
    rdfs:comment "Outcome: The security incident has been contained, and immediate threat mitigated."@en .

# Link a security event to this operation plan
<eventRecord/Firewall_Login_Attempt_20240315_1000> noria:alarmProposedRepairAction <operationPlan/SecurityIncidentResponsePlan> .

# Add a specific trouble ticket note for a security incident
<troubleTicketNote/TTN-20240315-001-03> a noria:TroubleTicketNote ;
    rdfs:label "Security Team Involvement for TT-20240315-001"@en ;
    rdfs:comment "SOC team engaged due to potential external attack vector identified during initial investigation."@en ;
    dcterms:isPartOf <troubleTicket/TT-20240315-001> ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    noria:troubleTicketRelatedParty <agent/SecurityOperationsCenter> .

# Add a specific change request for a security patch
<changeRequest/CR-20240315-005> a noria:ChangeRequest ;
    rdfs:label "Emergency Security Patch for Web Frontend"@en ;
    rdfs:comment "Emergency deployment of a critical security patch to Web Frontend 03."@en ;
    noria:changeRequestPlannedStartTime "2024-03-15T15:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-03-15T15:30:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-03-15T15:05:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Emergency> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/InProgress> ;
    noria:changeRequestImpact <resource/WebFrontend03> ;
