# Event record for monitoring delay
<eventRecord/Monitoring_Delay_20240315_1255> a noria:EventRecord ;
    rdfs:label "Monitoring System Latency Detected"@en ;
    rdfs:comment "Internal health check detected increased latency in alert processing."@en ;
    noria:loggingTime "2024-03-15T12:55:00Z"^^xsd:dateTime ;
    noria:logText "Alert processing queue length exceeded threshold for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logOriginatingManagedObject <application/MonitoringSystem> ;
