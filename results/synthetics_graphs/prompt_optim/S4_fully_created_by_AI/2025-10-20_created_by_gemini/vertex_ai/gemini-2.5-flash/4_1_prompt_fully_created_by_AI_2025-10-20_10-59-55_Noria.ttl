    noria:changeRequestActorParty <agent/ApplicationSupportTeam> ;
    noria:changeRequestOutageDuration "PT0H10M"^^xsd:duration ;
    noria:changeRequestIsRegulated true ;
    noria:documentHRef "https://itsm.example.com/cr/20240315-005" .

# Link the emergency change to the web portal outage
<troubleTicket/TT-20240315-001> dcterms:relation <changeRequest/CR-20240315-005> .

# Event record for the emergency patch deployment
<eventRecord/Web_Patch_Deployment_20240315_1505> a noria:EventRecord ;
    rdfs:label "Web Frontend Patch Deployment"@en ;
    rdfs:comment "Log entry for the deployment of an emergency security patch on Web Frontend 03."@en ;
    noria:loggingTime "2024-03-15T15:05:00Z"^^xsd:dateTime ;
    noria:logText "Started deployment of security patch CVE-2024-XXXX on web03.corp.example.com."@en ;
