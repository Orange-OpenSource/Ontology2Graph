    noria:operationPlanPostCondition <actionPostCondition/InterfaceUpPostCondition> .

<operationPlan/RouterFirmwareUpgradeProcedure> a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading router firmware with minimal downtime."@en ;
    skos:example "Includes pre-checks, backup, upgrade steps, and post-validation."@en ;
    noria:operationPlanPreCondition <actionPreCondition/NetworkStablePreCondition> ;
    noria:operationPlanPostCondition <actionPostCondition/RouterOperationalPostCondition> .

<operationPlan/DBDiskCleanupProcedure> a noria:OperationPlan ;
    rdfs:label "Database Disk Cleanup Procedure"@en ;
    rdfs:comment "Procedure for safely clearing disk space on database servers."@en ;
    skos:example "Steps involve identifying large files, archiving old logs, and verifying free space."@en ;
    noria:operationPlanPreCondition <actionPreCondition/DiskSpaceLowPreCondition> ;
    noria:operationPlanPostCondition <actionPostCondition/DiskSpaceNormalPostCondition> .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---

<actionPreCondition/InterfaceDownPreCondition> a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Pre-Condition"@en ;
    rdfs:comment "Condition: A network interface is reported as administratively or operationally down."@en .

<actionPostCondition/InterfaceUpPostCondition> a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up Post-Condition"@en ;
    rdfs:comment "Outcome: The network interface is administratively and operationally up, and traffic is flowing."@en .

<actionPreCondition/NetworkStablePreCondition> a noria:ActionPreCondition ;
    rdfs:label "Network Stable Pre-Condition"@en ;
    rdfs:comment "Condition: No active critical network incidents, and network utilization is within normal bounds."@en .

<actionPostCondition/RouterOperationalPostCondition> a noria:ActionPostCondition ;
    rdfs:label "Router Operational Post-Condition"@en ;
    rdfs:comment "Outcome: Router is fully operational, running new firmware, and all interfaces are up."@en .

<actionPreCondition/DiskSpaceLowPreCondition> a noria:ActionPreCondition ;
    rdfs:label "Disk Space Low Pre-Condition"@en ;
    rdfs:comment "Condition: Disk utilization on a critical volume exceeds 90%."@en .

<actionPostCondition/DiskSpaceNormalPostCondition> a noria:ActionPostCondition ;
    rdfs:label "Disk Space Normal Post-Condition"@en ;
    rdfs:comment "Outcome: Disk utilization on the critical volume is below 80%."@en .

