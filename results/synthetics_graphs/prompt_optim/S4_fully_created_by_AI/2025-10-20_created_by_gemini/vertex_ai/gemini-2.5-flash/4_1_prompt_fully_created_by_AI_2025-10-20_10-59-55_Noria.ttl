# Link more resources to applications
<resource/DNSServer01> noria:resourceForApplication <application/CorporateWebPortal> .
<resource/DNSServer01> noria:resourceForApplication <application/CustomerCRM> .
<resource/EdgeFirewall01> noria:resourceForApplication <application/CorporateWebPortal> .
<resource/EdgeFirewall01> noria:resourceForApplication <application/CustomerCRM> .
<resource/CoreRouter01> noria:resourceForApplication <application/MonitoringSystem> .

# Link application modules to resources
<applicationModule/CWP-Production> seas:subSystemOf <resource/WebFrontend03> .
<applicationModule/CWP-Production> seas:subSystemOf <resource/DNSServer01> .
<applicationModule/CRM-Development> seas:subSystemOf <resource/DatabaseServer02> .
<applicationModule/CMS-Production> seas:subSystemOf <resource/VirtualMachineHost01> .

# Link agents to resources they manage
<agent/NetworkOperationsTeam> noria:agentManagesResource <resource/CoreRouter01> .
<agent/NetworkOperationsTeam> noria:agentManagesResource <resource/EdgeFirewall01> .
<agent/ApplicationSupportTeam> noria:agentManagesResource <resource/WebFrontend03> .
<agent/DatabaseAdminTeam> noria:agentManagesResource <resource/DatabaseServer02> .
<agent/SecurityOperationsCenter> noria:agentManagesResource <resource/EdgeFirewall01> .

# Link agents to application modules they support
<agent/ApplicationSupportTeam> noria:applicationModuleSupportTeam <applicationModule/CWP-Production> .
<agent/ApplicationSupportTeam> noria:applicationModuleSupportLeader <agent/BobJohnson> .
<agent/NetworkOperationsTeam> noria:applicationModuleAdministrationTeam <applicationModule/CMS-Production> .

# More detailed network interface properties
<networkInterface/CR01-Gi0_0_1>
    noria:networkInterfaceLaserRxOpticalPowerAverage -6 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -3 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -15 .

<networkInterface/FW01-Ext>
    noria:networkInterfaceLaserTxOpticalPower -4 ;
    noria:networkInterfaceLaserRxOpticalPower -5 .

# Example of an anomaly pattern
<anomalyPattern/HighCPULoad> a noria:AnomalyPattern ;
    rdfs:label "High CPU Load Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high CPU utilization, potentially leading to service degradation."@en ;
    folio:hasCause "Excessive process activity or resource contention."@en ;
    folio:hasEffect "Service slowdown or unresponsiveness."@en .

# Link event record to anomaly pattern (as a potential cause)
<eventRecord/DNS_CPU_High_20240315_0900> dcterms:conformsTo <anomalyPattern/HighCPULoad> .

# Example of a corrective maintenance action (as a ProcedureExecutionContainer)
<pep/ClearDBLogsExecution> a pep:ProcedureExecutionContainer ;
    rdfs:label "Clear Database Logs Execution"@en ;
    rdfs:comment "Execution record for the procedure to clear old database logs."@en ;
    pep:usedProcedure <operationPlan/DBDiskCleanupProcedure> ;
    pep:hasInput <resource/DatabaseServer02> ;
    pep:hasOutput <actionPostCondition/DiskSpaceNormalPostCondition> .

<troubleTicket/TT-20240315-003> noria:alarmMitigatedBy <pep/ClearDBLogsExecution> .

# Example of a change action (as a ProcedureExecutionContainer)
<pep/RouterFirmwareUpgradeExecution> a pep:ProcedureExecutionContainer ;
    rdfs:label "Core Router Firmware Upgrade Execution"@en ;
    rdfs:comment "Execution record for the firmware upgrade on Core Router 01."@en ;
    pep:usedProcedure <operationPlan/RouterFirmwareUpgradeProcedure> ;
    pep:hasInput <resource/CoreRouter01> ;
    pep:hasOutput <actionPostCondition/RouterOperationalPostCondition> .

<changeRequest/CR-20240315-001> dcterms:relation <pep/RouterFirmwareUpgradeExecution> . # Using dcterms:relation as a general link for now, as no specific noria property for CR to ProcedureExecutionContainer. The schema mentions `pep:ProcedureExecutionContainer` for CR, so this is valid.

