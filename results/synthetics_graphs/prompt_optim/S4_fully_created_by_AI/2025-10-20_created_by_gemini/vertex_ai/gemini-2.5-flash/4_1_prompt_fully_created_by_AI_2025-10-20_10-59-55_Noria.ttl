# --- Locations (bot:Site, noria:Room, noria:Locus) ---

<location/Site_DC_Paris> a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center facility located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" .

<location/Site_RO_Lyon> a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office in Lyon with local IT infrastructure."@en ;
    noria:siteId "RO-LYN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "45 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressCountry "FR" .

<location/Room_DC_Paris_ServerRoom1> a noria:Room ;
    rdfs:label "DC Paris Server Room 1"@en ;
    rdfs:comment "Main server room in the Paris Data Center."@en ;
    bot:hasSpace <location/Site_DC_Paris> .

<location/Room_DC_Paris_NetworkCoreRoom> a noria:Room ;
    rdfs:label "DC Paris Network Core Room"@en ;
    rdfs:comment "Room housing core network equipment in Paris Data Center."@en ;
    bot:hasSpace <location/Site_DC_Paris> .

<location/Room_RO_Lyon_ITCloset> a noria:Room ;
    rdfs:label "RO Lyon IT Closet"@en ;
    rdfs:comment "Small IT closet in the Lyon Regional Office."@en ;
    bot:hasSpace <location/Site_RO_Lyon> .

<location/Locus_DC_Paris_SR1_RackA1> a noria:Locus ;
    rdfs:label "Rack A1 in Server Room 1"@en ;
    rdfs:comment "Location of servers in Rack A1."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:containsZone <location/Room_DC_Paris_ServerRoom1> .

<location/Locus_DC_Paris_SR1_RackB5> a noria:Locus ;
    rdfs:label "Rack B5 in Server Room 1"@en ;
    rdfs:comment "Location of database servers in Rack B5."@en ;
    noria:locusLine "B" ;
    noria:locusRow "5" ;
    bot:containsZone <location/Room_DC_Paris_ServerRoom1> .

<location/Locus_DC_Paris_NCR_RackC2> a noria:Locus ;
    rdfs:label "Rack C2 in Network Core Room"@en ;
    rdfs:comment "Location of core routers in Rack C2."@en ;
    noria:locusLine "C" ;
    noria:locusRow "2" ;
    bot:containsZone <location/Room_DC_Paris_NetworkCoreRoom> .

<location/Locus_RO_Lyon_ITC_Rack1> a noria:Locus ;
    rdfs:label "Rack 1 in Lyon IT Closet"@en ;
    rdfs:comment "Location of local network equipment in Lyon."@en ;
    noria:locusLine "1" ;
    noria:locusRow "1" ;
    bot:containsZone <location/Room_RO_Lyon_ITCloset> .

