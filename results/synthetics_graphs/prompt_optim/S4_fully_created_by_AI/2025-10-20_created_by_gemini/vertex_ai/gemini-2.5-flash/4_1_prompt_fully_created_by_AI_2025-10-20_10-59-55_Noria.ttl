    noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

# --- Network Interfaces (noria:NetworkInterface) ---

<networkInterface/DNS01-Eth0> a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Management interface for DNS Server 01."@en ;
    noria:networkInterfaceOf <resource/DNSServer01> ;
    noria:networkInterfaceDescription "Management interface" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

<networkInterface/Web03-Eth1> a noria:NetworkInterface ;
    rdfs:label "Web03 Ethernet 1"@en ;
    rdfs:comment "Data interface for Web Frontend 03."@en ;
    noria:networkInterfaceOf <resource/WebFrontend03> ;
    noria:networkInterfaceDescription "Application data interface" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

<networkInterface/CR01-Gi0_0_1> a noria:NetworkInterface ;
    rdfs:label "CR01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Uplink to another core router."@en ;
    noria:networkInterfaceOf <resource/CoreRouter01> ;
    noria:networkInterfaceDescription "Inter-DC Link to CR02" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -5 ;
    noria:networkInterfaceLaserRxOpticalPower -6 .

<networkInterface/CR01-Gi0_0_2> a noria:NetworkInterface ;
    rdfs:label "CR01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Link to Edge Firewall 01."@en ;
    noria:networkInterfaceOf <resource/CoreRouter01> ;
    noria:networkInterfaceDescription "Link to FW01" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

<networkInterface/FW01-Ext> a noria:NetworkInterface ;
    rdfs:label "FW01 External Interface"@en ;
    rdfs:comment "External facing interface of Edge Firewall 01."@en ;
    noria:networkInterfaceOf <resource/EdgeFirewall01> ;
    noria:networkInterfaceDescription "Internet Uplink" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -10 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -25 .

<networkInterface/VDNSReplica-Eth0> a noria:NetworkInterface ;
    rdfs:label "Virtual DNS Replica Ethernet 0"@en ;
    rdfs:comment "Network interface for the virtual DNS replica."@en ;
