<operationPlan/InterfaceTroubleshootingGuide> a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Guide"@en ;
    rdfs:comment "Standard procedure for diagnosing and resolving network interface issues."@en ;
    skos:example "Steps include checking cable, port status, configuration, and optical levels."@en ;
