<networkInterface/CR02-Gi0_0_1> a noria:NetworkInterface ; # Minimal definition for connectivity
    rdfs:label "CR02 GigabitEthernet 0/0/1"@en ;
    noria:networkInterfaceOf <resource/CoreRouter02> ;
    noria:networkInterfaceConnects <networkLink/DC-CoreLink-01> .

<networkLink/FW-InternalLink> a noria:NetworkLink ;
    rdfs:label "Firewall Internal Link"@en ;
    rdfs:comment "Internal link between Core Router 01 and Edge Firewall 01."@en ;
    noria:networkLinkId "NL-FW-INT-01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2021-08-22T17:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects <networkInterface/CR01-Gi0_0_2> ;
    noria:networkInterfaceConnects <networkInterface/FW01-Int> . # Assuming FW01-Int exists

<networkInterface/FW01-Int> a noria:NetworkInterface ; # Minimal definition for connectivity
    rdfs:label "FW01 Internal Interface"@en ;
    noria:networkInterfaceOf <resource/EdgeFirewall01> ;
    noria:networkInterfaceConnects <networkLink/FW-InternalLink> .

