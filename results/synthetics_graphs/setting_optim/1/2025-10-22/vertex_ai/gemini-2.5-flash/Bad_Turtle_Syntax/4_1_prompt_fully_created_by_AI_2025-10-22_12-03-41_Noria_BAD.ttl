# --- Resources (500 instances) ---
# 250 Servers, 150 Network Devices, 50 Firewalls, 50 Load Balancers
@for $i from 1 to 250 {
noria:Resource_Server_{$i} a noria:Resource ;
    rdfs:label "Server {$i}"@en, "Serveur {$i}"@fr ;
    rdfs:comment "A general-purpose server instance, part of the corporate infrastructure."@en ;
    noria:resourceManagedBy foaf:Agent_Team_{ ($i % 5) + 1 } ;
    noria:resourceHostName "srv{$i}.example.com" ;
    noria:resourceProductModel noria:ProductModel_{ ($i % 5) + 1 } ;
    noria:resourceType <kos/Resource/type/{ ($i % 2 == 0) ? "server" : "virtual-machine" }> ;
    noria:resourceSerialNumber "SN-SRV-{$i}-ABC{($i * 13) % 9999}" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-{ ($i % 28) + 1 }T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_{ ($i % 50) + 1 } ;
    noria:resourceManagementIPAddress observable:IPAddress_Server_{$i} .
observable:IPAddress_Server_{$i} a observable:IPAddress ;
    rdfs:label "IP Address for Server {$i}"@en ;
    observable:ipAddressValue "10.10.{ ($i % 20) + 1 }.{ ($i % 250) + 1 }" .
}

@for $i from 1 to 150 {
noria:Resource_Network_{$i} a noria:Resource ;
    rdfs:label "Network Device {$i}"@en, "Équipement Réseau {$i}"@fr ;
    rdfs:comment "A router or switch, critical for network connectivity."@en ;
    noria:resourceManagedBy foaf:Agent_Team_{ ($i % 3) + 1 } ;
    noria:resourceHostName "net{$i}.example.com" ;
    noria:resourceProductModel noria:ProductModel_{ ($i % 3) + 2 } ; # Using ProductModel 2,3,4 for network devices
    noria:resourceType <kos/Resource/type/{ ($i % 2 == 0) ? "router" : "switch" }> ;
    noria:resourceSerialNumber "SN-NET-{$i}-DEF{($i * 17) % 9999}" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-{ ($i % 28) + 1 }T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_{ ($i % 50) + 1 } ;
    noria:resourceManagementIPAddress observable:IPAddress_Network_{$i} .
observable:IPAddress_Network_{$i} a observable:IPAddress ;
    rdfs:label "IP Address for Network Device {$i}"@en ;
    observable:ipAddressValue "10.20.{ ($i % 15) + 1 }.{ ($i % 150) + 1 }" .
}

@for $i from 1 to 50 {
noria:Resource_Firewall_{$i} a noria:Resource ;
    rdfs:label "Firewall {$i}"@en, "Pare-feu {$i}"@fr ;
    rdfs:comment "A security firewall protecting network segments."@en ;
    noria:resourceManagedBy foaf:Agent_Team_4 ; # Security Team
    noria:resourceHostName "fw{$i}.example.com" ;
    noria:resourceProductModel noria:ProductModel_6 ; # Palo Alto
    noria:resourceType <kos/Resource/type/firewall> ;
    noria:resourceSerialNumber "SN-FW-{$i}-GHI{($i * 19) % 9999}" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-{ ($i % 28) + 1 }T12:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_{ ($i % 50) + 1 } ;
    noria:resourceManagementIPAddress observable:IPAddress_Firewall_{$i} .
observable:IPAddress_Firewall_{$i} a observable:IPAddress ;
    rdfs:label "IP Address for Firewall {$i}"@en ;
    observable:ipAddressValue "10.30.{ ($i % 5) + 1 }.{ ($i % 50) + 1 }" .
}

@for $i from 1 to 50 {
noria:Resource_LoadBalancer_{$i} a noria:Resource ;
    rdfs:label "Load Balancer {$i}"@en, "Équilibreur de Charge {$i}"@fr ;
    rdfs:comment "A network load balancer distributing traffic to servers."@en ;
    noria:resourceManagedBy foaf:Agent_Team_2 ; # App Support Team
    noria:resourceHostName "lb{$i}.example.com" ;
    noria:resourceProductModel noria:ProductModel_7 ; # F5 BIG-IP
    noria:resourceType <kos/Resource/type/load-balancer> ;
    noria:resourceSerialNumber "SN-LB-{$i}-JKL{($i * 23) % 9999}" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-04-{ ($i % 28) + 1 }T13:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_{ ($i % 50) + 1 } ;
    noria:resourceManagementIPAddress observable:IPAddress_LoadBalancer_{$i} .
observable:IPAddress_LoadBalancer_{$i} a observable:IPAddress ;
    rdfs:label "IP Address for Load Balancer {$i}"@en ;
    observable:ipAddressValue "10.40.{ ($i % 5) + 1 }.{ ($i % 50) + 1 }" .
}

# --- Network Interfaces (1000 instances) ---
# 2 interfaces per Resource on average (for the 500 resources)
@for $i from 1 to 500 {
noria:NetworkInterface_{$i}_Eth0 a noria:NetworkInterface ;
    rdfs:label "Ethernet 0 for Resource {$i}"@en, "Ethernet 0 pour Ressource {$i}"@fr ;
    rdfs:comment "Primary network interface for data traffic."@en ;
    noria:networkInterfaceOf noria:Resource_Server_{$i} ;
    noria:networkInterfaceDescription "Main data interface" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-7"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "0"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-20"^^xsd:int .

noria:NetworkInterface_{$i}_Eth1 a noria:NetworkInterface ;
    rdfs:label "Ethernet 1 for Resource {$i}"@en, "Ethernet 1 pour Ressource {$i}"@fr ;
    rdfs:comment "Secondary network interface, often used for management or redundancy."@en ;
    noria:networkInterfaceOf noria:Resource_Server_{$i} ;
    noria:networkInterfaceDescription "Management interface" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-6"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-8"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "0"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-20"^^xsd:int .
}

# --- Network Links (500 instances) ---
# Connecting pairs of Network Interfaces, ensuring connectivity
@for $i from 1 to 500 {
noria:NetworkLink_{$i} a noria:NetworkLink ;
    rdfs:label "Link NL-{$i}"@en, "Lien NL-{$i}"@fr ;
    rdfs:comment "A physical or logical network connection between two resources."@en ;
    noria:networkLinkId "NL-{$i}" ;
    noria:networkLinkInstallationDate "2023-09-{ ($i % 28) + 1 }T14:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10G" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_Server_{$i} ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Network_{ ($i % 150) + 1 } ;
    noria:networkInterfaceConnects noria:NetworkInterface_{$i}_Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_{ ($i % 500) + 1 }_Eth1 .
}

# --- Applications (20 instances) ---
@for $i from 1 to 20 {
noria:Application_{$i} a noria:Application ;
    rdfs:label "Business Application {$i}"@en, "Application Métier {$i}"@fr ;
    rdfs:comment "A critical business application supporting various corporate functions."@en ;
    noria:applicationModelIdentifier "APP-MODEL-{$i}" ;
    noria:applicationNumericalIdentifier "{ 1000 + $i }"^^xsd:int ;
    noria:applicationShortIdentifier "BA{$i}" ;
    noria:applicationType <kos/application/type/{ ($i % 2 == 0) ? "business-critical" : "infrastructure" }> ;
    noria:applicationBusinessImportance <kos/application/business-importance/{ ($i % 3 == 0) ? "high" : "medium" }> ;
    noria:applicationFunctionalDomain "{ ($i % 2 == 0) ? "Customer Management" : "Internal Operations" }" ;
    noria:applicationFunctionalSubDomain "{ ($i % 2 == 0) ? "Order Processing" : "HR Management" }" .
}

# --- Application Modules (100 instances) ---
# 5 modules per application
@for $i from 1 to 100 {
noria:ApplicationModule_{$i} a noria:ApplicationModule ;
    rdfs:label "Module {$i} of Application { ($i-1)//5 + 1 }"@en, "Module {$i} de l'Application { ($i-1)//5 + 1 }"@fr ;
    rdfs:comment "A specific instance or component of a business application, e.g., a development or production environment."@en ;
    noria:applicationModuleOf noria:Application_{ ($i-1)//5 + 1 } ;
    noria:applicationModuleName "APP{ ($i-1)//5 + 1 }-MOD{$i}" ;
    noria:applicationModuleIdentifier "AM-{$i}" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/{ ($i % 3 == 0) ? "InProduction" : ( ($i % 3 == 1) ? "Testing" : "Maintenance" ) }> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/{ ($i % 2 == 0) ? "Gold" : "Silver" }> ;
    noria:applicationModuleSlaLevelDate "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled "{ ($i % 2 == 0) ? "true" : "false" }"^^xsd:boolean ;
    noria:applicationModuleAdministrationTeam foaf:Agent_Team_{ ($i % 5) + 1 } ;
    noria:applicationModuleSupportTeam foaf:Agent_Team_{ ($i % 5) + 1 } ;
    noria:applicationModuleAdministrationLeader foaf:Agent_Person_{ ($i % 10) + 1 } ;
    noria:applicationModuleSupportLeader foaf:Agent_Person_{ (($i + 1) % 10) + 1 } ;
    noria:applicationModuleSupportGroup foaf:Agent_Team_{ (($i + 2) % 10) + 1 } ;
    noria:applicationModuleHotlineGroup foaf:Agent_Team_{ (($i + 3) % 10) + 1 } .
}

# --- Services (10 instances) ---
@for $i from 1 to 10 {
noria:Service_{$i} a noria:Service ;
    rdfs:label "Enterprise Service {$i}"@en, "Service d'Entreprise {$i}"@fr ;
    rdfs:comment "An end-to-end service provided to customers or internal users, composed of multiple application modules."@en ;
    noria:serviceType <kos/service/type/{ ($i % 2 == 0) ? "CustomerFacingService" : "ResourceFacingService" }> .
}

# Link Application Modules to Services (using seas:subSystemOf as noria:Service is seas:System)
@for $i from 1 to 100 {
noria:ApplicationModule_{$i} seas:subSystemOf noria:Service_{ ($i % 10) + 1 } .
}

# Link Resources to Applications
@for $i from 1 to 250 {
noria:Resource_Server_{$i} noria:resourceForApplication noria:Application_{ ($i % 20) + 1 } .
}

# --- Operation Plans (50 instances) ---
@for $i from 1 to 50 {
noria:OperationPlan_{$i} a noria:OperationPlan ;
    rdfs:label "Operation Plan {$i}: System Update Procedure"@en, "Plan d'Opération {$i}: Procédure de Mise à Jour Système"@fr ;
    rdfs:comment "Standard operating procedure for routine system updates and maintenance."@en .
noria:ActionPreCondition_{$i} a noria:ActionPreCondition ;
    rdfs:label "Pre-condition for OP {$i}"@en ;
    rdfs:comment "Verify system backups, check maintenance window, and ensure resource availability."@en .
noria:ActionPostCondition_{$i} a noria:ActionPostCondition ;
    rdfs:label "Post-condition for OP {$i}"@en ;
    rdfs:comment "Verify service functionality, check logs for errors, and confirm system health."@en .
noria:OperationPlan_{$i} noria:operationPlanPreCondition noria:ActionPreCondition_{$i} ;
    noria:operationPlanPostCondition noria:ActionPostCondition_{$i} .
}

# --- Event Records (5000 instances) ---
# Mix of log, alarm, status changes, originating from various sources
@for $i from 1 to 5000 {
noria:EventRecord_{$i} a noria:EventRecord ;
    rdfs:label "Event Record {$i}"@en, "Enregistrement d'Événement {$i}"@fr ;
    rdfs:comment "A log entry or alarm notification indicating a system event."@en ;
    noria:loggingTime "2024-01-{ ($i % 28) + 1 }T{ ($i % 23) + 1 }:{ ($i % 59) + 1 }:{ ($i % 59) + 1 }Z"^^xsd:dateTime ;
    noria:logText "System status changed to { ($i % 2 == 0) ? 'UP' : 'DOWN' } on interface Eth0 of srv{ ($i % 250) + 1 }."@en ;
    noria:logOriginatingManagedObject noria:Resource_Server_{ ($i % 250) + 1 } ;
    noria:logOriginatingManagementSystem noria:Application_1 ; # Assuming App 1 is a monitoring system
    noria:logOriginatingAgent foaf:Agent_Person_{ ($i % 10) + 1 } ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/{ ($i % 4 == 0) ? "Critical" : ( ($i % 4 == 1) ? "Major" : ( ($i % 4 == 2) ? "Minor" : "Warning" ) ) }> ;
    noria:alarmProposedRepairAction noria:OperationPlan_{ ($i % 50) + 1 } .
}

# --- Trouble Tickets (1000 instances) ---
@for $i from 1 to 1000 {
noria:TroubleTicket_{$i} a noria:TroubleTicket ;
    rdfs:label "Trouble Ticket {$i}: Service Interruption on BA{ ($i % 20) + 1 }"@en, "Ticket d'Incident {$i}: Interruption de Service sur BA{ ($i % 20) + 1 }"@fr ;
    rdfs:comment "Incident reported for a service or resource, requiring investigation and resolution."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/{ ($i % 3 == 0) ? "Critical" : ( ($i % 3 == 1) ? "Major" : "Minor" ) }> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/{ ($i % 4 == 0) ? "P1" : ( ($i % 4 == 1) ? "P2" : ( ($i % 4 == 2) ? "P3" : "P4" ) ) }> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/{ ($i % 2 == 0) ? "Customer" : "Supervision" }> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/{ ($i % 2 == 0) ? "ImmediateIntervention" : "DeferredIntervention" }> ;
    noria:troubleTicketSupervisionTool "MonitoringSystemX" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/NetworkFailure> ;
    noria:troubleTicketCause "Network link failure detected, impacting application BA{ ($i % 20) + 1 }."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-02-{ ($i % 28) + 1 }T{ ($i % 23) + 1 }:{ ($i % 59) + 1 }:{ ($i % 59) + 1 }Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-02-{ ($i % 28) + 1 }T{ ($i % 23) + 2 }:{ ($i % 59) + 1 }:{ ($i % 59) + 1 }Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-02-{ ($i % 28) + 1 }T{ ($i % 23) + 3 }:{ ($i % 59) + 1 }:{ ($i % 59) + 1 }Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-02-{ ($i % 28) + 1 }T{ ($i % 23) + 4 }:{ ($i % 59) + 1 }:{ ($i % 59) + 1 }Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/{ ($i % 2 == 0) ? "InProgress" : "Resolved" }> ;
    noria:documentExternalId "EXT-TT-{$i}" ;
    noria:documentHRef "https://tickets.example.com/tt/{$i}" ;
    noria:troubleTicketRelatedService noria:ApplicationModule_{ ($i % 100) + 1 } ;
    noria:troubleTicketRelatedResource noria:Resource_Network_{ ($i % 150) + 1 } ;
    noria:troubleTicketRelatedParty foaf:Agent_Team_{ ($i % 10) + 1 } ;
    noria:troubleTicketRelatedParty foaf:Agent_Person_{ ($i % 10) + 1 } ;
    noria:troubleTicketTrigger noria:EventRecord_{ ($i % 5000) + 1 } ;
    noria:documentStatusHistory noria:EventRecord_{ (($i + 1) % 5000) + 1 } .

    # --- Trouble Ticket Notes (3000 instances, 3 notes per TT) ---
    @for $j from 1 to 3 {
    noria:TroubleTicketNote_{$i}_{$j} a noria:TroubleTicketNote ;
        rdfs:label "Note {$j} for TT {$i}"@en, "Note {$j} pour TT {$i}"@fr ;
        rdfs:comment "Update on the trouble ticket progress: { ($j == 1) ? 'Initial diagnosis performed.' : ( ($j == 2) ? 'Corrective action applied.' : 'Service verified restored.' ) }"@en ;
        noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/{ ($j % 2 == 0) ? "Internal" : "Customer" }> ;
        noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/{ ($j % 2 == 0) ? "Diagnosis" : "TestsAndMeasurements" }> ;
        noria:troubleTicketNoteCorrelatedExecution noria:EventRecord_{ (($i * 3 + $j) % 5000) + 1 } .
    }
}

# --- Change Requests (500 instances) ---
@for $i from 1 to 500 {
noria:ChangeRequest_{$i} a noria:ChangeRequest ;
    rdfs:label "Change Request {$i}: Software Upgrade on srv{ ($i % 250) + 1 }"@en, "Demande de Changement {$i}: Mise à Jour Logicielle sur srv{ ($i % 250) + 1 }"@fr ;
    rdfs:comment "Planned software upgrade for a server, requiring a maintenance window."@en ;
    noria:changeRequestPlannedStartTime "2024-03-{ ($i % 28) + 1 }T18:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-03-{ ($i % 28) + 1 }T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-03-{ ($i % 28) + 1 }T18:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-03-{ ($i % 28) + 1 }T21:45:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestOutageDuration "PT3H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/{ ($i % 2 == 0) ? "Implemented" : "Scheduled" }> ;
    noria:changeRequestIsRegulated "false"^^xsd:boolean ;
    noria:documentExternalId "EXT-CR-{$i}" ;
    noria:documentHRef "https://changes.example.com/cr/{$i}" ;
    noria:changeRequestImpact noria:Resource_Server_{ ($i % 250) + 1 } ;
    noria:changeRequestImpact noria:ApplicationModule_{ ($i % 100) + 1 } ;
    noria:changeRequestInitiatorParty foaf:Agent_Person_{ ($i % 10) + 1 } ;
    noria:changeRequestPilotParty foaf:Agent_Team_{ ($i % 10) + 1 } ;
    noria:changeRequestActorParty foaf:Agent_Person_{ (($i + 1) % 10) + 1 } ;
    noria:documentStatusHistory noria:EventRecord_{ (($i + 2) % 5000) + 1 } .
}

# --- Document Attachments (100 instances) ---
@for $i from 1 to 100 {
noria:DocumentAttachment_{$i} a noria:DocumentAttachment ;
    rdfs:label "Attachment {$i}: Network Diagram for CR/TT { ($i % 2 == 0) ? ($i % 1000) + 1 : ($i % 500) + 1 }"@en, "Pièce jointe {$i}: Diagramme Réseau pour CR/TT { ($i % 2 == 0) ? ($i % 1000) + 1 : ($i % 500) + 1 }"@fr ;
    rdfs:comment "Diagram of the network topology or configuration related to an incident or change request."@en ;
    dcterms:format "image/png" ;
    dcterms:identifier "attachment-{$i}.png" ;
    dcterms:source "https://docs.example.com/attachments/attachment-{$i}.png" .
# Link to a random TroubleTicket or ChangeRequest
@if ($i % 2 == 0) {
noria:TroubleTicket_{ ($i % 1000) + 1 } dcterms:hasPart noria:DocumentAttachment_{$i} .
} @else {
noria:ChangeRequest_{ ($i % 500) + 1 } dcterms:hasPart noria:DocumentAttachment_{$i} .
}
}

# --- Additional Connectivity for Density ---
# Link some resources to other applications
@for $i from 1 to 100 {
noria:Resource_Network_{$i} noria:resourceForApplication noria:Application_{ (($i % 20) + 1) } .
}

# Link some firewalls to security team agents
@for $i from 1 to 50 {
foaf:Agent_Person_4 noria:agentManagesResource noria:Resource_Firewall_{$i} .
}

# Link some load balancers to application support team agents
@for $i from 1 to 50 {
foaf:Agent_Person_2 noria:agentManagesResource noria:Resource_LoadBalancer_{$i} .
}

# Link some servers to virtualization team agents
@for $i from 1 to 50 {
foaf:Agent_Person_8 noria:agentManagesResource noria:Resource_Server_{$i} .
}

# Link some network devices to network team agents
@for $i from 1 to 50 {
foaf:Agent_Person_1 noria:agentManagesResource noria:Resource_Network_{$i} .
}

# Link some application modules to specific resources they depend on
@for $i from 1 to 100 {
noria:ApplicationModule_{$i} seas:subSystemOf noria:Resource_Server_{ ($i % 250) + 1 } .
noria:ApplicationModule_{$i} seas:subSystemOf noria:Resource_LoadBalancer_{ ($i % 50) + 1 } .
}

# Link some services to specific resources they depend on
@for $i from 1 to 10 {
noria:Service_{$i} seas:subSystemOf noria:Resource_Firewall_{ ($i % 50) + 1 } .
noria:Service_{$i} seas:subSystemOf noria:Resource_Network_{ ($i % 150) + 1 } .
}

# Link some EventRecords to TroubleTickets as mitigation
@for $i from 1 to 500 {
noria:EventRecord_{ ($i % 5000) + 1 } noria:alarmMitigatedBy noria:TroubleTicket_{ ($i % 1000) + 1 } .
}

# Link some EventRecords to TroubleTicketNotes as correlated execution
@for $i from 1 to 500 {
noria:EventRecord_{ (($i + 1000) % 5000) + 1 } noria:troubleTicketNoteCorrelatedExecution noria:TroubleTicketNote_{ ($i % 1000) + 1 }_1 .
}

# Link some EventRecords to ChangeRequests as status history
@for $i from 1 to 250 {
noria:EventRecord_{ (($i + 2000) % 5000) + 1 } noria:documentStatusHistory noria:ChangeRequest_{ ($i % 500) + 1 } .
}

# --- End of Generated Graph ---
