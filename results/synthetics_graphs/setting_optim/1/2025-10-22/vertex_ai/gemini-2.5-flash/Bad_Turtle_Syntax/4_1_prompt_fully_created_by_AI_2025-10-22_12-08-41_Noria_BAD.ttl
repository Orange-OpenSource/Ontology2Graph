# --- Operation Plans, Pre/Post Conditions ---

noria:OperationPlan_ServerReboot a noria:OperationPlan ;
    rdfs:label "Standard Server Reboot Procedure"@en, "Procédure Standard de Redémarrage Serveur"@fr ;
    rdfs:comment "A documented procedure for safely rebooting a server."@en .

noria:ActionPreCondition_ServerReboot_NoCriticalLoad a noria:ActionPreCondition ;
    rdfs:label "No Critical Load on Server"@en, "Pas de Charge Critique sur le Serveur"@fr ;
    rdfs:comment "Ensure the server is not handling critical production load before reboot."@en ;
    noria:operationPlanPreCondition noria:OperationPlan_ServerReboot .

noria:ActionPostCondition_ServerReboot_ServiceRestored a noria:ActionPostCondition ;
    rdfs:label "Service Restored After Reboot"@en, "Service Restauré Après Redémarrage"@fr ;
    rdfs:comment "Verify that all services on the server are operational after reboot."@en ;
    noria:operationPlanPostCondition noria:OperationPlan_ServerReboot .

noria:OperationPlan_NetworkInterfaceReset a noria:OperationPlan ;
    rdfs:label "Network Interface Reset Procedure"@en, "Procédure de Réinitialisation d'Interface Réseau"@fr ;
    rdfs:comment "Procedure to reset a network interface on a network device."@en .

noria:ActionPreCondition_NetworkInterfaceReset_ImpactAssessed a noria:ActionPreCondition ;
    rdfs:label "Network Impact Assessed"@en, "Impact Réseau Évalué"@fr ;
    rdfs:comment "Confirm potential network impact of interface reset has been assessed."@en ;
    noria:operationPlanPreCondition noria:OperationPlan_NetworkInterfaceReset .

noria:ActionPostCondition_NetworkInterfaceReset_LinkUp a noria:ActionPostCondition ;
    rdfs:label "Network Link Operational"@en, "Liaison Réseau Opérationnelle"@fr ;
    rdfs:comment "Verify that the network link associated with the interface is up and passing traffic."@en ;
    noria:operationPlanPostCondition noria:OperationPlan_NetworkInterfaceReset .

noria:OperationPlan_DBBackup a noria:OperationPlan ;
    rdfs:label "Database Backup Procedure"@en, "Procédure de Sauvegarde de Base de Données"@fr ;
    rdfs:comment "Standard procedure for performing a full database backup."@en .

noria:ActionPreCondition_DBBackup_StorageAvailable a noria:ActionPreCondition ;
    rdfs:label "Backup Storage Available"@en, "Stockage de Sauvegarde Disponible"@fr ;
    rdfs:comment "Ensure sufficient storage space is available for the backup."@en ;
    noria:operationPlanPreCondition noria:OperationPlan_DBBackup .

noria:ActionPostCondition_DBBackup_IntegrityVerified a noria:ActionPostCondition ;
    rdfs:label "Backup Integrity Verified"@en, "Intégrité de la Sauvegarde Vérifiée"@fr ;
    rdfs:comment "Confirm the integrity of the completed database backup."@en ;
    noria:operationPlanPostCondition noria:OperationPlan_DBBackup .

# --- Event Records ---

noria:EventRecord_Net_LinkDown_001 a noria:EventRecord ;
    rdfs:label "Network Link Down Alert - Core Router PDC1 Eth0"@en, "Alerte Liaison Réseau Hors Service - Routeur Cœur PDC1 Eth0"@fr ;
    rdfs:comment "Automated alert indicating a network interface went down."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-DOWN: Line protocol on Interface Ethernet0, changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_Router_Core_PDC1 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_NetworkInterfaceReset .

noria:EventRecord_DB_HighCPU_001 a noria:EventRecord ;
    rdfs:label "Database High CPU Alert - CRM DB1"@en, "Alerte CPU Élevé Base de Données - CRM DB1"@fr ;
    rdfs:comment "Alert for sustained high CPU utilization on CRM Database Server 1."@en ;
    noria:loggingTime "2024-04-20T11:15:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on crm-db01 exceeded 90% for 15 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_Server_CRM_DB1 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_App_ErrorRate_001 a noria:EventRecord ;
    rdfs:label "Application Error Rate Spike - CRM Prod"@en, "Pic de Taux d'Erreur Applicatif - CRM Prod"@fr ;
    rdfs:comment "Monitoring alert for a sudden increase in error rates for CRM Production module."@en ;
    noria:loggingTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:logText "CRM_PROD error rate increased to 15% (threshold 5%) in the last 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Application_CRM_System ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_Firewall_BlockedTraffic_001 a noria:EventRecord ;
    rdfs:label "Firewall Blocked Traffic Alert - Edge FW PDC1"@en, "Alerte Trafic Bloqué Pare-feu - Pare-feu de Bordure PDC1"@fr ;
    rdfs:comment "Alert indicating a high volume of blocked traffic on the edge firewall."@en ;
    noria:loggingTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:logText "High number of denied connections from external source 203.0.113.42 to DMZ."@en ;
    noria:logOriginatingManagedObject noria:Resource_Firewall_Edge_PDC1 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_VM_Offline_001 a noria:EventRecord ;
    rdfs:label "Virtual Machine Offline - ERP App VM 01"@en, "Machine Virtuelle Hors Ligne - VM App ERP 01"@fr ;
    rdfs:comment "Alert indicating that ERP Application VM 01 is no longer reachable."@en ;
    noria:loggingTime "2024-04-20T13:00:00Z"^^xsd:dateTime ;
    noria:logText "VM erp-app-vm01.example.com reported as offline by hypervisor."@en ;
    noria:logOriginatingManagedObject noria:Resource_VM_ERP_App_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_ServerReboot . # Assuming VM reboot is a proposed action

noria:EventRecord_UserLoginFailure_001 a noria:EventRecord ;
    rdfs:label "Repeated Login Failures - Customer Portal"@en, "Échecs de Connexion Répétés - Portail Client"@fr ;
    rdfs:comment "Security event: multiple failed login attempts for a customer account on the portal."@en ;
    noria:loggingTime "2024-04-20T14:00:00Z"^^xsd:dateTime ;
    noria:logText "User 'jdoe' failed login 5 times from IP 198.51.100.10."@en ;
    noria:logOriginatingManagedObject noria:Application_CustomerPortal ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logOriginatingAgent <http://example.com/user/jdoe> ; # Example of an external agent
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

