# --- Scaling up: Generating more entities for density and token count ---

# Let's generate more resources, interfaces, and links, and then more tickets and events.
# We'll use a simple numbering scheme for URIs and labels.

# More Resources (Servers, VMs, Network Devices)
# 20 more servers, 10 more routers, 10 more switches, 5 more firewalls, 5 more LBs, 20 more VMs
# Total new resources: 70
# Total resources so far: 9 + 70 = 79

# Servers (Dell R750, HP DL380)
@for $i from 1 to 20 {
    noria:Resource_Server_App_{$i} a noria:Resource ;
        rdfs:label "Application Server {$i}"@en, "Serveur Applicatif {$i}"@fr ;
        rdfs:comment "Generic application server instance."@en ;
        noria:resourceLogisticId "SRV-APP-{$i}" ;
        noria:resourceHostName "app-srv{$i}.example.com" ;
        noria:resourceProductModel noria:ProductModel_DellR750 ;
        noria:resourceType <kos/Resource/type/application-server> ;
        noria:resourceSerialNumber "DELLR750-SN{100 + $i}" ;
        noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
        noria:resourceInstallationDate "2023-06-01T10:00:00Z"^^xsd:dateTime ;
        noria:resourceManagedBy org:Team_AppSupportL2 ;
        noria:locatedAtLocus noria:Locus_DC_Paris_RackC12 ;
        noria:resourceForApplication noria:Application_CRM_System ; # Link to an existing application
        noria:resourceManagementIPAddress <http://example.com/ip/10.10.1.{$i + 20}> .

    noria:Resource_Server_DB_{$i} a noria:Resource ;
        rdfs:label "Database Server {$i}"@en, "Serveur Base de Données {$i}"@fr ;
        rdfs:comment "Generic database server instance."@en ;
        noria:resourceLogisticId "SRV-DB-{$i}" ;
        noria:resourceHostName "db-srv{$i}.example.com" ;
        noria:resourceProductModel noria:ProductModel_HPProLiantDL380 ;
        noria:resourceType <kos/Resource/type/database-server> ;
        noria:resourceSerialNumber "HPDL380-SN{200 + $i}" ;
        noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
        noria:resourceInstallationDate "2023-07-01T10:00:00Z"^^xsd:dateTime ;
        noria:resourceManagedBy org:Team_DBA ;
        noria:locatedAtLocus noria:Locus_DC_Paris_RackB5 ;
        noria:resourceForApplication noria:Application_ERP_Suite ; # Link to an existing application
        noria:resourceManagementIPAddress <http://example.com/ip/10.10.2.{$i + 20}> .
}

# Routers (Juniper MX204)
@for $i from 1 to 10 {
    noria:Resource_Router_Edge_{$i} a noria:Resource ;
        rdfs:label "Edge Router {$i}"@en, "Routeur de Bordure {$i}"@fr ;
        rdfs:comment "Edge router for regional connectivity."@en ;
        noria:resourceLogisticId "RT-EDGE-{$i}" ;
        noria:resourceHostName "edge-rt{$i}.example.com" ;
        noria:resourceProductModel noria:ProductModel_JuniperMX204 ;
        noria:resourceType <kos/Resource/type/router> ;
        noria:resourceSerialNumber "JPRMX204-SN{300 + $i}" ;
        noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
        noria:resourceInstallationDate "2023-08-01T10:00:00Z"^^xsd:dateTime ;
        noria:resourceManagedBy org:Team_NetOps ;
        noria:locatedAtLocus noria:Locus_RO_Lyon_ServerRack ; # Vary location
        noria:resourceManagementIPAddress <http://example.com/ip/10.0.1.{$i}> .
}

# Switches (Cisco 9300)
@for $i from 1 to 10 {
    noria:Resource_Switch_Dist_{$i} a noria:Resource ;
        rdfs:label "Distribution Switch {$i}"@en, "Commutateur de Distribution {$i}"@fr ;
        rdfs:comment "Distribution layer switch in data center."@en ;
