        noria:logText "Traffic on NL-PDC-INT-001 increased by 200% in 5 minutes."@en ;
        noria:logOriginatingManagedObject noria:NetworkLink_PDC_Internal_Core ;
        noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
        noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .
}

