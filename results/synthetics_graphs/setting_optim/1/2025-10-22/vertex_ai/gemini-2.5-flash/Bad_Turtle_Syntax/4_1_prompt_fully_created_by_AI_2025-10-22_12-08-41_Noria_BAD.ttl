        noria:troubleTicketTargetRestorationDateTime "2024-04-27T{15 + floor($i / 200)}:{($i % 60)}:00Z"^^xsd:dateTime ;
        noria:troubleTicketPlannedRestorationDateTime "2024-04-27T{13 + floor($i / 200)}:{($i % 60)}:00Z"^^xsd:dateTime ;
        noria:troubleTicketCommittedRestorationDateTime "2024-04-27T{16 + floor($i / 200)}:{($i % 60)}:00Z"^^xsd:dateTime ;
        noria:troubleTicketIsNotificationEnable true ;
