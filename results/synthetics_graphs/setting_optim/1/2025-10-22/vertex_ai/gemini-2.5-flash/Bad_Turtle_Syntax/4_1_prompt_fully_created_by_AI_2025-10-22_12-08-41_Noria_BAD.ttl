    noria:networkLinkTerminationResourceDestination noria:Resource_Switch_Access_PDC1_A1 ;
    noria:networkInterfaceConnects noria:NetworkInterface_Core_PDC1_Eth1 ;
    noria:networkInterfaceConnects noria:NetworkInterface_Switch_Access_PDC1_A1_G0_1 ;
    noria:resourceManagedBy org:Team_NetOps .

noria:NetworkLink_CRM_DB_App_Link a noria:NetworkLink ;
