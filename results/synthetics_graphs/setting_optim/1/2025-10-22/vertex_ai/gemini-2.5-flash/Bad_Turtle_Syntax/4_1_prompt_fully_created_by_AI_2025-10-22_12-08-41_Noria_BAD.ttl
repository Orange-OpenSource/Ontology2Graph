        rdfs:label "Generic Log Entry {$i}"@en, "Entrée de Journal Générique {$i}"@fr ;
        rdfs:comment "A routine log entry from a system."@en ;
        noria:loggingTime "2024-04-20T{15 + floor($i / 60)}:{($i % 60)}:00Z"^^xsd:dateTime ;
        noria:logText "System health check passed for resource {$i}."@en ;
        noria:logOriginatingManagedObject noria:Resource_Server_App_{($i % 20) + 1} ; # Link to a random app server
        noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
        noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .
}

# More Trouble Tickets
# 200 more tickets
@for $i from 1 to 200 {
    noria:TroubleTicket_TT20240421_{$i} a noria:TroubleTicket ;
        rdfs:label "Application Performance Issue {$i}"@en, "Problème de Performance Applicative {$i}"@fr ;
        rdfs:comment "Intermittent performance degradation reported for an application module."@en ;
        noria:documentExternalId "INC-2024-100{$i}" ;
        noria:documentHRef <http://ticketing.example.com/ticket/INC-2024-100{$i}> ;
        noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
        noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
        noria:troubleTicketCriticity <kos/TroubleTicket/category/CorruptedService> ;
        noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
        noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
        noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
        noria:troubleTicketSupervisionTool "Dynatrace" ;
        noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ApplicationPerformance> ;
        noria:problemCategory <kos/TroubleTicket/trouble-category/ApplicationPerformance> ;
        noria:troubleTicketCause "High latency in database queries" ;
        noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
        noria:troubleTicketDetectionDateTime "2024-04-21T{10 + floor($i / 10)}:{($i % 60)}:00Z"^^xsd:dateTime ;
        noria:troubleTicketTargetRestorationDateTime "2024-04-21T{12 + floor($i / 10)}:{($i % 60)}:00Z"^^xsd:dateTime ;
        noria:troubleTicketPlannedRestorationDateTime "2024-04-21T{11 + floor($i / 10)}:{($i % 60)}:00Z"^^xsd:dateTime ;
        noria:troubleTicketCommittedRestorationDateTime "2024-04-21T{13 + floor($i / 10)}:{($i % 60)}:00Z"^^xsd:dateTime ;
        noria:troubleTicketIsNotificationEnable true ;
        noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
        noria:troubleTicketRelatedService noria:ApplicationModule_CRM_Prod ; # Link to an existing module
        noria:troubleTicketRelatedResource noria:Resource_Server_DB_{($i % 20) + 1} ; # Link to a random DB server
        noria:troubleTicketRelatedParty org:Team_AppSupportL2 ;
        noria:troubleTicketTrigger noria:EventRecord_Generic_Log_{($i % 500) + 1} . # Link to a random event record

    noria:TroubleTicketNote_TT20240421_{$i}_Note1 a noria:TroubleTicketNote ;
        rdfs:label "Initial Report for TT20240421_{$i}"@en ;
        rdfs:comment "Customer reported slow application response. Initial checks show high database load."@en ;
        dcterms:isPartOf noria:TroubleTicket_TT20240421_{$i} ;
        noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Customer> ;
        noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .
}

