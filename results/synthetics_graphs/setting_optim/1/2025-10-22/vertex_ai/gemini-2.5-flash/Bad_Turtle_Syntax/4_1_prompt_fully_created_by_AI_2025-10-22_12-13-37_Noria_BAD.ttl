    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .
<%
    }
  }
%>

# For each of the 200 Virtual Machines, 1 interface
<%
  for (let i = 1; i <= 200; i++) {
    const resUri = `noria:Res_VM_App_${String(i).padStart(3, '0')}`;
    const hostname = `vm-app${String(i).padStart(3, '0')}`;
%>
noria:NI_<%= hostname %>_vNIC0 a noria:NetworkInterface ;
    rdfs:label "<%= hostname %> Virtual NIC 0"@en ;
    rdfs:comment "Primary virtual network interface for virtual machine <%= hostname %>.corp.example.com."@en ;
    noria:networkInterfaceOf <%= resUri %> ;
    noria:networkInterfaceDescription "Virtual NIC connected to virtual switch" ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .
<%
  }
%>

# --- Network Links ---

# Links between App Servers and Access Switches (100 links)
<%
  for (let i = 1; i <= 100; i++) {
    const appServerUri = `noria:Res_AppServer_${String(i).padStart(3, '0')}`;
    const appServerNI = `noria:NI_appserver${String(i).padStart(3, '0')}_Eth0`;
    const switchIndex = (i % 50) + 1;
    const accessSwitchUri = `noria:Res_Switch_Access_${String(switchIndex).padStart(2, '0')}`;
    const accessSwitchNI = `noria:NI_acc-sw${String(switchIndex).padStart(2, '0')}_Gi1_0_${String((i % 24) + 1).padStart(2, '0')}`;
    const linkId = `NL-APP${String(i).padStart(3, '0')}-SW${String(switchIndex).padStart(2, '0')}`;
    const installDate = `2023-01-${String((i % 28) + 1).padStart(2, '0')}T10:05:00Z`;
%>
noria:NetLink_<%= linkId %> a noria:NetworkLink ;
    rdfs:label "Link App Server <%= String(i).padStart(3, '0') %> to Access Switch <%= String(switchIndex).padStart(2, '0') %>"@en ;
    rdfs:comment "Physical Ethernet link connecting application server <%= String(i).padStart(3, '0') %> to access switch <%= String(switchIndex).padStart(2, '0') %>."@en ;
    noria:networkLinkId "<%= linkId %>" ;
    noria:networkLinkType "Ethernet 1Gbps" ;
    noria:networkLinkInstallationDate "<%= installDate %>"^^xsd:dateTime ;
    noria:networkInterfaceConnects <%= appServerNI %> ;
    noria:networkInterfaceConnects <%= accessSwitchNI %> ;
    noria:networkLinkTerminationResource <%= appServerUri %> ;
    noria:networkLinkTerminationResource <%= accessSwitchUri %> ;
    noria:resourceManagedBy noria:OrgUnit_NetOps .
<%
  }
%>

# Links between Access Switches and Core Routers (50 links)
<%
  for (let i = 1; i <= 50; i++) {
    const accessSwitchUri = `noria:Res_Switch_Access_${String(i).padStart(2, '0')}`;
    const accessSwitchNI = `noria:NI_acc-sw${String(i).padStart(2, '0')}_Uplink1`;
    const coreRouterIndex = (i % 30) + 1;
    const coreRouterUri = `noria:Res_Router_Core_${String(coreRouterIndex).padStart(2, '0')}`;
    const coreRouterNI = `noria:NI_rtr-core${String(coreRouterIndex).padStart(2, '0')}_Vlan10`; # Logical connection to SVI
    const linkId = `NL-SW${String(i).padStart(2, '0')}-RTR${String(coreRouterIndex).padStart(2, '0')}`;
    const installDate = `2022-03-${String((i % 28) + 1).padStart(2, '0')}T14:10:00Z`;
%>
noria:NetLink_<%= linkId %> a noria:NetworkLink ;
    rdfs:label "Link Access Switch <%= String(i).padStart(2, '0') %> to Core Router <%= String(coreRouterIndex).padStart(2, '0') %>"@en ;
    rdfs:comment "Uplink from access switch <%= String(i).padStart(2, '0') %> to core router <%= String(coreRouterIndex).padStart(2, '0') %>, carrying multiple VLANs."@en ;
    noria:networkLinkId "<%= linkId %>" ;
    noria:networkLinkType "Fiber Optic 10Gbps" ;
    noria:networkLinkInstallationDate "<%= installDate %>"^^xsd:dateTime ;
    noria:networkInterfaceConnects <%= accessSwitchNI %> ;
    noria:networkInterfaceConnects <%= coreRouterNI %> ;
    noria:networkLinkTerminationResource <%= accessSwitchUri %> ;
    noria:networkLinkTerminationResource <%= coreRouterUri %> ;
    noria:resourceManagedBy noria:OrgUnit_NetOps .
<%
  }
%>

# Links between Core Routers and ISPs (30 links)
<%
  for (let i = 1; i <= 30; i++) {
    const coreRouterUri = `noria:Res_Router_Core_${String(i).padStart(2, '0')}`;
    const coreRouterNI = `noria:NI_rtr-core${String(i).padStart(2, '0')}_Gi0_0_0`;
    const linkId = `NL-RTR${String(i).padStart(2, '0')}-ISPA`;
    const installDate = `2021-01-${String((i % 28) + 1).padStart(2, '0')}T09:15:00Z`;
%>
noria:NetLink_<%= linkId %> a noria:NetworkLink ;
    rdfs:label "Link Core Router <%= String(i).padStart(2, '0') %> to ISP A"@en ;
    rdfs:comment "External connectivity link from core router <%= String(i).padStart(2, '0') %> to Internet Service Provider A. This is a critical path for customer internet access."@en ;
    noria:networkLinkId "<%= linkId %>" ;
    noria:networkLinkType "MPLS VPN 100Mbps" ;
    noria:networkLinkInstallationDate "<%= installDate %>"^^xsd:dateTime ;
    noria:networkInterfaceConnects <%= coreRouterNI %> ;
    noria:networkLinkTerminationResource <%= coreRouterUri %> ;
    noria:resourceManagedBy noria:OrgUnit_NetOps .
<%
  }
%>

# Links between DB Servers and Storage Arrays (20 links)
<%
  for (let i = 1; i <= 20; i++) {
    const dbServerUri = `noria:Res_DBServer_Oracle_${String(i).padStart(2, '0')}`;
    const dbServerNI = `noria:NI_oradb${String(i).padStart(2, '0')}_Data`;
    const storageArrayIndex = (i % 5) + 1;
    const storageArrayUri = `noria:Res_Storage_Array_${String(storageArrayIndex).padStart(2, '0')}`;
    const linkId = `NL-DB${String(i).padStart(2, '0')}-SA${String(storageArrayIndex).padStart(2, '0')}`;
    const installDate = `2023-06-${String((i % 28) + 1).padStart(2, '0')}T10:15:00Z`;
%>
noria:NetLink_<%= linkId %> a noria:NetworkLink ;
    rdfs:label "Link DB Server <%= String(i).padStart(2, '0') %> to Storage Array <%= String(storageArrayIndex).padStart(2, '0') %>"@en ;
    rdfs:comment "High-speed Fibre Channel link connecting Oracle database server <%= String(i).padStart(2, '0') %> to NetApp storage array <%= String(storageArrayIndex).padStart(2, '0') %> for data access."@en ;
    noria:networkLinkId "<%= linkId %>" ;
    noria:networkLinkType "Fibre Channel 16Gbps" ;
    noria:networkLinkInstallationDate "<%= installDate %>"^^xsd:dateTime ;
    noria:networkInterfaceConnects <%= dbServerNI %> ;
    noria:networkLinkTerminationResource <%= dbServerUri %> ;
    noria:networkLinkTerminationResource <%= storageArrayUri %> ;
    noria:resourceManagedBy noria:OrgUnit_InfraOps .
<%
  }
%>

# --- Event Records ---

# Generating 2000 Event Records
<%
  for (let i = 1; i <= 2000; i++) {
    const eventType = (i % 5);
    let logText, alarmSeverity, originatingObject, originatingSystem, originatingAgent;
    let year = 2024;
    let month = String(Math.floor((i-1)/166) + 1).padStart(2, '0'); // Distribute over 12 months
    let day = String((i % 28) + 1).padStart(2, '0');
    let hour = String(Math.floor(Math.random() * 24)).padStart(2, '0');
    let minute = String(Math.floor(Math.random() * 60)).padStart(2, '0');
    let second = String(Math.floor(Math.random() * 60)).padStart(2, '0');
    const loggingTime = `${year}-${month}-${day}T${hour}:${minute}:${second}Z`;

    if (eventType === 0) { // CPU High Alert
      const resIndex = (i % 100) + 1;
      originatingObject = `noria:Res_AppServer_${String(resIndex).padStart(3, '0')}`;
      logText = `CPU_UTILIZATION_HIGH: Host appserver${String(resIndex).padStart(3, '0')}.corp.example.com, Metric cpu.util, Value ${90 + (i % 9)}%`;
      alarmSeverity = `<Notification/Severity/PerceivedSeverity/Major>`;
      originatingSystem = `noria:App_MonitoringPlatform`;
      originatingAgent = `noria:Agent_AutomatedMonitor`;
    } else if (eventType === 1) { // Link Down Alert
      const rtrIndex = (i % 30) + 1;
      originatingObject = `noria:Res_Router_Core_${String(rtrIndex).padStart(2, '0')}`;
      logText = `LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down on rtr-core${String(rtrIndex).padStart(2, '0')}.dc-par.example.com`;
      alarmSeverity = `<Notification/Severity/PerceivedSeverity/Critical>`;
      originatingSystem = `noria:App_MonitoringPlatform`;
      originatingAgent = `noria:Agent_AutomatedMonitor`;
    } else if (eventType === 2) { // Disk Full Alert
      const dbIndex = (i % 20) + 1;
      originatingObject = `noria:Res_DBServer_Oracle_${String(dbIndex).padStart(2, '0')}`;
      logText = `DISK_SPACE_CRITICAL: Host oradb${String(dbIndex).padStart(2, '0')}.corp.example.com, Filesystem /u01, Used ${95 + (i % 4)}%`;
      alarmSeverity = `<Notification/Severity/PerceivedSeverity/Major>`;
      originatingSystem = `noria:App_MonitoringPlatform`;
      originatingAgent = `noria:Agent_AutomatedMonitor`;
    } else if (eventType === 3) { // Firewall Blocked Traffic
      const fwIndex = (i % 10) + 1;
      originatingObject = `noria:Res_Firewall_DMZ_${String(fwIndex).padStart(2, '0')}`;
      logText = `FIREWALL_ALERT: High number of denied connections from external source ${Math.floor(Math.random() * 255)}.${Math.floor(Math.random() * 255)}.${Math.floor(Math.random() * 255)}.${Math.floor(Math.random() * 255)} to DMZ.`;
      alarmSeverity = `<Notification/Severity/PerceivedSeverity/Warning>`;
      originatingSystem = `noria:App_MonitoringPlatform`;
      originatingAgent = `noria:Agent_AutomatedMonitor`;
    } else { // VM Reboot Event
      const vmIndex = (i % 200) + 1;
      originatingObject = `noria:Res_VM_App_${String(vmIndex).padStart(3, '0')}`;
      logText = `VM_EVENT: Virtual machine vm-app${String(vmIndex).padStart(3, '0')} rebooted due to kernel panic.`;
      alarmSeverity = `<Notification/Severity/PerceivedSeverity/Minor>`;
      originatingSystem = `noria:App_VirtualizationPlatform`;
      originatingAgent = `noria:Agent_InfraEngineer_Charlie`;
    }
%>
noria:Event_<%= String(i).padStart(4, '0') %> a noria:EventRecord ;
    rdfs:label "Event Record <%= String(i).padStart(4, '0') %>: <%= logText.substring(0, 50) %>..."@en ;
    rdfs:comment "Detailed log entry for event <%= String(i).padStart(4, '0') %>. This record captures a specific occurrence within the IT infrastructure, providing context for troubleshooting and analysis."@en ;
    noria:loggingTime "<%= loggingTime %>"^^xsd:dateTime ;
    noria:logText "<%= logText %>" ;
    noria:logOriginatingManagedObject <%= originatingObject %> ;
    noria:logOriginatingManagementSystem <%= originatingSystem %> ;
    noria:logOriginatingAgent <%= originatingAgent %> ;
    noria:alarmSeverity <%= alarmSeverity %> .
<%
  }
%>

# --- Trouble Tickets ---

# Generating 200 Trouble Tickets
<%
  for (let i = 1; i <= 200; i++) {
    const severityType = (i % 4);
    let severity, ttType, criticity, priority, origin, urgency, problemResponsibility;
    let relatedService, relatedResource;
    let triggerEvent = `noria:Event_${String((i % 2000) + 1).padStart(4, '0')}`; // Link to a random event

    if (severityType === 0) { // Critical - CRM Outage
      severity = `<kos/TroubleTicket/severity/Critical>`;
      ttType = `<kos/TroubleTicket/type/Failure>`;
      criticity = `<kos/TroubleTicket/category/InterruptedService>`;
      priority = `<kos/TroubleTicket/priority/P1>`;
      origin = `<kos/TroubleTicket/origin/Supervision>`;
      urgency = `<kos/TroubleTicket/urgency/ImmediateIntervention>`;
      problemResponsibility = `<kos/TroubleTicket/problemResponsibility/NetworkTeam>`;
      relatedService = `noria:AppMod_CRM_Prod`;
      relatedResource = `noria:Res_Router_Core_${String((i % 30) + 1).padStart(2, '0')}`;
    } else if (severityType === 1) { // Major - DB Performance
      severity = `<kos/TroubleTicket/severity/Major>`;
      ttType = `<kos/TroubleTicket/type/PerformanceIssue>`;
      criticity = `<kos/TroubleTicket/category/DegradedPerformance>`;
      priority = `<kos/TroubleTicket/priority/P2>`;
      origin = `<kos/TroubleTicket/origin/Internal>`;
      urgency = `<kos/TroubleTicket/urgency/DeferredIntervention>`;
      problemResponsibility = `<kos/TroubleTicket/problemResponsibility/ApplicationTeam>`;
      relatedService = `noria:AppMod_DB_Prod_Cluster1`;
      relatedResource = `noria:Res_DBServer_Oracle_${String((i % 20) + 1).padStart(2, '0')}`;
    } else if (severityType === 2) { // Minor - VM Issue
      severity = `<kos/TroubleTicket/severity/Minor>`;
      ttType = `<kos/TroubleTicket/type/Assistance>`;
      criticity = `<kos/TroubleTicket/category/PartialOutage>`;
      priority = `<kos/TroubleTicket/priority/P3>`;
      origin = `<kos/TroubleTicket/origin/User>`;
      urgency = `<kos/TroubleTicket/urgency/DeferredIntervention>`;
      problemResponsibility = `<kos/TroubleTicket/problemResponsibility/InfrastructureTeam>`;
      relatedService = `noria:App_VirtualizationPlatform`;
      relatedResource = `noria:Res_VM_App_${String((i % 200) + 1).padStart(3, '0')}`;
    } else { // Warning - Security Alert
      severity = `<kos/TroubleTicket/severity/Warning>`;
      ttType = `<kos/TroubleTicket/type/Failure>`;
      criticity = `<kos/TroubleTicket/category/SecurityBreach>`;
      priority = `<kos/TroubleTicket/priority/P2>`;
      origin = `<kos/TroubleTicket/origin/Supervision>`;
      urgency = `<kos/TroubleTicket/urgency/ImmediateIntervention>`;
      problemResponsibility = `<kos/TroubleTicket/problemResponsibility/SecurityTeam>`;
      relatedService = `noria:App_CRM_System`;
      relatedResource = `noria:Res_Firewall_DMZ_${String((i % 10) + 1).padStart(2, '0')}`;
    }

    let year = 2024;
    let month = String(Math.floor((i-1)/16) + 1).padStart(2, '0'); // Distribute over 12 months
    let day = String((i % 28) + 1).padStart(2, '0');
    let hour = String(Math.floor(Math.random() * 24)).padStart(2, '0');
    let minute = String(Math.floor(Math.random() * 60)).padStart(2, '0');
    let second = String(Math.floor(Math.random() * 60)).padStart(2, '0');
    const detectionTime = `${year}-${month}-${day}T${hour}:${minute}:${second}Z`;
    const targetRestorationTime = `${year}-${month}-${day}T${String(parseInt(hour) + 2).padStart(2, '0')}:${minute}:${second}Z`;
    const plannedRestorationTime = `${year}-${month}-${day}T${String(parseInt(hour) + 1).padStart(2, '0')}:${minute}:${second}Z`;
    const committedRestorationTime = `${year}-${month}-${day}T${String(parseInt(hour) + 3).padStart(2, '0')}:${minute}:${second}Z`;
    const status = (i % 3 === 0) ? `<kos/TroubleTicket/status/Resolved>` : `<kos/TroubleTicket/status/InProgress>`;
    const externalId = `INC-${String(i).padStart(4, '0')}`;
%>
noria:TT_<%= externalId %> a noria:TroubleTicket ;
    rdfs:label "Trouble Ticket <%= externalId %>: <%= criticity.split('/').pop() %> on <%= relatedService.split('/').pop() %>"@en, "Ticket Incident <%= externalId %>: <%= criticity.split('/').pop() %> sur <%= relatedService.split('/').pop() %>"@fr ;
    rdfs:comment "This trouble ticket documents an incident affecting <%= relatedService.split('/').pop() %> due to a <%= criticity.split('/').pop() %> event. Initial diagnosis points to an issue with <%= relatedResource.split('/').pop() %>."@en ;
    noria:documentExternalId "<%= externalId %>" ;
    noria:documentHRef <https://ticketing.example.com/<%= externalId %>> ;
    noria:troubleTicketSeverity <%= severity %> ;
    noria:troubleTicketType <%= ttType %> ;
    noria:troubleTicketCriticity <%= criticity %> ;
    noria:troubleTicketPriority <%= priority %> ;
    noria:troubleTicketOrigin <%= origin %> ;
    noria:troubleTicketTrigger <%= triggerEvent %> ;
    noria:troubleTicketUrgency <%= urgency %> ;
    noria:troubleTicketSupervisionTool "Zabbix" ;
    noria:troubleTicketCategory <%= criticity %> ;
    noria:troubleTicketCause "Root cause analysis is ongoing, but initial indicators suggest a problem with <%= relatedResource.split('/').pop() %>."@en ;
    noria:problemResponsibility <%= problemResponsibility %> ;
    noria:troubleTicketDetectionDateTime "<%= detectionTime %>"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "<%= targetRestorationTime %>"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "<%= plannedRestorationTime %>"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "<%= committedRestorationTime %>"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <%= status %> ;
    noria:troubleTicketRelatedParty noria:OrgUnit_NetOps, noria:OrgUnit_AppSupportL2 ;
    noria:troubleTicketRelatedService <%= relatedService %> ;
    noria:troubleTicketRelatedResource <%= relatedResource %> .
<%
  }
%>

# --- Trouble Ticket Notes ---

# Generating 500 Trouble Ticket Notes
<%
  for (let i = 1; i <= 500; i++) {
    const ttIndex = (i % 200) + 1;
    const ttUri = `noria:TT_INC-${String(ttIndex).padStart(4, '0')}`;
    const commentType = (i % 3);
    let noteCommentType, noteOperationType, creatorAgent;

    if (commentType === 0) {
      noteCommentType = `<kos/TroubleTicket/commentType/Internal>`;
      noteOperationType = `<kos/TroubleTicket/operationType/Diagnosis>`;
      creatorAgent = `noria:Agent_JohnDoe`;
    } else if (commentType === 1) {
      noteCommentType = `<kos/TroubleTicket/commentType/CustomerFacing>`;
      noteOperationType = `<kos/TroubleTicket/operationType/Communication>`;
      creatorAgent = `noria:Agent_JaneSmith`;
    } else {
      noteCommentType = `<kos/TroubleTicket/commentType/SystemGenerated>`;
      noteOperationType = `<kos/TroubleTicket/operationType/Verification>`;
      creatorAgent = `noria:Agent_AutomatedMonitor`;
    }

    let year = 2024;
    let month = String(Math.floor((i-1)/41) + 1).padStart(2, '0');
    let day = String((i % 28) + 1).padStart(2, '0');
    let hour = String(Math.floor(Math.random() * 24)).padStart(2, '0');
    let minute = String(Math.floor(Math.random() * 60)).padStart(2, '0');
    let second = String(Math.floor(Math.random() * 60)).padStart(2, '0');
    const noteTime = `${year}-${month}-${day}T${hour}:${minute}:${second}Z`;
    const correlatedEvent = `noria:Event_${String((i % 2000) + 1).padStart(4, '0')}`;
%>
noria:TTNote_<%= String(i).padStart(4, '0') %> a noria:TroubleTicketNote ;
    rdfs:label "Trouble Ticket Note <%= String(i).padStart(4, '0') %> for <%= ttUri.split('/').pop() %>"@en ;
    rdfs:comment "This note provides an update on the progress of trouble ticket <%= ttUri.split('/').pop() %>. It details the actions taken, observations made, or communications exchanged regarding the incident."@en ;
    dcterms:isPartOf <%= ttUri %> ;
    dcterms:created "<%= noteTime %>"^^xsd:dateTime ;
    dcterms:creator <%= creatorAgent %> ;
    noria:troubleTicketNoteCommentType <%= noteCommentType %> ;
    noria:troubleTicketNoteOperationType <%= noteOperationType %> ;
    noria:troubleTicketNoteCorrelatedExecution <%= correlatedEvent %> .
<%
  }
%>

# --- Change Requests ---

# Generating 50 Change Requests
<%
  for (let i = 1; i <= 50; i++) {
    const crType = (i % 3);
    let category, type, cause, initiator, pilot, actor;
    let impactResource, impactApplication, impactService;

    if (crType === 0) { // Software Upgrade
      category = `<kos/ChangeRequest/category/InternalIntervention>`;
      type = `<kos/ChangeRequest/type/Normal>`;
      cause = `<kos/ChangeRequest/cause/SoftwareUpgrade>`;
      initiator = `noria:Agent_JohnDoe`;
      pilot = `noria:Agent_JohnDoe`;
      actor = `noria:OrgUnit_NetOps`;
      impactResource = `noria:Res_Router_Core_${String((i % 30) + 1).padStart(2, '0')}`;
      impactApplication = `noria:App_MonitoringPlatform`;
      impactService = `noria:Service_CustomerInternetAccess`;
    } else if (crType === 1) { // Hardware Replacement
      category = `<kos/ChangeRequest/category/InternalIntervention>`;
      type = `<kos/ChangeRequest/type/Normal>`;
      cause = `<kos/ChangeRequest/cause/HardwareReplacement>`;
      initiator = `noria:Agent_InfraEngineer_Charlie`;
      pilot = `noria:Agent_InfraEngineer_Charlie`;
      actor = `noria:OrgUnit_InfraOps`;
      impactResource = `noria:Res_Hypervisor_Host_${String((i % 10) + 1).padStart(2, '0')}`;
      impactApplication = `noria:App_VirtualizationPlatform`;
      impactService = `noria:Service_DataBackup`;
    } else { // Configuration Change
      category = `<kos/ChangeRequest/category/CustomerIntervention>`;
      type = `<kos/ChangeRequest/type/Standard>`;
      cause = `<kos/ChangeRequest/cause/Configuration>`;
      initiator = `noria:Agent_JaneSmith`;
      pilot = `noria:Agent_JaneSmith`;
      actor = `noria:OrgUnit_AppSupportL2`;
      impactResource = `noria:Res_AppServer_${String((i % 100) + 1).padStart(3, '0')}`;
      impactApplication = `noria:App_CRM_System`;
      impactService = `noria:Service_CustomerInternetAccess`;
    }

    let year = 2024;
    let month = String(Math.floor((i-1)/4) + 1).padStart(2, '0');
    let day = String((i % 28) + 1).padStart(2, '0');
    let plannedStartHour = String(Math.floor(Math.random() * 2) + 2).padStart(2, '0'); // 02:00-03:00
    let plannedEndHour = String(parseInt(plannedStartHour) + 2).padStart(2, '0'); // 04:00-05:00
    let actualStartHour = String(parseInt(plannedStartHour) + (Math.random() > 0.5 ? 0 : 1)).padStart(2, '0');
    let actualEndHour = String(parseInt(plannedEndHour) + (Math.random() > 0.5 ? 0 : 1)).padStart(2, '0');
    let minute = String(Math.floor(Math.random() * 60)).padStart(2, '0');
    let second = String(Math.floor(Math.random() * 60)).padStart(2, '0');

    const plannedStartTime = `${year}-${month}-${day}T${plannedStartHour}:${minute}:${second}Z`;
    const plannedEndTime = `${year}-${month}-${day}T${plannedEndHour}:${minute}:${second}Z`;
    const actualStartTime = `${year}-${month}-${day}T${actualStartHour}:${minute}:${second}Z`;
    const actualEndTime = `${year}-${month}-${day}T${actualEndHour}:${minute}:${second}Z`;
    const status = (i % 2 === 0) ? `<kos/ChangeRequest/status/Completed>` : `<kos/ChangeRequest/status/Planned>`;
    const externalId = `CR-${String(i).padStart(3, '0')}`;
    const outageDuration = `PT${Math.floor(Math.random() * 4) + 1}H` ; // 1-4 hours
%>
noria:CR_<%= externalId %> a noria:ChangeRequest ;
    rdfs:label "Change Request <%= externalId %>: <%= cause.split('/').pop() %> on <%= impactResource.split('/').pop() %>"@en, "Demande de Changement <%= externalId %>: <%= cause.split('/').pop() %> sur <%= impactResource.split('/').pop() %>"@fr ;
    rdfs:comment "This change request outlines a planned <%= cause.split('/').pop() %> activity on <%= impactResource.split('/').pop() %>. The change aims to <%= (crType === 0 ? 'upgrade software for security and performance' : (crType === 1 ? 'replace faulty hardware' : 'implement a new configuration')) %>."@en ;
    noria:documentExternalId "<%= externalId %>" ;
    noria:documentHRef <https://changemgmt.example.com/<%= externalId %>> ;
    noria:changeRequestPlannedStartTime "<%= plannedStartTime %>"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "<%= plannedEndTime %>"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "<%= actualStartTime %>"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "<%= actualEndTime %>"^^xsd:dateTime ;
    noria:changeRequestCategory <%= category %> ;
    noria:changeRequestType <%= type %> ;
    noria:changeRequestChangeCause <%= cause %> ;
    noria:changeRequestImpact <%= impactResource %>, <%= impactApplication %>, <%= impactService %> ;
    noria:changeRequestOutageDuration "<%= outageDuration %>"^^xsd:duration ;
    noria:changeRequestStatusCurrent <%= status %> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/RoutineMaintenance> ;
    noria:changeRequestInitiatorParty <%= initiator %> ;
    noria:changeRequestPilotParty <%= pilot %> ;
    noria:changeRequestActorParty <%= actor %> ;
    noria:changeRequestIsRegulated true .
<%
  }
%>

# --- Operation Plans, Pre/Post Conditions ---

noria:OpPlan_CheckFiberLink a noria:OperationPlan ;
    rdfs:label "Check Fiber Link Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving fiber optic link issues. Includes steps for visual inspection, optical power measurement, and cable replacement."@en ;
    noria:operationPlanPreCondition noria:PreCond_FiberLinkDown ;
    noria:operationPlanPostCondition noria:PostCond_FiberLinkUp .

noria:PreCond_FiberLinkDown a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Down Pre-Condition"@en ;
    rdfs:comment "Condition: Network interface operational status is 'Down' and administrative status is 'Up', indicating a physical layer issue. Alarm severity is Critical or Major."@en ;
    skos:example "Interface Gi0/0/0 on core-rtr01 reports 'link down' but is administratively enabled. Associated alarm: Event_0002."@en .

noria:PostCond_FiberLinkUp a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Up Post-Condition"@en ;
    rdfs:comment "Condition: Network interface operational status is 'Up', traffic flow is restored, and optical power levels are within acceptable thresholds. No packet loss observed."@en ;
    skos:example "Interface Gi0/0/0 on core-rtr01 reports 'link up' and ping to external gateway is successful. Optical power Rx: -5dBm, Tx: -3dBm."@en .

noria:OpPlan_ClearDBLogs a noria:OperationPlan ;
    rdfs:label "Clear Database Logs Procedure"@en ;
    rdfs:comment "Procedure to safely clear old database archive logs to free up disk space. Involves identifying and archiving logs before deletion to ensure recoverability."@en ;
    noria:operationPlanPreCondition noria:PreCond_DBDiskFull ;
    noria:operationPlanPostCondition noria:PostCond_DBDiskSpaceOK .

noria:PreCond_DBDiskFull a noria:ActionPreCondition ;
    rdfs:label "Database Disk Full Pre-Condition"@en ;
    rdfs:comment "Condition: Database filesystem utilization exceeds 90%, leading to potential database stalls or crashes. Monitoring alert received."@en ;
    skos:example "Filesystem /u01 on oradb01 is 98% full. Associated alarm: Event_0003."@en .

noria:PostCond_DBDiskSpaceOK a noria:ActionPostCondition ;
    rdfs:label "Database Disk Space OK Post-Condition"@en ;
    rdfs:comment "Condition: Database filesystem utilization is below 80% and database operations are normal. No new disk full alerts generated for 30 minutes."@en ;
    skos:example "Filesystem /u01 on oradb01 is 60% full after log cleanup. Database performance metrics are stable."@en .

noria:OpPlan_VM_Reboot a noria:OperationPlan ;
    rdfs:label "Virtual Machine Reboot Procedure"@en ;
    rdfs:comment "Standard procedure for safely rebooting a virtual machine. Includes steps for notifying users, checking dependencies, and verifying service restoration."@en ;
    noria:operationPlanPreCondition noria:PreCond_VM_Unresponsive ;
    noria:operationPlanPostCondition noria:PostCond_VM_Running .

noria:PreCond_VM_Unresponsive a noria:ActionPreCondition ;
    rdfs:label "VM Unresponsive Pre-Condition"@en ;
    rdfs:comment "Condition: Virtual machine is unresponsive to ping or SSH, and application hosted on it is down. No other underlying infrastructure issues detected."@en ;
    skos:example "VM vm-app001.corp.example.com is not responding to network requests. Application status is 'Down'."@en .

noria:PostCond_VM_Running a noria:ActionPostCondition ;
    rdfs:label "VM Running Post-Condition"@en ;
    rdfs:comment "Condition: Virtual machine has successfully rebooted, is reachable on the network, and the hosted application is running and accessible."@en ;
    skos:example "VM vm-app001.corp.example.com is up and running. Application 'CRM Web' is accessible."@en .

# --- Linking Event Records to Operation Plans (as actions) ---
# Generating 100 Event Records representing execution of Operation Plans
<%
  for (let i = 1; i <= 100; i++) {
    const opPlanType = (i % 3);
    let opPlan, originatingObject, originatingAgent, logText;

    if (opPlanType === 0) { // Fiber Link Check
      opPlan = `noria:OpPlan_CheckFiberLink`;
      originatingObject = `noria:Res_Router_Core_${String((i % 30) + 1).padStart(2, '0')}`;
      originatingAgent = `noria:Agent_JohnDoe`;
      logText = `Executed 'Check Fiber Link Procedure' on interface Gi0/0/0 of rtr-core${String((i % 30) + 1).padStart(2, '0')}. Optical power levels verified.`;
    } else if (opPlanType === 1) { // DB Log Cleanup
      opPlan = `noria:OpPlan_ClearDBLogs`;
      originatingObject = `noria:Res_DBServer_Oracle_${String((i % 20) + 1).padStart(2, '0')}`;
      originatingAgent = `noria:Agent_DBA_Alice`;
      logText = `Executed 'Clear Database Logs Procedure' on oradb${String((i % 20) + 1).padStart(2, '0')}. Disk space recovered on /u01.`;
    } else { // VM Reboot
      opPlan = `noria:OpPlan_VM_Reboot`;
      originatingObject = `noria:Res_VM_App_${String((i % 200) + 1).padStart(3, '0')}`;
      originatingAgent = `noria:Agent_InfraEngineer_Charlie`;
      logText = `Executed 'Virtual Machine Reboot Procedure' for vm-app${String((i % 200) + 1).padStart(3, '0')}. VM is now responsive.`;
    }

    let year = 2024;
    let month = String(Math.floor((i-1)/8) + 1).padStart(2, '0');
    let day = String((i % 28) + 1).padStart(2, '0');
    let hour = String(Math.floor(Math.random() * 24)).padStart(2, '0');
    let minute = String(Math.floor(Math.random() * 60)).padStart(2, '0');
    let second = String(Math.floor(Math.random() * 60)).padStart(2, '0');
    const loggingTime = `${year}-${month}-${day}T${hour}:${minute}:${second}Z`;
%>
noria:Event_Execution_<%= String(i).padStart(3, '0') %> a noria:EventRecord ;
    rdfs:label "Execution Event <%= String(i).padStart(3, '0') %>: <%= opPlan.split('/').pop() %>"@en ;
    rdfs:comment "This event record documents the execution of the operation plan '<%= opPlan.split('/').pop() %>' by <%= originatingAgent.split('/').pop() %> on <%= originatingObject.split('/').pop() %>."@en ;
    noria:loggingTime "<%= loggingTime %>"^^xsd:dateTime ;
    noria:logText "<%= logText %>" ;
    noria:logOriginatingManagedObject <%= originatingObject %> ;
    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logOriginatingAgent <%= originatingAgent %> ;
    noria:actionCorrelatedOperationPlan <%= opPlan %> .
<%
  }
%>

# --- Document Status History (linking TT/CR to EventRecords) ---
# Generating 300 status history events for Trouble Tickets and Change Requests
<%
  for (let i = 1; i <= 300; i++) {
    const docType = (i % 2);
    let docUri, docIdPrefix, docLabelPrefix;
    let status;

    if (docType === 0) { // Trouble Ticket
      const ttIndex = (i % 200) + 1;
      docUri = `noria:TT_INC-${String(ttIndex).padStart(4, '0')}`;
      docIdPrefix = `INC-${String(ttIndex).padStart(4, '0')}`;
      docLabelPrefix = `Trouble Ticket ${docIdPrefix}`;
      status = (i % 3 === 0) ? "Resolved" : "InProgress";
    } else { // Change Request
      const crIndex = (i % 50) + 1;
      docUri = `noria:CR_CR-${String(crIndex).padStart(3, '0')}`;
      docIdPrefix = `CR-${String(crIndex).padStart(3, '0')}`;
      docLabelPrefix = `Change Request ${docIdPrefix}`;
      status = (i % 3 === 0) ? "Completed" : "Approved";
    }

    let year = 2024;
    let month = String(Math.floor((i-1)/25) + 1).padStart(2, '0');
    let day = String((i % 28) + 1).padStart(2, '0');
    let hour = String(Math.floor(Math.random() * 24)).padStart(2, '0');
    let minute = String(Math.floor(Math.random() * 60)).padStart(2, '0');
    let second = String(Math.floor(Math.random() * 60)).padStart(2, '0');
    const loggingTime = `${year}-${month}-${day}T${hour}:${minute}:${second}Z`;
%>
noria:Event_DocStatus_<%= String(i).padStart(4, '0') %> a noria:EventRecord ;
    rdfs:label "<%= docLabelPrefix %> Status: <%= status %>"@en ;
    rdfs:comment "Status change event for <%= docLabelPrefix %> to '<%= status %>'. This event is automatically logged by the ticketing/change management system."@en ;
    noria:loggingTime "<%= loggingTime %>"^^xsd:dateTime ;
    noria:logText "<%= docLabelPrefix %> status changed to <%= status %>." ;
    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logOriginatingAgent noria:Agent_AutomatedMonitor ;
    dcterms:references <%= docUri %> .

<%= docUri %> noria:documentStatusHistory noria:Event_DocStatus_<%= String(i).padStart(4, '0') %> .
<%
  }
%>

# --- Document Attachments ---
# Generating 50 Document Attachments
<%
  for (let i = 1; i <= 50; i++) {
    const docType = (i % 2);
    let parentDocUri, parentDocId;
    let title, description, format;

    if (docType === 0) { // Attached to Trouble Ticket
      const ttIndex = (i % 200) + 1;
      parentDocUri = `noria:TT_INC-${String(ttIndex).padStart(4, '0')}`;
      parentDocId = `INC-${String(ttIndex).padStart(4, '0')}`;
      title = `Trouble Ticket ${parentDocId} Log Analysis`;
      description = `Detailed log analysis report for trouble ticket ${parentDocId}.`;
      format = "application/pdf";
    } else { // Attached to Change Request
      const crIndex = (i % 50) + 1;
      parentDocUri = `noria:CR_CR-${String(crIndex).padStart(3, '0')}`;
      parentDocId = `CR-${String(crIndex).padStart(3, '0')}`;
      title = `Change Request ${parentDocId} Implementation Plan`;
      description = `Step-by-step implementation plan for change request ${parentDocId}.`;
      format = "application/vnd.openxmlformats-officedocument.wordprocessingml.document";
    }

    let year = 2024;
    let month = String(Math.floor((i-1)/4) + 1).padStart(2, '0');
    let day = String((i % 28) + 1).padStart(2, '0');
    let hour = String(Math.floor(Math.random() * 24)).padStart(2, '0');
    let minute = String(Math.floor(Math.random() * 60)).padStart(2, '0');
    let second = String(Math.floor(Math.random() * 60)).padStart(2, '0');
    const createdTime = `${year}-${month}-${day}T${hour}:${minute}:${second}Z`;
%>
noria:DocAttach_<%= String(i).padStart(3, '0') %> a noria:DocumentAttachment ;
    rdfs:label "Document Attachment <%= String(i).padStart(3, '0') %>: <%= title %>"@en ;
    rdfs:comment "This document attachment provides supplementary information for <%= parentDocId %>. It contains <%= description.toLowerCase() %>."@en ;
    dcterms:created "<%= createdTime %>"^^xsd:dateTime ;
    dcterms:format "<%= format %>" ;
    dcterms:title "<%= title %>" ;
    dcterms:description "<%= description %>" ;
    dcterms:isPartOf <%= parentDocUri %> .
<%
  }
%>
