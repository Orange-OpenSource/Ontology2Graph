    const app = appIndex === 1 ? noria:App_CRM_System : (appIndex === 2 ? noria:App_ERP_Suite : noria:App_MonitoringPlatform);
    const appMod = appIndex === 1 ? noria:AppMod_CRM_Prod : (appIndex === 2 ? noria:AppMod_ERP_Finance_Prod : noria:AppMod_Monitoring_Core);
    const locusIndex = (i % 200) + 1; // Distribute across 200 Locus in SRA
    const locusLine = Math.floor((locusIndex - 1) / 20) + 1;
    const locusCol = ((locusIndex - 1) % 20) + 1;
    const ipLastOctet = 100 + i;
    const ipSecondOctet = Math.floor(i / 25) + 1;
    const hostname = `appserver${String(i).padStart(3, '0')}`;
    const serial = `DELL-SN-APP${String(i).padStart(3, '0')}`;
