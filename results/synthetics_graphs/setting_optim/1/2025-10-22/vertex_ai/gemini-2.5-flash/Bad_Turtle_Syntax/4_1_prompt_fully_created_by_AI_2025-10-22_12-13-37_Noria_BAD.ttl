# --- Organizational Units and Agents ---

noria:OrgUnit_NetOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for the daily operation and maintenance of the network infrastructure, including routers, switches, and firewalls. They ensure network availability and performance."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation (3 shifts)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical network issues (P1/P2), call the hotline immediately. For non-critical issues (P3/P4), open a ticket in the network management system. Ensure detailed logs are attached."@en .

noria:OrgUnit_AppSupportL2 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support L2 Team"@en, "Équipe Support Applicatif N2"@fr ;
    rdfs:comment "Second-level support team for business-critical applications. They handle complex application incidents and problems, often requiring deep technical knowledge of the application stack."@en ;
    noria:agentWorkingHours "8:00 - 18:00 Mon-Fri, On-call for critical applications"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "All application issues must be logged in the ticketing system with appropriate severity. Escalation to L3 (development team or vendor) via specific procedure documented in the internal wiki."@en .

noria:OrgUnit_SecurityTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Cyber Security Operations Center (CSOC)"@en, "Centre d'Opérations de Cybersécurité (CSOC)"@fr ;
    rdfs:comment "Team responsible for monitoring, detecting, analyzing, and responding to cybersecurity incidents. They manage security tools, perform vulnerability assessments, and enforce security policies."@en ;
    noria:agentWorkingHours "24/7 Dedicated Team with incident response capabilities"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email>, <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Report all suspected security incidents via the dedicated security portal and email to 'security-incident@example.com'. For active attacks, call the security hotline immediately."@en .

noria:OrgUnit_DBA_Team a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en, "Équipe Administration Bases de Données"@fr ;
    rdfs:comment "Team managing all corporate database systems, ensuring performance, availability, and security. This includes Oracle, SQL Server, and PostgreSQL databases."@en ;
    noria:agentWorkingHours "9:00 - 17:00 Mon-Fri, On-call for critical issues (P1/P2)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "For database performance issues, open a P2 ticket. For outages or data corruption, call the on-call DBA immediately. Provide database logs and relevant application context."@en .

noria:OrgUnit_InfraOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Infrastructure Operations Team"@en, "Équipe Opérations Infrastructure"@fr ;
    rdfs:comment "Team responsible for server hardware, virtualization platforms, and storage systems. They ensure the underlying infrastructure for applications is stable and performant."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For hardware failures or virtualization platform issues, contact the InfraOps hotline. For routine requests, use the ticketing system."@en .

noria:OrgUnit_DevTeam_CRM a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "CRM Development Team"@en, "Équipe Développement CRM"@fr ;
    rdfs:comment "Software development team responsible for the CRM application lifecycle, including new features, bug fixes, and architecture."@en ;
    noria:agentWorkingHours "9:00 - 18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    noria:agentInstructions "Escalations from L2 support should be via the dedicated Slack channel or Jira tickets. Avoid direct calls unless it's a P1 incident."@en .

noria:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Senior Network Engineer, member of the Network Operations Team. Specializes in routing protocols and firewall management."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Lefevre"@fr ;
    rdfs:comment "Lead Application Support Engineer, member of the Application Support L2 Team. Expert in CRM and ERP application troubleshooting."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

noria:Agent_AutomatedMonitor a foaf:Agent ;
    rdfs:label "Automated Monitoring System"@en ;
    rdfs:comment "Automated system responsible for generating alerts and events based on predefined thresholds and rules. It integrates with various infrastructure and application monitoring tools."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> .

noria:Agent_DBA_Alice a foaf:Agent ;
    rdfs:label "Alice Wonderland"@en ;
    rdfs:comment "Database Administrator, specializing in Oracle databases and performance tuning. Part of the DBA Team."@en ;
    foaf:mbox <mailto:alice.wonderland@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:Agent_SecurityAnalyst_Bob a foaf:Agent ;
