    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Site_RO_Lyon a bot:Site ;
    rdfs:label "Lyon Regional Office"@en, "Bureau Régional de Lyon"@fr ;
    rdfs:comment "Regional office hosting local services, user workstations, and a small server room for branch applications."@en ;
    noria:siteId "RO-LYN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddressStreet "45 Avenue Jean Jaures" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Site_DR_Marseille a bot:Site ;
    rdfs:label "Marseille Disaster Recovery Site"@en, "Site de Reprise après Sinistre de Marseille"@fr ;
    rdfs:comment "Secondary data center for disaster recovery and business continuity, hosting replicated critical services."@en ;
    noria:siteId "DR-MRS-01" ;
    noria:siteType "disaster recovery site" ;
    noria:sitePrincipalAddressStreet "8 Boulevard de la Liberté" ;
    noria:sitePrincipalAddressCityName "Marseille" ;
    noria:sitePrincipalAddressPostalCode "13001" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_DC_Paris_ServerRoom_A a noria:Room ;
    rdfs:label "Paris DC Server Room A"@en, "Salle Serveurs DC Paris A"@fr ;
    rdfs:comment "Main server room in the Paris Data Center, housing application servers, database servers, and storage arrays."@en ;
    bot:hasSpace noria:Site_DC_Paris .

noria:Room_DC_Paris_NetworkRoom_B a noria:Room ;
    rdfs:label "Paris DC Network Room B"@en, "Salle Réseau DC Paris B"@fr ;
    rdfs:comment "Dedicated network equipment room in the Paris Data Center, containing core routers, switches, and firewalls."@en ;
    bot:hasSpace noria:Site_DC_Paris .

noria:Room_RO_Lyon_CommsRoom_1 a noria:Room ;
    rdfs:label "Lyon RO Comms Room 1"@en, "Salle Comms RO Lyon 1"@fr ;
    rdfs:comment "Communication equipment room in the Lyon Regional Office, hosting edge routers, access switches, and local servers."@en ;
    bot:hasSpace noria:Site_RO_Lyon .

noria:Room_DR_Marseille_ServerRoom_C a noria:Room ;
    rdfs:label "Marseille DR Server Room C"@en, "Salle Serveurs DR Marseille C"@fr ;
    rdfs:comment "Server room in the Marseille DR site, containing replicated application and database servers."@en ;
    bot:hasSpace noria:Site_DR_Marseille .

# Generating 200 Locus entities for Paris DC Server Room A
# (L1C1 to L10C20)
<%
  for (let i = 1; i <= 10; i++) {
    for (let j = 1; j <= 20; j++) {
%>
noria:Locus_DC_Paris_SRA_L<%= i %>C<%= j %> a noria:Locus ;
    rdfs:label "Locus L<%= i %>C<%= j %> in Paris DC Server Room A"@en ;
    rdfs:comment "Specific location for rack L<%= i %>, column C<%= j %> within Paris DC Server Room A. This locus is designed to host high-density server equipment."@en ;
    noria:locusLine "L<%= i %>" ;
    noria:locusRow "C<%= j %>" ;
    bot:containsZone noria:Room_DC_Paris_ServerRoom_A .
<%
    }
  }
%>

# Generating 100 Locus entities for Paris DC Network Room B
# (R1S1 to R5S20)
<%
  for (let i = 1; i <= 5; i++) {
    for (let j = 1; j <= 20; j++) {
%>
noria:Locus_DC_Paris_NRB_R<%= i %>S<%= j %> a noria:Locus ;
    rdfs:label "Locus R<%= i %>S<%= j %> in Paris DC Network Room B"@en ;
    rdfs:comment "Specific location for rack R<%= i %>, shelf S<%= j %> within Paris DC Network Room B. Primarily used for network devices like routers, switches, and firewalls."@en ;
    noria:locusLine "R<%= i %>" ;
    noria:locusRow "S<%= j %>" ;
    bot:containsZone noria:Room_DC_Paris_NetworkRoom_B .
<%
    }
  }
%>

# Generating 50 Locus entities for Lyon RO Comms Room 1
# (C1U1 to C5U10)
<%
  for (let i = 1; i <= 5; i++) {
    for (let j = 1; j <= 10; j++) {
%>
noria:Locus_RO_Lyon_CR1_C<%= i %>U<%= j %> a noria:Locus ;
    rdfs:label "Locus C<%= i %>U<%= j %> in Lyon RO Comms Room 1"@en ;
    rdfs:comment "Specific location for cabinet C<%= i %>, unit U<%= j %> within Lyon RO Comms Room 1. This room hosts local network and server equipment for the regional office."@en ;
    noria:locusLine "C<%= i %>" ;
    noria:locusRow "U<%= j %>" ;
    bot:containsZone noria:Room_RO_Lyon_CommsRoom_1 .
<%
    }
  }
%>

# Generating 100 Locus entities for Marseille DR Server Room C
# (DR1R1 to DR5R20)
<%
  for (let i = 1; i <= 5; i++) {
    for (let j = 1; j <= 20; j++) {
%>
noria:Locus_DR_Marseille_SRC_DR<%= i %>R<%= j %> a noria:Locus ;
    rdfs:label "Locus DR<%= i %>R<%= j %> in Marseille DR Server Room C"@en ;
    rdfs:comment "Specific location for rack DR<%= i %>, row R<%= j %> within Marseille DR Server Room C. Dedicated to disaster recovery infrastructure."@en ;
    noria:locusLine "DR<%= i %>" ;
    noria:locusRow "R<%= j %>" ;
    bot:containsZone noria:Room_DR_Marseille_ServerRoom_C .
<%
    }
  }
%>

