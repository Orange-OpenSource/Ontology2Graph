# --- Services ---

noria:Service_CustomerInternetAccess a noria:Service ;
    rdfs:label "Customer Internet Access Service"@en, "Service d'Accès Internet Client"@fr ;
    rdfs:comment "End-to-end service providing internet connectivity to corporate customers. This service relies on core network infrastructure and DMZ applications."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:AppMod_CRM_Prod, noria:AppMod_Monitoring_Core .

noria:Service_InternalVPN a noria:Service ;
    rdfs:label "Internal VPN Service"@en, "Service VPN Interne"@fr ;
    rdfs:comment "Secure VPN access for internal employees to corporate resources, enabling remote work and secure access to internal applications."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:AppMod_Monitoring_Core, noria:App_EmailService .

noria:Service_CorporateEmail a noria:Service ;
    rdfs:label "Corporate Email Service"@en, "Service de Messagerie d'Entreprise"@fr ;
    rdfs:comment "Essential communication service for all employees, including email, calendar, and contacts. Integrated with other collaboration tools."@en ;
    noria:serviceType <kos/service/type/InternalService> ;
    seas:subSystemOf noria:AppMod_Email_Prod .

noria:Service_DataBackup a noria:Service ;
    rdfs:label "Enterprise Data Backup Service"@en, "Service de Sauvegarde de Données d'Entreprise"@fr ;
    rdfs:comment "Centralized service for backing up critical application data and user files, ensuring data recovery capabilities."@en ;
    noria:serviceType <kos/service/type/PlatformService> ;
    seas:subSystemOf noria:AppMod_Storage_Prod_NetApp, noria:AppMod_DB_Prod_Cluster1 .

# --- Resources ---

# IP Addresses (observable:IPAddress) - Generating a large pool
<%
  for (let i = 0; i < 255; i++) {
    for (let j = 0; j < 255; j++) {
      if (i < 10 && j < 10) { // Limit the number of IPs to avoid excessive output
%>
observable:IPAddress_10_0_<%= i %>_<%= j %> a observable:IPAddress ; rdfs:label "10.0.<%= i %>.<%= j %>"@en .
<%
      }
    }
  }
%>

# Servers (100 instances)
<%
  for (let i = 1; i <= 100; i++) {
