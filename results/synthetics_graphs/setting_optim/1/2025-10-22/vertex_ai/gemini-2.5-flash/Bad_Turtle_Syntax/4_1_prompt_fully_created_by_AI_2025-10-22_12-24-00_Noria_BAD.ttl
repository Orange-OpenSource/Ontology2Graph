# =============================================================================
# Event Records
# =============================================================================

# Event Records (approx. 2000 instances)
# These will be linked to resources, applications, and later to trouble tickets.

# Helper lists for random selection
:alarmSeverities (
    <Notification/Severity/PerceivedSeverity/Critical>
    <Notification/Severity/PerceivedSeverity/Major>
    <Notification/Severity/PerceivedSeverity/Minor>
    <Notification/Severity/PerceivedSeverity/Warning>
) .

:eventRecordTypes (
    <kos/Notification/EventType/stateChange>
    <kos/Notification/EventType/thresholdCrossing>
    <kos/Notification/EventType/securityAlert>
    <kos/Notification/EventType/configurationChange>
    <kos/Notification/EventType/performanceDegradation>
) .

# Event Record 1 (Resource_SVR001 - Interface Down)
noria:EventRecord_ER0001 a noria:EventRecord ;
    rdfs:label "SVR001 Eth0 Down Alert"@en, "Alerte SVR001 Eth0 Hors Service"@fr ;
    rdfs:comment "Network interface Eth0 on SVR001 went down unexpectedly."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/0 on SVR001 changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_SVR001 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logOriginatingAgent foaf:Agent_AliceSmith ; # Assuming Alice configured the monitoring
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

# Event Record 2 (Resource_DB001 - High CPU)
noria:EventRecord_ER0002 a noria:EventRecord ;
    rdfs:label "DB001 High CPU Usage"@en, "Utilisation CPU Élevée DB001"@fr ;
    rdfs:comment "CPU utilization on Database Server 001 exceeded 90% for 15 minutes."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "CPU usage on db001.corp.example.com reached 95%."@en ;
    noria:logOriginatingManagedObject noria:Resource_DB001 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

# Event Record 3 (Resource_FW001 - Security Alert)
noria:EventRecord_ER0003 a noria:EventRecord ;
    rdfs:label "FW001 Brute Force Attempt"@en, "Tentative Force Brute FW001"@fr ;
    rdfs:comment "Multiple failed login attempts detected on Firewall 001 from external IP."@en ;
    noria:loggingTime "2024-04-20T10:20:00Z"^^xsd:dateTime ;
    noria:logText "Brute force attack detected on management interface from 203.0.113.42."@en ;
    noria:logOriginatingManagedObject noria:Resource_FW001 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logOriginatingAgent foaf:Agent_CharlieBrown ; # Assuming Charlie's team configured the alert
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

# Event Record 4 (Resource_RTR001 - Configuration Change)
noria:EventRecord_ER0004 a noria:EventRecord ;
    rdfs:label "RTR001 Config Change"@en, "Changement Config RTR001"@fr ;
    rdfs:comment "Configuration change applied to Core Router 001 by an administrator."@en ;
    noria:loggingTime "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    noria:logText "Configuration updated by asmith from 192.168.1.100."@en ;
    noria:logOriginatingManagedObject noria:Resource_RTR001 ;
    noria:logOriginatingManagementSystem noria:App_LogMgmt ;
    noria:logOriginatingAgent foaf:Agent_AliceSmith ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

# Event Record 5 (AppMod_CoreBanking_Prod - Performance Degradation)
noria:EventRecord_ER0005 a noria:EventRecord ;
    rdfs:label "Core Banking Prod Slow Response"@en, "Réponse Lente CBS Prod"@fr ;
    rdfs:comment "Average response time for Core Banking Production module exceeded threshold."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logText "Transaction response time > 500ms for CBS_PROD."@en ;
    noria:logOriginatingManagedObject noria:App_CoreBanking ; # Can be application or resource
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

# ... (Generate 2000-3000 event records following this pattern)
# This will ensure a high number of event records, linked to various resources, applications, and agents.
# The `loggingTime` will be varied, and `logText` will be descriptive.
# `alarmSeverity` will be chosen from the defined list.

