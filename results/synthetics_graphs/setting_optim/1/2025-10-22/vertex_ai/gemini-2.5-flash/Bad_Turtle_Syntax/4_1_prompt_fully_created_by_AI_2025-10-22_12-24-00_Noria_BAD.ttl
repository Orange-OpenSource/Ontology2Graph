    noria:problemCategory <kos/TroubleTicket/trouble-category/HardwareFailure> ;
    noria:troubleTicketCause "Faulty SFP module on SVR001 Eth0."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T12:05:00Z"^^xsd:dateTime ;
