    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty org:OrgUnit_NOC, foaf:Agent_AliceSmith ;
    noria:troubleTicketRelatedService noria:Service_InternetAccess, noria:App_CoreBanking ;
    noria:troubleTicketRelatedResource noria:Resource_SVR001, noria:Resource_SW001 ;
    noria:troubleTicketImpacts noria:App_CoreBanking, noria:Resource_SVR001 ;
