# =============================================================================
# Resources (Servers, Routers, Firewalls, etc.)
# =============================================================================

# Generating 1000 Resources for density
# Each resource will have 2-4 network interfaces
# Each resource will be managed by an agent, have a product model, be located, and associated with an application.

# Helper lists for random selection
:resourceTypes (
    <kos/Resource/type/server>
    <kos/Resource/type/router>
    <kos/Resource/type/switch>
    <kos/Resource/type/firewall>
    <kos/Resource/type/load-balancer>
    <kos/Resource/type/storage-array>
    <kos/Resource/type/virtual-machine>
