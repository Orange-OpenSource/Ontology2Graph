# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

# Operation Plan 1 (SFP Replacement)
noria:OperationPlan_SFPReplace a noria:OperationPlan ;
    rdfs:label "SFP Module Replacement Procedure"@en, "Procédure de Remplacement Module SFP"@fr ;
    rdfs:comment "Standard operating procedure for replacing a faulty SFP module in a network device."@en ;
    noria:operationPlanPreCondition noria:ActionPreCond_SFPFaultConfirmed ;
    noria:operationPlanPostCondition noria:ActionPostCond_InterfaceUp .

noria:ActionPreCond_SFPFaultConfirmed a noria:ActionPreCondition ;
    rdfs:label "SFP Fault Confirmed"@en, "Défaut SFP Confirmé"@fr ;
    rdfs:comment "Pre-condition: Monitoring alert for interface down, physical inspection confirms SFP fault."@en ;
    skos:example "EventRecord_ER0001 indicates interface down. Visual inspection shows no link light on SFP."@en .

noria:ActionPostCond_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Interface Operational"@en, "Interface Opérationnelle"@fr ;
    rdfs:comment "Post-condition: Network interface shows operational status 'up', traffic flows normally."@en ;
    skos:example "noria:networkInterfaceOperationalStatus is <kos/Resource/OperationalState/up>. Ping tests successful."@en .

# Operation Plan 2 (SQL Query Optimization)
noria:OperationPlan_SQLOptimize a noria:OperationPlan ;
    rdfs:label "SQL Query Optimization Procedure"@en, "Procédure d'Optimisation Requête SQL"@fr ;
    rdfs:comment "Procedure for identifying and optimizing inefficient SQL queries impacting database performance."@en ;
    noria:operationPlanPreCondition noria:ActionPreCond_HighCPUDB ;
    noria:operationPlanPostCondition noria:ActionPostCond_CPUNormalized .

noria:ActionPreCond_HighCPUDB a noria:ActionPreCondition ;
    rdfs:label "High CPU on Database Server"@en, "CPU Élevé sur Serveur BD"@fr ;
    rdfs:comment "Pre-condition: Database server CPU utilization consistently above 80%."@en ;
    skos:example "EventRecord_ER0002 indicates sustained high CPU on DB001."@en .

noria:ActionPostCond_CPUNormalized a noria:ActionPostCondition ;
    rdfs:label "CPU Utilization Normalized"@en, "Utilisation CPU Normalisée"@fr ;
    rdfs:comment "Post-condition: Database server CPU utilization returns to normal levels (below 50%)."@en ;
    skos:example "Monitoring shows DB001 CPU at 30% after query rollback."@en .

# Operation Plan 3 (BGP Peer Addition)
noria:OperationPlan_BGPAdd a noria:OperationPlan ;
    rdfs:label "BGP Peer Addition Procedure"@en, "Procédure d'Ajout Pair BGP"@fr ;
    rdfs:comment "Standard procedure for adding a new BGP peer configuration on a router."@en ;
    noria:operationPlanPreCondition noria:ActionPreCond_NewISPConfig ;
    noria:operationPlanPostCondition noria:ActionPostCond_BGPUp .

noria:ActionPreCond_NewISPConfig a noria:ActionPreCondition ;
    rdfs:label "New ISP Connection Ready"@en, "Nouvelle Connexion FAI Prête"@fr ;
    rdfs:comment "Pre-condition: Physical link to new ISP is established and interfaces are up."@en ;
    skos:example "New network link is provisioned and operational."@en .

noria:ActionPostCond_BGPUp a noria:ActionPostCondition ;
    rdfs:label "BGP Session Established"@en, "Session BGP Établie"@fr ;
    rdfs:comment "Post-condition: BGP session with new peer is established and routes are exchanged."@en ;
    skos:example "Router shows BGP neighbor state 'Established'."@en .

# ... (Generate 10-20 operation plans with associated pre/post conditions)

