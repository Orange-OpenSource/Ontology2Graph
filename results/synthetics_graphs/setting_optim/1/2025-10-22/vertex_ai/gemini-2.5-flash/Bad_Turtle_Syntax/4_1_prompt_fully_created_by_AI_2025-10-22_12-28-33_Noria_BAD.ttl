# --- Agents and Organizations ---
# Creating 10 teams and 40 individuals (total 50 agents)

# Organizational Units (Teams)
org:Team_NetworkOperations a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Responsible for the core network infrastructure and services."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "For critical issues, call the hotline. For non-critical, use ticketing system."@en .

org:Team_ServerAdmins a org:OrganizationalUnit ;
    rdfs:label "Server Administration Team"@en, "Équipe Administration Serveurs"@fr ;
    rdfs:comment "Manages all physical and virtual server resources."@en ;
