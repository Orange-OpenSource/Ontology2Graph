]

for i, (label, uri_suffix, manufacturer) in enumerate(product_models):
    print(f"""
noria:ProductModel_{uri_suffix} a noria:ProductModel ;
    rdfs:label "{label}"@en ;
    rdfs:comment "Product model for {label}."@en ;
    noria:productManufacturedBy {manufacturer} .
""")
    # Define manufacturers if not already defined (e.g., Microsoft, Citrix, Check Point)
    if "microsoft" in str(manufacturer):
        print(f"""
<http://www.microsoft.com/organization> a org:Organization ;
    rdfs:label "Microsoft Corporation"@en ;
    rdfs:comment "American multinational technology corporation."@en .
""")
    if "citrix" in str(manufacturer):
        print(f"""
<http://www.citrix.com/organization> a org:Organization ;
    rdfs:label "Citrix Systems"@en ;
    rdfs:comment "American multinational software company."@en .
""")
    if "checkpoint" in str(manufacturer):
        print(f"""
<http://www.checkpoint.com/organization> a org:Organization ;
    rdfs:label "Check Point Software Technologies"@en ;
