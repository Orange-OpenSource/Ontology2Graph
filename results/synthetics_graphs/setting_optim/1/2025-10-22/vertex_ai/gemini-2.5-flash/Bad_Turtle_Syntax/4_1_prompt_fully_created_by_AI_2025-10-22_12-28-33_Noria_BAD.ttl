""")

# --- Applications ---
# Creating 30 applications
application_types = [
    "<kos/application/type/business-critical>", "<kos/application/type/infrastructure>",
    "<kos/application/type/communication>", "<kos/application/type/customer-facing>",
    "<kos/application/type/internal-business>", "<kos/application/type/infrastructure-management>"
]
business_importance = [
    "<kos/application/business-importance/high>", "<kos/application/business-importance/critical>",
    "<kos/application/business-importance/medium>", "<kos/application/business-importance/low>"
]
functional_domains = [
    "Market and Customer Relationship Management", "Service Development, Management and Operations",
    "Resource Development, Management and Operations"
]
functional_subdomains = [
    "Customer Order Management", "Financial Management", "Service Monitoring",
    "Network Resource Management", "Customer Interaction Management", "Customer Self-Service",
    "Human Resource Management", "Resource Inventory Management", "Data Protection",
    "Incident Management", "Supply Chain Management", "Project Management"
]

for i in range(1, 31):
    app_uri = f"noria:Application_{i:02d}"
    app_label_en = f"Enterprise Application {i:02d}"
    app_label_fr = f"Application d'Entreprise {i:02d}"
    app_comment = f"A critical business application for enterprise operations."
    app_model_id = f"APP-MOD-{i:02d}"
    app_num_id = 1000 + i
    app_short_id = f"APP{i:02d}"
    app_type = application_types[i % len(application_types)]
    app_biz_importance = business_importance[i % len(business_importance)]
    app_func_domain = functional_domains[i % len(functional_domains)]
    app_func_subdomain = functional_subdomains[i % len(functional_subdomains)]

    print(f"""
{app_uri} a noria:Application ;
    rdfs:label "{app_label_en}"@en, "{app_label_fr}"@fr ;
    rdfs:comment "{app_comment}"@en ;
    noria:applicationModelIdentifier "{app_model_id}" ;
    noria:applicationNumericalIdentifier {app_num_id} ;
    noria:applicationShortIdentifier "{app_short_id}" ;
    noria:applicationType {app_type} ;
    noria:applicationBusinessImportance {app_biz_importance} ;
    noria:applicationFunctionalDomain "{app_func_domain}" ;
    noria:applicationFunctionalSubDomain "{app_func_subdomain}" .
""")

# --- Application Modules ---
# Creating 3 modules per application (30 applications * 3 modules = 90 modules)
app_module_statuses = [
    "<https://w3id.org/noria/kos/application/status/InProduction>",
    "<https://w3id.org/noria/kos/application/status/Development>",
    "<https://w3id.org/noria/kos/application/status/Testing>",
    "<https://w3id.org/noria/kos/application/status/Standby>"
]
sla_levels = [
    "<https://w3id.org/noria/kos/application/sla-level/Platinum>",
    "<https://w3id.org/noria/kos/application/sla-level/Gold>",
    "<https://w3id.org/noria/kos/application/sla-level/Silver>",
    "<https://w3id.org/noria/kos/application/sla-level/Bronze>"
]
admin_teams = [org.Team_AppSupport_CRM, org.Team_ServerAdmins, org.Team_DevOps_Platform]
support_teams = [org.Team_AppSupport_CRM, org.Team_HelpDesk, org.Team_Monitoring]
support_leaders = [foaf.Agent_Diana, foaf.Agent_Bob, foaf.Agent_Grace]
hotline_groups = [org.Team_HelpDesk, org.Team_NetworkOperations, org.Team_SecurityOps]

for i in range(1, 31): # 30 applications
    app_uri = f"noria:Application_{i:02d}"
    for j in range(1, 4): # 3 modules per application
        module_type = "Prod" if j == 1 else "Dev" if j == 2 else "Test"
        app_module_uri = f"noria:ApplicationModule_{i:02d}_{module_type}"
        app_module_label_en = f"Application {i:02d} {module_type} Module"
        app_module_label_fr = f"Module Application {i:02d} {module_type}"
        app_module_comment = f"{module_type} instance of Application {i:02d}."
        app_module_name = f"APP{i:02d}_{module_type}_MOD"
        app_module_id = f"APP-MOD-{i:02d}-{j}"
        app_module_status = app_module_statuses[j-1] if j <= 4 else app_module_statuses[0]
        sla_level = sla_levels[j-1] if j <= 4 else sla_levels[0]
        sla_date = f"2023-01-{(i%28)+1:02d}T00:00:00Z"
        hotline_enabled = "true" if j == 1 else "false"
        admin_team = admin_teams[i % len(admin_teams)]
        support_team = support_teams[i % len(support_teams)]
        support_leader = support_leaders[i % len(support_leaders)]
        hotline_group = hotline_groups[i % len(hotline_groups)]

        print(f"""
{app_module_uri} a noria:ApplicationModule ;
    rdfs:label "{app_module_label_en}"@en, "{app_module_label_fr}"@fr ;
    rdfs:comment "{app_module_comment}"@en ;
    noria:applicationModuleOf {app_uri} ;
    noria:applicationModuleName "{app_module_name}" ;
    noria:applicationModuleIdentifier "{app_module_id}" ;
    noria:applicationModuleStatus {app_module_status} ;
    noria:applicationModuleSlaLevel {sla_level} ;
    noria:applicationModuleSlaLevelDate "{sla_date}"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled {hotline_enabled} ;
    noria:applicationModuleAdministrationTeam {admin_team} ;
    noria:applicationModuleSupportTeam {support_team} ;
    noria:applicationModuleSupportLeader {support_leader} ;
    noria:applicationModuleHotlineGroup {hotline_group} .
""")

# --- Services ---
# Creating 10 services
service_types = [
    "<kos/service/type/ResourceFacingService>",
    "<kos/service/type/CustomerFacingService>"
]

for i in range(1, 11):
    service_uri = f"noria:Service_{i:02d}"
    service_label_en = f"Enterprise Service {i:02d}"
    service_label_fr = f"Service d'Entreprise {i:02d}"
    service_comment = f"A key service provided to internal or external customers."
    service_type = service_types[i % len(service_types)]

    print(f"""
{service_uri} a noria:Service ;
    rdfs:label "{service_label_en}"@en, "{service_label_fr}"@fr ;
    rdfs:comment "{service_comment}"@en ;
    noria:serviceType {service_type} .
""")

# --- Resources ---
# Creating 300 resources (mix of servers, network devices, virtual machines)
# Each resource will have 2 network interfaces and 2 network links.
# Total: 300 Resources, 600 Network Interfaces, 600 Network Links.

resource_types = [
    "<kos/Resource/type/server>", "<kos/Resource/type/router>", "<kos/Resource/type/switch>",
    "<kos/Resource/type/virtual-machine>", "<kos/Resource/type/firewall>", "<kos/Resource/type/storage-array>"
]
usage_states = [
    "<kos/Resource/LifecycleState/InProduction>", "<kos/Resource/LifecycleState/Staging>",
    "<kos/Resource/LifecycleState/Decommissioned>"
]
admin_states = ["<kos/Resource/AdministrativeState/up>", "<kos/Resource/AdministrativeState/down>"]
op_states = ["<kos/Resource/OperationalState/up>", "<kos/Resource/OperationalState/down>"]
interface_types = ["<kos/Resource/network-interface-type/physical>", "<kos/Resource/network-interface-type/virtual>"]

for i in range(1, 301): # 300 resources
    resource_uri = f"noria:Resource_{i:03d}"
    resource_label_en = f"IT Resource {i:03d}"
    resource_label_fr = f"Ressource IT {i:03d}"
    resource_comment = f"A generic IT resource in the infrastructure."
    resource_logistic_id = f"RES-{i:05d}"
    resource_hostname = f"res-{i:05d}.corp.example.com"
    resource_product_model = product_models[i % len(product_models)][0].replace(" ", "") # Use URI suffix
    resource_type = resource_types[i % len(resource_types)]
    resource_serial_number = f"SN-RES-{i:07d}"
    resource_usage_state = usage_states[i % len(usage_states)]
    resource_install_date = f"2023-01-{(i%28)+1:02d}T{((i*2)%24):02d}:{((i*3)%60):02d}:{((i*5)%60):02d}Z"
    resource_for_application = f"noria:Application_{((i-1)%30)+1:02d}"
    resource_located_at_locus = f"noria:Locus_DC-HQ-01_ServerRoom1_Rack{((i-1)%4)+1}" # Distribute across HQ racks
    resource_managed_by = org.Team_ServerAdmins if "server" in resource_type else org.Team_NetworkOperations if "router" in resource_type or "switch" in resource_type else org.Team_StorageAdmins if "storage" in resource_type else org.Team_SecurityOps if "firewall" in resource_type else org.Team_CloudInfra
    resource_mgmt_ip = f"10.10.{((i-1)//25)+1}.{((i-1)%25)+10}"

    print(f"""
{resource_uri} a noria:Resource ;
    rdfs:label "{resource_label_en}"@en, "{resource_label_fr}"@fr ;
    rdfs:comment "{resource_comment}"@en ;
    noria:resourceLogisticId "{resource_logistic_id}" ;
    noria:resourceHostName "{resource_hostname}" ;
    noria:resourceProductModel noria:ProductModel_{resource_product_model} ;
    noria:resourceType {resource_type} ;
    noria:resourceSerialNumber "{resource_serial_number}" ;
    noria:resourceUsageState {resource_usage_state} ;
    noria:resourceInstallationDate "{resource_install_date}"^^xsd:dateTime ;
    noria:resourceForApplication {resource_for_application} ;
    noria:locatedAtLocus {resource_located_at_locus} ;
    noria:resourceManagedBy {resource_managed_by} ;
    noria:resourceManagementIPAddress <observable:IPAddress_Res{i:03d}_Mgmt> .

<observable:IPAddress_Res{i:03d}_Mgmt> a observable:IPAddress ;
    rdfs:label "Management IP for {resource_hostname}"@en ;
    observable:ipAddressValue "{resource_mgmt_ip}" .
""")

    for j in range(1, 3): # 2 network interfaces per resource
        interface_uri = f"noria:NetworkInterface_Res{i:03d}_Eth{j-1}"
        interface_label_en = f"{resource_hostname} Eth{j-1}"
        interface_comment = f"Network interface {j-1} for {resource_hostname}."
        interface_description = f"Interface for data traffic." if j == 1 else f"Interface for management/backup."
        interface_type = interface_types[0] if "virtual-machine" not in resource_type else interface_types[1]
        admin_status = admin_states[j % 2]
        op_status = op_states[(j+1) % 2] # Vary operational status
        link_uri = f"noria:NetworkLink_Res{i:03d}_Link{j-1}"
        link_label_en = f"Link {resource_hostname} to Network {j-1}"
        link_comment = f"Network link for interface Eth{j-1} of {resource_hostname}."
        link_id = f"LINK-RES{i:05d}-ETH{j-1}"
        link_type = "Ethernet" if "virtual-machine" not in resource_type else "Virtual Ethernet"

        print(f"""
{interface_uri} a noria:NetworkInterface ;
    rdfs:label "{interface_label_en}"@en ;
    rdfs:comment "{interface_comment}"@en ;
    noria:networkInterfaceDescription "{interface_description}" ;
    noria:networkInterfaceType {interface_type} ;
    noria:networkInterfaceAdministrativeStatus {admin_status} ;
    noria:networkInterfaceOperationalStatus {op_status} ;
    noria:networkInterfaceRoutingPriorityMetric {100 + i} ;
    noria:networkInterfaceLaserTxOpticalPower {-10 + (i%5)} ;
    noria:networkInterfaceLaserRxOpticalPower {-15 + (i%5)} ;
    noria:networkInterfaceOf {resource_uri} ;
    noria:networkInterfaceConnects {link_uri} .

{link_uri} a noria:NetworkLink ;
    rdfs:label "{link_label_en}"@en ;
    rdfs:comment "{link_comment}"@en ;
    noria:networkLinkId "{link_id}" ;
    noria:networkLinkType "{link_type}" ;
    noria:networkLinkInstallationDate "{resource_install_date}"^^xsd:dateTime ;
    noria:networkLinkTerminationResource {resource_uri} ;
    noria:resourceManagedBy {resource_managed_by} .
""")

# --- Operation Plans and Conditions ---
# Creating 10 operation plans with pre/post conditions
operation_plans = [
    ("Restart Application Service", "RestartService", "The application service is reported as down or unresponsive.", "The application service is confirmed to be running and accessible."),
    ("Network Connectivity Troubleshoot", "NetworkTroubleshoot", "A network resource is unreachable or experiencing packet loss.", "Network connectivity to the resource is restored and stable."),
    ("Database Restore from Backup", "DBRestore", "Database is corrupted, data loss detected, or service is unavailable.", "Database is restored to a consistent state and data integrity verified."),
    ("Server Reboot Procedure", "ServerReboot", "Server is unresponsive or experiencing critical errors.", "Server has rebooted successfully and is accessible."),
    ("Firewall Rule Update", "FirewallUpdate", "New network access is required or security vulnerability detected.", "Firewall rules are updated and verified to allow/block traffic as intended."),
    ("Storage Volume Expansion", "StorageExpand", "Storage volume is nearing full capacity.", "Storage volume has been successfully expanded and is available."),
    ("Cloud Instance Scaling", "CloudScale", "Application experiences high load or low utilization.", "Cloud instance scaled up/down and performance is optimized."),
    ("Software Patch Deployment", "SoftwarePatch", "Security vulnerability or bug fix required.", "Software patch deployed successfully and system is stable."),
    ("User Account Provisioning", "UserProvision", "New employee onboarding or access request.", "User account created and access rights granted."),
    ("Log Rotation and Archiving", "LogArchive", "Log storage is reaching capacity limits.", "Logs rotated, archived, and storage space freed.")
]

for i, (op_label, op_suffix, pre_cond_text, post_cond_text) in enumerate(operation_plans):
    op_uri = f"noria:OperationPlan_{op_suffix}"
    pre_uri = f"noria:ActionPreCondition_{op_suffix}"
    post_uri = f"noria:ActionPostCondition_{op_suffix}"

    print(f"""
{op_uri} a noria:OperationPlan ;
    rdfs:label "{op_label}"@en, "{op_label.replace(' ', ' ')}"@fr ;
    rdfs:comment "Standard operating procedure for {op_label.lower()}."@en ;
    noria:operationPlanPreCondition {pre_uri} ;
    noria:operationPlanPostCondition {post_uri} .

{pre_uri} a noria:ActionPreCondition ;
    rdfs:label "{op_label} Pre-Condition"@en ;
    rdfs:comment "Condition: {pre_cond_text}"@en .

{post_uri} a noria:ActionPostCondition ;
    rdfs:label "{op_label} Post-Condition"@en ;
    rdfs:comment "Outcome: {post_cond_text}"@en .
""")

# --- Event Records ---
# Generating 1500 Event Records, linking to resources, applications, and agents
# These will be used to trigger Trouble Tickets and Change Requests.

severity_kos = ["<Notification/Severity/PerceivedSeverity/Critical>", "<Notification/Severity/PerceivedSeverity/Major>", "<Notification/Severity/PerceivedSeverity/Minor>", "<Notification/Severity/PerceivedSeverity/Warning>"]
op_plans_uris = [f"noria:OperationPlan_{op[1]}" for op in operation_plans]
agents_list = [f"foaf:Agent_{agent.split('_')[-1]}" for agent in dir(foaf) if agent.startswith("Agent_")]
applications_list = [f"noria:Application_{i:02d}" for i in range(1, 31)]
resources_list = [f"noria:Resource_{i:03d}" for i in range(1, 301)]

for i in range(1, 1501): # 1500 event records
    event_uri = f"noria:EventRecord_{i:04d}"
    log_time = f"2024-04-{(i%30)+1:02d}T{((i*2)%24):02d}:{((i*3)%60):02d}:{((i*5)%60):02d}Z"
    severity = severity_kos[i % len(severity_kos)]
    
    originating_object = ""
    log_text = ""
    comment = ""
    originating_system = applications_list[i % len(applications_list)] # Random application as system
    originating_agent = agents_list[i % len(agents_list)]
    alarm_proposed_action = op_plans_uris[i % len(op_plans_uris)]

    if i % 5 == 0: # Network event
        originating_object = resources_list[i % len(resources_list)]
        log_text = f"LINEPROTO-5-UPDOWN: Interface Eth0 on {originating_object.split('_')[-1]} changed state to down."
        comment = f"Network interface down event on {originating_object.split('_')[-1]}."
    elif i % 5 == 1: # Server event
        originating_object = resources_list[i % len(resources_list)]
        log_text = f"CRITICAL: Disk usage on {originating_object.split('_')[-1]} reached 95%."
        comment = f"High disk usage alert on server {originating_object.split('_')[-1]}."
    elif i % 5 == 2: # Application event
        originating_object = applications_list[i % len(applications_list)]
        log_text = f"ERROR: Application {originating_object.split('_')[-1]} experienced database connection timeout."
        comment = f"Application error: database connection issue for {originating_object.split('_')[-1]}."
    elif i % 5 == 3: # Security event
        originating_object = resources_list[i % len(resources_list)]
        log_text = f"ALERT: Multiple failed login attempts detected from external IP 203.0.113.{i} on {originating_object.split('_')[-1]}."
        comment = f"Security alert: Brute force attempt detected on {originating_object.split('_')[-1]}."
    else: # Generic system event
        originating_object = resources_list[i % len(resources_list)]
        log_text = f"INFO: System reboot initiated on {originating_object.split('_')[-1]} by scheduled task."
        comment = f"Informational event: Scheduled reboot of {originating_object.split('_')[-1]}."

    print(f"""
{event_uri} a noria:EventRecord ;
    rdfs:label "Event Record {i:04d}"@en ;
    rdfs:comment "{comment}"@en ;
    noria:logText "{log_text}"@en ;
    noria:loggingTime "{log_time}"^^xsd:dateTime ;
    noria:logOriginatingManagedObject {originating_object} ;
    noria:logOriginatingManagementSystem {originating_system} ;
    noria:logOriginatingAgent {originating_agent} ;
    noria:alarmSeverity {severity} ;
    noria:alarmProposedRepairAction {alarm_proposed_action} .
""")

# --- Trouble Tickets ---
# Generating 700 Trouble Tickets, linking to events, resources, applications, and agents
# Each TT will have 2 TroubleTicketNotes (total 1400 notes)

severity_tt_kos = ["<kos/TroubleTicket/severity/Critical>", "<kos/TroubleTicket/severity/Major>", "<kos/TroubleTicket/severity/Minor>", "<kos/TroubleTicket/severity/Warning>"]
type_tt_kos = ["<kos/TroubleTicket/type/Failure>", "<kos/TroubleTicket/type/Assistance>", "<kos/TroubleTicket/type/Maintenance>"]
criticity_tt_kos = ["<kos/TroubleTicket/category/Interruptedservice>", "<kos/TroubleTicket/category/Corruptedservice>", "<kos/TroubleTicket/category/Workingbackup>"]
priority_tt_kos = ["<kos/TroubleTicket/priority/P1>", "<kos/TroubleTicket/priority/P2>", "<kos/TroubleTicket/priority/P3>", "<kos/TroubleTicket/priority/P4>"]
origin_tt_kos = ["<kos/TroubleTicket/origin/Customer>", "<kos/TroubleTicket/origin/Supervision>", "<kos/TroubleTicket/origin/Internal>"]
urgency_tt_kos = ["<kos/TroubleTicket/urgency/ImmediateIntervention>", "<kos/TroubleTicket/urgency/DeferredIntervention>", "<kos/TroubleTicket/urgency/Nointervention>"]
category_tt_kos = ["<kos/TroubleTicket/trouble-category/Isolatedcustomersite>", "<kos/TroubleTicket/trouble-category/Totalbreakdown>", "<kos/TroubleTicket/trouble-category/Downgradingequipment>"]
problem_responsibility_tt_kos = ["<kos/TroubleTicket/problemResponsibility/Customer>", "<kos/TroubleTicket/problemResponsibility/Managedbackbonenetworks>", "<kos/TroubleTicket/problemResponsibility/Contractapplication-hostingservices>"]
status_tt_kos = ["<kos/TroubleTicket/status/Initialised>", "<kos/TroubleTicket/status/InProgress>", "<kos/TroubleTicket/status/Resolved