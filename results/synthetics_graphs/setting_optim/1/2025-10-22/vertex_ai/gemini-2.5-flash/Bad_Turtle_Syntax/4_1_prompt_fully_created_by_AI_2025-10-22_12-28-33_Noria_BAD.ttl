# --- Locations ---
# Creating 10 sites, 5 rooms per site, 20 loci per room (total 10 sites, 50 rooms, 200 loci)

# Sites
bot:Site_HQ a bot:Site ;
    rdfs:label "Headquarters Data Center"@en, "Centre de Données du Siège Social"@fr ;
    rdfs:comment "Main data center for corporate operations."@en ;
    noria:siteId "DC-HQ-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Main Street" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCityName "New York" ;
    noria:sitePrincipalAddressCountry "US" ;
    noria:sitePrincipalAddressStreet "Main Street" .

bot:Site_DR a bot:Site ;
    rdfs:label "Disaster Recovery Site"@en, "Site de Reprise après Sinistre"@fr ;
    rdfs:comment "Secondary data center for disaster recovery and business continuity."@en ;
    noria:siteId "DC-DR-02" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Backup Road" ;
    noria:sitePrincipalAddressPostalCode "90210" ;
    noria:sitePrincipalAddressCityName "Los Angeles" ;
    noria:sitePrincipalAddressCountry "US" ;
    noria:sitePrincipalAddressStreet "Backup Road" .

bot:Site_BranchOffice_LON a bot:Site ;
    rdfs:label "London Branch Office"@en, "Bureau Régional de Londres"@fr ;
    rdfs:comment "Smaller office with local IT infrastructure in London."@en ;
    noria:siteId "BO-LON-03" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "789 High Street" ;
    noria:sitePrincipalAddressPostalCode "SW1A 0AA" ;
    noria:sitePrincipalAddressCityName "London" ;
    noria:sitePrincipalAddressCountry "UK" ;
    noria:sitePrincipalAddressStreet "High Street" .

bot:Site_BranchOffice_PAR a bot:Site ;
    rdfs:label "Paris Branch Office"@en, "Bureau Régional de Paris"@fr ;
    rdfs:comment "Smaller office with local IT infrastructure in Paris."@en ;
    noria:siteId "BO-PAR-04" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "10 Rue de la Paix" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressStreet "Rue de la Paix" .

bot:Site_EdgeLocation_NYC a bot:Site ;
    rdfs:label "NYC Edge Location"@en, "Point d'Accès Edge NYC"@fr ;
    rdfs:comment "Small edge data center for localized services in New York City."@en ;
    noria:siteId "EDGE-NYC-05" ;
    noria:siteType "edge data center" ;
    noria:sitePrincipalAddress "500 Edge Avenue" ;
    noria:sitePrincipalAddressPostalCode "10005" ;
    noria:sitePrincipalAddressCityName "New York" ;
    noria:sitePrincipalAddressCountry "US" ;
    noria:sitePrincipalAddressStreet "Edge Avenue" .

# Rooms (5 per site, 50 rooms total)
for i in range(1, 11): # 10 sites
    site_id = f"DC-HQ-01" if i == 1 else f"DC-DR-02" if i == 2 else f"BO-LON-03" if i == 3 else f"BO-PAR-04" if i == 4 else f"EDGE-NYC-05" if i == 5 else f"bot:Site_Generic_{i:02d}"
    site_label = f"Site {i}"
    if i > 5: # Create generic sites for scaling
        print(f"""
bot:Site_Generic_{i:02d} a bot:Site ;
    rdfs:label "Generic Site {i}"@en, "Site Générique {i}"@fr ;
    rdfs:comment "A generic branch office or small data center."@en ;
    noria:siteId "GEN-SITE-{i:02d}" ;
    noria:siteType "branch office" ;
    noria:sitePrincipalAddress "{i*10} Generic Road" ;
    noria:sitePrincipalAddressPostalCode "G{i:02d}001" ;
    noria:sitePrincipalAddressCityName "GenericCity{i}" ;
    noria:sitePrincipalAddressCountry "US" ;
    noria:sitePrincipalAddressStreet "Generic Road" .
""")
        site_id = f"bot:Site_Generic_{i:02d}"

    for j in range(1, 6): # 5 rooms per site
        room_type = "ServerRoom" if j == 1 else "NetworkRoom" if j == 2 else "StorageRoom" if j == 3 else "CommsRoom" if j == 4 else "UtilityRoom"
        room_label_en = f"{site_label} {room_type} {j}"
        room_label_fr = f"Salle {room_type.replace('Room', '')} {site_label} {j}"
        room_comment = f"Room {j} in {site_label}."
        room_uri = f"noria:Room_{site_id.split(':')[-1]}_{room_type}{j}"
        print(f"""
{room_uri} a noria:Room ;
    rdfs:label "{room_label_en}"@en, "{room_label_fr}"@fr ;
    rdfs:comment "{room_comment}"@en ;
    bot:hasSpace {site_id} .
""")
        # Loci (4 per room, 200 loci total)
        for k in range(1, 5): # 4 loci per room
            locus_uri = f"noria:Locus_{site_id.split(':')[-1]}_{room_type}{j}_Rack{k}"
            locus_label_en = f"{room_label_en} Rack {k}"
            locus_label_fr = f"{room_label_fr} Rack {k}"
            locus_comment = f"Rack {k} in {room_label_en}."
            print(f"""
{locus_uri} a noria:Locus ;
    rdfs:label "{locus_label_en}"@en, "{locus_label_fr}"@fr ;
    rdfs:comment "{locus_comment}"@en ;
    noria:locusLine "{chr(64 + (k%2)+1)}" ;
    noria:locusRow "{k}" ;
    bot:containsZone {room_uri} .
""")

