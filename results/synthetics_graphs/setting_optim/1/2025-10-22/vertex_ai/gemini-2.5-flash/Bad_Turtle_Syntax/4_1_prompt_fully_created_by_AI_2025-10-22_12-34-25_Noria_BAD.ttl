    noria:applicationModuleOf <noria/Application_CRM_Suite> ;
    noria:applicationModuleName "CRM_DEV" ;
    noria:applicationModuleIdentifier "DEV-001" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Bronze> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled false ;
    noria:applicationModuleAdministrationTeam <org/Team_DevOps> ;
    noria:applicationModuleSupportTeam <org/Team_DevOps> .

<noria/ApplicationModule_ERP_Prod> a noria:ApplicationModule ;
    rdfs:label "ERP Production Module"@en, "Module ERP Production"@fr ;
    rdfs:comment "The live production instance of the ERP System, critical for business operations."@en ;
    noria:applicationModuleOf <noria/Application_ERP_System> ;
    noria:applicationModuleName "ERP_PROD" ;
    noria:applicationModuleIdentifier "PROD-002" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleAdministrationTeam <org/Team_ServerAdmins> ;
    noria:applicationModuleSupportTeam <org/Team_ServerAdmins> ;
    noria:applicationModuleHotlineGroup <org/Team_ServerAdmins> .

<noria/ApplicationModule_Monitoring_Core> a noria:ApplicationModule ;
    rdfs:label "Monitoring Core Module"@en, "Module Cœur Supervision"@fr ;
    rdfs:comment "Core components of the Monitoring Platform, including data collectors and alert engines."@en ;
    noria:applicationModuleOf <noria/Application_Monitoring_Platform> ;
    noria:applicationModuleName "MON_CORE" ;
    noria:applicationModuleIdentifier "CORE-003" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleAdministrationTeam <org/Team_NetworkOperations> ;
    noria:applicationModuleSupportTeam <org/Team_NetworkOperations> .

# Generate more applications and modules
@for $i from 1 to 10 do
<noria/Application_App{$i}> a noria:Application ;
    rdfs:label "Application {$i}"@en, "Application {$i}"@fr ;
    rdfs:comment "A generic business application."@en ;
    noria:applicationModelIdentifier "APP-00{$i}" ;
    noria:applicationNumericalIdentifier 1000 + {$i} ;
    noria:applicationShortIdentifier "APP{$i}" ;
    noria:applicationType <kos/application/type/business-support> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "Business Operations" ;
    noria:applicationFunctionalSubDomain "General Services" .

@for $j from 1 to 2 do
<noria/ApplicationModule_App{$i}_Env{$j}> a noria:ApplicationModule ;
    rdfs:label "Application {$i} Environment {$j}"@en, "Application {$i} Environnement {$j}"@fr ;
    rdfs:comment "Instance of Application {$i} for environment {$j} (1=Prod, 2=Test)."@en ;
