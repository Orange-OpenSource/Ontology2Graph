# --- Event Records ---

# Event Record 1: CRM DB CPU Spike
<noria/EventRecord_CRM_DB_CPU_Spike> a noria:EventRecord ;
    rdfs:label "CRM DB Server CPU Spike"@en, "Pic CPU Serveur BD CRM"@fr ;
    rdfs:comment "High CPU utilization detected on the CRM database server, exceeding 90% for 15 minutes."@en ;
    noria:logOriginatingManagedObject <noria/Resource_Server_DB01_Paris> ;
    noria:logOriginatingManagementSystem <noria/Application_Monitoring_Platform> ;
    noria:logOriginatingAgent <org/Team_DatabaseAdmins> ;
    noria:logText "CPU utilization on db01.paris.example.com exceeded 90% for 15 minutes. Current: 95%."@en ;
    noria:loggingTime "2024-04-20T08:55:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction <pep/Procedure_RestartDBService> ;
    noria:alarmMitigatedBy <pep/ProcedureExecutionContainer_DBRestart> .

# Event Record 2: Network Interface Down
<noria/EventRecord_Core01_Interface_Down> a noria:EventRecord ;
    rdfs:label "Core Router Interface Down"@en, "Interface Routeur Cœur Hors Service"@fr ;
    rdfs:comment "GigabitEthernet0/0/0 on Core Router 01 went down unexpectedly."@en ;
    noria:logOriginatingManagedObject <noria/Resource_Router_Core01_Paris> ;
    noria:logOriginatingManagementSystem <noria/Application_Monitoring_Platform> ;
    noria:logOriginatingAgent <org/Team_NetworkOperations> ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/0, changed state to down."@en ;
    noria:loggingTime "2024-04-20T13:58:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction <pep/Procedure_CheckFiberConnection> .

# Event Record 3: Firewall Blocked Traffic
<noria/EventRecord_Firewall_Blocked_Traffic> a noria:EventRecord ;
    rdfs:label "Firewall Blocked Malicious Traffic"@en, "Pare-feu Trafic Malveillant Bloqué"@fr ;
    rdfs:comment "Firewall detected and blocked an attempted port scan from an external IP address."@en ;
    noria:logOriginatingManagedObject <noria/Resource_Firewall_Edge01_Paris> ;
    noria:logOriginatingManagementSystem <noria/Application_Monitoring_Platform> ;
    noria:logOriginatingAgent <org/Team_SecurityOperations> ;
    noria:logText "Threat detected: Port Scan. Source IP: 198.51.100.1, Destination IP: 10.0.0.100. Action: Block."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Warning> .

# Link Event Records to Trouble Tickets and Change Requests
<noria/TroubleTicket_CRM_Outage_TT1> noria:troubleTicketTrigger <noria/EventRecord_CRM_DB_CPU_Spike> .
<noria/TroubleTicket_Network_Degradation_TT2> noria:troubleTicketTrigger <noria/EventRecord_Core01_Interface_Down> .

<noria/TroubleTicket_CRM_Outage_TT1> noria:documentStatusHistory <noria/EventRecord_TT1_StatusChange_InProgress> .
<noria/EventRecord_TT1_StatusChange_InProgress> a noria:EventRecord ;
    rdfs:label "TT1 Status Change to InProgress"@en ;
    rdfs:comment "Automated event recording the status change of TroubleTicket_CRM_Outage_TT1 to InProgress."@en ;
    noria:logOriginatingManagementSystem <noria/Application_Monitoring_Platform> ;
    noria:logText "TroubleTicket INC-CRM-20240420-001 status changed from Initialised to InProgress."@en ;
    noria:loggingTime "2024-04-20T09:10:00Z"^^xsd:dateTime .

<noria/ChangeRequest_CRM_DB_Upgrade_CR1> noria:documentStatusHistory <noria/EventRecord_CR1_StatusChange_Completed> .
<noria/EventRecord_CR1_StatusChange_Completed> a noria:EventRecord ;
    rdfs:label "CR1 Status Change to Completed"@en ;
    rdfs:comment "Automated event recording the status change of ChangeRequest_CRM_DB_Upgrade_CR1 to Completed."@en ;
    noria:logOriginatingManagementSystem <noria/Application_Monitoring_Platform> ;
    noria:logText "ChangeRequest CR-CRM-DB-20240501-001 status changed from InProgress to Completed."@en ;
    noria:loggingTime "2024-05-01T05:45:00Z"^^xsd:dateTime .

# Generate many more event records
@for $i from 1 to 100 do
<noria/EventRecord_ResourceHealth{$i}> a noria:EventRecord ;
    rdfs:label "Resource Health Check {$i}"@en, "Contrôle Santé Ressource {$i}"@fr ;
    rdfs:comment "Routine health check event for a generic application server."@en ;
    noria:logOriginatingManagedObject <noria/Resource_Server_App{$i % 50 + 1}> ; # Link to one of the generic app servers
    noria:logOriginatingManagementSystem <noria/Application_Monitoring_Platform> ;
    noria:logText "Health check passed for appserver{$i % 50 + 1}.example.com. CPU: 20%, Memory: 40%."@en ;
    noria:loggingTime "2024-04-21T{$i % 24}:{$i % 60}:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Informational> .

<noria/EventRecord_NetworkTrafficAlert{$i}> a noria:EventRecord ;
    rdfs:label "Network Traffic Alert {$i}"@en, "Alerte Trafic Réseau {$i}"@fr ;
    rdfs:comment "Alert indicating unusual traffic pattern on an edge router."@en ;
    noria:logOriginatingManagedObject <noria/Resource_Router_Edge{$i % 20 + 1}> ; # Link to one of the generic edge routers
    noria:logOriginatingManagementSystem <noria/Application_Monitoring_Platform> ;
    noria:logText "Unusual outbound traffic detected on edgerouter{$i % 20 + 1}.example.com. Threshold exceeded by 15%."@en ;
    noria:loggingTime "2024-04-21T{$i % 24}:{$i % 60}:30Z"^^xsd:dateTime ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Warning> .

<noria/EventRecord_VM_DiskUsage{$i}> a noria:EventRecord ;
    rdfs:label "VM Disk Usage Alert {$i}"@en, "Alerte Utilisation Disque VM {$i}"@fr ;
    rdfs:comment "Disk usage on a database VM is approaching critical levels."@en ;
    noria:logOriginatingManagedObject <noria/Resource_VM_DB{$i % 50 + 1}> ; # Link to one of the generic DB VMs
    noria:logOriginatingManagementSystem <noria/Application_Monitoring_Platform> ;
    noria:logText "Disk usage on dbvm{$i % 50 + 1}.example.com is 85%. Threshold: 90%."@en ;
    noria:loggingTime "2024-04-21T{$i % 24}:{$i % 60}:45Z"^^xsd:dateTime ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Minor> .
@end

# --- Procedural Elements ---

# Operation Plans
<noria/OperationPlan_RestartDBService> a noria:OperationPlan ;
    rdfs:label "Restart Database Service Procedure"@en, "Procédure de Redémarrage du Service de Base de Données"@fr ;
    rdfs:comment "Standard operating procedure for restarting a database service in case of performance issues or unresponsiveness."@en ;
    skos:example "Steps include checking logs, gracefully stopping the service, verifying process termination, and starting the service."@en ;
    noria:operationPlanPreCondition <noria/ActionPreCondition_DBUnresponsive> ;
    noria:operationPlanPostCondition <noria/ActionPostCondition_DBServiceRestored> .

<noria/OperationPlan_ReplaceSFPModule> a noria:OperationPlan ;
    rdfs:label "Replace SFP Module Procedure"@en, "Procédure de Remplacement Module SFP"@fr ;
    rdfs:comment "Procedure for replacing a faulty Small Form-Factor Pluggable (SFP) module in a network device."@en ;
    skos:example "Steps include identifying the faulty module, preparing a replacement, hot-swapping the module, and verifying link status."@en ;
    noria:operationPlanPreCondition <noria/ActionPreCondition_FaultySFPDetected> ;
    noria:operationPlanPostCondition <noria/ActionPostCondition_LinkOperational> .

<noria/OperationPlan_ApplyNetworkConfig> a noria:OperationPlan ;
    rdfs:label "Apply Network Configuration Procedure"@en, "Procédure d'Application Configuration Réseau"@fr ;
    rdfs:comment "Standard procedure for applying new network configurations to core routers."@en ;
    skos:example "Steps include backing up current config, applying new config, verifying connectivity, and saving config."@en ;
    noria:operationPlanPreCondition <noria/ActionPreCondition_ConfigApproved> ;
    noria:operationPlanPostCondition <noria/ActionPostCondition_ConfigAppliedVerified> .

# Anomaly Patterns
<noria/AnomalyPattern_DBConnectionExhaustion> a noria:AnomalyPattern ;
    rdfs:label "Database Connection Exhaustion Pattern"@en, "Modèle d'Épuisement des Connexions BD"@fr ;
    rdfs:comment "Pattern indicating a database connection pool exhaustion, often leading to application unresponsiveness."@en ;
    skos:example "High CPU on DB server, increased connection errors in application logs, slow query responses."@en .

<noria/AnomalyPattern_NetworkLinkFlap> a noria:AnomalyPattern ;
    rdfs:label "Network Link Flapping Pattern"@en, "Modèle de Flapping de Lien Réseau"@fr ;
    rdfs:comment "Pattern describing intermittent up/down states of a network link, often caused by physical layer issues."@en ;
    skos:example "Repeated 'link up/down' messages in router logs, intermittent packet loss, high error rates on interface."@en .

# Action Pre-Conditions
<noria/ActionPreCondition_DBUnresponsive> a noria:ActionPreCondition ;
    rdfs:label "Database Unresponsive Pre-Condition"@en, "Pré-condition Base de Données Non Répondante"@fr ;
    rdfs:comment "Condition where the database service is not responding to queries or connections."@en ;
    skos:example "Application logs show connection timeouts, direct database connection attempts fail."@en .

<noria/ActionPreCondition_FaultySFPDetected> a noria:ActionPreCondition ;
    rdfs:label "Faulty SFP Detected Pre-Condition"@en, "Pré-condition SFP Défectueux Détecté"@fr ;
    rdfs:comment "Condition where a Small Form-Factor Pluggable (SFP) module is identified as faulty."@en ;
    skos:example "Interface errors, low optical power readings, 'bad SFP' messages in device logs."@en .

<noria/ActionPreCondition_ConfigApproved> a noria:ActionPreCondition ;
    rdfs:label "Configuration Approved Pre-Condition"@en, "Pré-condition Configuration Approuvée"@fr ;
    rdfs:comment "Condition that the new network configuration has been formally approved by all stakeholders."@en ;
    skos:example "Change Request status is 'Approved', all necessary approvals are recorded."@en .

# Action Post-Conditions
<noria/ActionPostCondition_DBServiceRestored> a noria:ActionPostCondition ;
    rdfs:label "Database Service Restored Post-Condition"@en, "Post-condition Service BD Restauré"@fr ;
    rdfs:comment "Expected outcome: the database service is fully operational and responsive."@en ;
    skos:example "Application can connect to DB, queries are successful, CPU/memory usage is normal."@en .

<noria/ActionPostCondition_LinkOperational> a noria:ActionPostCondition ;
    rdfs:label "Network Link Operational Post-Condition"@en, "Post-condition Lien Réseau Opérationnel"@fr ;
    rdfs:comment "Expected outcome: the network link is stable, up, and free of errors."@en ;
    skos:example "Interface status is 'up', no packet loss, optical power levels are within normal range."@en .

<noria/ActionPostCondition_ConfigAppliedVerified> a noria:ActionPostCondition ;
    rdfs:label "Configuration Applied and Verified Post-Condition"@en, "Post-condition Configuration Appliquée et Vérifiée"@fr ;
    rdfs:comment "Expected outcome: the new configuration is active on the device and verified to be working correctly."@en ;
    skos:example "New routing policies are active, connectivity tests pass, security rules are enforced."@en .

# Link Operation Plans to Change Requests and Trouble Tickets
<noria/ChangeRequest_CRM_DB_Upgrade_CR1> noria:actionCorrelatedOperationPlan <noria/OperationPlan_RestartDBService> . # Simplified, a DB upgrade would be more complex
<noria/TroubleTicket_Network_Degradation_TT2> noria:actionCorrelatedOperationPlan <noria/OperationPlan_ReplaceSFPModule> .

# Procedure Execution Containers (for Event Records)
<pep/ProcedureExecutionContainer_DBRestart> a pep:ProcedureExecutionContainer ;
    rdfs:label "Database Restart Execution"@en ;
    rdfs:comment "Container for events related to the execution of the database restart procedure."@en ;
    dcterms:created "2024-04-20T09:35:00Z"^^xsd:dateTime ;
    dcterms:creator <foaf/Agent_BobWilliams> .

# Link Event Records to Procedure Execution Containers
<noria/EventRecord_CRM_DB_CPU_Spike> noria:alarmMitigatedBy <pep/ProcedureExecutionContainer_DBRestart> .
<noria/TroubleTicketNote_CRM_Outage_TT1_Note2> noria:troubleTicketNoteCorrelatedExecution <pep/ProcedureExecutionContainer_DBRestart> .

# Generate more procedural elements
@for $i from 1 to 10 do
<noria/OperationPlan_GenericMaintenance{$i}> a noria:OperationPlan ;
    rdfs:label "Generic Maintenance Plan {$i}"@en, "Plan de Maintenance Générique {$i}"@fr ;
    rdfs:comment "A routine maintenance procedure for various IT assets."@en ;
    skos:example "Includes steps for system checks, log review, and minor adjustments."@en ;
    noria:operationPlanPreCondition <noria/ActionPreCondition_SystemStable> ;
    noria:operationPlanPostCondition <noria/ActionPostCondition_SystemOptimized> .

<noria/AnomalyPattern_HighLatency{$i}> a noria:AnomalyPattern ;
    rdfs:label "High Latency Pattern {$i}"@en, "Modèle de Latence Élevée {$i}"@fr ;
    rdfs:comment "Pattern indicating elevated network latency affecting user experience."@en ;
    skos:example "Ping times consistently above 100ms, application response times degraded."@en .

<noria/ActionPreCondition_SystemStable> a noria:ActionPreCondition ;
    rdfs:label "System Stable Pre-Condition"@en, "Pré-condition Système Stable"@fr ;
    rdfs:comment "Ensures the system is in a stable state before maintenance."@en .

<noria/ActionPostCondition_SystemOptimized> a noria:ActionPostCondition ;
    rdfs:label "System Optimized Post-Condition"@en, "Post-condition Système Optimisé"@fr ;
    rdfs:comment "Verifies that system performance and health are improved after maintenance."@en .
@end

