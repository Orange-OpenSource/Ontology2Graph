    noria:networkInterfaceLaserRxOpticalPower -4 .

<noria/NetworkLink_EdgeRouter{$i}_Core01_WAN> a noria:NetworkLink ;
    rdfs:label "WAN Link EdgeRouter{$i} to Core01"@en, "Lien WAN RouteurEdge{$i} vers Core01"@fr ;
    rdfs:comment "WAN link connecting Edge Router {$i} to the Core01 router in Paris DC."@en ;
    noria:networkLinkId "NL-EDGE{$i}-CORE01-WAN" ;
    noria:networkLinkInstallationDate "2023-02-01T00:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "MPLS VPN" ;
    noria:networkLinkTerminationResourceOrigin <noria/Resource_Router_Edge{$i}> ;
    noria:networkLinkTerminationResourceDestination <noria/Resource_Router_Core01_Paris> ;
    noria:networkInterfaceConnects <noria/NetworkInterface_EdgeRouter{$i}_WAN> ;
    noria:networkInterfaceConnects <noria/NetworkInterface_Core01_Gi0_0_0> . # All edge routers connect to the same core interface for simplicity
@end

# --- Trouble Tickets and Notes ---

# Trouble Ticket 1: Critical CRM Outage
<noria/TroubleTicket_CRM_Outage_TT1> a noria:TroubleTicket ;
    rdfs:label "Critical CRM Application Outage"@en, "Panne Critique Application CRM"@fr ;
    rdfs:comment "The CRM production application is completely down, affecting all sales and customer service operations. Users cannot log in."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/TotalBreakdown> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ApplicationFailure> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/ApplicationFailure> ;
    noria:troubleTicketCause "Database connection pool exhaustion" ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ApplicationHosting> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty <org/Team_AppSupport_CRM> ;
    noria:troubleTicketRelatedParty <foaf/Agent_JaneSmith> ;
    noria:troubleTicketRelatedService <noria/ApplicationModule_CRM_Prod> ;
    noria:troubleTicketRelatedResource <noria/Resource_Server_DB01_Paris> ;
    noria:troubleTicketImpacts <noria/ApplicationModule_CRM_Prod> ;
    noria:troubleTicketImpacts <noria/Resource_Server_Web01_Paris> ;
    noria:troubleTicketImpacts <noria/Resource_Server_DB01_Paris> ;
    noria:documentExternalId "INC-CRM-20240420-001" ;
    noria:documentHRef "https://itsm.example.com/ticket/INC-CRM-20240420-001" .

<noria/TroubleTicketNote_CRM_Outage_TT1_Note1> a noria:TroubleTicketNote ;
    rdfs:label "Initial Report - CRM Outage"@en, "Rapport Initial - Panne CRM"@fr ;
    rdfs:comment "Customer reported inability to access CRM. Initial checks confirm application is unresponsive. Escalated to L2 CRM support."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Customer> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:created "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    dcterms:creator <org/Team_HelpDesk> ;
    dcterms:isPartOf <noria/TroubleTicket_CRM_Outage_TT1> .

<noria/TroubleTicketNote_CRM_Outage_TT1_Note2> a noria:TroubleTicketNote ;
    rdfs:label "L2 Investigation - CRM Outage"@en, "Investigation N2 - Panne CRM"@fr ;
    rdfs:comment "L2 team identified high CPU on DB server and database connection pool exhaustion. Restarting application services on web servers."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:created "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    dcterms:creator <foaf/Agent_JaneSmith> ;
    dcterms:isPartOf <noria/TroubleTicket_CRM_Outage_TT1> .

# Trouble Ticket 2: Network Link Degradation
<noria/TroubleTicket_Network_Degradation_TT2> a noria:TroubleTicket ;
    rdfs:label "Network Link Degradation - Paris DC"@en, "Dégradation Lien Réseau - DC Paris"@fr ;
    rdfs:comment "Intermittent packet loss and high latency observed on the core network link in Paris DC, affecting multiple services."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/CorruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "Zabbix" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/NetworkFailure> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/NetworkFailure> ;
    noria:troubleTicketCause "Suspected faulty SFP module on Core Router 01" ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T18:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T17:30:00Z"^^xsd:dateTime ;
