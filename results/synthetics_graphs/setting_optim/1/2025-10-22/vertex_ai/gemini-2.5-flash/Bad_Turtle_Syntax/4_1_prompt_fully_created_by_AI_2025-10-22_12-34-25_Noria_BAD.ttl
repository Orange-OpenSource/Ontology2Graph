# Generate more trouble tickets and notes
@for $i from 1 to 50 do
<noria/TroubleTicket_GenericTT{$i}> a noria:TroubleTicket ;
    rdfs:label "Generic Incident {$i}"@en, "Incident Générique {$i}"@fr ;
    rdfs:comment "A routine incident affecting a specific resource or application module."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Minor> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/WorkingBackup> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P3> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/User> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/NoIntervention> ;
    noria:troubleTicketSupervisionTool "ServiceNow" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/UserError> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/UserError> ;
    noria:troubleTicketCause "User misconfiguration" ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/Customer> ;
    noria:troubleTicketDetectionDateTime "2024-04-21T08:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-21T17:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-21T16:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-22T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable false ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ;
    noria:troubleTicketRelatedParty <org/Team_HelpDesk> ;
    noria:troubleTicketRelatedParty <foaf/Agent_Employee1> ;
    noria:troubleTicketRelatedService <noria/Application_App1> ;
    noria:troubleTicketRelatedResource <noria/Resource_Server_App1> ;
    noria:troubleTicketImpacts <noria/ApplicationModule_App1_Env1> ;
    noria:documentExternalId "INC-GEN-20240421-{$i}" ;
    noria:documentHRef "https://itsm.example.com/ticket/INC-GEN-20240421-{$i}" .

@for $j from 1 to 2 do
<noria/TroubleTicketNote_GenericTT{$i}_Note{$j}> a noria:TroubleTicketNote ;
    rdfs:label "Note {$j} for Generic Incident {$i}"@en, "Note {$j} pour Incident Générique {$i}"@fr ;
    rdfs:comment "Details regarding the resolution of generic incident {$i}."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/CorrectiveAction> ;
    dcterms:created "2024-04-21T08:30:00Z"^^xsd:dateTime ;
    dcterms:creator <org/Team_HelpDesk> ;
    dcterms:isPartOf <noria/TroubleTicket_GenericTT{$i}> .
@end
@end

