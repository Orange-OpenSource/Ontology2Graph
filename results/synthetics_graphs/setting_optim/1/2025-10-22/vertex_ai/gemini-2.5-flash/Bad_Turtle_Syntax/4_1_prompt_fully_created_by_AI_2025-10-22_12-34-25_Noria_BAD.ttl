    rdfs:comment "A standard server model used across the infrastructure."@en ;
    noria:productManufacturedBy <org/Organization_Dell> .

<noria/ProductModel_GenericRouter{$i}> a noria:ProductModel ;
    rdfs:label "Generic Router Model {$i}"@en ;
    rdfs:comment "A standard router model for network connectivity."@en ;
    noria:productManufacturedBy <org/Organization_Cisco> .
@end

# --- Applications and Modules ---

# Applications
<noria/Application_CRM_Suite> a noria:Application ;
    rdfs:label "CRM Suite"@en, "Suite CRM"@fr ;
    rdfs:comment "Enterprise Customer Relationship Management application, critical for sales and customer service."@en ;
    noria:applicationModelIdentifier "CRM-001" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Sales & Support" .

<noria/Application_ERP_System> a noria:Application ;
    rdfs:label "ERP System"@en, "Système ERP"@fr ;
    rdfs:comment "Enterprise Resource Planning system, managing finance, HR, and supply chain."@en ;
    noria:applicationModelIdentifier "ERP-002" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "ERP" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Enterprise Resource Planning" ;
    noria:applicationFunctionalSubDomain "Finance & Logistics" .

<noria/Application_Monitoring_Platform> a noria:Application ;
    rdfs:label "Monitoring Platform"@en, "Plateforme de Supervision"@fr ;
    rdfs:comment "Centralized platform for infrastructure and application monitoring, alerting, and logging."@en ;
    noria:applicationModelIdentifier "MON-003" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "MON" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Monitoring & Alerting" .

<noria/Application_Internal_Wiki> a noria:Application ;
    rdfs:label "Internal Wiki"@en, "Wiki Interne"@fr ;
    rdfs:comment "Knowledge base and collaboration platform for internal documentation."@en ;
    noria:applicationModelIdentifier "WIKI-004" ;
    noria:applicationNumericalIdentifier 1004 ;
    noria:applicationShortIdentifier "WIKI" ;
    noria:applicationType <kos/application/type/internal-tool> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "Knowledge Management" ;
    noria:applicationFunctionalSubDomain "Collaboration & Documentation" .

# Application Modules
<noria/ApplicationModule_CRM_Prod> a noria:ApplicationModule ;
    rdfs:label "CRM Production Module"@en, "Module CRM Production"@fr ;
    rdfs:comment "The live production instance of the CRM Suite, serving end-users."@en ;
    noria:applicationModuleOf <noria/Application_CRM_Suite> ;
    noria:applicationModuleName "CRM_PROD" ;
    noria:applicationModuleIdentifier "PROD-001" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleAdministrationTeam <org/Team_AppSupport_CRM> ;
    noria:applicationModuleSupportTeam <org/Team_AppSupport_CRM> ;
    noria:applicationModuleHotlineGroup <org/Team_AppSupport_CRM> .

<noria/ApplicationModule_CRM_Dev> a noria:ApplicationModule ;
    rdfs:label "CRM Development Module"@en, "Module CRM Développement"@fr ;
