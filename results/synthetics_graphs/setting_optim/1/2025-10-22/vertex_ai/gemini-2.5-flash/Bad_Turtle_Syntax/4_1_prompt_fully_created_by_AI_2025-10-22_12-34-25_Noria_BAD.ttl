# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents and Organizations ---

# Organizational Units (Teams)
<org/Team_NetworkOperations> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Responsible for the day-to-day operation and maintenance of the core network infrastructure."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "For critical network incidents, call the primary hotline. For routine requests, use the ticketing system."@en .

<org/Team_ServerAdmins> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Server Administration Team"@en, "Équipe Administration Serveurs"@fr ;
    rdfs:comment "Manages all physical and virtual server resources across data centers."@en ;
    noria:agentWorkingHours "Mon-Fri, 08:00-18:00 CET"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Submit all server-related requests via the internal portal. Urgent issues can be escalated via chat."@en .

<org/Team_AppSupport_CRM> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "CRM Application Support"@en, "Support Application CRM"@fr ;
    rdfs:comment "Provides level 2 and 3 support for the Customer Relationship Management application suite."@en ;
    noria:agentWorkingHours "Mon-Fri, 09:00-17:00 Local Time"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing> ;
    noria:agentInstructions "All CRM application issues must be logged in the dedicated CRM support queue."@en .

<org/Team_SecurityOperations> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en, "Centre d'Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Monitors, detects, analyzes, and responds to cybersecurity incidents."@en ;
    noria:agentWorkingHours "24/7 Continuous Monitoring"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/alerting> ;
    noria:agentInstructions "Automated alerts are processed directly. For manual reporting, use the security incident portal."@en .

<org/Team_DatabaseAdmins> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en, "Équipe Administration Bases de Données"@fr ;
    rdfs:comment "Manages and maintains all corporate database systems, ensuring data integrity and performance."@en ;
    noria:agentWorkingHours "Mon-Fri, 08:30-17:30 CET"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Database change requests require prior approval and must be scheduled. Incident response is 24/7."@en .

<org/Team_CloudInfra> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Cloud Infrastructure Team"@en, "Équipe Infrastructure Cloud"@fr ;
    rdfs:comment "Responsible for the design, deployment, and management of cloud-based resources and services."@en ;
    noria:agentWorkingHours "Mon-Fri, 09:00-18:00 UTC"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> ;
    noria:agentInstructions "Cloud resource provisioning requests are handled via automated pipelines. For support, contact via dedicated chat channel."@en .

<org/Team_DevOps> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "DevOps Team"@en, "Équipe DevOps"@fr ;
    rdfs:comment "Facilitates collaboration between development and operations, automating software delivery and infrastructure changes."@en ;
    noria:agentWorkingHours "Mon-Fri, 09:00-17:00 CET"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/internal-wiki> ;
    noria:agentInstructions "Consult the internal knowledge base for common issues. For new feature requests or complex deployments, open a project ticket."@en .

<org/Team_HelpDesk> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "IT Help Desk"@en, "Service d'Assistance Informatique"@fr ;
    rdfs:comment "First point of contact for all IT-related issues and requests from end-users."@en ;
    noria:agentWorkingHours "Mon-Fri, 07:00-19:00 Local Time"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Users should call the help desk number or submit a ticket through the self-service portal."@en .

# Individual Agents
<foaf/Agent_JohnDoe> a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Senior Network Engineer, member of the Network Operations Team."@en ;
    noria:agentWorkingHours "Mon-Fri, 09:00-17:00 CET"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact for complex routing issues or network design queries."@en .

<foaf/Agent_JaneSmith> a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Lead CRM Support Specialist, member of the CRM Application Support Team."@en ;
    noria:agentWorkingHours "Mon-Fri, 09:00-17:00 Local Time"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing> ;
    noria:agentInstructions "Primary contact for critical CRM application outages."@en .

<foaf/Agent_AliceJohnson> a foaf:Agent ;
    rdfs:label "Alice Johnson"@en, "Alice Dubois"@fr ;
    rdfs:comment "Cloud Architect, member of the Cloud Infrastructure Team."@en ;
    noria:agentWorkingHours "Mon-Fri, 09:00-18:00 UTC"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> ;
    noria:agentInstructions "Consult for new cloud service deployments or architectural reviews."@en .

<foaf/Agent_BobWilliams> a foaf:Agent ;
    rdfs:label "Bob Williams"@en, "Bob Lefebvre"@fr ;
    rdfs:comment "Database Administrator, member of the Database Administration Team."@en ;
    noria:agentWorkingHours "Mon-Fri, 08:30-17:30 CET"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact for database performance tuning or schema changes."@en .

<foaf/Agent_EveDavis> a foaf:Agent ;
    rdfs:label "Eve Davis"@en, "Ève Bernard"@fr ;
    rdfs:comment "SOC Analyst, member of the Security Operations Center."@en ;
    noria:agentWorkingHours "Shift A: 06:00-14:00 UTC"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/alerting> ;
    noria:agentInstructions "Handles real-time security alerts and initial incident response."@en .

# Generate more agents and link them to teams
@for $i from 1 to 20 do
<foaf/Agent_Employee{$i}> a foaf:Agent ;
    rdfs:label "Employee {$i}"@en, "Employé {$i}"@fr ;
    rdfs:comment "General IT employee, part of various operational teams."@en ;
    noria:agentWorkingHours "Mon-Fri, 09:00-17:00"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Standard contact methods apply."@en .
@end

# --- Locations ---

# Sites
<bot/Site_DC_Paris> a bot:Site ;
    rdfs:label "Paris Data Center"@en, "Centre de Données de Paris"@fr ;
    rdfs:comment "Primary data center facility located in Paris, France."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressStreet "Rue de la Paix" .

<bot/Site_DC_Lyon> a bot:Site ;
    rdfs:label "Lyon Data Center"@en, "Centre de Données de Lyon"@fr ;
    rdfs:comment "Secondary data center facility located in Lyon, France, serving as a disaster recovery site."@en ;
    noria:siteId "DC-LYN-02" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressStreet "Avenue Jean Jaurès" .

<bot/Site_Office_London> a bot:Site ;
    rdfs:label "London Office"@en, "Bureau de Londres"@fr ;
    rdfs:comment "Corporate office building in London, UK."@en ;
    noria:siteId "OFF-LDN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "789 Baker Street" ;
    noria:sitePrincipalAddressCityName "London" ;
    noria:sitePrincipalAddressPostalCode "NW1 6XE" ;
    noria:sitePrincipalAddressCountry "UK" ;
    noria:sitePrincipalAddressStreet "Baker Street" .

# Rooms
<noria/Room_DC_Paris_ServerRoomA> a noria:Room ;
    rdfs:label "Paris DC Server Room A"@en, "Salle Serveurs A DC Paris"@fr ;
    rdfs:comment "Main server room in the Paris Data Center, housing critical production systems."@en ;
    bot:hasSpace <bot/Site_DC_Paris> .

<noria/Room_DC_Paris_NetworkRoom> a noria:Room ;
    rdfs:label "Paris DC Network Room"@en, "Salle Réseau DC Paris"@fr ;
    rdfs:comment "Dedicated room for core network equipment in the Paris Data Center."@en ;
    bot:hasSpace <bot/Site_DC_Paris> .

<noria/Room_DC_Lyon_ServerRoomB> a noria:Room ;
    rdfs:label "Lyon DC Server Room B"@en, "Salle Serveurs B DC Lyon"@fr ;
    rdfs:comment "Server room in the Lyon Data Center, primarily for backup and DR systems."@en ;
    bot:hasSpace <bot/Site_DC_Lyon> .

# Loci (specific locations within rooms)
<noria/Locus_DC_Paris_RackA1_U10> a noria:Locus ;
    rdfs:label "Paris DC Rack A1, Unit 10"@en, "DC Paris Baie A1, Unité 10"@fr ;
    rdfs:comment "Specific rack unit location for a server in Paris Data Center."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "10" ;
    bot:hasSpace <noria/Room_DC_Paris_ServerRoomA> .

<noria/Locus_DC_Paris_RackA1_U11> a noria:Locus ;
    rdfs:label "Paris DC Rack A1, Unit 11"@en, "DC Paris Baie A1, Unité 11"@fr ;
    rdfs:comment "Specific rack unit location for a server in Paris Data Center."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "11" ;
    bot:hasSpace <noria/Room_DC_Paris_ServerRoomA> .

<noria/Locus_DC_Paris_RackN1_U5> a noria:Locus ;
    rdfs:label "Paris DC Network Rack N1, Unit 5"@en, "DC Paris Baie Réseau N1, Unité 5"@fr ;
    rdfs:comment "Specific rack unit location for a router in Paris Data Center Network Room."@en ;
    noria:locusLine "N1" ;
    noria:locusRow "5" ;
    bot:hasSpace <noria/Room_DC_Paris_NetworkRoom> .

# Generate more locations
@for $i from 1 to 5 do
<bot/Site_BranchOffice{$i}> a bot:Site ;
    rdfs:label "Branch Office {$i}"@en, "Agence {$i}"@fr ;
    rdfs:comment "Remote branch office location."@en ;
    noria:siteId "BO-0{$i}" ;
    noria:siteType "branch office" ;
    noria:sitePrincipalAddress "{$i} Main Street" ;
    noria:sitePrincipalAddressCityName "City {$i}" ;
    noria:sitePrincipalAddressPostalCode "1000{$i}" ;
    noria:sitePrincipalAddressCountry "US" ;
    noria:sitePrincipalAddressStreet "Main Street" .

<noria/Room_BO{$i}_ServerCloset> a noria:Room ;
    rdfs:label "Branch Office {$i} Server Closet"@en, "Placard Serveurs Agence {$i}"@fr ;
    rdfs:comment "Small server closet in Branch Office {$i}."@en ;
    bot:hasSpace <bot/Site_BranchOffice{$i}> .

@for $j from 1 to 3 do
<noria/Locus_BO{$i}_Rack1_U{$j}> a noria:Locus ;
    rdfs:label "BO {$i} Rack 1, Unit {$j}"@en, "BO {$i} Baie 1, Unité {$j}"@fr ;
    rdfs:comment "Rack unit location in Branch Office {$i}."@en ;
    noria:locusLine "R1" ;
    noria:locusRow "{$j}" ;
    bot:hasSpace <noria/Room_BO{$i}_ServerCloset> .
@end
@end

