    noria:applicationModuleName "APP{$i}_ENV{$j}" ;
    noria:applicationModuleIdentifier "ENV{$j}-00{$i}" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Silver> ;
