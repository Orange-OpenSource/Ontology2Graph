@end

@for $i from 1 to 20 do
<noria/NetworkInterface_EdgeRouter{$i}_WAN> a noria:NetworkInterface ;
    rdfs:label "WAN Interface on EdgeRouter{$i}"@en, "Interface WAN sur RouteurEdge{$i}"@fr ;
