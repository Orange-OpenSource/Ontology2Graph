# Link resources to applications they serve
noria:Resource_DNS_Server_01 noria:resourceForApplication noria:Application_DNSInfrastructure .
noria:Resource_DNS_Server_02 noria:resourceForApplication noria:Application_DNSInfrastructure .
noria:Resource_Web_Server_01 noria:resourceForApplication noria:Application_CorporateWebsite .
noria:Resource_DB_Server_01 noria:resourceForApplication noria:Application_CRMSystem .
noria:Resource_Router_Core_Paris_01 noria:resourceForApplication noria:Application_MonitoringPlatform .
noria:Resource_Switch_DC_Paris_01 noria:resourceForApplication noria:Application_MonitoringPlatform .
noria:Resource_Firewall_Perimeter_01 noria:resourceForApplication noria:Application_SecurityGateway .
noria:Resource_VirtualMachine_CRM_01 noria:resourceForApplication noria:Application_CRMSystem .

# Link applications to resources they use (inverse of resourceForApplication, but not explicitly defined as inverse)
# We can use seas:subSystemOf for this, as Application is a seas:System and Resource is a seas:System.
noria:Application_CorporateWebsite seas:subSystemOf noria:Resource_Web_Server_01 .
noria:Application_CorporateWebsite seas:subSystemOf noria:Resource_DB_Server_01 . # Assuming it uses the DB
noria:Application_CRMSystem seas:subSystemOf noria:Resource_DB_Server_01 .
noria:Application_CRMSystem seas:subSystemOf noria:Resource_VirtualMachine_CRM_01 .
noria:Application_MonitoringPlatform seas:subSystemOf noria:Resource_DNS_Server_01 .
noria:Application_MonitoringPlatform seas:subSystemOf noria:Resource_Web_Server_01 .
noria:Application_MonitoringPlatform seas:subSystemOf noria:Resource_DB_Server_01 .
noria:Application_DNSInfrastructure seas:subSystemOf noria:Resource_DNS_Server_01 .
noria:Application_DNSInfrastructure seas:subSystemOf noria:Resource_DNS_Server_02 .
noria:Application_SecurityGateway seas:subSystemOf noria:Resource_Firewall_Perimeter_01 .
noria:Application_SecurityGateway seas:subSystemOf noria:Resource_Firewall_Perimeter_02 .

# Link agents to resources they manage (inverse of resourceManagedBy)
foaf:Agent_JohnDoe noria:agentManagesResource noria:Resource_Router_Core_Paris_01 .
foaf:Agent_JohnDoe noria:agentManagesResource noria:Resource_DNS_Server_01 .
foaf:Agent_JaneSmith noria:agentManagesResource noria:Resource_Web_Server_01 .
foaf:Agent_JaneSmith noria:agentManagesResource noria:Resource_DB_Server_01 .
foaf:Agent_AliceBrown noria:agentManagesResource noria:Resource_VirtualMachine_CRM_01 .
foaf:Agent_BobWhite noria:agentManagesResource noria:Resource_Firewall_Perimeter_01 .

# Link EventRecords to TroubleTickets via documentStatusHistory
noria:TroubleTicket_DNSOutage_01 noria:documentStatusHistory noria:EventRecord_DNS01_Down_01 .
noria:TroubleTicket_DNSOutage_01 noria:documentStatusHistory noria:EventRecord_DNS01_Cleared_01 .
noria:TroubleTicket_WebHighCPU_01 noria:documentStatusHistory noria:EventRecord_Web01_HighCPU_01 .

# Link ChangeRequests to EventRecords (e.g., for audit logs of changes)
noria:ChangeRequest_WebConfig_01 noria:documentStatusHistory noria:EventRecord_Web01_HighCPU_01 . # Example: a config change might be triggered by an event.

# Link OperationPlans to specific actions/events
noria:EventRecord_DNS01_Down_01 noria:alarmProposedRepairAction noria:OperationPlan_RestartInterface .
noria:EventRecord_Web01_HighCPU_01 noria:alarmProposedRepairAction noria:OperationPlan_TroubleshootHighCPU .

# Example of a ProcedureExecutionContainer for a resolution
noria:ProcedureExecutionContainer_DNSFix a pep:ProcedureExecutionContainer ;
    rdfs:label "DNS Server 01 Interface Fix Execution"@en ;
    rdfs:comment "Container for actions taken to resolve the DNS Server 01 interface issue."@en ;
    pep:hasMember noria:EventRecord_DNS01_Cleared_01 . # The clearing event is part of the execution.

noria:TroubleTicket_DNSOutage_01 noria:troubleTicketFreezeItem noria:ProcedureExecutionContainer_DNSFix . # Example of linking a freeze item to a procedure execution.
noria:EventRecord_DNS01_Down_01 noria:alarmMitigatedBy noria:ProcedureExecutionContainer_DNSFix .

# More complex interconnections for density
# Let's create more resources and link them.
# We'll create 10 more generic servers and 5 more generic routers, and interlink them.

# Generic Servers (10 instances)
[1..10] noria:Resource_Generic_Server_ ;
    a noria:Resource ;
    rdfs:label "Generic Server %1d"@en ;
    rdfs:comment "A generic server for various applications."@en ;
    noria:resourceManagedBy org:ServerTeam ;
    noria:resourceHostName "gen-srv%1d.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-01T08:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Paris_A1_R12_U42 ; # Distribute them
    noria:resourceManagementIPAddress "10.0.0.1%1d" .

# Generic Routers (5 instances)
[1..5] noria:Resource_Generic_Router_ ;
    a noria:Resource ;
    rdfs:label "Generic Router %1d"@en ;
