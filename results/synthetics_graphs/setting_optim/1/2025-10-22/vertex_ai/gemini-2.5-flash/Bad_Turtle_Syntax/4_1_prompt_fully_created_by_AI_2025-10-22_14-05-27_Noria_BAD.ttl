<Notification/Severity/PerceivedSeverity/Cleared> a skos:Concept ; rdfs:label "Cleared"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .

# Agent Contact Method
<kos/org/agent-contact-method/Email> a skos:Concept ; rdfs:label "Email"@en ; skos:inScheme <kos/org/agent-contact-method> .
<kos/org/agent-contact-method/Phone> a skos:Concept ; rdfs:label "Phone"@en ; skos:inScheme <kos/org/agent-contact-method> .
<kos/org/agent-contact-method/TicketingSystem> a skos:Concept ; rdfs:label "Ticketing System"@en ; skos:inScheme <kos/org/agent-contact-method> .

# Service Type
<kos/service/type/CustomerFacingService> a skos:Concept ; rdfs:label "Customer Facing Service"@en ; skos:inScheme <kos/service/type> .
<kos/service/type/ResourceFacingService> a skos:Concept ; rdfs:label "Resource Facing Service"@en ; skos:inScheme <kos/service/type> .

# ChangeRequest Specification
<kos/ChangeRequest/specification/StandardOperationProcedure> a skos:Concept ; rdfs:label "Standard Operation Procedure"@en ; skos:inScheme <kos/ChangeRequest/specification> .
<kos/ChangeRequest/specification/EmergencyMaintenance> a skos:Concept ; rdfs:label "Emergency Maintenance"@en ; skos:inScheme <kos/ChangeRequest/specification> .

# =============================================================================
# Agents and Organizations
# =============================================================================

# Organizations
org:OrangeCorp a org:Organization ;
    rdfs:label "Orange Corporation"@en ;
    rdfs:comment "The main corporate entity."@en .

org:ITOperationsDept a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Department responsible for overall IT infrastructure operations."@en ;
    org:unitOf org:OrangeCorp .

org:NetworkTeam a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network infrastructure."@en ;
    org:unitOf org:ITOperationsDept .

org:ServerTeam a org:OrganizationalUnit ;
    rdfs:label "Server Administration Team"@en ;
    rdfs:comment "Team managing physical and virtual servers."@en ;
    org:unitOf org:ITOperationsDept .

org:AppDevTeam a org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    org:unitOf org:ITOperationsDept .

org:SecurityTeam a org:OrganizationalUnit ;
    rdfs:label "Cybersecurity Operations Center"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    org:unitOf org:ITOperationsDept .

org:CustomerSupport a org:OrganizationalUnit ;
    rdfs:label "Customer Support Center"@en ;
    rdfs:comment "First line support for customer issues."@en ;
    org:unitOf org:OrangeCorp .

# Agents (foaf:Agent)
foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Network Engineer, Team Lead for Network Operations."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."@en ;
    org:memberOf org:NetworkTeam .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Server Administrator."@en ;
    noria:agentWorkingHours "8:30-16:30 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call directly for server-related incidents."@en ;
    org:memberOf org:ServerTeam .

foaf:Agent_AliceBrown a foaf:Agent ;
    rdfs:label "Alice Brown"@en ;
    rdfs:comment "Application Developer, specializing in CRM systems."@en ;
    noria:agentWorkingHours "10:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Submit all requests via the internal ticketing system."@en ;
    org:memberOf org:AppDevTeam .

foaf:Agent_BobWhite a foaf:Agent ;
    rdfs:label "Bob White"@en ;
    rdfs:comment "Security Analyst, responsible for incident response."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Emergency contact number available via internal directory."@en ;
    org:memberOf org:SecurityTeam .

foaf:Agent_Customer1 a foaf:Agent ;
    rdfs:label "Premium Customer A"@en ;
    rdfs:comment "A key external customer with high SLA requirements."@en .

foaf:Agent_Customer2 a foaf:Agent ;
    rdfs:label "Standard Customer B"@en ;
    rdfs:comment "A standard external customer."@en .

