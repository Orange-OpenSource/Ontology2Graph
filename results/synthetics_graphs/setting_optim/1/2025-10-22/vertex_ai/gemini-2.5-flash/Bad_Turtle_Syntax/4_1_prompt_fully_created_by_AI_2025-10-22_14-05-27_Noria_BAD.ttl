# Add more complex relations for density
# Example: A service might depend on another service
noria:Service_CustomerInternetAccess seas:subSystemOf noria:Service_InternalVPN .
noria:Service_CRMDataSync seas:subSystemOf noria:Service_InternalVPN .

# Example: An application module might be hosted on a virtual machine, which is on a physical server
noria:ApplicationModule_CRMSystem_Prod seas:subSystemOf noria:Resource_VirtualMachine_CRM_01 .
noria:Resource_VirtualMachine_CRM_01 seas:subSystemOf noria:Resource_Web_Server_01 .

# Example: A resource might be managed by multiple agents/teams for different aspects
noria:Resource_DNS_Server_01 noria:resourceManagedBy org:SecurityTeam . # Security team also manages DNS for security aspects

# Example: An event record might be correlated with another event record
noria:EventRecord_DNS01_Down_01 dcterms:relation noria:EventRecord_Web01_HighCPU_01 . # DNS outage might cause web server issues

# Example: A trouble ticket might be related to another trouble ticket (parent/child)
noria:TroubleTicket_DNSOutage_01 dcterms:hasPart noria:TroubleTicket_WebHighCPU_01 . # Web high CPU is a symptom/child of DNS outage

# Example: A change request might be related to a trouble ticket (e.g., a fix)
noria:ChangeRequest_RouterUpgrade_01 dcterms:relation noria:TroubleTicket_DNSOutage_01 . # Router upgrade might be a long-term fix for network stability issues that caused DNS outage

# Example: A resource might have multiple network interfaces
noria:Resource_DNS_Server_01 noria:networkInterfaceOf noria:NetworkInterface_DNS01_Eth0 .
noria:Resource_DNS_Server_01 noria:networkInterfaceOf noria:NetworkInterface_DNS01_Eth1 . # New interface
noria:NetworkInterface_DNS01_Eth1 a noria:NetworkInterface ;
    rdfs:label "dns01.corp.example.com:eth1"@en ;
    noria:networkInterfaceOf noria:Resource_DNS_Server_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# Example: A network link might connect two interfaces on the same resource (loopback, internal)
noria:NetworkLink_DNS01_Internal a noria:NetworkLink ;
    rdfs:label "DNS01 Internal Loopback Link"@en ;
    noria:networkLinkId "NL-DNS01-INT" ;
    noria:networkLinkType "Loopback" ;
    noria:networkInterfaceConnects noria:NetworkInterface_DNS01_Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_DNS01_Eth1 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS_Server_01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_DNS_Server_01 .

