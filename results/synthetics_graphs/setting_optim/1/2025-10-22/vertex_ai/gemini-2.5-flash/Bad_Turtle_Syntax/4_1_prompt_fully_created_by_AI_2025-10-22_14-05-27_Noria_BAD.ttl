    noria:resourceProductModel noria:ProductModel_JuniperMX480 ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-04-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Paris_B2_R05_U10 ; # Distribute them
    noria:resourceManagementIPAddress "10.0.1.1%1d" .

# Create more Network Interfaces for generic resources and link them
[1..10] noria:NetworkInterface_GenSrv%1d_Eth0 ;
    a noria:NetworkInterface ;
    rdfs:label "gen-srv%1d.example.com:eth0"@en ;
    noria:networkInterfaceOf noria:Resource_Generic_Server_%1d ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

