# =============================================================================
# Network Links
# =============================================================================

noria:NetworkLink_Paris_DC_Internal_Core a noria:NetworkLink ;
    rdfs:label "Paris DC Internal Core Link"@en ;
    rdfs:comment "High-speed link between Core Router Paris 01 and DC Switch Paris 01."@en ;
    noria:networkLinkId "NL-PAR-INT-001" ;
    noria:networkLinkType "Ethernet 100Gbps" ;
    noria:networkLinkInstallationDate "2021-06-01T10:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR_Paris_Eth0_0_0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_SW_Paris_Eth0_0_0 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_Router_Core_Paris_01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Switch_DC_Paris_01 .

noria:NetworkLink_Inter_DC_Paris_Lyon a noria:NetworkLink ;
    rdfs:label "Inter-DC Link Paris-Lyon"@en ;
    rdfs:comment "Redundant fiber link connecting Paris and Lyon Data Centers."@en ;
    noria:networkLinkId "NL-INTER-DC-001" ;
    noria:networkLinkType "DWDM Fiber 10Gbps" ;
    noria:networkLinkInstallationDate "2021-05-25T14:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR_Paris_Eth0_0_1 ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR_Lyon_Eth0_0_1 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_Router_Core_Paris_01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Router_Core_Lyon_01 .

noria:NetworkLink_Lyon_DC_Internal_Core a noria:NetworkLink ;
    rdfs:label "Lyon DC Internal Core Link"@en ;
    rdfs:comment "High-speed link between Core Router Lyon 01 and DC Switch Lyon 01."@en ;
    noria:networkLinkId "NL-LYN-INT-001" ;
    noria:networkLinkType "Ethernet 100Gbps" ;
    noria:networkLinkInstallationDate "2021-06-01T10:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR_Lyon_Eth0_0_0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_SW_Lyon_Eth0_0_0 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_Router_Core_Lyon_01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Switch_DC_Lyon_01 .

