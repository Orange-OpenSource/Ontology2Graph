    noria:operationPlanPostCondition noria:ActionPostCondition_CPUBackToNormal .

# =============================================================================
# Action Pre/Post Conditions
# =============================================================================

noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: A network interface's operational status is 'down'."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Expected outcome: A network interface's operational status is 'up'."@en .

noria:ActionPreCondition_HighCPU a noria:ActionPreCondition ;
    rdfs:label "Server CPU Utilization High"@en ;
    rdfs:comment "Condition: Server CPU utilization exceeds a predefined threshold (e.g., 90%)."@en .

noria:ActionPostCondition_CPUBackToNormal a noria:ActionPostCondition ;
    rdfs:label "Server CPU Utilization Normal"@en ;
    rdfs:comment "Expected outcome: Server CPU utilization returns to normal levels (e.g., below 70%)."@en .

# =============================================================================
# Document Attachments
# =============================================================================

noria:DocumentAttachment_DNSOutage_Log a noria:DocumentAttachment ;
    rdfs:label "DNS Server Log Excerpt"@en ;
    rdfs:comment "Relevant log entries from DNS Server 01 during the outage."@en ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage_01 ;
    dcterms:format "text/plain" ;
    dcterms:identifier "dns01_log_20240420.txt" .

noria:DocumentAttachment_RouterUpgrade_Plan a noria:DocumentAttachment ;
    rdfs:label "Router Upgrade Plan"@en ;
    rdfs:comment "Detailed plan for the Core Router Paris 01 software upgrade."@en ;
    dcterms:isPartOf noria:ChangeRequest_RouterUpgrade_01 ;
    dcterms:format "application/pdf" ;
    dcterms:identifier "CR-20240501-001_Plan.pdf" .

