# --- Connecting Trouble Tickets to Change Requests and vice-versa ---
noria:TroubleTicket_HIGH_CPU_DB_002 dcterms:relation noria:ChangeRequest_DB_OPTIMIZATION_001 .
noria:ChangeRequest_DB_OPTIMIZATION_001 dcterms:relation noria:TroubleTicket_HIGH_CPU_DB_002 .

noria:TroubleTicket_CWP_APP_ERROR_005 dcterms:relation noria:ChangeRequest_CWP_ROLLBACK_004 .
noria:ChangeRequest_CWP_ROLLBACK_004 dcterms:relation noria:TroubleTicket_CWP_APP_ERROR_005 .

# --- Connecting Event Records to Trouble Tickets and Change Requests ---
noria:TroubleTicket_CRITICAL_WAN_OUTAGE_001 noria:documentStatusHistory noria:EventRecord_RouterDown_PAR01_20240101 .
noria:TroubleTicket_HIGH_CPU_DB_002 noria:documentStatusHistory noria:EventRecord_DBHighCPU_SQL01_20240101 .
noria:TroubleTicket_EMAIL_DISK_FULL_004 noria:documentStatusHistory noria:EventRecord_EmailServerDiskFull_20240104 .
noria:TroubleTicket_CWP_APP_ERROR_005 noria:documentStatusHistory noria:EventRecord_WebPortalError_20240104 .

noria:ChangeRequest_DB_OPTIMIZATION_001 noria:documentStatusHistory noria:EventRecord_DBHighCPU_SQL01_20240101 . # CR triggered by this event
noria:ChangeRequest_EMAIL_DISK_CLEANUP_003 noria:documentStatusHistory noria:EventRecord_EmailServerDiskFull_20240104 .

# --- More complex relationships for density ---
# Anomaly Pattern for WAN outage
noria:AnomalyPattern_WAN_Outage a noria:AnomalyPattern ;
    rdfs:label "WAN Link Outage Pattern"@en ;
    rdfs:comment "Pattern indicating a WAN link outage, typically involving interface down events on both ends."@en ;
    folio:hasCause noria:TroubleTicket_CRITICAL_WAN_OUTAGE_001 . # Link to a specific TT as an example of its cause

# Operation Plan for Firewall Policy Update
noria:OperationPlan_Firewall_Update a noria:OperationPlan ;
    rdfs:label "Firewall Policy Update Procedure"@en ;
    rdfs:comment "Standard procedure for updating firewall policies."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_Policy_Approved ;
    noria:operationPlanPostCondition noria:ActionPostCondition_Policy_Applied .

noria:ActionPreCondition_Policy_Approved a noria:ActionPreCondition ;
    rdfs:label "Firewall Policy Approved Pre-condition"@en ;
    rdfs:comment "Condition: Firewall policy change request is approved."@en .

noria:ActionPostCondition_Policy_Applied a noria:ActionPostCondition ;
    rdfs:label "Firewall Policy Applied Post-condition"@en ;
    rdfs:comment "Outcome: New firewall policy successfully applied and verified."@en .

noria:ChangeRequest_FW_POLICY_UPDATE_002 noria:actionCorrelatedOperationPlan noria:OperationPlan_Firewall_Update .

