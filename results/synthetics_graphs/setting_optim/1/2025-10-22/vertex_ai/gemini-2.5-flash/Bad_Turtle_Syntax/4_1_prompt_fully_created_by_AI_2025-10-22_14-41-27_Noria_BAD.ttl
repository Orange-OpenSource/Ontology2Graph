# Example of EventRecord correlation to ProcedureExecutionContainer
noria:ProcedureExecutionContainer_WAN_Fix_001 a pep:ProcedureExecutionContainer ;
    rdfs:label "WAN Fix Execution Container 001"@en ;
    rdfs:comment "Container for events related to the WAN link repair."@en ;
    dcterms:relation noria:TroubleTicket_CRITICAL_WAN_OUTAGE_001 .

noria:EventRecord_RouterUp_PAR01_20240101_Resolved a noria:EventRecord ;
    rdfs:label "CR-PAR01 Interface Up Event (Resolved)"@en ;
    rdfs:comment "Log entry indicating a network interface on CR-PAR01 came back up after repair."@en ;
    noria:loggingTime "2024-01-01T13:50:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter_PAR01 ;
    noria:logOriginatingManagementSystem noria:Application_InternalMonitoringSystem ;
    noria:logText "Interface GigabitEthernet0/0/0 on cr-par01.example.com changed state to up. Link restored."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> ;
    dcterms:isPartOf noria:ProcedureExecutionContainer_WAN_Fix_001 .

noria:TroubleTicket_CRITICAL_WAN_OUTAGE_001 noria:alarmMitigatedBy noria:ProcedureExecutionContainer_WAN_Fix_001 .

