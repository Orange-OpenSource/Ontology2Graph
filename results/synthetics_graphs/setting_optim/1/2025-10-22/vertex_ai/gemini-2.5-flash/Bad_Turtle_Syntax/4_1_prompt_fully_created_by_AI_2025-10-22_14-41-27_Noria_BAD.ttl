# --- Operation Plans and Conditions ---
noria:OperationPlan_WAN_Troubleshooting a noria:OperationPlan ;
    rdfs:label "WAN Link Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving WAN link issues."@en ;
