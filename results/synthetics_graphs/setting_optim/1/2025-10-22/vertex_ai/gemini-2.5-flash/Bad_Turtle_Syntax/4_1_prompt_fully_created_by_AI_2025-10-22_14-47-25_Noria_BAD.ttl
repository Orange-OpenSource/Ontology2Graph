    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationType <kos/application/type/infrastructure-management> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Operations" ;
    noria:applicationFunctionalSubDomain "Performance Monitoring" ;
    noria:resourceForApplication noria:Resource5 . # Virtual Host 1 hosts NMS VM

