noria:ActionPostCondition9 a noria:ActionPostCondition ;
    rdfs:label "Hardware Replaced and Functional"@en ;
    rdfs:comment "Post-condition: Faulty hardware is replaced, and the new component is fully operational."@en ;
    skos:example "System health checks pass, and service is restored."@en .

