    skos:example "Steps include pre-checks, physical replacement, configuration transfer, and post-checks."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition9 ;
    noria:operationPlanPostCondition noria:ActionPostCondition9 .

noria:ActionPreCondition9 a noria:ActionPreCondition ;
