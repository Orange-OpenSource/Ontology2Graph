# --- Procedural Elements (noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition) ---

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "Router Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for troubleshooting router interface issues."@en ;
    skos:example "Steps include checking physical connection, interface configuration, and logging."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "Interface Down Detected"@en ;
    rdfs:comment "Pre-condition: A network interface is reported as being in a 'down' state."@en ;
    skos:example "EventRecord with alarmSeverity Critical and logText containing 'changed state to down'."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "Interface Up Confirmed"@en ;
    rdfs:comment "Post-condition: The network interface is confirmed to be in an 'up' state and traffic is flowing."@en ;
    skos:example "EventRecord with logText containing 'changed state to up' and traffic metrics returning to normal."@en .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Database Index Optimization Procedure"@en ;
    rdfs:comment "Procedure for analyzing and optimizing database indexes."@en ;
    skos:example "Steps include performance monitoring, query analysis, index creation/rebuild."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Database Performance Degradation"@en ;
    rdfs:comment "Pre-condition: Database queries are slow, or CPU/IO utilization is consistently high."@en ;
    skos:example "EventRecord with alarmSeverity Major and logText indicating 'Database connection pool exhausted' or 'CPU utilization exceeded 90%'."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Database Performance Restored"@en ;
    rdfs:comment "Post-condition: Database query times are within SLA, and resource utilization is normal."@en ;
    skos:example "Monitoring metrics show reduced query latency and CPU/IO utilization below thresholds."@en .

noria:TroubleTicket1 noria:actionCorrelatedOperationPlan noria:OperationPlan1 .
noria:ChangeRequest2 noria:actionCorrelatedOperationPlan noria:OperationPlan2 .

