# --- Application and Service Entities ---

noria:Application1 a noria:Application ;
    rdfs:label "Corporate Web Portal"@en ;
    rdfs:comment "Main web application for internal and external users."@en ;
    noria:applicationModelIdentifier "CWP-V2" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CWP" ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Customer Self-Service" ;
    noria:resourceForApplication noria:Resource2 ; # App Server 1 supports CWP
    noria:resourceForApplication noria:Resource3 ; # DB Server 1 supports CWP
    noria:resourceForApplication noria:Resource8 . # Load Balancer supports CWP

noria:Application2 a noria:Application ;
    rdfs:label "Internal Ticketing System"@en ;
    rdfs:comment "Application for managing IT support tickets."@en ;
