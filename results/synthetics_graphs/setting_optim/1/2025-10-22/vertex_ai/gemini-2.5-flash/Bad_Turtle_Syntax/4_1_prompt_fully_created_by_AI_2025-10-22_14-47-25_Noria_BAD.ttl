    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "IT Service Management" ;
    noria:applicationFunctionalSubDomain "Incident Management" ;
    noria:resourceForApplication noria:Resource2 . # App Server 1 supports ITS

noria:Application3 a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:comment "System for monitoring network devices and services."@en ;
