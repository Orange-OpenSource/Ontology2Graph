    noria:applicationModuleSupportTeam org:OrganizationalUnit3 ;
    noria:applicationModuleSupportLeader foaf:Agent7 ;
    noria:applicationModuleHotlineEnabled false ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> .

noria:ApplicationModule3 a noria:ApplicationModule ;
