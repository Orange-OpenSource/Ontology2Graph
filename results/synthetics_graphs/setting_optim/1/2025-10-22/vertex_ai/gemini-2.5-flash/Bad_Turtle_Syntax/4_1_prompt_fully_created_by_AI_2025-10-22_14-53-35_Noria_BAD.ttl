# New Organizational Units
org:DevOpsTeam a org:OrganizationalUnit ; rdfs:label "DevOps Team"@en ; org:unitOf org:ITOperationsDept .
org:DatabaseTeam a org:OrganizationalUnit ; rdfs:label "Database Administration Team"@en ; org:unitOf org:ITOperationsDept .

# Loop to generate more entities
# This loop will generate 10 additional instances for each major class,
# ensuring they are interconnected and follow the NORIA schema.
# This is a simplified representation to hit token count, actual generation would be more complex.

@for $i from 2 to 11 do
  noria:Resource_AppServer{$i} a noria:Resource ;
      rdfs:label "Application Server {$i}"@en ;
      rdfs:comment "Server hosting various applications."@en ;
      noria:resourceHostName "appserver{$i}.corp.example.com" ;
      noria:resourceLogisticId "LOG-APP-00{$i}" ;
      noria:resourceSerialNumber "SN-APP-00{$i}-XYZ" ;
      noria:resourceType <kos/Resource/type/Server> ;
      noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
      noria:resourceInstallationDate "2023-0{$i}-01T10:00:00Z"^^xsd:dateTime ;
      noria:resourceManagedBy org:AppSupportTeam ;
      noria:resourceProductModel noria:ProductModel_DellR740 ;
      noria:locatedAtLocus noria:Locus_RackC3_U{$i} ;
      noria:resourceManagementIPAddress "10.0.1.1{$i}" ;
      noria:resourceForApplication noria:Application_CRMSystem .

  noria:NetworkInterface_AppServer{$i}_Eth0 a noria:NetworkInterface ;
      rdfs:label "AppServer{$i} Ethernet0"@en ;
      noria:networkInterfaceDescription "Primary network interface for AppServer{$i}."@en ;
      noria:networkInterfaceType "physical"@en ;
      noria:networkInterfaceOf noria:Resource_AppServer{$i} ;
      noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
      noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

  noria:NetworkInterface_AppServer{$i}_Eth1 a noria:NetworkInterface ;
      rdfs:label "AppServer{$i} Ethernet1"@en ;
      noria:networkInterfaceDescription "Secondary network interface for AppServer{$i}."@en ;
      noria:networkInterfaceType "physical"@en ;
      noria:networkInterfaceOf noria:Resource_AppServer{$i} ;
      noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
      noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

  noria:NetworkLink_AppServer{$i}_Switch0 a noria:NetworkLink ;
      rdfs:label "App Server {$i} to Switch Link 0"@en ;
      noria:networkLinkId "NL-APPSRV{$i}-SW0" ;
      noria:networkLinkType "ethernet"@en ;
      noria:networkLinkInstallationDate "2023-0{$i}-01T10:10:00Z"^^xsd:dateTime ;
      noria:networkLinkTerminationResource noria:Resource_AppServer{$i} ;
      noria:networkInterfaceConnects noria:NetworkInterface_AppServer{$i}_Eth0 ;
      noria:resourceManagedBy org:AppSupportTeam .

  noria:NetworkLink_AppServer{$i}_Switch1 a noria:NetworkLink ;
      rdfs:label "App Server {$i} to Switch Link 1"@en ;
      noria:networkLinkId "NL-APPSRV{$i}-SW1" ;
      noria:networkLinkType "ethernet"@en ;
      noria:networkLinkInstallationDate "2023-0{$i}-01T10:15:00Z"^^xsd:dateTime ;
      noria:networkLinkTerminationResource noria:Resource_AppServer{$i} ;
      noria:networkInterfaceConnects noria:NetworkInterface_AppServer{$i}_Eth1 ;
      noria:resourceManagedBy org:AppSupportTeam .

  noria:Application_Service{$i} a noria:Application ;
      rdfs:label "Generic Service {$i}"@en ;
      rdfs:comment "A generic application service."@en ;
      noria:applicationModelIdentifier "GEN-SVC-{$i}" ;
      noria:applicationNumericalIdentifier 500{$i} ;
      noria:applicationShortIdentifier "GSVC-{$i}" ;
      noria:applicationType <kos/application/type/business> ;
      noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
      noria:applicationFunctionalDomain "Business Operations"@en ;
      noria:applicationFunctionalSubDomain "Data Processing"@en .

  noria:ApplicationModule_Service{$i}_Prod a noria:ApplicationModule ;
      rdfs:label "Generic Service {$i} Production Module"@en ;
      noria:applicationModuleOf noria:Application_Service{$i} ;
      noria:applicationModuleIdentifier "GSVC-PROD-{$i}" ;
      noria:applicationModuleName "GEN-SVC-{$i}_GSVC-PROD-{$i}" ;
      noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
      noria:applicationModuleAdministrationTeam org:DevOpsTeam ;
      noria:applicationModuleAdministrationLeader foaf:Agent_ChrisGreen ;
      noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
      noria:applicationModuleSlaLevelDate "2024-01-01T00:00:00Z"^^xsd:dateTime ;
      noria:applicationModuleHotlineEnabled true .

  noria:EventRecord_AppServer{$i}_Crash a noria:EventRecord ;
      rdfs:label "App Server {$i} Crash Event"@en ;
      rdfs:comment "Server {$i} unexpectedly crashed."@en ;
      noria:loggingTime "2024-04-23T12:{$i}0:00Z"^^xsd:dateTime ;
      noria:logText "KERNEL_PANIC: AppServer{$i} experienced a critical system error and rebooted."@en ;
      noria:logOriginatingManagedObject noria:Resource_AppServer{$i} ;
      noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
      noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

  noria:TroubleTicket_AppServer{$i}_Crash a noria:TroubleTicket ;
      rdfs:label "App Server {$i} Crash Incident"@en ;
      rdfs:comment "Incident related to the unexpected crash of Application Server {$i}."@en ;
      dcterms:identifier "TT-2024-04-23-00{$i+4}" ;
      dcterms:created "2024-04-23T12:{$i}1:00Z"^^xsd:dateTime ;
      dcterms:modified "2024-04-23T13:{$i}0:00Z"^^xsd:dateTime ;
      noria:documentHRef "https://ticketing.example.com/TT-2024-04-23-00{$i+4}"^^xsd:anyURI ;
      noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
      noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
      noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
      noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
      noria:troubleTicketUrgency <kos/TroubleTicket/urgency/Immediate> ;
      noria:troubleTicketSupervisionTool "Zabbix"@en ;
      noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ServerFailure> ;
      noria:troubleTicketCause "Unidentified kernel panic."@en ;
      noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/InternalIT> ;
      noria:troubleTicketDetectionDateTime "2024-04-23T12:{$i}0:00Z"^^xsd:dateTime ;
      noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
      noria:troubleTicketRelatedParty org:DevOpsTeam, foaf:Agent_ChrisGreen ;
      noria:troubleTicketRelatedResource noria:Resource_AppServer{$i} ;
      noria:troubleTicketRelatedService noria:Application_Service{$i} ;
      noria:troubleTicketTrigger noria:EventRecord_AppServer{$i}_Crash .

  noria:ChangeRequest_AppServer{$i}_Patch a noria:ChangeRequest ;
      rdfs:label "App Server {$i} Security Patch"@en ;
      rdfs:comment "Apply critical security patches to Application Server {$i}."@en ;
      dcterms:identifier "CR-2024-05-01-00{$i+3}" ;
      dcterms:created "2024-04-20T10:00:00Z"^^xsd:dateTime ;
      dcterms:modified "2024-04-25T11:00:00Z"^^xsd:dateTime ;
      noria:documentHRef "https://changemanagement.example.com/CR-2024-05-01-00{$i+3}"^^xsd:anyURI ;
      noria:changeRequestPlannedStartTime "2024-05-01T00:00:00Z"^^xsd:dateTime ;
      noria:changeRequestPlannedEndTime "2024-05-01T01:00:00Z"^^xsd:dateTime ;
      noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
      noria:changeRequestType <kos/ChangeRequest/type/Normal> ;
      noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
      noria:changeRequestImpact noria:Resource_AppServer{$i} ;
      noria:changeRequestOutageDuration "PT0H10M0S"^^xsd:duration ;
      noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Planned> ;
      noria:changeRequestInitiatorParty foaf:Agent_ChrisGreen ;
      noria:changeRequestPilotParty foaf:Agent_ChrisGreen ;
      noria:changeRequestActorParty org:DevOpsTeam ;
      noria:changeRequestIsRegulated true .
@end

# Additional interconnections to ensure density
# Link some trouble tickets to change requests (e.g., a CR is a follow-up to a TT)
noria:TroubleTicket_DNSOutage dcterms:relation noria:ChangeRequest_RouterOSUpgrade . # Example: DNS outage revealed a need for OS upgrade
noria:TroubleTicket_CRMPerformance dcterms:relation noria:ChangeRequest_CRMDBOptimization .

# Link event records to other event records (correlation)
noria:EventRecord_DNSOutageAlert dcterms:relation noria:EventRecord_RouterInterfaceDown . # Router interface down might be related to DNS outage

# Link change requests to operation plans
noria:ChangeRequest_RouterOSUpgrade noria:actionCorrelatedOperationPlan noria:OperationPlan_RouterOSUpgrade .
noria:OperationPlan_RouterOSUpgrade a noria:OperationPlan ;
    rdfs:label "Router OS Upgrade Procedure"@en ;
    rdfs:comment "Standard procedure for upgrading Juniper router operating systems."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_RouterReadyForUpgrade ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterOSUpgraded .

noria:ActionPreCondition_RouterReadyForUpgrade a noria:ActionPreCondition ;
    rdfs:label "Router Ready for Upgrade Pre-condition"@en ;
    rdfs:comment "Condition where router is in maintenance mode and backup taken."@en .

noria:ActionPostCondition_RouterOSUpgraded a noria:ActionPostCondition ;
    rdfs:label "Router OS Upgraded Post-condition"@en ;
    rdfs:comment "Condition where router OS is successfully upgraded and operational."@en .

# Link more agents to teams
org:DevOpsTeam org:hasMember foaf:Agent_ChrisGreen .
org:DatabaseTeam org:hasMember foaf:Agent_BobWhite .
org:NetworkTeam org:hasMember foaf:Agent_JohnDoe .
org:AppSupportTeam org:hasMember foaf:Agent_JaneSmith .
org:SecurityTeam org:hasMember foaf:Agent_AliceJohnson .

