    noria:logText "AUTH_FAILED: User 'baduser' failed to login 5 times from 192.168.1.100"@en ;
    noria:logOriginatingManagedObject noria:Resource_AppServer01 ;
    noria:logOriginatingManagementSystem noria:Application_SecuritySIEM ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logOriginatingAgent foaf:Agent_ExternalAttacker .

foaf:Agent_ExternalAttacker a foaf:Agent ;
    rdfs:label "External Attacker"@en ;
    rdfs:comment "Hypothetical external entity attempting unauthorized access."@en .

noria:EventRecord_CRMHighCPU a noria:EventRecord ;
