# --- Operation Plans ---
noria:OperationPlan_RestartDNS a noria:OperationPlan ;
    rdfs:label "Restart DNS Service Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the corporate DNS service."@en ;
    skos:example "Steps: 1. Check service status. 2. Attempt graceful restart. 3. Force restart if necessary. 4. Verify service."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSRestored .

noria:ActionPreCondition_DNSDown a noria:ActionPreCondition ;
    rdfs:label "DNS Service Down Pre-condition"@en ;
    rdfs:comment "Condition where the DNS service is not responding."@en .

noria:ActionPostCondition_DNSRestored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored Post-condition"@en ;
    rdfs:comment "Condition where the DNS service is fully operational and reachable."@en .

noria:OperationPlan_TroubleshootCRMCPU a noria:OperationPlan ;
    rdfs:label "Troubleshoot CRM High CPU Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving high CPU issues on CRM virtual machines."@en ;
    skos:example "Steps: 1. Check VM resource usage. 2. Analyze application logs. 3. Review database queries. 4. Scale resources if needed."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_CRMHighCPU ;
    noria:operationPlanPostCondition noria:ActionPostCondition_CRMCPUResolved .

noria:ActionPreCondition_CRMHighCPU a noria:ActionPreCondition ;
    rdfs:label "CRM High CPU Pre-condition"@en ;
    rdfs:comment "Condition where CRM VM CPU utilization exceeds threshold."@en .

noria:ActionPostCondition_CRMCPUResolved a noria:ActionPostCondition ;
    rdfs:label "CRM CPU Resolved Post-condition"@en ;
    rdfs:comment "Condition where CRM VM CPU utilization returns to normal levels."@en .

# --- Anomaly Patterns ---
noria:AnomalyPattern_NetworkLoop a noria:AnomalyPattern ;
    rdfs:label "Network Loop Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a network loop, characterized by high broadcast traffic and interface flapping."@en ;
    skos:example "High broadcast rate on multiple interfaces, rapid administrative state changes on connected ports."@en .

noria:AnomalyPattern_ResourceExhaustion a noria:AnomalyPattern ;
    rdfs:label "Resource Exhaustion Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a resource (CPU, Memory, Disk) exhaustion on a server."@en ;
    skos:example "Sustained high CPU/memory usage, low disk space, slow application response."@en .

# --- Connecting more entities for density ---
# Link resources to applications
noria:Resource_DNS01 noria:resourceForApplication noria:Application_CorporateDNS .
noria:Resource_RouterCore01 noria:resourceForApplication noria:Application_CorporateDNS, noria:Application_MonitoringPlatform .
noria:Resource_FirewallDMZ01 noria:resourceForApplication noria:Application_SecuritySIEM .
noria:Resource_AppServer01 noria:resourceForApplication noria:Application_CRMSystem .
noria:Resource_VMHost01 noria:resourceForApplication noria:Application_CRMSystem, noria:Application_MonitoringPlatform .
noria:Resource_VM_CRM01 noria:resourceForApplication noria:Application_CRMSystem .
noria:Resource_SwitchAccess01 noria:resourceForApplication noria:Application_CorporateDNS .

# Link agents to resources they manage
org:NetworkTeam noria:agentManagesResource noria:Resource_DNS01, noria:Resource_RouterCore01, noria:Resource_SwitchAccess01 .
org:AppSupportTeam noria:agentManagesResource noria:Resource_AppServer01, noria:Resource_VM_CRM01 .
org:SecurityTeam noria:agentManagesResource noria:Resource_FirewallDMZ01 .
foaf:Agent_JohnDoe noria:agentManagesResource noria:Resource_RouterCore01 .
foaf:Agent_JaneSmith noria:agentManagesResource noria:Resource_AppServer01 .

# Link application modules to resources
noria:ApplicationModule_CorporateDNS_Prod seas:subSystem noria:Resource_DNS01 .
noria:ApplicationModule_CRMSystem_Prod seas:subSystem noria:Resource_AppServer01, noria:Resource_VM_CRM01 .
noria:ApplicationModule_MonitoringPlatform_Prod seas:subSystem noria:Resource_VMHost01 .
noria:ApplicationModule_SecuritySIEM_Prod seas:subSystem noria:Resource_FirewallDMZ01 .

# Add more network interfaces and links to increase density
