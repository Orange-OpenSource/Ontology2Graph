    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 20 .

noria:NetworkLink_Core01_Lyon a noria:NetworkLink ;
    rdfs:label "Core Router 01 to Lyon Office Link"@en ;
    noria:networkLinkId "NL-CORE01-LYON" ;
    noria:networkLinkType "MPLS VPN"@en ;
    noria:networkLinkInstallationDate "2022-08-01T10:10:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_SwitchAccess01 ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore01_Gi0_0_2 ;
    noria:networkInterfaceConnects noria:NetworkInterface_SwitchAccess01_Gi0_1 ;
    noria:resourceManagedBy org:NetworkTeam .

# Add more trouble tickets and events
noria:EventRecord_FirewallBlockedTraffic a noria:EventRecord ;
    rdfs:label "Firewall Blocked Traffic Alert"@en ;
    rdfs:comment "Alert indicating traffic from external source blocked by DMZ firewall."@en ;
    noria:loggingTime "2024-04-23T11:15:00Z"^^xsd:dateTime ;
    noria:logText "FIREWALL_BLOCK: Source 203.0.113.10 blocked attempting access to DMZ."@en ;
    noria:logOriginatingManagedObject noria:Resource_FirewallDMZ01 ;
    noria:logOriginatingManagementSystem noria:Application_SecuritySIEM ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:TroubleTicket_BlockedTraffic a noria:TroubleTicket ;
