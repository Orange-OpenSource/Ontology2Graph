    noria:troubleTicketPriority <kos/TroubleTicket/priority/P3> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/Deferred> ;
    noria:troubleTicketSupervisionTool "Splunk"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/NetworkOutage> ;
    noria:troubleTicketCause "Unknown external source attempting connection."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/Security> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T11:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Open> ;
    noria:troubleTicketRelatedParty org:SecurityTeam, foaf:Agent_AliceJohnson ;
    noria:troubleTicketRelatedResource noria:Resource_FirewallDMZ01 ;
    noria:troubleTicketRelatedService noria:Application_SecuritySIEM ;
    noria:troubleTicketTrigger noria:EventRecord_FirewallBlockedTraffic .

