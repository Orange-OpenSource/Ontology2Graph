# --- Event Records ---
noria:EventRecord_DNSOutageAlert a noria:EventRecord ;
    rdfs:label "DNS Server Outage Alert"@en ;
    rdfs:comment "Alert indicating primary DNS server is unreachable."@en ;
    noria:loggingTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: DNS server dns01.corp.example.com is down!"@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_RestartDNS .

noria:EventRecord_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-23T09:58:30Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down"@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_LoginFailure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Multiple failed login attempts detected on App Server 01."@en ;
