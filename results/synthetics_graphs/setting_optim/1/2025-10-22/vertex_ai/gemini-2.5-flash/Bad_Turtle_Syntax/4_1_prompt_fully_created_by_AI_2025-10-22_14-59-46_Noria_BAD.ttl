    noria:troubleTicketRelatedService noria:App_HRSystem, noria:AppMod_HR_Prod ;
    noria:troubleTicketRelatedResource noria:Resource_HRServer1 ;
    noria:troubleTicketRelatedParty foaf:Agent_AppSupportTeam ;
    noria:troubleTicketDetectionDateTime "2024-04-22T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCause "Authentication service timeout."@en ;
    noria:documentExternalId "HR-INC-20240422-001"@en .

noria:Event_HR_AuthFail a noria:EventRecord ;
    rdfs:label "HR Auth Failure Log"@en ;
    rdfs:comment "Multiple authentication failures recorded on HR server."@en ;
    noria:loggingTime "2024-04-22T08:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_HRServer1 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "Authentication failed for user 'jdoe' from IP 192.168.100.15."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    dcterms:type <kos/Notification/EventType/securityAlert> ;
    dcterms:identifier "EVT-HR-AUTH-20240422-001"@en .

noria:TroubleTicket_HR_Access noria:troubleTicketTrigger noria:Event_HR_AuthFail .

