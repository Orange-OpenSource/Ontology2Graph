    rdfs:comment "Versatile 2U rack server."@en ;
    noria:productManufacturedBy org:VendorB .

noria:ProductModel_Juniper_MX204 a noria:ProductModel ;
    rdfs:label "Juniper MX204 Universal Routing Platform"@en ;
    rdfs:comment "Compact, high-density routing platform."@en ;
    noria:productManufacturedBy org:VendorA .

noria:ProductModel_HP_DL380 a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10"@en ;
    rdfs:comment "Industry-leading server for diverse workloads."@en ;
    noria:productManufacturedBy org:VendorB .

# Locations
bot:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    noria:siteId "DC-PAR-01"@en ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressPostalCode "75002"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressCountry "FR"@en ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"@en .

bot:Site_LyonOffice a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    noria:siteId "OFF-LYN-01"@en ;
    noria:siteType "office building"@en ;
    noria:sitePrincipalAddress "45 Avenue Jean Jaurès"@en ;
    noria:sitePrincipalAddressPostalCode "69007"@en ;
    noria:sitePrincipalAddressCityName "Lyon"@en ;
    noria:sitePrincipalAddressCountry "FR"@en ;
    noria:sitePrincipalAddressStreet "Avenue Jean Jaurès"@en .

noria:Room_DC_ServerRoom1 a noria:Room ;
    rdfs:label "DC Server Room 1"@en ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace noria:Locus_R1_C1, noria:Locus_R1_C2, noria:Locus_R2_C1, noria:Locus_R2_C2 ;
    bot:hasElement noria:Resource_CoreRouter1, noria:Resource_AppServer1 .

noria:Room_Office_CommsRoom a noria:Room ;
    rdfs:label "Office Communications Room"@en ;
