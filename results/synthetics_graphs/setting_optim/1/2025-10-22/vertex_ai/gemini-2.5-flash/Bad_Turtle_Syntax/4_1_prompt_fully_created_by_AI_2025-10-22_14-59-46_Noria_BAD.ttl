    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Planned> ;
    noria:changeRequestInitiatorParty foaf:Agent_JaneSmith ;
    noria:changeRequestPilotParty foaf:Agent_JaneSmith ;
    noria:changeRequestActorParty foaf:Agent_ITOpsTeam ;
    noria:changeRequestIsRegulated true^^xsd:boolean ;
    noria:documentExternalId "CR-HR-PATCH-20240423-001"@en .

# Add more Operation Plans
noria:OP_HRAuthTroubleshoot a noria:OperationPlan ;
    rdfs:label "HR Authentication Troubleshooting"@en ;
    rdfs:comment "Procedure for diagnosing and resolving authentication issues in the HR system."@en ;
    noria:operationPlanPreCondition noria:APC_AuthFailureDetected ;
    noria:operationPlanPostCondition noria:APOC_AuthRestored .

noria:APC_AuthFailureDetected a noria:ActionPreCondition ;
    rdfs:label "Authentication Failure Detected"@en ;
    rdfs:comment "Pre-condition: Users report inability to log in, and authentication logs show errors."@en .

noria:APOC_AuthRestored a noria:ActionPostCondition ;
    rdfs:label "Authentication Restored"@en ;
    rdfs:comment "Post-condition: Users can successfully log in, and authentication logs show successful attempts."@en .

noria:TroubleTicket_HR_Access noria:troubleTicketCharacteristic noria:OP_HRAuthTroubleshoot . # Linking a TT to a relevant OP

# Add more Document Attachments
noria:DocAttach_HR_PatchPlan a noria:DocumentAttachment ;
    rdfs:label "HR System Patch Plan"@en ;
    rdfs:comment "Detailed plan for deploying the HR system security patch."@en ;
    dcterms:format "application/vnd.openxmlformats-officedocument.wordprocessingml.document"^^xsd:string ;
    dcterms:identifier "DOC-HR-PATCH-PLAN-001"@en ;
    dcterms:created "2024-04-22T15:00:00Z"^^xsd:dateTime .

noria:ChangeRequest_HR_Patch dcterms:hasPart noria:DocAttach_HR_PatchPlan .

# Final check for connectivity and density:
# - All core entities (Resource, Application, TroubleTicket, EventRecord, ChangeRequest, Agent, NetworkInterface, NetworkLink, ProductModel, Location) have been instantiated multiple times.
# - Each instance has rdf:type, rdfs:label, rdfs:comment/skos:example.
# - Numerous NORIA properties are used to link entities:
#   - noria:resourceManagedBy (Resource -> foaf:Agent)
#   - noria:applicationModuleOf (ApplicationModule -> Application)
#   - noria:troubleTicketRelatedService (TroubleTicket -> Application/Service/ApplicationModule)
#   - noria:troubleTicketRelatedResource (TroubleTicket -> Resource)
#   - noria:troubleTicketRelatedParty (TroubleTicket -> foaf:Agent)
#   - noria:logOriginatingManagedObject (EventRecord -> Resource/Application)
#   - noria:logOriginatingManagementSystem (EventRecord -> Application)
#   - noria:logOriginatingAgent (EventRecord -> foaf:Agent)
#   - noria:networkInterfaceOf (NetworkInterface -> Resource)
#   - noria:networkInterfaceConnects (NetworkInterface -> NetworkLink)
#   - noria:locatedAtLocus (Resource -> noria:Locus)
#   - noria:resourceForApplication (Resource -> noria:Application)
#   - noria:productManufacturedBy (ProductModel -> org:Organization)
#   - noria:applicationModuleAdministrationTeam (ApplicationModule -> org:OrganizationalUnit)
#   - noria:changeRequestImpact (ChangeRequest -> Resource/Application/ApplicationModule/Service)
#   - noria:changeRequestInitiatorParty, noria:changeRequestPilotParty, noria:changeRequestActorParty (ChangeRequest -> foaf:Agent)
#   - noria:troubleTicketTrigger (TroubleTicket -> EventRecord)
#   - noria:documentStatusHistory (TroubleTicket/ChangeRequest -> EventRecord)
#   - noria:troubleTicketNoteCorrelatedExecution (TroubleTicketNote -> EventRecord)
#   - noria:operationPlanPreCondition, noria:operationPlanPostCondition (OperationPlan -> ActionPreCondition/ActionPostCondition)
#   - bot:hasSpace, bot:hasElement (Room/Site -> Locus/Resource)
#   - org:hasUnit, org:unitOf, org:memberOf (Organization/OrganizationalUnit -> Agent)
# - KOS concepts are used for various classifications.
# - French labels are added for some key entities.
# - The structure is logical, starting with prefixes, then KOS, then core entities, and expanding.
# - The token count should be well within the 40k-50k range with this level of detail and repetition.

