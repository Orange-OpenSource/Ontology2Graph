noria:AppMod_Monitoring_Domain_1 noria:applicationModuleAdministrationLeader foaf:Agent_Employee_5 .

# More locations (Locus)
[1..10] noria:Locus_R3_C_ ;
    a noria:Locus ;
    rdfs:label "Rack 3, Slot [i]"@en ;
    noria:locusLine "R3"@en ;
    noria:locusRow "C[i]"@en ;
    bot:hasElement noria:Resource_AppServer_[i] . # Link to existing app servers

# More Network Interfaces for Access Switches
[1..3] noria:NI_AccessSwitch_Uplink_ ;
    a noria:NetworkInterface ;
    rdfs:label "uplink (Access Switch [i])"@en ;
    noria:networkInterfaceOf noria:Resource_AccessSwitch_[i] ;
    noria:networkInterfaceDescription "Uplink to Core Router 1"@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# Link Access Switches to Core Router 1
[1..3] noria:NL_AccessSwitch_CoreRouter_ ;
    a noria:NetworkLink ;
    rdfs:label "Link Access Switch [i] to Core Router 1"@en ;
    rdfs:comment "Internal network link."@en ;
    noria:resourceManagedBy foaf:Agent_NetEngTeam ;
    noria:networkLinkId "NL-ASW[i]-CR1-001"@en ;
    noria:networkLinkTerminationResource noria:Resource_AccessSwitch_[i], noria:Resource_CoreRouter1 ;
    noria:networkLinkInstallationDate "2022-08-01T13:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet"@en ;
    noria:networkInterfaceConnects noria:NI_AccessSwitch_Uplink_[i], noria:NI_CR1_GE0_0_1 . # Simplified, reusing CR1 interface

# More complex interconnections
# Example: A TroubleTicketNote correlated with a ProcedureExecutionContainer (EventRecord)
noria:TTN_CRM_Perf_1 noria:troubleTicketNoteCorrelatedExecution noria:Event_DB_HighCPU .

# Example: AnomalyPattern
noria:AnomalyPattern_HighCPULatency a noria:AnomalyPattern ;
    rdfs:label "High CPU and Latency Anomaly"@en ;
    rdfs:comment "Pattern indicating a potential performance bottleneck: sustained high CPU on DB server combined with increased application latency."@en ;
    folio:hasCause noria:OP_DBPerformanceTuning . # The tuning guide is a potential solution/cause analysis

# Example: OperationPlan linked to AnomalyPattern
noria:OP_DBPerformanceTuning noria:operationPlanPreCondition noria:AnomalyPattern_HighCPULatency .

