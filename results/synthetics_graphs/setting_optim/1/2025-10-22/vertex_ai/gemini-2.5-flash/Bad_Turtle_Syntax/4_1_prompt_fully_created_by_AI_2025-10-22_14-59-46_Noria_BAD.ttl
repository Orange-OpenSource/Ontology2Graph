# =============================================================================
# Operation Plans and Action Conditions
# =============================================================================

noria:OP_RouterLinkTroubleshoot a noria:OperationPlan ;
    rdfs:label "Router Link Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving router link failures."@en ;
    noria:operationPlanPreCondition noria:APC_LinkDownDetected ;
    noria:operationPlanPostCondition noria:APOC_LinkRestored .

noria:APC_LinkDownDetected a noria:ActionPreCondition ;
    rdfs:label "Link Down Detected"@en ;
    rdfs:comment "Pre-condition: A network interface's operational status is 'down' and an alarm has been raised."@en .

noria:APOC_LinkRestored a noria:ActionPostCondition ;
    rdfs:label "Link Restored"@en ;
    rdfs:comment "Post-condition: The network interface's operational status is 'up' and traffic is flowing normally."@en .

noria:OP_DBPerformanceTuning a noria:OperationPlan ;
    rdfs:label "Database Performance Tuning Guide"@en ;
    rdfs:comment "Procedure for optimizing database queries and configurations to improve application performance."@en ;
    noria:operationPlanPreCondition noria:APC_HighCPUorLatency ;
    noria:operationPlanPostCondition noria:APOC_PerformanceNormalized .

noria:APC_HighCPUorLatency a noria:ActionPreCondition ;
    rdfs:label "High CPU or Latency Detected"@en ;
    rdfs:comment "Pre-condition: Database server CPU utilization is consistently high or application latency is observed."@en .

noria:APOC_PerformanceNormalized a noria:ActionPostCondition ;
    rdfs:label "Performance Normalized"@en ;
    rdfs:comment "Post-condition: Database server CPU utilization is within normal limits and application response times are acceptable."@en .

# Linking actions to operation plans (example via EventRecord)
noria:Event_ER1_ConfigChange noria:actionCorrelatedOperationPlan noria:OP_RouterLinkTroubleshoot . # A config change might be part of a troubleshooting plan

