    rdfs:label "HR System Security Patch"@en ;
    rdfs:comment "Emergency patch deployment for a critical vulnerability in the HR system."@en ;
    noria:changeRequestPlannedStartTime "2024-04-23T00:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-23T01:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Emergency> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_HRServer1, noria:App_HRSystem, noria:AppMod_HR_Prod ;
