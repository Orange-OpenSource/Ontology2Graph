    skos:inScheme <kos/org/agent-contact-method> .

# =============================================================================
# Core Entities: Organizations, Agents, Product Models, Locations
# =============================================================================

# Organizations
org:Orange a org:Organization ;
    rdfs:label "Orange S.A."@en ;
    rdfs:comment "Global telecommunications operator."@en ;
    org:hasUnit org:ITOperationsDept, org:NetworkEngineeringDept, org:CustomerSupportDept .

org:ITOperationsDept a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Department responsible for daily IT infrastructure operations."@en ;
    org:unitOf org:Orange .

org:NetworkEngineeringDept a org:OrganizationalUnit ;
    rdfs:label "Network Engineering Department"@en ;
    rdfs:comment "Department responsible for network design and architecture."@en ;
    org:unitOf org:Orange .

org:CustomerSupportDept a org:OrganizationalUnit ;
    rdfs:label "Customer Support Department"@en ;
    rdfs:comment "Department responsible for customer assistance."@en ;
    org:unitOf org:Orange .

org:VendorA a org:Organization ;
    rdfs:label "Vendor A Inc."@en ;
    rdfs:comment "Manufacturer of network equipment."@en .

org:VendorB a org:Organization ;
    rdfs:label "Vendor B Corp."@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

# Agents (Teams and Individuals)
foaf:Agent_ITOpsTeam a foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team managing core IT infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues."@en .

foaf:Agent_NetEngTeam a foaf:Agent ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:comment "Team responsible for network configuration and changes."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical network issues, call the on-call engineer."@en .

foaf:Agent_AppSupportTeam a foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Sat"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Use the application-specific support portal."@en .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC) Team"@en ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Critical alerts are automatically escalated."@en .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Senior Network Engineer."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead Application Administrator."@en ;
    noria:agentWorkingHours "8:00-16:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

# Product Models
noria:ProductModel_Cisco_ASR9K a noria:ProductModel ;
