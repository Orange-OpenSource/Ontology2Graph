# --- Operation Plans, Pre/Post Conditions ---
noria:OperationPlan_RouterPortTroubleshoot a noria:OperationPlan ;
    rdfs:label "Router Port Troubleshooting Procedure"@en, "Procédure de Dépannage Port Routeur"@fr ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving router port issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_RouterPortDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterPortUp .

noria:ActionPreCondition_RouterPortDown a noria:ActionPreCondition ;
    rdfs:label "Router Port Down Pre-Condition"@en, "Pré-condition Port Routeur Hors Service"@fr ;
    rdfs:comment "Condition: Network interface operational status is 'down'."@en ;
    skos:example "noria:NetworkInterface_Gi0_0_RouterCore_P1 noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/down>" .

noria:ActionPostCondition_RouterPortUp a noria:ActionPostCondition ;
    rdfs:label "Router Port Up Post-Condition"@en, "Post-condition Port Routeur Actif"@fr ;
    rdfs:comment "Expected outcome: Network interface operational status is 'up' and traffic flows."@en ;
    skos:example "noria:NetworkInterface_Gi0_0_RouterCore_P1 noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up>" .

noria:OperationPlan_AppServerCPUOptimization a noria:OperationPlan ;
    rdfs:label "Application Server CPU Optimization Procedure"@en, "Procédure d'Optimisation CPU Serveur Applicatif"@fr ;
    rdfs:comment "Procedure to identify and mitigate high CPU usage on application servers."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_AppServerCPUHigh ;
    noria:operationPlanPostCondition noria:ActionPostCondition_AppServerCPUNormal .

noria:ActionPreCondition_AppServerCPUHigh a noria:ActionPreCondition ;
    rdfs:label "Application Server High CPU Pre-Condition"@en, "Pré-condition CPU Élevé Serveur Applicatif"@fr ;
    rdfs:comment "Condition: Application server CPU utilization consistently above threshold (e.g., 80%)."@en ;
    skos:example "noria:Resource_AppServer01_NY has high CPU metric." .

noria:ActionPostCondition_AppServerCPUNormal a noria:ActionPostCondition ;
    rdfs:label "Application Server Normal CPU Post-Condition"@en, "Post-condition CPU Normal Serveur Applicatif"@fr ;
    rdfs:comment "Expected outcome: Application server CPU utilization returns to normal levels (e.g., below 50%)."@en ;
    skos:example "noria:Resource_AppServer01_NY has normal CPU metric." .

# Link Trouble Tickets to Operation Plans (via correlated execution)
noria:TroubleTicketNote_TT001_Note2 noria:troubleTicketNoteCorrelatedExecution noria:OperationPlan_RouterPortTroubleshoot .
# Note: The schema defines noria:troubleTicketNoteCorrelatedExecution to range pep:ProcedureExecutionContainer.
# Since noria:OperationPlan is a pep:Procedure, and pep:ProcedureExecutionContainer is a container for executions of procedures,
# we can imply a link here, but a direct instance of pep:ProcedureExecutionContainer would be more precise if available.
# For this exercise, we'll link to the plan as a proxy for the execution context.

