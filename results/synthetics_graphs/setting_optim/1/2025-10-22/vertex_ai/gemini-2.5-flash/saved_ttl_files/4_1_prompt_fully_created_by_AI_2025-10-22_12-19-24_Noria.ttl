    noria:loggingTime "2024-05-15T09:00:05Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore_P1 ;
    noria:logOriginatingManagementSystem noria:Application_CustomerPortal ; # Example: NMS is part of Customer Portal app
    noria:logOriginatingAgent foaf:Agent_Alice ; # Could be an automated script or a human action
