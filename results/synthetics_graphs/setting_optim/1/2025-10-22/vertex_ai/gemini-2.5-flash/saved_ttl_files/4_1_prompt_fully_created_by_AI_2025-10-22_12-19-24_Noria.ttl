    noria:logOriginatingManagementSystem noria:Application_CustomerPortal ;
    noria:logOriginatingAgent foaf:Agent_Alice ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0, changed state to up"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    noria:alarmMitigatedBy noria:TroubleTicket_TT001 . # Linking to the TT as the container for the corrective action

