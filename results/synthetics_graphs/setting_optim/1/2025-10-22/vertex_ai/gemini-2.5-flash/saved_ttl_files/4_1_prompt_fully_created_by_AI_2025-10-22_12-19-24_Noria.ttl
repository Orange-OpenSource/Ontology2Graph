    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:troubleTicketTrigger noria:TroubleTicket_TT001 .

noria:EventRecord_Log_RouterLinkUp a noria:EventRecord ;
