# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_RouterDown_01 a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating that an interface on Core Router 01 went down."@en ;
    noria:loggingTime "2023-10-26T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter_01 ;
    noria:logOriginatingManagementSystem noria:Application_InternalMonitoringSystem ;
    noria:logText "Interface cr01-eth0/0 changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_TroubleshootNetworkInterface .

noria:EventRecord_AppError_01 a noria:EventRecord ;
    rdfs:label "Application Error Log"@en ;
    rdfs:comment "Log entry indicating a critical error in the Corporate Web Portal."@en ;
    noria:loggingTime "2023-10-26T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Application_CorporateWebPortal ;
    noria:logOriginatingManagementSystem noria:Application_InternalMonitoringSystem ;
    noria:logText "CRITICAL: Database connection failed for CWP_PROD."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_FirewallConfigChange_01 a noria:EventRecord ;
    rdfs:label "Firewall Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on the Data Center Firewall."@en ;
    noria:loggingTime "2023-10-25T15:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Firewall_DC01 ;
    noria:logOriginatingAgent noria:Agent_AliceJohnson ;
    noria:logText "Configuration updated by Alice Johnson: added new ACL rule."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord_DBHighCPU_01 a noria:EventRecord ;
    rdfs:label "Database High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Database Server 01."@en ;
    noria:loggingTime "2023-10-26T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBServer_01 ;
    noria:logOriginatingManagementSystem noria:Application_InternalMonitoringSystem ;
    noria:logText "High CPU usage (95%) detected on db01.dc01.example.com."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_WebVM_Restart_01 a noria:EventRecord ;
    rdfs:label "Web VM Restart Log"@en ;
    rdfs:comment "Log entry for a restart of Web Server VM 01."@en ;
    noria:loggingTime "2023-10-26T08:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_VirtualMachine_Web_01 ;
    noria:logOriginatingManagementSystem noria:Application_InternalMonitoringSystem ;
    noria:logText "Virtual machine web01.dc01.example.com restarted."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

