# --- More Operation Plans, Pre/Post Conditions ---
noria:OperationPlan_ClearLogSpace a noria:OperationPlan ;
    rdfs:label "Clear Log Collector Disk Space Procedure"@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_LogCollectorDiskFull ;
    noria:operationPlanPostCondition noria:ActionPostCondition_LogCollectorDiskNormal .

noria:ActionPreCondition_LogCollectorDiskFull a noria:ActionPreCondition ;
    rdfs:label "Log Collector Disk Full"@en ;
    rdfs:comment "Condition: Log collector disk usage exceeds 95%."@en .

noria:ActionPostCondition_LogCollectorDiskNormal a noria:ActionPostCondition ;
    rdfs:label "Log Collector Disk Normal"@en ;
    rdfs:comment "Expected outcome: Log collector disk usage is below 80%."@en .

noria:OperationPlan_RestartMonitoringAgent a noria:OperationPlan ;
    rdfs:label "Restart Monitoring Agent Procedure"@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_MonitoringAgentOffline ;
    noria:operationPlanPostCondition noria:ActionPostCondition_MonitoringAgentOnline .

noria:ActionPreCondition_MonitoringAgentOffline a noria:ActionPreCondition ;
    rdfs:label "Monitoring Agent Offline"@en ;
    rdfs:comment "Condition: Monitoring agent is not reporting data for more than 5 minutes."@en .

noria:ActionPostCondition_MonitoringAgentOnline a noria:ActionPostCondition ;
    rdfs:label "Monitoring Agent Online"@en ;
    rdfs:comment "Expected outcome: Monitoring agent is reporting data successfully."@en .

