    rdfs:label "Core Router Interface Down Incident"@en ;
    rdfs:comment "Critical incident: Core Router 01 interface to firewall is down, impacting internet access."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketDetectionDateTime "2023-10-26T09:01:00Z"^^xsd:dateTime ;
    noria:troubleTicketRelatedService noria:Service_CustomerInternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_CoreRouter_01 ;
    noria:troubleTicketRelatedParty noria:Agent_JohnDoe ;
    noria:troubleTicketTrigger noria:EventRecord_RouterDown_01 ;
    noria:troubleTicketCause "Physical link failure on cr01-eth0/0."@en ;
    noria:documentHRef "https://ticketing.example.com/TT-2023-10-26-001" .

noria:TroubleTicket_AppDBIssue_01 a noria:TroubleTicket ;
