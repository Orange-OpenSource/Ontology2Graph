noria:EventRecord_VPNLoginFail_01 a noria:EventRecord ;
    rdfs:label "VPN Login Failure Alert"@en ;
    noria:loggingTime "2023-10-26T13:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_VPN_Gateway_01 ;
    noria:logOriginatingManagementSystem noria:Application_Security_Analytics ;
