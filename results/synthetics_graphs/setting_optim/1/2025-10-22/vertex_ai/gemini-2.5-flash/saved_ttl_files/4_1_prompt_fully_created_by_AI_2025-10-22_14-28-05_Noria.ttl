# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OperationPlan_RestartWebServer a noria:OperationPlan ;
    rdfs:label "Restart Web Server Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a web server."@en ;
    skos:example "Steps: 1. Check logs. 2. Attempt graceful restart. 3. Force restart if necessary. 4. Verify service."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_WebServerHighCPU ;
    noria:operationPlanPostCondition noria:ActionPostCondition_WebServerNormalCPU .

noria:ActionPreCondition_WebServerHighCPU a noria:ActionPreCondition ;
    rdfs:label "Web Server High CPU Condition"@en ;
    rdfs:comment "Condition: Web server CPU utilization is consistently above 90%."@en ;
    skos:example "Monitoring alert for CPU > 90% for 5 minutes."@en .

noria:ActionPostCondition_WebServerNormalCPU a noria:ActionPostCondition ;
    rdfs:label "Web Server Normal CPU Condition"@en ;
    rdfs:comment "Expected outcome: Web server CPU utilization returns to normal levels (below 50%)."@en ;
    skos:example "Monitoring shows CPU < 50% for 10 minutes, and application responsiveness is normal."@en .

noria:OperationPlan_ReplaceFiberCable a noria:OperationPlan ;
    rdfs:label "Replace Fiber Cable Procedure"@en ;
    rdfs:comment "Procedure for replacing a damaged fiber optic cable."@en ;
    skos:example "Steps: 1. Identify damaged segment. 2. Prepare new cable. 3. Cut and splice/replace. 4. Test connectivity."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_FiberLinkDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_FiberLinkUp .

noria:ActionPreCondition_FiberLinkDown a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Down Condition"@en ;
    rdfs:comment "Condition: Optical fiber link is reported as down or experiencing severe errors."@en ;
    skos:example "Interface status 'down', high error rates, no light detected."@en .

noria:ActionPostCondition_FiberLinkUp a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Up Condition"@en ;
    rdfs:comment "Expected outcome: Optical fiber link is operational with no errors."@en ;
    skos:example "Interface status 'up', low error rates, optical power levels within acceptable range."@en .

