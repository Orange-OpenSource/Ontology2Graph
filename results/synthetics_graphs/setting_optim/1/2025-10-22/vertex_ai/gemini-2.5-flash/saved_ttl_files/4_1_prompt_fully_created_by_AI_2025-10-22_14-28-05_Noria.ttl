# Trouble Ticket Note Operation Type
<kos/TroubleTicket/operationType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Operation Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the type of operation described in trouble ticket notes."@en .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis"@en ;
    rdfs:comment "Note describing diagnostic steps."@en .

<kos/TroubleTicket/operationType/Resolution> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Resolution"@en ;
    rdfs:comment "Note describing resolution steps."@en .

# Change Request Category
<kos/ChangeRequest/category> a skos:ConceptScheme ;
    rdfs:label "Change Request Category Scheme"@en ;
    rdfs:comment "A scheme for classifying the category of change requests."@en .

<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "Change request for internal team intervention."@en .

<kos/ChangeRequest/category/CustomerIntervention> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Customer Intervention"@en ;
    rdfs:comment "Change request requiring customer intervention."@en .

# Change Request Type
<kos/ChangeRequest/type> a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the type of change requests."@en .

<kos/ChangeRequest/type/Standard> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "A pre-approved change with low risk."@en .

<kos/ChangeRequest/type/Normal> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Normal Change"@en ;
    rdfs:comment "A planned change requiring assessment and authorization."@en .

# Change Request Cause
<kos/ChangeRequest/cause> a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A scheme for classifying the cause or reason for change requests."@en .

<kos/ChangeRequest/cause/Configuration> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Configuration Change"@en ;
    rdfs:comment "Change due to configuration update."@en .

<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change due to software version upgrade."@en .

# Change Request Status
<kos/ChangeRequest/status> a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the status of change requests."@en .

<kos/ChangeRequest/status/Planned> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Planned"@en ;
    rdfs:comment "Change request is planned."@en .

<kos/ChangeRequest/status/InProgress> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "Change request is currently being implemented."@en .

<kos/ChangeRequest/status/Completed> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Completed"@en ;
    rdfs:comment "Change request has been completed."@en .

# Change Request Specification
<kos/ChangeRequest/specification> a skos:ConceptScheme ;
    rdfs:label "Change Request Specification Scheme"@en ;
    rdfs:comment "A scheme for classifying the specification of change requests."@en .

<kos/ChangeRequest/specification/StandardOperation> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:label "Standard Operation"@en ;
    rdfs:comment "Change request follows a standard operating procedure."@en .

# Resource Operational State
<kos/Resource/OperationalState> a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational state of resources."@en .

<kos/Resource/OperationalState/Up> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "Resource is operational."@en .

<kos/Resource/OperationalState/Down> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "Resource is not operational."@en .

# Resource Administrative State
<kos/Resource/AdministrativeState> a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    rdfs:comment "A scheme for classifying the administrative state of resources."@en .

<kos/Resource/AdministrativeState/Enabled> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Enabled"@en ;
    rdfs:comment "Resource is administratively enabled."@en .

<kos/Resource/AdministrativeState/Disabled> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Disabled"@en ;
    rdfs:comment "Resource is administratively disabled."@en .

# Resource Type
<kos/Resource/type> a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of IT resources."@en .

<kos/Resource/type/Server> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server"@en ;
    rdfs:comment "A computing server resource."@en .

<kos/Resource/type/Router> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network router resource."@en .

<kos/Resource/type/Switch> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Switch"@en ;
    rdfs:comment "A network switch resource."@en .

<kos/Resource/type/Firewall> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Firewall"@en ;
    rdfs:comment "A network firewall resource."@en .

<kos/Resource/type/LoadBalancer> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Load Balancer"@en ;
    rdfs:comment "A network load balancer resource."@en .

<kos/Resource/type/VirtualMachine> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Virtual Machine"@en ;
    rdfs:comment "A virtual machine resource."@en .

<kos/Resource/type/Storage> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Storage System"@en ;
    rdfs:comment "A storage system resource."@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState> a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    rdfs:comment "A scheme for classifying the lifecycle state of resources."@en .

<kos/Resource/LifecycleState/InUse> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "In Use"@en ;
    rdfs:comment "Resource is currently in active use."@en .

<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Decommissioned"@en ;
    rdfs:comment "Resource has been decommissioned."@en .

# Notification Severity (PerceivedSeverity)
<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ;
    rdfs:label "Notification Perceived Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the perceived severity of notifications/alarms."@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Critical perceived severity."@en .

<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Major"@en ;
    rdfs:comment "Major perceived severity."@en .

<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Minor"@en ;
    rdfs:comment "Minor perceived severity."@en .

<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning"@en ;
    rdfs:comment "Warning perceived severity."@en .

<Notification/Severity/PerceivedSeverity/Indeterminate> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Indeterminate"@en ;
    rdfs:comment "Indeterminate perceived severity."@en .

<Notification/Severity/PerceivedSeverity/Cleared> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Cleared"@en ;
    rdfs:comment "Alarm has been cleared."@en .

# Agent Contact Method
<kos/org/agent-contact-method> a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents."@en .

<kos/org/agent-contact-method/Email> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method is email."@en .

<kos/org/agent-contact-method/Phone> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

# Application SLA Level
<https://w3id.org/noria/kos/application/sla-level> a skos:ConceptScheme ;
    rdfs:label "Application SLA Level Scheme"@en ;
    rdfs:comment "A scheme for classifying the SLA level of application modules."@en .

<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Gold SLA"@en ;
    rdfs:comment "Highest SLA level with maximum availability and performance guarantees."@en .

<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Silver SLA"@en ;
    rdfs:comment "Medium SLA level with good availability and performance."@en .

<https://w3id.org/noria/kos/application/sla-level/Bronze> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Bronze SLA"@en ;
    rdfs:comment "Basic SLA level with standard availability."@en .

# =============================================================================
# Organizations and Agents
# =============================================================================

# Organizations
org:Org_IT_Operations a org:Organization ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Main department responsible for IT infrastructure and services."@en .

org:Org_Network_Services a org:Organization ;
    rdfs:label "Network Services Division"@en ;
    rdfs:comment "Specialized division for network infrastructure management."@en ;
    org:hasSubOrganization org:OrgUnit_Network_L2_Support, org:OrgUnit_Network_L3_Engineering .

org:Org_Application_Development a org:Organization ;
    rdfs:label "Application Development Department"@en ;
    rdfs:comment "Department responsible for developing and maintaining business applications."@en ;
    org:hasSubOrganization org:OrgUnit_App_Dev_Team_A, org:OrgUnit_App_Dev_Team_B .

org:Org_Security_Operations a org:Organization ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Department responsible for monitoring and responding to security incidents."@en .

org:Org_HR_Department a org:Organization ;
    rdfs:label "Human Resources Department"@en ;
    rdfs:comment "Department managing human capital."@en .

# Organizational Units (Teams)
org:OrgUnit_Network_L2_Support a org:OrganizationalUnit ;
    rdfs:label "Network L2 Support Team"@en ;
    rdfs:comment "Team providing second-level support for network issues."@en ;
    org:unitOf org:Org_Network_Services ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical network issues, call the hotline directly. For non-critical, use ticketing system."@en .

org:OrgUnit_Network_L3_Engineering a org:OrganizationalUnit ;
    rdfs:label "Network L3 Engineering Team"@en ;
    rdfs:comment "Team responsible for network design, architecture, and advanced troubleshooting."@en ;
    org:unitOf org:Org_Network_Services ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Escalate from L2 for complex network problems."@en .

org:OrgUnit_App_Dev_Team_A a org:OrganizationalUnit ;
    rdfs:label "Application Development Team A"@en ;
    rdfs:comment "Team developing and maintaining core business application 'EnterpriseSuite'."@en ;
    org:unitOf org:Org_Application_Development ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

org:OrgUnit_App_Dev_Team_B a org:OrganizationalUnit ;
    rdfs:label "Application Development Team B"@en ;
    rdfs:comment "Team developing and maintaining 'CustomerPortal' application."@en ;
    org:unitOf org:Org_Application_Development ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

org:OrgUnit_Server_Admin_Team a org:OrganizationalUnit ;
    rdfs:label "Server Administration Team"@en ;
    rdfs:comment "Team managing physical and virtual servers."@en ;
    org:unitOf org:Org_IT_Operations ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For server outages, contact on-call engineer immediately."@en .

org:OrgUnit_Database_Team a org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all database systems."@en ;
    org:unitOf org:Org_IT_Operations ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

org:OrgUnit_Security_Incident_Response_Team a org:OrganizationalUnit ;
    rdfs:label "Security Incident Response Team (SIRT)"@en ;
    rdfs:comment "Team responsible for responding to security incidents."@en ;
    org:unitOf org:Org_Security_Operations ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Report all security breaches to SIRT immediately."@en .

# Agents (Individuals)
