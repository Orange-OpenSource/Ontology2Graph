    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority, critical impact."@en .

<kos/TroubleTicket/priority/P2> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 2"@en ;
    rdfs:comment "High priority, significant impact."@en .

<kos/TroubleTicket/priority/P3> a skos:Concept ;
