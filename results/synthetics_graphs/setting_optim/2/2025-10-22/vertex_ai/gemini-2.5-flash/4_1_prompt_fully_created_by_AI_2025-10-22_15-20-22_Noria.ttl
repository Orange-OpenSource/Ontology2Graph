    rdfs:comment "Dedicated link for database replication to DR site."@en ;
    noria:networkLinkId "NL-PAR-DR-REP-01" ;
    noria:networkLinkType "Fiber Optic 1Gbps" ;
    noria:networkLinkInstallationDate "2022-04-01T11:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_DBServer_01_Eth0 ; # Simplified, assuming direct link
    noria:networkInterfaceConnects noria:NetworkInterface_DR_DBServer_01_Eth0 ;
    noria:resourceManagedBy org:OU_AppDev_InnovateIT .

# --- Applications ---
# Creating 5 Applications
noria:Application_CustomerPortal a noria:Application ;
    rdfs:label "Customer Portal"@en ;
    rdfs:comment "Web application allowing customers to manage their services."@en ;
    noria:applicationModelIdentifier "CP-V2.0" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CustPortal" ;
    noria:applicationType <kos/application/type/customer-facing> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Self-Service Portal"@en ;
    noria:resourceManagedBy org:OU_AppDev_InnovateIT ;
    noria:resourceForApplication noria:Resource_WebServer_01, noria:Resource_DBServer_01, noria:Resource_LoadBalancer_01 .

noria:Application_InternalERP a noria:Application ;
    rdfs:label "Internal ERP System"@en ;
    rdfs:comment "Enterprise Resource Planning system for internal operations."@en ;
    noria:applicationModelIdentifier "ERP-V3.1" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "ERP" ;
    noria:applicationType <kos/application/type/back-office> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Operations Management"@en ;
    noria:applicationFunctionalSubDomain "Financial Accounting"@en ;
    noria:resourceManagedBy foaf:Agent_BobWhite ;
    noria:resourceForApplication noria:Resource_AppServer_01, noria:Resource_DBServer_01, noria:Resource_StorageArray_01 .

noria:Application_NetworkMonitoring a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:comment "Monitors the health and performance of the network infrastructure."@en ;
    noria:applicationModelIdentifier "NMS-V1.5" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations Management"@en ;
    noria:applicationFunctionalSubDomain "Network Performance Monitoring"@en ;
    noria:resourceManagedBy org:OU_NOC_GlobalTech ;
    noria:resourceForApplication noria:Resource_MonitoringServer_01 .

noria:Application_SecurityAnalytics a noria:Application ;
    rdfs:label "Security Analytics Platform"@en ;
    rdfs:comment "Collects and analyzes security logs for threat detection."@en ;
    noria:applicationModelIdentifier "SAP-V1.0" ;
    noria:applicationNumericalIdentifier 1004 ;
    noria:applicationShortIdentifier "SecAnalytics" ;
    noria:applicationType <kos/application/type/security> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Cybersecurity Operations"@en ;
    noria:applicationFunctionalSubDomain "Security Information and Event Management"@en ;
    noria:resourceManagedBy org:OU_SecOps_SecureNet ;
    noria:resourceForApplication noria:Resource_LogServer_01 .

noria:Application_CloudIntegration a noria:Application ;
    rdfs:label "Cloud Integration Service"@en ;
    rdfs:comment "Manages data synchronization and API calls between on-premise and cloud."@en ;
    noria:applicationModelIdentifier "CIS-V1.0" ;
    noria:applicationNumericalIdentifier 1005 ;
    noria:applicationShortIdentifier "CloudInt" ;
    noria:applicationType <kos/application/type/hybrid-cloud> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Cloud Operations"@en ;
    noria:applicationFunctionalSubDomain "Hybrid Cloud Management"@en ;
    noria:resourceManagedBy foaf:Agent_CharlieGreen ;
    noria:resourceForApplication noria:Resource_CloudGateway_01 .

