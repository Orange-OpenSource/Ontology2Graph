    noria:networkLinkId "NL-PAR-CS-FW-01" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2021-05-20T10:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_CoreSwitch_Paris_Gi0_1 ;
    noria:networkInterfaceConnects noria:NetworkInterface_Firewall_Paris_Gi0_0 ;
