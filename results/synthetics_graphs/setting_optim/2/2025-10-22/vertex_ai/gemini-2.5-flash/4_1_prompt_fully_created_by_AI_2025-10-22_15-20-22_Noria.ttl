# --- Agents and Organizations ---
# Creating 10 Agents (Teams/Individuals) and 3 Organizations
org:Org_GlobalTech a org:Organization ;
    rdfs:label "GlobalTech Solutions Inc."@en ;
    rdfs:comment "A multinational technology corporation providing IT services."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via global NOC email for critical issues."@en .

org:Org_InnovateIT a org:Organization ;
    rdfs:label "InnovateIT Services"@en ;
    rdfs:comment "Specialized IT consulting and managed services provider."@en ;
