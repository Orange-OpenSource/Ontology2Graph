# --- Services ---
# Creating 3 Services
noria:Service_GlobalCustomerAccess a noria:Service ;
    rdfs:label "Global Customer Access Service"@en ;
    rdfs:comment "Provides end-to-end access for customers to all online services."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    noria:elementManagedBy org:OU_AppDev_InnovateIT ;
    seas:subSystem noria:ApplicationModule_CustomerPortal_Prod, noria:Application_CustomerPortal .

noria:Service_InternalBusinessOperations a noria:Service ;
    rdfs:label "Internal Business Operations Service"@en ;
    rdfs:comment "Supports all core internal business processes."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    noria:elementManagedBy org:OU_AppDev_InnovateIT ;
    seas:subSystem noria:ApplicationModule_InternalERP_Prod, noria:Application_InternalERP .

noria:Service_ITInfrastructureManagement a noria:Service ;
    rdfs:label "IT Infrastructure Management Service"@en ;
    rdfs:comment "Ensures the stability and performance of the underlying IT infrastructure."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    noria:elementManagedBy org:OU_NOC_GlobalTech ;
    seas:subSystem noria:ApplicationModule_NMS_Main, noria:Application_NetworkMonitoring, noria:Application_SecurityAnalytics .

# --- Event Records ---
# Creating 15 Event Records
noria:EventRecord_DB_HighCPU_01 a noria:EventRecord ;
    rdfs:label "DB Server High CPU Alert"@en ;
    rdfs:comment "CPU utilization on DBServer_01 exceeded 90% for 5 minutes."@en ;
    noria:loggingTime "2024-01-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBServer_01 ;
    noria:logOriginatingManagementSystem noria:Application_NetworkMonitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logText "CPU usage on db01.corp.innovateit.com at 95%."@en .

noria:EventRecord_Web_Latency_01 a noria:EventRecord ;
    rdfs:label "Web Server Latency Warning"@en ;
    rdfs:comment "Increased response time detected on WebServer_01."@en ;
    noria:loggingTime "2024-01-20T10:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebServer_01 ;
    noria:logOriginatingManagementSystem noria:Application_NetworkMonitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logText "WebServer_01 response time > 500ms."@en .

noria:EventRecord_Firewall_Blocked_01 a noria:EventRecord ;
    rdfs:label "Firewall Blocked Connection Alert"@en ;
    rdfs:comment "Attempted unauthorized connection blocked by Firewall_Paris."@en ;
    noria:loggingTime "2024-01-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Firewall_Paris ;
    noria:logOriginatingManagementSystem noria:Application_SecurityAnalytics ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "Blocked connection from 1.2.3.4 to internal network."@en .

noria:EventRecord_Link_Down_01 a noria:EventRecord ;
    rdfs:label "Network Link Down Alert"@en ;
    rdfs:comment "NetworkLink_Paris_Core_Firewall detected as down."@en ;
    noria:loggingTime "2024-01-20T10:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:NetworkLink_Paris_Core_Firewall ;
    noria:logOriginatingManagementSystem noria:Application_NetworkMonitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "Link NL-PAR-CS-FW-01 is down."@en .

noria:EventRecord_App_Error_01 a noria:EventRecord ;
