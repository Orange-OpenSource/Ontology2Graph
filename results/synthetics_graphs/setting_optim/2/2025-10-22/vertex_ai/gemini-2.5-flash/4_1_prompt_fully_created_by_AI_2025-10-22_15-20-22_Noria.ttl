    noria:logOriginatingManagementSystem noria:Application_NetworkMonitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logText "Customer Portal production error rate > 5%."@en .

noria:EventRecord_DB_DiskFull_01 a noria:EventRecord ;
