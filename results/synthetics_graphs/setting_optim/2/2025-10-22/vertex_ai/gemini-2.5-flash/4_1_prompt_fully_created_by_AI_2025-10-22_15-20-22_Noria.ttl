# --- Operation Plans ---
# Creating 3 Operation Plans
noria:OperationPlan_DB_Restart a noria:OperationPlan ;
    rdfs:label "Database Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the database service on a server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DB_Service_Down ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DB_Service_Up .

noria:OperationPlan_Network_Link_Troubleshoot a noria:OperationPlan ;
    rdfs:label "Network Link Troubleshooting Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving issues on a network link."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_Link_Operational_Status_Down ;
    noria:operationPlanPostCondition noria:ActionPostCondition_Link_Operational_Status_Up .

noria:OperationPlan_Firewall_Rule_Add a noria:OperationPlan ;
    rdfs:label "Firewall Rule Addition Procedure"@en ;
    rdfs:comment "Standard procedure for adding new rules to the perimeter firewall."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_Firewall_Access_Granted ;
    noria:operationPlanPostCondition noria:ActionPostCondition_Firewall_Rule_Active .

# --- Action Pre/Post Conditions ---
# Creating 6 Action Pre/Post Conditions
noria:ActionPreCondition_DB_Service_Down a noria:ActionPreCondition ;
    rdfs:label "Database Service is Down"@en ;
    rdfs:comment "Condition: The database service process is not running or is unresponsive."@en .

noria:ActionPostCondition_DB_Service_Up a noria:ActionPostCondition ;
    rdfs:label "Database Service is Up"@en ;
    rdfs:comment "Outcome: The database service process is running and accepting connections."@en .

noria:ActionPreCondition_Link_Operational_Status_Down a noria:ActionPreCondition ;
    rdfs:label "Network Link Operational Status is Down"@en ;
    rdfs:comment "Condition: The operational status of the network interface is 'down'."@en .

noria:ActionPostCondition_Link_Operational_Status_Up a noria:ActionPostCondition ;
    rdfs:label "Network Link Operational Status is Up"@en ;
    rdfs:comment "Outcome: The operational status of the network interface is 'up'."@en .

noria:ActionPreCondition_Firewall_Access_Granted a noria:ActionPreCondition ;
    rdfs:label "Firewall Management Access Granted"@en ;
    rdfs:comment "Condition: Administrator has authenticated access to the firewall management interface."@en .

noria:ActionPostCondition_Firewall_Rule_Active a noria:ActionPostCondition ;
    rdfs:label "Firewall Rule is Active"@en ;
    rdfs:comment "Outcome: The newly added firewall rule is active and traffic is flowing as expected."@en .

