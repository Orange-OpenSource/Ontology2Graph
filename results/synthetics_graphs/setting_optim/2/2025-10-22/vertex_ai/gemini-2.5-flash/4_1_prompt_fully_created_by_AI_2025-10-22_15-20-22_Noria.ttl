noria:NetworkLink_Paris_DB_App a noria:NetworkLink ;
    rdfs:label "Paris DB to App Server Link"@en ;
    rdfs:comment "Internal link between database and application servers."@en ;
    noria:networkLinkId "NL-PAR-DB-APP-01" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2022-08-01T11:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_DBServer_01_Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_AppServer_01_Eth0 ;
    noria:resourceManagedBy org:OU_AppDev_InnovateIT .

noria:NetworkLink_Paris_App_App a noria:NetworkLink ;
    rdfs:label "Paris App Server to App Server Link"@en ;
    rdfs:comment "Internal link between application servers."@en ;
    noria:networkLinkId "NL-PAR-APP-APP-01" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2022-08-01T11:15:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_AppServer_01_Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_AppServer_02_Eth0 ;
    noria:resourceManagedBy org:OU_AppDev_InnovateIT .

noria:NetworkLink_Paris_DR_Replication a noria:NetworkLink ;
