# --- Trouble Tickets ---
# Creating 10 Trouble Tickets
noria:TroubleTicket_TT001 a noria:TroubleTicket ;
    rdfs:label "Customer Portal Outage"@en ;
    rdfs:comment "Customer Portal is completely inaccessible, impacting all users."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Customer Feedback" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Unidentified" ;
    noria:troubleTicketDetectionDateTime "2024-01-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:Application_CustomerPortal ;
    noria:troubleTicketRelatedParty foaf:Agent_EveBlack, org:OU_AppDev_InnovateIT ;
    noria:troubleTicketTrigger noria:EventRecord_App_Error_01 ;
    noria:troubleTicketImpacts noria:Resource_WebServer_01, noria:Resource_DBServer_01, noria:ApplicationModule_CustomerPortal_Prod .

noria:TroubleTicket_TT002 a noria:TroubleTicket ;
    rdfs:label "ERP Database Performance Degradation"@en ;
    rdfs:comment "Users reporting slow performance on Internal ERP system, traced to database server."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Internal> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "Internal Monitoring" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/DowngradingEquipment> ;
    noria:troubleTicketCause "High CPU on DB server" ;
    noria:troubleTicketDetectionDateTime "2024-01-20T10:06:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:Application_InternalERP ;
    noria:troubleTicketRelatedResource noria:Resource_DBServer_01 ;
    noria:troubleTicketRelatedParty foaf:Agent_BobWhite, org:OU_AppDev_InnovateIT ;
    noria:troubleTicketTrigger noria:EventRecord_DB_HighCPU_01 ;
