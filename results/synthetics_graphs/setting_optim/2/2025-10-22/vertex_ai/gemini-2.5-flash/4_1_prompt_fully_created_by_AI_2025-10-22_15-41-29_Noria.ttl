# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_DNS_Down_Log a noria:EventRecord ;
    rdfs:label "DNS Server 01 Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS Server 01 became unreachable."@en ;
    noria:loggingTime "2024-03-20T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS_Server_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - PING CRITICAL - Packet loss = 100%" ;
    dcterms:type <kos/Notification/EventType/StateChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_Web_CPU_High_Log a noria:EventRecord ;
    rdfs:label "Web Server 01 High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-03-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Web_Server_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "WARNING: CPU utilization on web01.corp.example.com is 95% (threshold 90%)" ;
    dcterms:type <kos/Notification/EventType/ThresholdExceeded> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_Router_Interface_Down_Log a noria:EventRecord ;
    rdfs:label "Edge Router Interface Down Log"@en ;
    rdfs:comment "Log entry for Edge Router 01 Gig0/0/0 interface going down."@en ;
    noria:loggingTime "2024-03-20T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Router_Edge_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/0, changed state to down" ;
    dcterms:type <kos/Notification/EventType/StateChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_DB_Disk_Full_Log a noria:EventRecord ;
    rdfs:label "DB Server 01 Disk Full Alert"@en ;
    rdfs:comment "Alert indicating disk space is critically low on DB Server 01."@en ;
    noria:loggingTime "2024-03-20T10:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DB_Server_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CRITICAL: Disk usage on /data for db01.corp.example.com is 98% (threshold 95%)" ;
    dcterms:type <kos/Notification/EventType/ThresholdExceeded> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_Firewall_Blocked_Attempt a noria:EventRecord ;
    rdfs:label "Firewall Blocked Access Attempt"@en ;
    rdfs:comment "Log entry for a blocked access attempt by the DMZ Firewall."@en ;
    noria:loggingTime "2024-03-20T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Firewall_DMZ_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "FIREWALL: Blocked connection attempt from 1.2.3.4 to 10.0.0.20 on port 80" ;
    dcterms:type <kos/Notification/EventType/SecurityAlert> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_User_Login_Failure a noria:EventRecord ;
    rdfs:label "User Login Failure"@en ;
    rdfs:comment "Log entry for a failed login attempt on a system."@en ;
    noria:loggingTime "2024-03-20T11:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Web_Server_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ; # Example of a user attempting login
    noria:logText "Authentication failure for user 'johndoe' from IP 192.168.1.100" ;
    dcterms:type <kos/Notification/EventType/SecurityAlert> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

noria:EventRecord_Config_Change_Router a noria:EventRecord ;
    rdfs:label "Router Configuration Change"@en ;
    rdfs:comment "Log entry indicating a configuration change on Edge Router 01."@en ;
    noria:loggingTime "2024-03-19T15:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Router_Edge_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by user 'johndoe' (192.168.1.10)" ;
    dcterms:type <kos/Notification/EventType/ConfigurationChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

