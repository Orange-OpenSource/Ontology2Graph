# =============================================================================
# Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OperationPlan_ServerReboot a noria:OperationPlan ;
    rdfs:label "Standard Server Reboot Procedure"@en ;
    rdfs:comment "A documented procedure for safely rebooting a server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_ServerPingFailure ;
    noria:operationPlanPostCondition noria:ActionPostCondition_ServerPingSuccess .

noria:ActionPreCondition_ServerPingFailure a noria:ActionPreCondition ;
    rdfs:label "Server Ping Failure"@en ;
    rdfs:comment "Condition: Server is not responding to ICMP (ping) requests."@en .

noria:ActionPostCondition_ServerPingSuccess a noria:ActionPostCondition ;
    rdfs:label "Server Ping Success"@en ;
    rdfs:comment "Outcome: Server is responding to ICMP (ping) requests."@en .

noria:OperationPlan_DiskCleanup a noria:OperationPlan ;
    rdfs:label "Database Disk Cleanup Procedure"@en ;
    rdfs:comment "Procedure to free up disk space on database servers by archiving/deleting old logs."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DiskSpaceCritical ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DiskSpaceNormal .

noria:ActionPreCondition_DiskSpaceCritical a noria:ActionPreCondition ;
    rdfs:label "Disk Space Critical"@en ;
    rdfs:comment "Condition: Disk utilization exceeds 95%."@en .

noria:ActionPostCondition_DiskSpaceNormal a noria:ActionPostCondition ;
    rdfs:label "Disk Space Normal"@en ;
    rdfs:comment "Outcome: Disk utilization is below 80%."@en .

noria:AnomalyPattern_HighCPULowThroughput a noria:AnomalyPattern ;
    rdfs:label "High CPU, Low Throughput Anomaly"@en ;
    rdfs:comment "Pattern indicating a potential performance bottleneck: high CPU usage on a server but low network throughput, suggesting internal processing issues."@en ;
    skos:example "Observed on web01.corp.example.com, leading to Web Portal performance degradation."@en .

noria:AnomalyPattern_InterfaceFlap a noria:AnomalyPattern ;
    rdfs:label "Network Interface Flapping Anomaly"@en ;
    rdfs:comment "Pattern where a network interface repeatedly changes its operational state (up/down) in a short period, often indicating a physical layer issue or faulty transceiver."@en ;
    skos:example "Observed on edge-rtr01 Gig0/0/0, causing intermittent internet outages."@en .

