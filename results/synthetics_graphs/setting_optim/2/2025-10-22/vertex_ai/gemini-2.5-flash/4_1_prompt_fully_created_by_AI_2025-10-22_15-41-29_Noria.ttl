# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_ITOpsTeam a foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all incidents. For critical issues, use emergency hotline."@en .

foaf:Agent_NetworkAdminTeam a foaf:Agent ;
    rdfs:label "Network Administration Team"@en ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Open a ticket for all requests. For network outages, call directly."@en .

foaf:Agent_AppDevTeam a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining core business applications."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    noria:agentInstructions "Use internal chat for quick queries, JIRA for bug reports."@en .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Monitors and responds to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlert> ;
    noria:agentInstructions "All security alerts are automatically routed to the SIEM. For manual reports, use dedicated portal."@en .

foaf:Agent_DatabaseAdminTeam a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Manages and maintains all database systems."@en ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit database change requests via the change management system."@en .

foaf:Agent_CloudOpsTeam a foaf:Agent ;
    rdfs:label "Cloud Operations Team"@en ;
    rdfs:comment "Manages cloud infrastructure and services."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Pager> ;
    noria:agentInstructions "Automated alerts for critical cloud issues. Manual contact via dedicated Slack channel."@en .

foaf:Agent_HelpDesk a foaf:Agent ;
    rdfs:label "IT Help Desk"@en ;
    rdfs:comment "First line of support for end-users."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Users should call the help desk for all IT issues."@en .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual member of the Network Administration Team."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Direct email for urgent matters."@en .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Individual member of the Application Development Team."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    noria:agentInstructions "Ping on internal chat for quick questions."@en .

org:OrgUnit_NetworkOps a org:OrganizationalUnit ;
    rdfs:label "Network Operations Unit"@en ;
    rdfs:comment "Organizational unit responsible for network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

org:OrgUnit_AppSupport a org:OrganizationalUnit ;
    rdfs:label "Application Support Unit"@en ;
    rdfs:comment "Organizational unit providing L2/L3 support for applications."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

org:OrgUnit_SecurityOps a org:OrganizationalUnit ;
    rdfs:label "Security Operations Unit"@en ;
    rdfs:comment "Organizational unit handling cybersecurity."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlert> .

# =============================================================================
# Locations
# =============================================================================

bot:Site_DataCenter_Paris a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressStreet "Rue de la Paix" .

bot:Site_Office_Lyon a bot:Site ;
    rdfs:label "Lyon Office Building"@en ;
    rdfs:comment "Regional office building in Lyon."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressStreet "Avenue Jean Jaurès" .

noria:Room_ServerRoom_DC_Paris_A1 a noria:Room ;
    rdfs:label "Server Room A1 - Paris DC"@en ;
    rdfs:comment "Main server room in the Paris Data Center."@en ;
    bot:hasSpace noria:Locus_Rack_A1_R1 .

noria:Room_NetworkRoom_Office_Lyon_B2 a noria:Room ;
    rdfs:label "Network Room B2 - Lyon Office"@en ;
    rdfs:comment "Network equipment room in the Lyon office."@en ;
    bot:hasSpace noria:Locus_Rack_B2_R5 .

noria:Locus_Rack_A1_R1 a noria:Locus ;
    rdfs:label "Rack R1 in Server Room A1"@en ;
    rdfs:comment "Specific rack location for servers."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "R1" .

noria:Locus_Rack_B2_R5 a noria:Locus ;
    rdfs:label "Rack R5 in Network Room B2"@en ;
    rdfs:comment "Specific rack location for network devices."@en ;
    noria:locusLine "B2" ;
    noria:locusRow "R5" .

