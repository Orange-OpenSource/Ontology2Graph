# --- Operation Plans ---
noria:OperationPlan_DNS_Restart_Procedure a noria:OperationPlan ;
    rdfs:label "DNS Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the corporate DNS service."@en ;
    skos:example "Steps: 1. Check service status. 2. Attempt graceful restart. 3. Force restart if necessary. 4. Verify service functionality."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNS_Service_Down ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNS_Service_Up .

noria:OperationPlan_Router_SFP_Replacement a noria:OperationPlan ;
    rdfs:label "Router SFP Replacement Procedure"@en ;
    rdfs:comment "Procedure for replacing a Small Form-Factor Pluggable (SFP) module on a network router."@en ;
    skos:example "Steps: 1. Identify faulty SFP. 2. Safely remove SFP. 3. Insert new SFP. 4. Verify link status."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_Interface_Flapping ;
    noria:operationPlanPostCondition noria:ActionPostCondition_Interface_Stable .

noria:OperationPlan_DB_Query_Optimization a noria:OperationPlan ;
    rdfs:label "Database Query Optimization Procedure"@en ;
    rdfs:comment "Procedure for identifying and optimizing inefficient database queries."@en ;
    skos:example "Steps: 1. Monitor database performance. 2. Identify slow queries. 3. Analyze query execution plans. 4. Apply indexes or rewrite queries. 5. Re-verify performance."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DB_High_CPU ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DB_CPU_Normal .

noria:OperationPlan_WebApp_Rollback a noria:OperationPlan ;
    rdfs:label "Web Application Rollback Procedure"@en ;
    rdfs:comment "Procedure for rolling back a web application to a previous stable version."@en ;
    skos:example "Steps: 1. Identify problematic deployment. 2. Initiate rollback to previous version. 3. Monitor application health. 4. Verify functionality."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_WebApp_Errors ;
    noria:operationPlanPostCondition noria:ActionPostCondition_WebApp_Stable .

# --- Action Pre/Post Conditions ---
noria:ActionPreCondition_DNS_Service_Down a noria:ActionPreCondition ;
    rdfs:label "DNS Service Down Pre-Condition"@en ;
    rdfs:comment "Condition: DNS service is not responding or process is stopped."@en .

noria:ActionPostCondition_DNS_Service_Up a noria:ActionPostCondition ;
    rdfs:label "DNS Service Up Post-Condition"@en ;
    rdfs:comment "Outcome: DNS service is running and responding to queries."@en .

noria:ActionPreCondition_Interface_Flapping a noria:ActionPreCondition ;
    rdfs:label "Interface Flapping Pre-Condition"@en ;
    rdfs:comment "Condition: Network interface is repeatedly changing between up and down states."@en .

noria:ActionPostCondition_Interface_Stable a noria:ActionPostCondition ;
    rdfs:label "Interface Stable Post-Condition"@en ;
    rdfs:comment "Outcome: Network interface is consistently in an 'up' state."@en .

noria:ActionPreCondition_DB_High_CPU a noria:ActionPreCondition ;
    rdfs:label "Database High CPU Pre-Condition"@en ;
    rdfs:comment "Condition: Database server CPU utilization is consistently above 80%."@en .

noria:ActionPostCondition_DB_CPU_Normal a noria:ActionPostCondition ;
    rdfs:label "Database CPU Normal Post-Condition"@en ;
    rdfs:comment "Outcome: Database server CPU utilization is within normal operating range (e.g., below 50%)."@en .

noria:ActionPreCondition_WebApp_Errors a noria:ActionPreCondition ;
    rdfs:label "Web Application Errors Pre-Condition"@en ;
    rdfs:comment "Condition: Web application is returning a high rate of server-side errors (e.g., HTTP 5xx)."@en .

noria:ActionPostCondition_WebApp_Stable a noria:ActionPostCondition ;
    rdfs:label "Web Application Stable Post-Condition"@en ;
    rdfs:comment "Outcome: Web application is responding with successful status codes and no critical errors."@en .

# --- Anomaly Patterns ---
noria:AnomalyPattern_DNS_Cache_Poisoning a noria:AnomalyPattern ;
    rdfs:label "DNS Cache Poisoning Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a potential DNS cache poisoning attack, characterized by unusual DNS query responses and high DNS server load."@en ;
    skos:example "Multiple DNS queries for non-existent domains, unexpected IP addresses in DNS responses, sudden increase in DNS traffic."@en .

noria:AnomalyPattern_Network_Loop a noria:AnomalyPattern ;
    rdfs:label "Network Loop Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a network loop, characterized by high broadcast traffic, MAC address flapping, and network instability."@en ;
    skos:example "High broadcast storm detected, duplicate MAC addresses reported on different switch ports, intermittent connectivity issues."@en .

noria:AnomalyPattern_Resource_Exhaustion a noria:AnomalyPattern ;
    rdfs:label "Resource Exhaustion Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a server or application is running out of critical resources (CPU, Memory, Disk I/O)."@en ;
    skos:example "Sustained high CPU usage, low available memory, high disk queue length, application crashes due to out-of-memory errors."@en .

noria:AnomalyPattern_SQL_Injection_Attempt a noria:AnomalyPattern ;
    rdfs:label "SQL Injection Attempt Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating attempts to exploit SQL injection vulnerabilities, characterized by suspicious database queries."@en ;
    skos:example "Database logs showing queries with 'OR 1=1', 'UNION SELECT', or other common SQL injection payloads."@en .

noria:AnomalyPattern_DDoS_Attack a noria:AnomalyPattern ;
    rdfs:label "DDoS Attack Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a Distributed Denial of Service (DDoS) attack, characterized by a massive influx of traffic from multiple sources targeting a single service."@en ;
    skos:example "Sudden and significant increase in network traffic to a specific IP/port, multiple source IPs, service unavailability."@en .

