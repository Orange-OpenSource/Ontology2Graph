    rdfs:comment "Manages employee-related services."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Email for general inquiries. Use internal portal for specific requests."@en .

foaf:Agent_Finance_Team a foaf:Agent ;
