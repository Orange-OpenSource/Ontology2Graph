# =============================================================================
# Operation Plans
# =============================================================================

noria:OperationPlan_DNS_Troubleshooting a noria:OperationPlan ;
    rdfs:label "DNS Server Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving DNS server issues."@en ;
    skos:example "Check network connectivity, verify DNS service status, inspect logs, restart service."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNS_Unreachable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNS_Resolved .

noria:OperationPlan_Web_Server_CPU_Mitigation a noria:OperationPlan ;
    rdfs:label "Web Server High CPU Mitigation"@en ;
    rdfs:comment "Procedure to address high CPU usage on web servers, including service restart and process identification."@en ;
    skos:example "Identify rogue processes, restart web server, scale out application."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_High_CPU_Alert ;
    noria:operationPlanPostCondition noria:ActionPostCondition_CPU_Normalized .

noria:OperationPlan_Router_Interface_Restore a noria:OperationPlan ;
    rdfs:label "Router Interface Restoration Procedure"@en ;
    rdfs:comment "Steps to restore a down router interface, including physical checks and configuration verification."@en ;
    skos:example "Verify physical cable, check interface status, re-enable interface, verify routing."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_Interface_Down ;
    noria:operationPlanPostCondition noria:ActionPostCondition_Interface_Up .

noria:OperationPlan_Security_Incident_Response a noria:OperationPlan ;
    rdfs:label "Security Incident Response Plan"@en ;
    rdfs:comment "Procedure for responding to detected security incidents, including containment, eradication, and recovery."@en ;
    skos:example "Isolate affected systems, block malicious IPs, analyze logs, restore from backup."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_Security_Alert ;
    noria:operationPlanPostCondition noria:ActionPostCondition_Threat_Contained .

noria:OperationPlan_DB_Disk_Cleanup a noria:OperationPlan ;
    rdfs:label "Database Disk Space Cleanup"@en ;
    rdfs:comment "Procedure for freeing up disk space on database servers, typically by archiving or deleting old logs."@en ;
    skos:example "Identify large files, archive old logs, delete temporary files, monitor disk usage."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_Disk_Full_Alert ;
    noria:operationPlanPostCondition noria:ActionPostCondition_Disk_Space_Freed .

# =============================================================================
# Action Pre/Post Conditions
# =============================================================================

noria:ActionPreCondition_DNS_Unreachable a noria:ActionPreCondition ;
    rdfs:label "DNS Server Unreachable"@en ;
    rdfs:comment "Condition: DNS server is not responding to network requests."@en .

noria:ActionPostCondition_DNS_Resolved a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Outcome: DNS server is reachable and resolving queries correctly."@en .

noria:ActionPreCondition_High_CPU_Alert a noria:ActionPreCondition ;
    rdfs:label "High CPU Usage Alert"@en ;
    rdfs:comment "Condition: Monitoring system reports CPU utilization above threshold."@en .

noria:ActionPostCondition_CPU_Normalized a noria:ActionPostCondition ;
    rdfs:label "CPU Usage Normalized"@en ;
    rdfs:comment "Outcome: CPU utilization returns to normal operating levels."@en .

noria:ActionPreCondition_Interface_Down a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down"@en ;
    rdfs:comment "Condition: A critical network interface is reported as administratively or operationally down."@en .

noria:ActionPostCondition_Interface_Up a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up"@en ;
    rdfs:comment "Outcome: The network interface is operational and passing traffic."@en .

noria:ActionPreCondition_Security_Alert a noria:ActionPreCondition ;
    rdfs:label "Security Alert Triggered"@en ;
    rdfs:comment "Condition: A security system (e.g., firewall, SIEM) has detected and alerted on a potential threat."@en .

noria:ActionPostCondition_Threat_Contained a noria:ActionPostCondition ;
    rdfs:label "Security Threat Contained"@en ;
    rdfs:comment "Outcome: The identified security threat has been mitigated and contained."@en .

noria:ActionPreCondition_Disk_Full_Alert a noria:ActionPreCondition ;
    rdfs:label "Disk Space Critical Alert"@en ;
    rdfs:comment "Condition: A storage volume has reached a critical threshold of disk space usage."@en .

noria:ActionPostCondition_Disk_Space_Freed a noria:ActionPostCondition ;
    rdfs:label "Disk Space Freed"@en ;
    rdfs:comment "Outcome: Sufficient disk space has been reclaimed, and usage is below warning thresholds."@en .

# =============================================================================
# Anomaly Patterns
# =============================================================================

noria:AnomalyPattern_DNS_Failure_Chain a noria:AnomalyPattern ;
    rdfs:label "DNS Service Failure Pattern"@en ;
    rdfs:comment "Pattern indicating a complete failure of the DNS service, often starting with network unreachability and leading to application outages."@en ;
    skos:example "EventRecord_DNS_Outage_Alert_01 followed by TroubleTicket_DNS_Outage_01."@en .

noria:AnomalyPattern_Web_Performance_Degradation a noria:AnomalyPattern ;
    rdfs:label "Web Application Performance Degradation Pattern"@en ;
    rdfs:comment "Pattern characterized by high resource utilization on web servers, leading to slow application response times."@en ;
    skos:example "EventRecord_Web_Server_HighCPU_01 leading to TroubleTicket_Web_Performance_01."@en .

noria:AnomalyPattern_Network_Link_Failure a noria:AnomalyPattern ;
    rdfs:label "Network Link Failure Pattern"@en ;
    rdfs:comment "Pattern indicating a critical network link failure, potentially causing widespread connectivity loss."@en ;
    skos:example "EventRecord_Router_Interface_Down_01 leading to TroubleTicket_Router_Interface_01."@en .

noria:AnomalyPattern_Unauthorized_Access_Attempt a noria:AnomalyPattern ;
    rdfs:label "Unauthorized Access Attempt Pattern"@en ;
    rdfs:comment "Pattern indicating attempts to gain unauthorized access, typically detected by perimeter security devices."@en ;
    skos:example "EventRecord_Firewall_Blocked_Traffic_01 leading to TroubleTicket_Security_Incident_01."@en .

noria:AnomalyPattern_Storage_Capacity_Exhaustion a noria:AnomalyPattern ;
    rdfs:label "Storage Capacity Exhaustion Pattern"@en ;
    rdfs:comment "Pattern indicating critical depletion of storage capacity, often impacting database or application logs."@en ;
    skos:example "EventRecord_DB_Disk_Full_01 leading to TroubleTicket_DB_Disk_Full_01."@en .

