# =============================================================================
# Network Interfaces
# =============================================================================

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DNS_Server_01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to corporate LAN."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_LAN_Paris_A1 .

noria:NetworkInterface_Web01_Eth0 a noria:NetworkInterface ;
    rdfs:label "Web01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_Web_Server_01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to corporate LAN."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_LAN_Paris_A1 .

noria:NetworkInterface_DB01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DB01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DB Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DB_Server_01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to corporate LAN."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_LAN_Paris_A1 .

noria:NetworkInterface_CR01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "CR01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Interface on Core Router 01 connecting to internal LAN."@en ;
    noria:networkInterfaceOf noria:Resource_Router_Core_01 ;
    noria:networkInterfaceDescription "Uplink to internal network segment."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceConnects noria:NetworkLink_LAN_Paris_A1 .

noria:NetworkInterface_CR01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "CR01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface on Core Router 01 connecting to external WAN."@en ;
    noria:networkInterfaceOf noria:Resource_Router_Core_01 ;
    noria:networkInterfaceDescription "Uplink to Internet Service Provider."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -5 ;
    noria:networkInterfaceLaserRxOpticalPower -7 ;
    noria:networkInterfaceConnects noria:NetworkLink_WAN_Paris_ISP .

noria:NetworkInterface_ASW01_Gi0_1 a noria:NetworkInterface ;
    rdfs:label "ASW01 GigabitEthernet0/1"@en ;
    rdfs:comment "Uplink interface on Access Switch 01 to Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_Switch_Access_01 ;
    noria:networkInterfaceDescription "Uplink to core network."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_LAN_Paris_A1 .

noria:NetworkInterface_FW01_Eth0 a noria:NetworkInterface ;
    rdfs:label "FW01 Ethernet 0"@en ;
    rdfs:comment "Internal interface on Perimeter Firewall 01."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall_Perimeter_01 ;
    noria:networkInterfaceDescription "Internal network segment."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_LAN_Paris_A1 .

noria:NetworkInterface_FW01_Eth1 a noria:NetworkInterface ;
    rdfs:label "FW01 Ethernet 1"@en ;
