noria:EventRecord_DNS_Outage_Alert_01 a noria:EventRecord ;
    rdfs:label "DNS Server 01 Unreachable Alert"@en ;
    rdfs:comment "Alert generated by monitoring system indicating DNS Server 01 is unreachable."@en ;
    noria:loggingTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS_Server_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - PING CRITICAL - Packet loss = 100%"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    dcterms:type <kos/Notification/EventType/AvailabilityAlarm> .

noria:EventRecord_Web_Server_HighCPU_01 a noria:EventRecord ;
    rdfs:label "Web Server 01 High CPU Usage Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Web_Server_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "WARNING: CPU usage on web01.corp.example.com is 95% (threshold 90%)"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    dcterms:type <kos/Notification/EventType/PerformanceAlarm> .

noria:EventRecord_Router_Interface_Down_01 a noria:EventRecord ;
    rdfs:label "Core Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating that interface Gi0/0/1 on Core Router 01 went down."@en ;
