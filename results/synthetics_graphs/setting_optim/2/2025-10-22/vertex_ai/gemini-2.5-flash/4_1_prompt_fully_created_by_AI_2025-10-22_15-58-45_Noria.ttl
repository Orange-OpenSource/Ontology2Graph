# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_ITOpsTeam a foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all incidents. For critical issues, use emergency hotline."@en .

foaf:Agent_NetworkAdminTeam a foaf:Agent ;
    rdfs:label "Network Administration Team"@en ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Open a ticket for all requests. For network outages, call directly."@en .

foaf:Agent_AppDevTeam a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining core business applications."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    noria:agentInstructions "Use internal chat for quick queries, JIRA for bug reports."@en .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Monitors and responds to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlert> ;
    noria:agentInstructions "All security alerts are automatically routed to the SIEM. For manual reports, use dedicated portal."@en .

foaf:Agent_DatabaseAdminTeam a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Manages and maintains all database systems."@en ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit database change requests via the change management system."@en .

foaf:Agent_VirtualizationTeam a foaf:Agent ;
    rdfs:label "Virtualization Infrastructure Team"@en ;
    rdfs:comment "Manages virtual machines and hypervisor platforms."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "All VM provisioning and support requests must go through the ticketing system."@en .

foaf:Agent_StorageTeam a foaf:Agent ;
    rdfs:label "Storage Management Team"@en ;
    rdfs:comment "Responsible for all storage area networks (SAN) and network-attached storage (NAS)."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "For storage allocation or issues, create a ticket."@en .

foaf:Agent_HelpDesk a foaf:Agent ;
    rdfs:label "IT Help Desk"@en ;
    rdfs:comment "First line of support for all IT-related issues."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Users should call the help desk for immediate assistance or use the self-service portal."@en .

foaf:Agent_CustomerSupport a foaf:Agent ;
    rdfs:label "Customer Support Team"@en ;
    rdfs:comment "Handles external customer inquiries and issues."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/CRM> ;
    noria:agentInstructions "All customer interactions are logged in the CRM system."@en .

foaf:Agent_ProjectManager a foaf:Agent ;
    rdfs:label "Project Manager for Core Services"@en ;
    rdfs:comment "Oversees projects related to critical business services."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact for project-related updates and escalations."@en .

org:OrgUnit_ITOperations a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The main department overseeing all IT operational activities."@en .

org:OrgUnit_NetworkOps a org:OrganizationalUnit ;
    rdfs:label "Network Operations Division"@en ;
    rdfs:comment "Division focused on network infrastructure management."@en .

org:OrgUnit_AppDev a org:OrganizationalUnit ;
    rdfs:label "Application Development Division"@en ;
    rdfs:comment "Division responsible for software development."@en .

org:OrgUnit_Security a org:OrganizationalUnit ;
    rdfs:label "Cybersecurity Department"@en ;
    rdfs:comment "Department dedicated to IT security."@en .

org:OrgUnit_DBA a org:OrganizationalUnit ;
    rdfs:label "Database Administration Department"@en ;
    rdfs:comment "Department managing all database systems."@en .

org:OrgUnit_Virtualization a org:OrganizationalUnit ;
    rdfs:label "Virtualization Services"@en ;
    rdfs:comment "Team managing virtual infrastructure."@en .

org:OrgUnit_Storage a org:OrganizationalUnit ;
    rdfs:label "Storage Services"@en ;
    rdfs:comment "Team managing storage infrastructure."@en .

org:OrgUnit_HelpDesk a org:OrganizationalUnit ;
    rdfs:label "IT Help Desk Department"@en ;
    rdfs:comment "First-line support for internal users."@en .

org:OrgUnit_CustomerSupport a org:OrganizationalUnit ;
    rdfs:label "Customer Support Department"@en ;
    rdfs:comment "Handles customer-facing issues."@en .

# =============================================================================
# Locations
# =============================================================================

bot:Site_DataCenter_Paris a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002"@en ;
    noria:sitePrincipalAddressCountry "FR"@en ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"@en .

bot:Site_DataCenter_Lyon a bot:Site ;
    rdfs:label "Lyon Data Center"@en ;
    rdfs:comment "Secondary data center located in Lyon, serving as disaster recovery site."@en ;
    noria:siteId "DC-LYO-02" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès"@en ;
    noria:sitePrincipalAddressCityName "Lyon"@en ;
    noria:sitePrincipalAddressPostalCode "69007"@en ;
    noria:sitePrincipalAddressCountry "FR"@en ;
    noria:sitePrincipalAddressStreet "Avenue Jean Jaurès"@en .

noria:Room_ServerRoom_Paris_A1 a noria:Room ;
    rdfs:label "Server Room A1 (Paris DC)"@en ;
    rdfs:comment "Main server room in the Paris Data Center."@en ;
    bot:hasSpace bot:Site_DataCenter_Paris .

noria:Room_NetworkRoom_Paris_B2 a noria:Room ;
    rdfs:label "Network Room B2 (Paris DC)"@en ;
    rdfs:comment "Dedicated network equipment room in the Paris Data Center."@en ;
    bot:hasSpace bot:Site_DataCenter_Paris .

noria:Room_ServerRoom_Lyon_C3 a noria:Room ;
    rdfs:label "Server Room C3 (Lyon DC)"@en ;
    rdfs:comment "Main server room in the Lyon Data Center."@en ;
    bot:hasSpace bot:Site_DataCenter_Lyon .

noria:Locus_Rack_Paris_A1_R12 a noria:Locus ;
    rdfs:label "Rack R12 in Server Room A1 (Paris)"@en ;
    rdfs:comment "Location of servers in Rack 12, Server Room A1."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "12" ;
    bot:hasSpace noria:Room_ServerRoom_Paris_A1 .

noria:Locus_Rack_Paris_B2_N05 a noria:Locus ;
    rdfs:label "Rack N05 in Network Room B2 (Paris)"@en ;
    rdfs:comment "Location of network devices in Rack 05, Network Room B2."@en ;
    noria:locusLine "B2" ;
    noria:locusRow "05" ;
    bot:hasSpace noria:Room_NetworkRoom_Paris_B2 .

noria:Locus_Rack_Lyon_C3_R08 a noria:Locus ;
    rdfs:label "Rack R08 in Server Room C3 (Lyon)"@en ;
    rdfs:comment "Location of servers in Rack 08, Server Room C3."@en ;
    noria:locusLine "C3" ;
    noria:locusRow "08" ;
    bot:hasSpace noria:Room_ServerRoom_Lyon_C3 .

