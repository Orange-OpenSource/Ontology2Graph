    noria:logOriginatingManagedObject noria:Resource_Router_Core_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CRITICAL: Interface Gi0/0/1 on cr01.paris.example.com is DOWN"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    dcterms:type <kos/Notification/EventType/StateChange> .

noria:EventRecord_Firewall_Blocked_Traffic_01 a noria:EventRecord ;
    rdfs:label "Firewall Blocked Traffic Alert"@en ;
    rdfs:comment "Security alert from firewall indicating blocked suspicious traffic."@en ;
    noria:loggingTime "2024-04-23T10:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Firewall_Perimeter_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "ALERT: Suspicious traffic from 1.2.3.4 to 10.0.0.20 blocked by firewall"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    dcterms:type <kos/Notification/EventType/SecurityAlarm> .

noria:EventRecord_DB_Disk_Full_01 a noria:EventRecord ;
    rdfs:label "Database Server Disk Full Alert"@en ;
    rdfs:comment "Alert indicating that a disk on DB Server 01 is nearly full."@en ;
    noria:loggingTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DB_Server_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "WARNING: Disk usage on /data on db01.corp.example.com is 98%"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    dcterms:type <kos/Notification/EventType/ThresholdCrossingAlarm> .

noria:EventRecord_VM_Migration_Success_01 a noria:EventRecord ;
    rdfs:label "VM Migration Success Log"@en ;
