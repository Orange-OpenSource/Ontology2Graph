    noria:logOriginatingManagedObject noria:Resource_Router_Edge01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "Interface Gi0/0/0 on edge-rtr01.corp.example.com changed state to down."@en .

