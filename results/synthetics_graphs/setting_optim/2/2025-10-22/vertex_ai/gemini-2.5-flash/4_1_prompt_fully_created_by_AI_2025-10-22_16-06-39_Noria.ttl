    noria:logOriginatingManagedObject noria:AppModule_HR_Portal_Prod ;
    noria:logOriginatingManagementSystem noria:AppModule_Monitoring_Prod ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logText "Application error 'NullPointerException' in HR Portal login module."@en .

noria:EventRecord_VPN_Auth_Fail a noria:EventRecord ;
