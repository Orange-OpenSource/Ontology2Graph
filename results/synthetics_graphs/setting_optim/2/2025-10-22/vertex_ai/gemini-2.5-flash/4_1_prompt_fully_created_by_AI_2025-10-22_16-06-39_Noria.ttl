    rdfs:label "Web Server Responsive Post-Condition"@en ;
    rdfs:comment "Outcome: Web server is responding to HTTP requests normally."@en .

noria:ActionPreCondition_MaliciousIPDetected a noria:ActionPreCondition ;
    rdfs:label "Malicious IP Detected Pre-Condition"@en ;
    rdfs:comment "Condition: An IP address is identified as source of malicious traffic."@en .

noria:ActionPostCondition_TrafficBlocked a noria:ActionPostCondition ;
    rdfs:label "Traffic Blocked Post-Condition"@en ;
    rdfs:comment "Outcome: Traffic from the malicious IP address is successfully blocked."@en .

noria:ActionPreCondition_HighStorageLatency a noria:ActionPreCondition ;
    rdfs:label "High Storage Latency Pre-Condition"@en ;
    rdfs:comment "Condition: Monitoring system reports high I/O latency on storage array."@en .

noria:ActionPostCondition_LatencyCauseIdentified a noria:ActionPostCondition ;
