# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents and Organizations ---
foaf:Agent_IT_Ops_Team a foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

foaf:Agent_Network_Admin a foaf:Agent ;
    rdfs:label "Network Administration Team"@en ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Open a ticket for routine changes. Call for network outages."@en .

foaf:Agent_App_Dev_Team a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining core business applications."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> ;
    noria:agentInstructions "Use internal chat for quick queries, JIRA for bug reports."@en .

foaf:Agent_Security_Team a foaf:Agent ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Monitors and responds to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/alert_system> ;
    noria:agentInstructions "Automated alerts for critical events. Manual review for suspicious activities."@en .

foaf:Agent_DBA_Team a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Manages and optimizes all database systems."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri, on-call for critical"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing_system> ;
    noria:agentInstructions "Submit tickets for all database requests. Critical issues trigger automated pages."@en .

foaf:Agent_Cloud_Ops_Team a foaf:Agent ;
    rdfs:label "Cloud Operations Team"@en ;
    rdfs:comment "Manages cloud infrastructure and services."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/monitoring_dashboard> ;
    noria:agentInstructions "Monitor dashboards for performance issues. Use incident management system for outages."@en .

foaf:Agent_Customer_Support a foaf:Agent ;
    rdfs:label "Customer Support Team"@en ;
    rdfs:comment "First line of contact for customer issues."@en ;
    noria:agentWorkingHours "8:00-20:00 Mon-Sun"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Log all customer interactions. Escalate to L2 support as needed."@en .

foaf:Agent_HR_Team a foaf:Agent ;
    rdfs:label "Human Resources Department"@en ;
    rdfs:comment "Manages employee-related services."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Email for general inquiries. Use HR portal for specific requests."@en .

foaf:Agent_Finance_Team a foaf:Agent ;
    rdfs:label "Finance Department"@en ;
    rdfs:comment "Handles financial operations and reporting."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Email for all financial queries. Use ERP system for transactions."@en .

foaf:Agent_Marketing_Team a foaf:Agent ;
    rdfs:label "Marketing Department"@en ;
    rdfs:comment "Manages marketing campaigns and brand promotion."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> ;
    noria:agentInstructions "Internal chat for quick updates. Project management tool for campaign tracking."@en .

org:OrgUnit_IT_Infrastructure a org:OrganizationalUnit ;
    rdfs:label "IT Infrastructure Unit"@en ;
    rdfs:comment "Organizational unit responsible for core IT infrastructure."@en ;
    noria:elementManagedBy foaf:Agent_IT_Ops_Team .

org:OrgUnit_Network_Services a org:OrganizationalUnit ;
    rdfs:label "Network Services Unit"@en ;
    rdfs:comment "Organizational unit responsible for network services."@en ;
    noria:elementManagedBy foaf:Agent_Network_Admin .

org:OrgUnit_Application_Services a org:OrganizationalUnit ;
    rdfs:label "Application Services Unit"@en ;
    rdfs:comment "Organizational unit responsible for application development and support."@en ;
    noria:elementManagedBy foaf:Agent_App_Dev_Team .

org:OrgUnit_Security_Services a org:OrganizationalUnit ;
    rdfs:label "Security Services Unit"@en ;
    rdfs:comment "Organizational unit responsible for cybersecurity."@en ;
    noria:elementManagedBy foaf:Agent_Security_Team .

org:OrgUnit_Database_Services a org:OrganizationalUnit ;
    rdfs:label "Database Services Unit"@en ;
    rdfs:comment "Organizational unit responsible for database management."@en ;
    noria:elementManagedBy foaf:Agent_DBA_Team .

org:OrgUnit_Cloud_Services a org:OrganizationalUnit ;
    rdfs:label "Cloud Services Unit"@en ;
    rdfs:comment "Organizational unit responsible for cloud infrastructure."@en ;
    noria:elementManagedBy foaf:Agent_Cloud_Ops_Team .

org:OrgUnit_Customer_Care a org:OrganizationalUnit ;
    rdfs:label "Customer Care Unit"@en ;
    rdfs:comment "Organizational unit responsible for customer support."@en ;
    noria:elementManagedBy foaf:Agent_Customer_Support .

