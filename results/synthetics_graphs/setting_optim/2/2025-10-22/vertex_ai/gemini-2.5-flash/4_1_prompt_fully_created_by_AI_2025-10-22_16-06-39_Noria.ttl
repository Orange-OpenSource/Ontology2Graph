# --- Event Records ---
noria:EventRecord_WebSrv01_CPU_High a noria:EventRecord ;
    rdfs:label "WebSrv01 High CPU Alert"@en ;
    rdfs:comment "Alert: CPU utilization on Web Server 01 exceeded 90% for 5 minutes."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logText "CPU usage on websrv01.corp.example.com at 95%."@en .

noria:EventRecord_Router_Link_Down a noria:EventRecord ;
    rdfs:label "Edge Router Link Down"@en ;
