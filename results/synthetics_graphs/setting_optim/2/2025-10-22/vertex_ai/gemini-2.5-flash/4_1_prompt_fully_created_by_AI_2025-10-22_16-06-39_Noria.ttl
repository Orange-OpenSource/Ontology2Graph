    noria:logOriginatingManagedObject noria:Application_CI_CD_Pipeline ;
    noria:logOriginatingManagementSystem noria:AppModule_Monitoring_Prod ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logText "Build #1234 for 'CorporateWebsite' failed due to compilation errors."@en .

