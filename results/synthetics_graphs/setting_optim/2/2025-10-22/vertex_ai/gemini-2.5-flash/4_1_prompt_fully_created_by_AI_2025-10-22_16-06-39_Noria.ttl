    rdfs:label "Network Link Flap Pattern"@en ;
    rdfs:comment "Pattern indicating intermittent network link failures, often due to physical layer issues."@en .

noria:AnomalyPattern_DBDeadlock a noria:AnomalyPattern ;
    rdfs:label "Database Deadlock Pattern"@en ;
    rdfs:comment "Pattern indicating recurring database deadlocks, leading to application slowdowns."@en .

