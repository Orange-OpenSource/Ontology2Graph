# =============================================================================
# Network Links
# =============================================================================

noria:NetworkLink_ISP_Edge01 a noria:NetworkLink ;
    rdfs:label "ISP Uplink to Edge01"@en ;
    rdfs:comment "Primary internet uplink from ISP to Edge Router 01."@en ;
    noria:networkLinkId "NL-ISP-EDGE01-01" ;
    noria:networkLinkType "fiber-optic" ;
    noria:networkLinkInstallationDate "2021-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_Network_Team ;
    noria:networkLinkTerminationResource noria:Resource_Router_Edge01 ;
    noria:networkInterfaceConnects noria:NetworkInterface_Edge01_Gi0_0_0 .

noria:NetworkLink_Edge01_Core01 a noria:NetworkLink ;
