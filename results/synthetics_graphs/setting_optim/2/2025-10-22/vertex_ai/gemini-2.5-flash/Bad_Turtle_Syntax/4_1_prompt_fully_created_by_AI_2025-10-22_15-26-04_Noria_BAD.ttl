# =============================================================================
# Operation Plans and Anomaly Patterns
# =============================================================================

noria:OperationPlan_ISP_Failover a noria:OperationPlan ;
    rdfs:label "ISP Link Failover Procedure"@en ;
    rdfs:comment "Procedure to activate backup ISP link in case of primary link failure."@en ;
    skos:example "Steps include verifying primary link status, activating secondary link, verifying connectivity, and notifying stakeholders."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_PrimaryISPDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InternetRestored .

noria:ActionPreCondition_PrimaryISPDown a noria:ActionPreCondition ;
    rdfs:label "Primary ISP Link Down Pre-condition"@en ;
    rdfs:comment "Condition: Primary internet service provider link is detected as down."@en .

noria:ActionPostCondition_InternetRestored a noria:ActionPostCondition ;
    rdfs:label "Internet Access Restored Post-condition"@en ;
    rdfs:comment "Outcome: Internet access is fully restored and verified."@en .

noria:OperationPlan_AppRestart a noria:OperationPlan ;
    rdfs:label "Application Service Restart Procedure"@en ;
    rdfs:comment "Standard procedure for restarting a critical application service."@en ;
    skos:example "Steps include checking dependencies, gracefully stopping service, starting service, and verifying functionality."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_AppUnresponsive ;
    noria:operationPlanPostCondition noria:ActionPostCondition_AppRunning .

noria:ActionPreCondition_AppUnresponsive a noria:ActionPreCondition ;
    rdfs:label "Application Unresponsive Pre-condition"@en ;
    rdfs:comment "Condition: Application service is unresponsive or crashing."@en .

noria:ActionPostCondition_AppRunning a noria:ActionPostCondition ;
    rdfs:label "Application Service Running Post-condition"@en ;
    rdfs:comment "Outcome: Application service is running and responsive."@en .

noria:AnomalyPattern_HighCPU_DB a noria:AnomalyPattern ;
    rdfs:label "High CPU on Database Server Anomaly"@en ;
    rdfs:comment "Pattern indicating a potential database performance issue due to sustained high CPU usage."@en ;
    skos:example "Triggered when CPU > 90% for 5 minutes on DB servers, often correlated with slow query logs."@en .

noria:AnomalyPattern_NetworkOutage a noria:AnomalyPattern ;
    rdfs:label "Network Outage Anomaly"@en ;
    rdfs:comment "Pattern indicating a widespread network connectivity loss, often starting from an edge device."@en ;
    skos:example "Triggered by multiple interface down events on core/edge routers, impacting multiple services."@en .

# =============================================================================
# Connecting Operations to Tickets
# =============================================================================

noria:TroubleTicket_TT001 noria:troubleTicketCharacteristic noria:AnomalyPattern_NetworkOutage .
noria:TroubleTicket_TT003 noria:troubleTicketCharacteristic noria:AnomalyPattern_HighCPU_DB .

noria:TroubleTicketNote_TT001_Note1 noria:actionCorrelatedOperationPlan noria:OperationPlan_ISP_Failover .
noria:TroubleTicketNote_TT002_Note2 noria:actionCorrelatedOperationPlan noria:OperationPlan_AppRestart .

