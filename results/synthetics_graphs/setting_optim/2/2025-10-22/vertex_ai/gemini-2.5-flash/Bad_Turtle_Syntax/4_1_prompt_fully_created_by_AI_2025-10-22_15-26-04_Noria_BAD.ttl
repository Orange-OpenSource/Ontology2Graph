# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_IT_Ops_Team a foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for non-critical issues, phone for critical incidents."@en .

foaf:Agent_Network_Team a foaf:Agent ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri, on-call for emergencies"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Escalate network-related critical incidents directly to their hotline."@en .

foaf:Agent_App_Dev_Team a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining core business applications."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> ;
    noria:agentInstructions "Use internal chat for quick queries, ticketing system for bugs/features."@en .

foaf:Agent_Security_Team a foaf:Agent ;
    rdfs:label "Cyber Security Operations Center (CSOC)"@en ;
    rdfs:comment "Monitors and responds to security threats and incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Immediate notification for any suspected security breach."@en .

foaf:Agent_Database_Admin a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Manages and maintains all database systems."@en ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Submit requests for database changes or issues via the dedicated portal."@en .

foaf:Agent_Cloud_Ops_Team a foaf:Agent ;
    rdfs:label "Cloud Operations Team"@en ;
    rdfs:comment "Manages cloud infrastructure and services."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "For cloud-related incidents, use the cloud provider's support channel and inform this team."@en .

foaf:Agent_Customer_Support a foaf:Agent ;
    rdfs:label "Customer Support Center"@en ;
    rdfs:comment "First line of contact for customer issues."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Log all customer interactions and escalate as per procedure."@en .

foaf:Agent_Service_Owner_CRM a foaf:Agent ;
    rdfs:label "CRM Service Owner"@en ;
    rdfs:comment "Responsible for the overall health and strategy of the CRM application."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Informed of major incidents affecting CRM."@en .

foaf:Agent_Service_Owner_ERP a foaf:Agent ;
    rdfs:label "ERP Service Owner"@en ;
    rdfs:comment "Responsible for the overall health and strategy of the ERP application."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Informed of major incidents affecting ERP."@en .

foaf:Agent_Employee_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual employee, member of the IT Operations Team."@en ;
    foaf:mbox "john.doe@example.com" ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en .

foaf:Agent_Employee_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Individual employee, member of the Network Engineering Team."@en ;
    foaf:mbox "jane.smith@example.com" ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en .

noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "Corporate User Identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent_Employee_JohnDoe .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    rdfs:comment "Corporate User Identifier for Jane Smith."@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:Agent_Employee_JaneSmith .

org:OrgUnit_IT_Operations a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The main IT operations department."@en ;
    org:member foaf:Agent_IT_Ops_Team .

org:OrgUnit_Network_Engineering a org:OrganizationalUnit ;
    rdfs:label "Network Engineering Department"@en ;
    rdfs:comment "Department focused on network infrastructure."@en ;
    org:member foaf:Agent_Network_Team .

org:OrgUnit_App_Development a org:OrganizationalUnit ;
    rdfs:label "Application Development Department"@en ;
    rdfs:comment "Department responsible for software development."@en ;
    org:member foaf:Agent_App_Dev_Team .

org:OrgUnit_Security_Operations a org:OrganizationalUnit ;
    rdfs:label "Security Operations Department"@en ;
    rdfs:comment "Department handling cybersecurity."@en ;
    org:member foaf:Agent_Security_Team .

org:OrgUnit_Database_Management a org:OrganizationalUnit ;
    rdfs:label "Database Management Department"@en ;
    rdfs:comment "Department managing database systems."@en ;
    org:member foaf:Agent_Database_Admin .

org:OrgUnit_Cloud_Services a org:OrganizationalUnit ;
    rdfs:label "Cloud Services Department"@en ;
    rdfs:comment "Department managing cloud infrastructure."@en ;
    org:member foaf:Agent_Cloud_Ops_Team .

org:OrgUnit_Customer_Care a org:OrganizationalUnit ;
    rdfs:label "Customer Care Department"@en ;
    rdfs:comment "Department handling customer support."@en ;
    org:member foaf:Agent_Customer_Support .

