    noria:operationPlanPostCondition noria:ActionPostCondition_DiskSpaceNormal .

noria:ActionPreCondition_DiskSpaceLow a noria:ActionPreCondition ;
    rdfs:label "Low Disk Space Pre-condition"@en ;
    rdfs:comment "Condition: Filesystem usage exceeds a predefined threshold."@en .

noria:ActionPostCondition_DiskSpaceNormal a noria:ActionPostCondition ;
    rdfs:label "Normal Disk Space Post-condition"@en ;
    rdfs:comment "Outcome: Filesystem usage is within normal operating parameters."@en .

noria:TroubleTicket_TT006 noria:troubleTicketCharacteristic noria:AnomalyPattern_HighDiskUsage .
noria:AnomalyPattern_HighDiskUsage a noria:AnomalyPattern ;
    rdfs:label "High Disk Usage Anomaly"@en ;
    rdfs:comment "Pattern indicating a server is running out of disk space, potentially impacting services."@en ;
    skos:example "Triggered when disk usage > 90% for 15 minutes, often correlated with application errors."@en .

noria:TroubleTicketNote_TT006_Note1 noria:actionCorrelatedOperationPlan noria:OperationPlan_LogCleanup .

