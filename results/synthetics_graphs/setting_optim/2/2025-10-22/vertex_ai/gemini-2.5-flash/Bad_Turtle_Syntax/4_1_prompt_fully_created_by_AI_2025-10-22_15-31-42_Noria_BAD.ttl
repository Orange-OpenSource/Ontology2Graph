noria:Service_InternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "Provides internet access for all corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ; # Assuming this KOS exists
    seas:subSystemOf noria:Application_MonitoringPlatform ; # Example: Monitoring platform is part of the service delivery chain
    seas:subSystemOf noria:ApplicationModule_Monitoring_Prod ;
    seas:subSystemOf noria:Resource_CoreRouter_01, noria:Resource_EdgeSwitch_01 .

noria:Service_DatabaseConnectivity a noria:Service ;
    rdfs:label "Database Connectivity Service"@en ;
    rdfs:comment "Ensures reliable connectivity to corporate databases."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ; # Assuming this KOS exists
    seas:subSystemOf noria:Resource_DBServer_01, noria:Resource_AppServer_01 .

# =============================================================================
# Event Records
