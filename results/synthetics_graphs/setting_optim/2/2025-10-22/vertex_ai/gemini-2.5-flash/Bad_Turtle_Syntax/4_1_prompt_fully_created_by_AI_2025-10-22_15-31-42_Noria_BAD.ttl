noria:EventRecord_NetDown_001 a noria:EventRecord ;
    rdfs:label "Network Interface Down Alert"@en ;
    rdfs:comment "Alert: Interface ge-0/0/0 on cr01.lyn.example.com went down."@en ;
    noria:loggingTime "2024-04-10T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/0, changed state to down"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_DB_HighCPU_001 a noria:EventRecord ;
    rdfs:label "Database Server High CPU Alert"@en ;
    rdfs:comment "Alert: CPU utilization on db01.lyn.example.com exceeded 90%."@en ;
    noria:loggingTime "2024-04-10T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBServer_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "CPU utilization on db01.lyn.example.com is 95% for the last 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_AppLog_Error_001 a noria:EventRecord ;
    rdfs:label "Application Error Log"@en ;
    rdfs:comment "Error log from Core Banking System indicating a transaction failure."@en ;
    noria:loggingTime "2024-04-10T10:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:ApplicationModule_CBS_Prod ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "ERROR: Transaction failed for user 'customer123' - Database connection timeout."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_Security_LoginFail_001 a noria:EventRecord ;
    rdfs:label "Failed Login Attempt Alert"@en ;
    rdfs:comment "Multiple failed login attempts detected on web01.lyn.example.com."@en ;
    noria:loggingTime "2024-04-10T10:25:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_VM_Web_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "SSH login failed for user 'root' from IP 192.168.5.10 (5 attempts)."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_ConfigChange_CR01_001 a noria:EventRecord ;
    rdfs:label "Router Configuration Change"@en ;
    rdfs:comment "Configuration change applied to Core Router 01 by John Doe."@en ;
    noria:loggingTime "2024-04-09T15:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter_01 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "Configured from console by vty0 (10.0.0.100) - added new static route."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Cleared> . # Not an alarm, but a log entry.

