# =============================================================================
# Network Links
# =============================================================================

noria:NetworkLink_DC_Interconnect_01 a noria:NetworkLink ;
    rdfs:label "DC Interconnect Link 01"@en ;
    rdfs:comment "High-speed link between Core Router 01 and Core Router 02."@en ;
    noria:networkLinkId "NL-DC-INT-01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter_01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter_02 ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR01_GE0_0_0, noria:NetworkInterface_CR02_GE0_0_0 ;
    noria:networkLinkType "Fiber Optic"@en ;
    noria:networkLinkInstallationDate "2020-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:Team_NetworkOperations .

noria:NetworkLink_DC_Interconnect_02 a noria:NetworkLink ;
    rdfs:label "DC Interconnect Link 02"@en ;
    rdfs:comment "Redundant high-speed link between Core Router 01 and Core Router 02."@en ;
    noria:networkLinkId "NL-DC-INT-02" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter_01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter_02 ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR01_GE0_0_1, noria:NetworkInterface_CR02_GE0_0_1 ;
    noria:networkLinkType "Fiber Optic"@en ;
    noria:networkLinkInstallationDate "2020-01-15T11:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:Team_NetworkOperations .

noria:NetworkLink_HQ_DC_Uplink a noria:NetworkLink ;
    rdfs:label "HQ-DC Uplink"@en ;
    rdfs:comment "Uplink from Paris HQ Edge Switch to Lyon DC Core Router 01."@en ;
    noria:networkLinkId "NL-HQ-DC-01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_EdgeSwitch_01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter_01 ;
    noria:networkInterfaceConnects noria:NetworkInterface_ES01_GE0_0_0, noria:NetworkInterface_CR01_GE0_0_0 ; # Simplified, in reality it would be a specific interface on CR01
    noria:networkLinkType "MPLS VPN"@en ;
    noria:networkLinkInstallationDate "2021-03-01T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:Team_NetworkOperations .

noria:NetworkLink_DB_App_Link a noria:NetworkLink ;
    rdfs:label "Database-Application Link"@en ;
    rdfs:comment "Internal network link between Database Server 01 and Application Server 01."@en ;
    noria:networkLinkId "NL-DB-APP-01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DBServer_01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_AppServer_01 ;
    noria:networkInterfaceConnects noria:NetworkInterface_DB01_ETH0, noria:NetworkInterface_VMWeb01_ETH0 ; # Simplified, assuming direct link or through a switch
    noria:networkLinkType "Ethernet"@en ;
    noria:networkLinkInstallationDate "2020-05-20T12:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:Team_ServerAdmins .

