bot:Site_HQ_Paris a bot:Site ;
    rdfs:label "Headquarters Paris Site"@en ;
    rdfs:comment "Main corporate headquarters located in Paris."@en ;
    noria:siteId "PAR-HQ-01" ;
    noria:siteType "Office Building"@en ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

bot:Site_DC_Lyon a bot:Site ;
    rdfs:label "Lyon Data Center Site"@en ;
    rdfs:comment "Primary data center facility in Lyon."@en ;
    noria:siteId "LYN-DC-01" ;
    noria:siteType "Data Center"@en ;
    noria:sitePrincipalAddress "456 Avenue des Lumières"@en ;
    noria:sitePrincipalAddressCityName "Lyon"@en ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoom_A a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Lyon Data Center."@en ;
    bot:hasSpace noria:Locus_Rack_A1, noria:Locus_Rack_A2, noria:Locus_Rack_A3 ;
    bot:hasElement noria:Resource_CoreRouter_01, noria:Resource_DBServer_01 .

noria:Room_NetworkCloset_B a noria:Room ;
    rdfs:label "Network Closet B"@en ;
    rdfs:comment "Network equipment closet in Paris HQ."@en ;
    bot:hasSpace noria:Locus_Rack_B1 ;
    bot:hasElement noria:Resource_EdgeSwitch_01 .

noria:Locus_Rack_A1 a noria:Locus ;
    rdfs:label "Rack A1 in Server Room A"@en ;
    rdfs:comment "Location for critical servers in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en .

noria:Locus_Rack_A2 a noria:Locus ;
    rdfs:label "Rack A2 in Server Room A"@en ;
    rdfs:comment "Location for database servers in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "2"@en .

noria:Locus_Rack_A3 a noria:Locus ;
    rdfs:label "Rack A3 in Server Room A"@en ;
    rdfs:comment "Location for virtual host servers in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "3"@en .

noria:Locus_Rack_B1 a noria:Locus ;
    rdfs:label "Rack B1 in Network Closet B"@en ;
    rdfs:comment "Location for edge network equipment in Network Closet B."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "1"@en .

