# =============================================================================
# Procedural Elements (Operation Plans, Pre/Post Conditions)
# =============================================================================

noria:OperationPlan_RouterOSUpgrade a noria:OperationPlan ;
    rdfs:label "Standard Router OS Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading the operating system of core routers."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_BackupConfig, noria:ActionPreCondition_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:ActionPostCondition_OSVersionCheck, noria:ActionPostCondition_ConnectivityTest .

noria:OperationPlan_DBHardwareRefresh a noria:OperationPlan ;
    rdfs:label "Database Hardware Refresh Procedure"@en ;
    rdfs:comment "Procedure for replacing database server hardware with minimal downtime."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DBBackup, noria:ActionPreCondition_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DBServiceCheck, noria:ActionPostCondition_PerformanceValidation .

noria:ActionPreCondition_BackupConfig a noria:ActionPreCondition ;
    rdfs:label "Configuration Backup Completed"@en ;
    rdfs:comment "Ensure a full backup of the device configuration is completed and verified."@en .

noria:ActionPreCondition_MaintenanceWindow a noria:ActionPreCondition ;
    rdfs:label "Approved Maintenance Window"@en ;
    rdfs:comment "Verify that the change is scheduled within an approved maintenance window."@en .

noria:ActionPreCondition_DBBackup a noria:ActionPreCondition ;
    rdfs:label "Database Backup Completed"@en ;
    rdfs:comment "Ensure a full backup of the database is completed and verified."@en .

noria:ActionPostCondition_OSVersionCheck a noria:ActionPostCondition ;
    rdfs:label "OS Version Verified"@en ;
    rdfs:comment "Verify that the router is running the new OS version."@en .

noria:ActionPostCondition_ConnectivityTest a noria:ActionPostCondition ;
    rdfs:label "Network Connectivity Restored"@en ;
    rdfs:comment "Confirm full network connectivity for all affected services."@en .

noria:ActionPostCondition_DBServiceCheck a noria:ActionPostCondition ;
    rdfs:label "Database Service Operational"@en ;
    rdfs:comment "Verify that all database services are running and accessible."@en .

noria:ActionPostCondition_PerformanceValidation a noria:ActionPostCondition ;
    rdfs:label "Performance Metrics Validated"@en ;
    rdfs:comment "Validate that database performance metrics are within acceptable thresholds."@en .

# Link Change Requests to Operation Plans
noria:ChangeRequest_001 noria:actionCorrelatedOperationPlan noria:OperationPlan_RouterOSUpgrade .
noria:ChangeRequest_002 noria:actionCorrelatedOperationPlan noria:OperationPlan_DBHardwareRefresh .

