    skos:inScheme <Notification/Severity/PerceivedSeverity> .

# =============================================================================
# Agents (Teams and Individuals)
# =============================================================================

# Organizational Units (Teams)
org:Team_NetworkOperations a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing the core network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call hotline for critical issues, use ticketing system for standard requests."@en .

org:Team_ServerAdmins a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Server Administration Team"@en ;
    rdfs:comment "Team responsible for maintaining physical and virtual servers."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for non-urgent requests, open a P1 ticket for server outages."@en .

org:Team_AppSupport_CoreBanking a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Core Banking Application Support"@en ;
    rdfs:comment "Dedicated support team for the critical Core Banking application."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Immediate escalation for any Core Banking related incident."@en .

org:Team_SecurityOperations a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Report all suspicious activities via email, call for confirmed breaches."@en .

org:Team_DatabaseAdmins a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Use ticketing system for database requests."@en .

org:Team_CloudOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Cloud Operations Team"@en ;
    rdfs:comment "Team managing cloud infrastructure and services."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Critical cloud issues require immediate phone contact."@en .

org:Team_DevOps_Platform a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "DevOps Platform Team"@en ;
    rdfs:comment "Team responsible for the CI/CD pipelines and development platforms."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit issues via internal chat or ticketing system."@en .

