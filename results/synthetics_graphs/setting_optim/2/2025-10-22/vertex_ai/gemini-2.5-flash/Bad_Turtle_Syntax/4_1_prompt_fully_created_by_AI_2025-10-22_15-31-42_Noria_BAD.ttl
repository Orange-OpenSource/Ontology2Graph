    noria:documentExternalId "CR-2024-003" .

# =============================================================================
# Interconnections and Density
# =============================================================================

# Connect resources to applications
noria:Resource_DBServer_01 noria:resourceForApplication noria:Application_CoreBanking, noria:Application_CRM .
noria:Resource_AppServer_01 noria:resourceForApplication noria:Application_CRM, noria:Application_HR_Portal .
noria:Resource_VM_Web_01 noria:resourceForApplication noria:Application_CRM .
noria:Resource_VM_Web_02 noria:resourceForApplication noria:Application_CRM .
noria:Resource_CoreRouter_01 noria:resourceForApplication noria:Application_MonitoringPlatform .
noria:Resource_EdgeSwitch_01 noria:resourceForApplication noria:Application_MonitoringPlatform .
noria:Resource_Firewall_01 noria:resourceForApplication noria:Application_MonitoringPlatform .
noria:Resource_LoadBalancer_01 noria:resourceForApplication noria:Application_CRM .

# Connect application modules to resources (more specific than application)
noria:ApplicationModule_CBS_Prod seas:subSystemOf noria:Resource_DBServer_01, noria:Resource_AppServer_01 .
noria:ApplicationModule_CRM_Prod seas:subSystemOf noria:Resource_DBServer_01, noria:Resource_VM_Web_01, noria:Resource_VM_Web_02, noria:Resource_LoadBalancer_01 .
noria:ApplicationModule_Monitoring_Prod seas:subSystemOf noria:Resource_CoreRouter_01, noria:Resource_Firewall_01 .
noria:ApplicationModule_Email_Prod seas:subSystemOf noria:Resource_AppServer_01 . # Assuming email runs on an app server

# Connect agents to resources they manage
org:Team_NetworkOperations noria:agentManagesResource noria:Resource_CoreRouter_01, noria:Resource_CoreRouter_02, noria:Resource_EdgeSwitch_01, noria:NetworkLink_DC_Interconnect_01, noria:NetworkLink_HQ_DC_Uplink, noria:NetworkLink_FW_LB_Link .
org:Team_ServerAdmins noria:agentManagesResource noria:Resource_DBServer_01, noria:Resource_AppServer_01, noria:Resource_VirtualHost_01, noria:Resource_VM_Web_01, noria:Resource_VM_Web_02, noria:Resource_LoadBalancer_01, noria:NetworkLink_DB_App_Link, noria:NetworkLink_LB_WebVM_Link .
org:Team_DatabaseAdmins noria:agentManagesResource noria:Resource_DBServer_01 .
org:Team_SecurityOperations noria:agentManagesResource noria:Resource_Firewall_01 .

# Connect agents to applications/modules they support
org:Team_AppSupport_CoreBanking noria:agentManagesResource noria:Application_CoreBanking, noria:ApplicationModule_CBS_Prod .
org:Team_DevOps_Platform noria:agentManagesResource noria:Application_CRM, noria:ApplicationModule_CRM_Prod, noria:ApplicationModule_CBS_Dev .

# Example of document status history (simplified with direct EventRecord links)
noria:TroubleTicket_001 noria:documentStatusHistory noria:EventRecord_NetDown_001 .
noria:TroubleTicket_002 noria:documentStatusHistory noria:EventRecord_DB_HighCPU_001 .
noria:TroubleTicket_004 noria:documentStatusHistory noria:EventRecord_EmailQueue_001 .

# Example of alarm mitigation
noria:EventRecord_NetDown_001 noria:alarmMitigatedBy noria:TroubleTicketNote_001_02 . # The note describes the action that mitigated the alarm

# =============================================================================
# Generate more entities to reach token count
# =============================================================================

# Generate 50 more resources, 100 network interfaces, 50 network links, 20 applications, 40 application modules, 10 services, 100 event records, 50 trouble tickets, 20 change requests.

# Helper for generating unique URIs and labels
@prefix ex: <http://example.com/noria/data/> .

# More Resources (50 instances)
# Base: noria:Resource_CoreRouter_01 (1) + noria:Resource_CoreRouter_02 (1) + noria:Resource_EdgeSwitch_01 (1) + noria:Resource_DBServer_01 (1) + noria:Resource_AppServer_01 (1) + noria:Resource_VirtualHost_01 (1) + noria:Resource_VM_Web_01 (1) + noria:Resource_VM_Web_02 (1) + noria:Resource_Firewall_01 (1) + noria:Resource_LoadBalancer_01 (1) = 10 base resources
# Need 40 more.
@for $i from 1 to 40 do
ex:Resource_Generic_{$i} a noria:Resource ;
    rdfs:label "Generic Server {$i}"@en ;
    rdfs:comment "A generic server instance for various purposes."@en ;
    noria:resourceManagedBy org:Team_ServerAdmins ;
    noria:resourceLogisticId "GEN-SRV-{$i}" ;
    noria:resourceHostName "gen-srv{$i}.example.com" ;
    noria:resourceProductModel noria:ProductModel_Dell_PowerEdge_R740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "DELL-GEN-SN{$i}" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-01T08:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_A3 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.2.{$i}> ;
    noria:resourceForApplication noria:Application_HR_Portal .
@end

# More Network Interfaces (100 instances)
# Base: 7 interfaces. Need 93 more.
@for $i from 1 to 93 do
ex:NetworkInterface_Gen_{$i} a noria:NetworkInterface ;
    rdfs:label "gen-srv{$i}.example.com eth0"@en ;
    rdfs:comment "Ethernet interface for Generic Server {$i}."@en ;
    noria:networkInterfaceOf ex:Resource_Generic_{$i} ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .
@end

# More Network Links (50 instances)
# Base: 4 links. Need 46 more.
@for $i from 1 to 46 do
ex:NetworkLink_Gen_{$i} a noria:NetworkLink ;
    rdfs:label "Generic Link {$i}"@en ;
    rdfs:comment "A generic network link connecting two resources."@en ;
    noria:networkLinkId "NL-GEN-{$i}" ;
    noria:networkLinkTerminationResourceOrigin ex:Resource_Generic_{$i} ;
    noria:networkLinkTerminationResourceDestination ex:Resource_Generic_{$i+1} ; # Connects to the next generic resource
    noria:networkInterfaceConnects ex:NetworkInterface_Gen_{$i}, ex:NetworkInterface_Gen_{$i+1} ;
    noria:networkLinkType "Ethernet"@en ;
    noria:resourceManagedBy org:Team_NetworkOperations .
@end

# More Applications (20 instances)
# Base: 4 applications. Need 16 more.
@for $i from 1 to 16 do
ex:Application_BizApp_{$i} a noria:Application ;
    rdfs:label "Business Application {$i}"@en ;
    rdfs:comment "A standard business application."@en ;
    noria:applicationModelIdentifier "BIZ-APP-V1.{$i}" ;
    noria:applicationNumericalIdentifier 2000 + {$i} ;
    noria:applicationShortIdentifier "BIZAPP{$i}" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "Business Operations"@en ;
    noria:resourceManagedBy org:Team_DevOps_Platform .
@end

# More Application Modules (40 instances)
# Base: 4 modules. Need 36 more.
@for $i from 1 to 36 do
ex:ApplicationModule_BizApp_{$i}_Prod a noria:ApplicationModule ;
    rdfs:label "Business Application {$i} - Production"@en ;
    rdfs:comment "Production instance of Business Application {$i}."@en ;
    noria:applicationModuleOf ex:Application_BizApp_{$i} ;
    noria:applicationModuleName "BIZAPP{$i}_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleAdministrationTeam org:Team_DevOps_Platform ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Silver> ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .
@end

# More Services (10 instances)
# Base: 2 services. Need 8 more.
@for $i from 1 to 8 do
ex:Service_DataProcessing_{$i} a noria:Service ;
    rdfs:label "Data Processing Service {$i}"@en ;
    rdfs:comment "Service for processing various data streams."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf ex:Application_BizApp_{$i}, ex:ApplicationModule_BizApp_{$i}_Prod .
@end

# More Event Records (100 instances)
# Base: 5 event records. Need 95 more.
@for $i from 1 to 95 do
ex:EventRecord_Gen_{$i} a noria:EventRecord ;
    rdfs:label "Generic Event Record {$i}"@en ;
    rdfs:comment "A routine log entry or minor alert."@en ;
    noria:loggingTime "2024-04-10T12:00:00Z"^^xsd:dateTime + "PT{$i}M"^^xsd:duration ;
    noria:logOriginatingManagedObject ex:Resource_Generic_{$i % 40 + 1} ; # Cycle through generic resources
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "Log message for generic event {$i}."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .
@end

# More Trouble Tickets (50 instances)
# Base: 3 trouble tickets. Need 47 more.
@for $i from 1 to 47 do
ex:TroubleTicket_Gen_{$i} a noria:TroubleTicket ;
    rdfs:label "Generic Incident {$i}"@en ;
    rdfs:comment "A routine incident reported for a generic application."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Minor> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P3> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketTrigger ex:EventRecord_Gen_{$i} ;
    noria:troubleTicketSupervisionTool "ServiceNow"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ServerFailure> ;
    noria:troubleTicketCause "Minor configuration error."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/InternalIT> ;
    noria:troubleTicketDetectionDateTime "2024-04-10T12:00:00Z"^^xsd:dateTime + "PT{$i}M"^^xsd:duration ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Open> ;
    noria:troubleTicketRelatedParty org:Team_Helpdesk ;
    noria:troubleTicketRelatedService ex:Application_BizApp_{$i % 16 + 1} ;
    noria:documentExternalId "GEN-INC-{$i}" .
@end

# More Change Requests (20 instances)
# Base: 2 change requests. Need 18 more.
@for $i from 1 to 18 do
ex:ChangeRequest_Gen_{$i} a noria:ChangeRequest ;
    rdfs:label "Generic Change Request {$i}"@en ;
    rdfs:comment "A routine change request for system maintenance."@en ;
    dcterms:created "2024-04-01T09:00:00Z"^^xsd:dateTime + "PT{$i}H"^^xsd:duration ;
    noria:changeRequestPlannedStartTime "2024-04-20T00:00:00Z"^^xsd:dateTime + "PT{$i}H"^^xsd:duration ;
    noria:changeRequestPlannedEndTime "2024-04-20T01:00:00Z"^^xsd:dateTime + "PT{$i}H"^^xsd:duration ;
    noria:changeRequestCategory <kos/ChangeRequest/category/SoftwareUpgrade> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/PreventativeMaintenance> ;
    noria:changeRequestImpact ex:Resource_Generic_{$i % 40 + 1} ;
    noria:changeRequestOutageDuration "PT30M"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Pending> ;
    noria:changeRequestInitiatorParty foaf:Agent_JaneSmith ;
    noria:changeRequestPilotParty org:Team_ServerAdmins ;
    noria:documentExternalId "GEN-CR-{$i}" .
@end

