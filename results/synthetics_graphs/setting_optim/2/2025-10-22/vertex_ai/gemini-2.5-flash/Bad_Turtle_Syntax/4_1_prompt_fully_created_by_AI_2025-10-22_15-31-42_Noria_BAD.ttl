    noria:loggingTime "2024-04-10T11:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Firewall_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "Blocked TCP SYN from 203.0.113.42 to 192.0.2.10 on port 80."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

# More Trouble Tickets
noria:TroubleTicket_004 a noria:TroubleTicket ;
    rdfs:label "Email Service Degradation"@en ;
    rdfs:comment "Users reporting delays in sending/receiving emails."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
