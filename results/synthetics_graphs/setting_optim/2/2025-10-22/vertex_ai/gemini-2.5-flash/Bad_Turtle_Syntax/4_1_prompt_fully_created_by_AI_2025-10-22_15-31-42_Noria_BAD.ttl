    noria:troubleTicketSupervisionTool "Zabbix"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ServerFailure> ;
    noria:troubleTicketCause "Disk I/O bottleneck on email server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/InternalIT> ;
    noria:troubleTicketDetectionDateTime "2024-04-10T11:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-10T15:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty org:Team_ServerAdmins, org:Team_Helpdesk, foaf:Agent_Customer_A ;
    noria:troubleTicketRelatedService noria:Application_EmailService, noria:ApplicationModule_Email_Prod ;
    noria:documentExternalId "INC-2024-004" .

noria:TroubleTicket_005 a noria:TroubleTicket ;
    rdfs:label "Suspicious Network Activity"@en ;
    rdfs:comment "Investigation into blocked traffic by perimeter firewall."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Minor> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P3> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_FirewallBlock_001 ;
    noria:troubleTicketSupervisionTool "Splunk"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/NetworkOutage> ; # Can be security related, but for this example, using network outage
    noria:troubleTicketCause "Potential port scanning activity from external source."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ExternalVendor> ; # Assuming external threat
    noria:troubleTicketDetectionDateTime "2024-04-10T11:20:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Open> ;
    noria:troubleTicketRelatedParty org:Team_SecurityOperations, foaf:Agent_BobWhite ;
    noria:troubleTicketRelatedResource noria:Resource_Firewall_01 ;
    noria:documentExternalId "SEC-2024-005" .

# More Change Requests
noria:ChangeRequest_003 a noria:ChangeRequest ;
    rdfs:label "Firewall Rule Update"@en ;
    rdfs:comment "Update firewall rules to allow new application traffic."@en ;
    dcterms:created "2024-04-08T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-18T18:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-18T19:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/SoftwareUpgrade> ; # Using software upgrade for rule changes
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/PreventativeMaintenance> ; # Proactive change
    noria:changeRequestImpact noria:Resource_Firewall_01 ;
    noria:changeRequestOutageDuration "PT0H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty foaf:Agent_BobWhite ;
