    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

# More Event Records
noria:EventRecord_EmailQueue_001 a noria:EventRecord ;
    rdfs:label "Email Queue Alert"@en ;
    rdfs:comment "Email queue length exceeded threshold on EMS_PROD."@en ;
    noria:loggingTime "2024-04-10T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:ApplicationModule_Email_Prod ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "Email queue for 'outbound' is 1500, threshold 1000."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_FirewallBlock_001 a noria:EventRecord ;
