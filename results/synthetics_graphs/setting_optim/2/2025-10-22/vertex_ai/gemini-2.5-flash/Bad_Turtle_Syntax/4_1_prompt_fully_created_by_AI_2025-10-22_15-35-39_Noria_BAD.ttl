    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations" ;
    noria:applicationFunctionalSubDomain "Performance Monitoring" ;
    noria:resourceManagedBy foaf:Agent_SysAdminTeam ;
