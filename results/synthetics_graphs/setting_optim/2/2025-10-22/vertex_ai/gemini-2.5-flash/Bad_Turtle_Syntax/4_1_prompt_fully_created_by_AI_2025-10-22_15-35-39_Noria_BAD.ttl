# --- Event Records ---
noria:EventRecord_NetIntDown_001 a noria:EventRecord ;
    rdfs:label "Network Interface Down Alert"@en ;
    rdfs:comment "Alert: Interface cr-par01 Ethernet0/0 went down."@en ;
    noria:loggingTime "2023-10-26T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface Ethernet0/0, changed state to down"@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter_PAR01 ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_Platform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_DBHighCPU_001 a noria:EventRecord ;
    rdfs:label "Database High CPU Alert"@en ;
    rdfs:comment "Alert: Database Server 01 CPU utilization exceeded 90%."@en ;
    noria:loggingTime "2023-10-26T10:15:00Z"^^xsd:dateTime ;
    noria:logText "CPU_UTILIZATION_HIGH: db-srv01 CPU usage 95% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_DB_Srv_01 ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_Platform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_WebSrvRestart_001 a noria:EventRecord ;
    rdfs:label "Web Server Restart Log"@en ;
    rdfs:comment "Log: Web Server 01 restarted by Jane Smith."@en ;
    noria:loggingTime "2023-10-26T10:30:00Z"^^xsd:dateTime ;
    noria:logText "SYSTEM_REBOOT: web-srv01 initiated by user jane.smith"@en ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv_01 ;
    noria:logOriginatingAgent foaf:Agent_JaneSmith ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_Platform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord_FirewallBlock_001 a noria:EventRecord ;
    rdfs:label "Firewall Block Alert"@en ;
    rdfs:comment "Alert: Firewall blocked suspicious traffic from external IP."@en ;
    noria:loggingTime "2023-10-26T10:45:00Z"^^xsd:dateTime ;
    noria:logText "FW_BLOCK: Source IP 192.168.1.100 blocked for port 22 scan."@en ;
    noria:logOriginatingManagedObject noria:Resource_Firewall_PAR01 ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_Platform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_DNSFailure_001 a noria:EventRecord ;
    rdfs:label "DNS Service Failure Alert"@en ;
    rdfs:comment "Alert: Corporate DNS Service experiencing resolution failures."@en ;
    noria:loggingTime "2023-10-26T11:00:00Z"^^xsd:dateTime ;
    noria:logText "DNS_SERVICE_FAILURE: dns-srv01 unable to resolve external domains."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS_Srv_01 ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_Platform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_CR_PAR01_ConfigChange_001 a noria:EventRecord ;
    rdfs:label "Router Configuration Change Log"@en ;
    rdfs:comment "Log: Configuration change applied to cr-par01 by John Doe."@en ;
    noria:loggingTime "2023-10-26T11:15:00Z"^^xsd:dateTime ;
    noria:logText "CONFIG_CHANGE: Interface Ethernet0/0 shutdown by john.doe."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter_PAR01 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_Platform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord_VM_ERP_HighMem_001 a noria:EventRecord ;
    rdfs:label "ERP VM High Memory Usage Alert"@en ;
    rdfs:comment "Alert: ERP Application VM memory utilization exceeded 85%."@en ;
    noria:loggingTime "2023-10-26T11:30:00Z"^^xsd:dateTime ;
    noria:logText "MEMORY_UTILIZATION_HIGH: erp-app-vm memory usage 90%."@en ;
    noria:logOriginatingManagedObject noria:Resource_VM_ERP_App ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_Platform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

# --- Trouble Tickets ---
noria:TroubleTicket_0001 a noria:TroubleTicket ;
    rdfs:label "Critical Network Outage - Paris DC Uplink"@en ;
    rdfs:comment "The primary internet uplink for Paris Data Center is down, impacting all services."@en ;
    dcterms:identifier "TT-20231026-0001" ;
    dcterms:created "2023-10-26T10:10:00Z"^^xsd:dateTime ;
    dcterms:modified "2023-10-26T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/Immediate> ;
    noria:troubleTicketSupervisionTool "Monitoring Platform" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "ISP A fiber cut detected."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ExternalProvider> ;
    noria:troubleTicketDetectionDateTime "2023-10-26T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2023-10-26T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_NetOpsTeam, foaf:Agent_JohnDoe ;
    noria:troubleTicketRelatedService noria:Service_CustomerFacingWebPortal, noria:Service_InternalNetworkConnectivity ;
    noria:troubleTicketRelatedResource noria:Resource_CoreRouter_PAR01, noria:NetworkLink_ISP_PAR_Uplink ;
    noria:troubleTicketImpacts noria:Application_ERP_System, noria:Application_Monitoring_Platform, noria:Application_Corporate_DNS ;
    noria:troubleTicketTrigger noria:EventRecord_NetIntDown_001 .

noria:TroubleTicket_0002 a noria:TroubleTicket ;
    rdfs:label "ERP Database Performance Degradation"@en ;
    rdfs:comment "Users report slow response times for the ERP system, traced to high CPU on the database server."@en ;
