    noria:troubleTicketDetectionDateTime "2023-10-26T10:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2023-10-26T16:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_DBATeam, foaf:Agent_AppDevTeam ;
