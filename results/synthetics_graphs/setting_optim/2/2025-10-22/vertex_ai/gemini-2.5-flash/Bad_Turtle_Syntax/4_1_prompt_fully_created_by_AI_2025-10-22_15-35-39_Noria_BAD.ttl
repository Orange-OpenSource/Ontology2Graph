    noria:troubleTicketRelatedResource noria:Resource_DB_Srv_01 ;
    noria:troubleTicketImpacts noria:ApplicationModule_ERP_Prod ;
    noria:troubleTicketTrigger noria:EventRecord_DBHighCPU_001 .

