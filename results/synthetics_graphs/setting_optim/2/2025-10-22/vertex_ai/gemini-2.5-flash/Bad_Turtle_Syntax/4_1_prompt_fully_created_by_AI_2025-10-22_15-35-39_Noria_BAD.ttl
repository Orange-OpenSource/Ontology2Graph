# --- Procedural Elements (Operation Plans, Pre/Post Conditions) ---
noria:OperationPlan_RouterFirmwareUpgrade a noria:OperationPlan ;
    rdfs:label "Standard Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "A documented procedure for upgrading router firmware, including pre-checks and post-checks."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_NetworkStable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterOperational .

noria:ActionPreCondition_NetworkStable a noria:ActionPreCondition ;
    rdfs:label "Network Stable Pre-Condition"@en ;
    rdfs:comment "All critical network links are up and no major incidents are active."@en .

noria:ActionPostCondition_RouterOperational a noria:ActionPostCondition ;
    rdfs:label "Router Operational Post-Condition"@en ;
    rdfs:comment "Router is reachable, all interfaces are up, and routing protocols are converged."@en .

noria:OperationPlan_DBQueryOptimization a noria:OperationPlan ;
    rdfs:label "Database Query Optimization Procedure"@en ;
    rdfs:comment "Procedure for identifying and optimizing inefficient database queries."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_HighCPUDetected ;
    noria:operationPlanPostCondition noria:ActionPostCondition_CPUNormalized .

noria:ActionPreCondition_HighCPUDetected a noria:ActionPreCondition ;
    rdfs:label "High CPU Detected Pre-Condition"@en ;
    rdfs:comment "Database server CPU utilization is consistently above 80%."@en .

noria:ActionPostCondition_CPUNormalized a noria:ActionPostCondition ;
    rdfs:label "CPU Normalized Post-Condition"@en ;
    rdfs:comment "Database server CPU utilization is below 50% for at least 30 minutes."@en .

# --- Linking Operations to Change Requests ---
noria:ChangeRequest_0001 noria:actionCorrelatedOperationPlan noria:OperationPlan_RouterFirmwareUpgrade .
noria:TroubleTicket_0002 noria:actionCorrelatedOperationPlan noria:OperationPlan_DBQueryOptimization .

