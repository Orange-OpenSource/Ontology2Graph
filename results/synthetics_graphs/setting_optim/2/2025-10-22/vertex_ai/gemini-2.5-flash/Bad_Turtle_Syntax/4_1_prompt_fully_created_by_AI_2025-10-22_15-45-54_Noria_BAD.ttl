# =============================================================================
# Network Links
# =============================================================================

noria:NetworkLink_ISP_Uplink a noria:NetworkLink ;
    rdfs:label "ISP Uplink - Edge Router 01"@en ;
    rdfs:comment "Link from Edge Router 01 to Internet Service Provider."@en ;
    noria:networkLinkId "NL-ISP-001" ;
    noria:networkLinkType "fiber-optic" ;
    noria:networkLinkInstallationDate "2021-11-20T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_Router_Edge_01 ;
    noria:networkInterfaceConnects noria:NetworkInterface_EdgeRtr01_Gi0_0_0 ;
