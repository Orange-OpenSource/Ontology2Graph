# More Anomaly Patterns
noria:AnomalyPattern_Network_Latency a noria:AnomalyPattern ;
    rdfs:label "Network Latency Anomaly"@en ;
    rdfs:comment "Anomaly pattern indicating unusual network latency between critical components."@en ;
    skos:example "Ping latency > 100ms between web server and database for 5 minutes."@en .

noria:AnomalyPattern_Failed_Logins a noria:AnomalyPattern ;
    rdfs:label "Repeated Failed Logins Anomaly"@en ;
    rdfs:comment "Anomaly pattern indicating multiple failed login attempts from a single source."@en ;
    skos:example "5+ failed login attempts from same IP within 1 minute."@en .

# Connecting Anomaly Patterns to Event Records (as potential triggers)
noria:EventRecord_Security_Alert_001 folio:hasFailureMode noria:AnomalyPattern_Failed_Logins .
noria:EventRecord_CPU_High_001 folio:hasFailureMode noria:AnomalyPattern_High_CPU_Usage .
noria:EventRecord_Disk_Full_001 folio:hasFailureMode noria:AnomalyPattern_Disk_Full .

# Connecting Trouble Tickets to Operation Plans (as proposed repair actions)
noria:TroubleTicket_001 noria:troubleTicketCharacteristic noria:OperationPlan_Router_Restart . # Using characteristic as a proxy for proposed action
noria:TroubleTicket_002 noria:troubleTicketCharacteristic noria:OperationPlan_DB_Service_Restart .
noria:TroubleTicket_005 noria:troubleTicketCharacteristic noria:OperationPlan_Clear_Logs .

# Connecting Change Requests to Operation Plans (as specifications)
noria:ChangeRequest_001 noria:changeRequestSpecification noria:OperationPlan_Router_Restart . # Reusing for example
noria:ChangeRequest_003 noria:changeRequestSpecification noria:OperationPlan_Clear_Logs .

