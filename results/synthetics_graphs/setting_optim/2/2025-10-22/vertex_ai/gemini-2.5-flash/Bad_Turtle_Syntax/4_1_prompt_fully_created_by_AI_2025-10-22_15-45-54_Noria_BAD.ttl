# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_IT_Ops_Team a foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for non-critical issues, phone for critical incidents."@en .

foaf:Agent_Network_Team a foaf:Agent ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri, on-call for emergencies"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Escalate network-related critical incidents directly to their hotline."@en .

foaf:Agent_App_Dev_Team a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining core business applications."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> ;
    noria:agentInstructions "Use internal chat for quick queries, ticketing system for bugs/features."@en .

foaf:Agent_Security_Team a foaf:Agent ;
    rdfs:label "Cyber Security Operations Center (CSOC)"@en ;
    rdfs:comment "Monitors and responds to security threats and incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Immediate notification for any suspected security breach."@en .

foaf:Agent_Database_Admin a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Manages and maintains all database systems."@en ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Submit requests for database changes or issues via the dedicated portal."@en .

foaf:Agent_Cloud_Ops_Team a foaf:Agent ;
    rdfs:label "Cloud Operations Team"@en ;
    rdfs:comment "Manages cloud infrastructure and services."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/pager> ;
    noria:agentInstructions "Automated alerts for cloud resource issues, direct contact for critical outages."@en .

foaf:Agent_User_Support a foaf:Agent ;
    rdfs:label "User Support Helpdesk"@en ;
    rdfs:comment "First line of support for end-users."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "All user-reported issues should be logged here first."@en .

foaf:Agent_Customer_A a foaf:Agent ;
    rdfs:label "Customer A"@en ;
    rdfs:comment "External customer using services."@en .

foaf:Agent_Customer_B a foaf:Agent ;
    rdfs:label "Customer B"@en ;
    rdfs:comment "External customer using services."@en .

org:OrgUnit_IT_Ops a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The main department for IT operations."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Follow standard incident management procedures."@en .

org:OrgUnit_Network_Eng a org:OrganizationalUnit ;
    rdfs:label "Network Engineering Department"@en ;
    rdfs:comment "Department responsible for network architecture and engineering."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en .

org:OrgUnit_App_Dev a org:OrganizationalUnit ;
    rdfs:label "Application Development Department"@en ;
    rdfs:comment "Department overseeing application development."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en .

org:OrgUnit_CSOC a org:OrganizationalUnit ;
    rdfs:label "Cyber Security Operations Center"@en ;
    rdfs:comment "Department for cybersecurity monitoring and response."@en ;
    noria:agentWorkingHours "24/7"@en .

org:OrgUnit_DBA a org:OrganizationalUnit ;
    rdfs:label "Database Administration Department"@en ;
    rdfs:comment "Department for database management."@en ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"@en .

org:OrgUnit_Cloud_Ops a org:OrganizationalUnit ;
    rdfs:label "Cloud Operations Department"@en ;
    rdfs:comment "Department for cloud infrastructure management."@en ;
    noria:agentWorkingHours "24/7"@en .

org:OrgUnit_Helpdesk a org:OrganizationalUnit ;
    rdfs:label "IT Helpdesk"@en ;
    rdfs:comment "First-line support department for users."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en .

noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate User ID for John Doe, a member of the IT Operations Team."@en ;
    foaf:accountName "jdoe"@en ;
    foaf:holdsAccount foaf:Agent_IT_Ops_Team .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate User ID for Jane Smith, a member of the Network Engineering Team."@en ;
    foaf:accountName "jsmith"@en ;
    foaf:holdsAccount foaf:Agent_Network_Team .

# =============================================================================
# Locations
# =============================================================================

bot:Site_DataCenter_Paris a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75001"@en ;
    noria:sitePrincipalAddressCountry "FR"@en ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"@en .

bot:Site_Office_Lyon a bot:Site ;
    rdfs:label "Lyon Office Building"@en ;
    rdfs:comment "Regional office building in Lyon."@en ;
    noria:siteId "OFF-LYO-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès"@en ;
    noria:sitePrincipalAddressCityName "Lyon"@en ;
    noria:sitePrincipalAddressPostalCode "69007"@en ;
    noria:sitePrincipalAddressCountry "FR"@en ;
    noria:sitePrincipalAddressStreet "Avenue Jean Jaurès"@en .

noria:Room_ServerRoom_A a noria:Room ;
    rdfs:label "Server Room A - Paris DC"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace noria:Locus_Rack_A1 .

noria:Room_NetworkRoom_B a noria:Room ;
    rdfs:label "Network Room B - Paris DC"@en ;
    rdfs:comment "Dedicated network equipment room in Paris DC."@en ;
    bot:hasSpace noria:Locus_Rack_B5 .

noria:Locus_Rack_A1 a noria:Locus ;
    rdfs:label "Rack A1 - Server Room A"@en ;
    rdfs:comment "Location of servers in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en .

noria:Locus_Rack_B5 a noria:Locus ;
    rdfs:label "Rack B5 - Network Room B"@en ;
    rdfs:comment "Location of network devices in Network Room B."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "5"@en .

