# Network Links
# =============================================================================

noria:NetworkLink_WebSrv_01_to_AS_01 a noria:NetworkLink ;
    rdfs:label "Link WebSrv_01 to AS_01"@en ;
    rdfs:comment "Ethernet link between Web Server 01 and Access Switch 01."@en ;
    noria:networkLinkId "NL-WS01-AS01" ;
    noria:networkLinkTerminationResource noria:Resource_WebSrv_01, noria:Resource_Switch_Access_01 ;
    noria:networkLinkInstallationDate "2022-01-15T10:10:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:resourceManagedBy foaf:Agent_Network_Team .

