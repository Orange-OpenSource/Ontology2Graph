bot:Site_DataCenter_Paris a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"@en .

bot:Site_Office_Lyon a bot:Site ;
    rdfs:label "Lyon Office Building"@en ;
    rdfs:comment "Regional office building in Lyon."@en ;
    noria:siteId "OFF-LYO-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès"@en ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCityName "Lyon"@en ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressStreet "Avenue Jean Jaurès"@en .

noria:Room_ServerRoom_A1 a noria:Room ;
    rdfs:label "Server Room A1"@en ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace noria:Locus_Rack_A1_01 .

noria:Room_NetworkCloset_B2 a noria:Room ;
    rdfs:label "Network Closet B2"@en ;
    rdfs:comment "Network equipment closet in Lyon Office."@en ;
    bot:hasSpace noria:Locus_Rack_B2_01 .

noria:Locus_Rack_A1_01 a noria:Locus ;
    rdfs:label "Rack A1-01"@en ;
    rdfs:comment "First rack in Server Room A1."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "01" .

noria:Locus_Rack_B2_01 a noria:Locus ;
    rdfs:label "Rack B2-01"@en ;
    rdfs:comment "First rack in Network Closet B2."@en ;
    noria:locusLine "B2" ;
    noria:locusRow "01" .

