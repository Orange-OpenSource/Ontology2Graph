# =============================================================================
# Operation Plans
# =============================================================================

noria:OperationPlan_RouterFirmwareUpgrade a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router firmware."@en ;
    skos:example "Steps include backup configuration, upload image, verify checksum, reload, verify operation."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_RouterBackupComplete ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterOperational .

noria:OperationPlan_DatabaseCleanup a noria:OperationPlan ;
    rdfs:label "Database Disk Cleanup Procedure"@en ;
    rdfs:comment "Procedure to free up disk space on database servers."@en ;
    skos:example "Steps include identifying large files, archiving old logs, deleting temporary data."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DiskSpaceLow ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DiskSpaceRestored .

noria:OperationPlan_WebSrvScaleUp a noria:OperationPlan ;
    rdfs:label "Web Server Scale-Up Procedure"@en ;
    rdfs:comment "Procedure to add resources (CPU/RAM) to a web server or add new instances."@en ;
    skos:example "Steps include provisioning new VM, configuring load balancer, testing."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_HighCPULoad ;
    noria:operationPlanPostCondition noria:ActionPostCondition_CPULoadNormal .

# =============================================================================
# Action Pre/Post Conditions
# =============================================================================

noria:ActionPreCondition_RouterBackupComplete a noria:ActionPreCondition ;
    rdfs:label "Router Configuration Backup Complete"@en ;
    rdfs:comment "Ensures a recent backup of the router configuration is available before upgrade."@en .

noria:ActionPostCondition_RouterOperational a noria:ActionPostCondition ;
    rdfs:label "Router Operational After Upgrade"@en ;
    rdfs:comment "Verifies that the router is fully operational and routing traffic correctly after firmware upgrade."@en .

noria:ActionPreCondition_DiskSpaceLow a noria:ActionPreCondition ;
    rdfs:label "Disk Space Below Threshold"@en ;
    rdfs:comment "Condition where disk space on a critical system is below a safe operational threshold."@en .

noria:ActionPostCondition_DiskSpaceRestored a noria:ActionPostCondition ;
    rdfs:label "Disk Space Restored to Normal"@en ;
    rdfs:comment "Condition where disk space on a critical system has been brought back to a safe level."@en .

noria:ActionPreCondition_HighCPULoad a noria:ActionPreCondition ;
    rdfs:label "High CPU Load Detected"@en ;
    rdfs:comment "Condition where CPU utilization on a server exceeds a predefined high threshold."@en .

noria:ActionPostCondition_CPULoadNormal a noria:ActionPostCondition ;
    rdfs:label "CPU Load Normalized"@en ;
    rdfs:comment "Condition where CPU utilization on a server has returned to normal operating levels."@en .

# =============================================================================
# Anomaly Patterns
# =============================================================================

noria:AnomalyPattern_DDoSAttack a noria:AnomalyPattern ;
    rdfs:label "DDoS Attack Pattern"@en ;
    rdfs:comment "Pattern indicating a Distributed Denial of Service attack, characterized by high traffic and resource exhaustion."@en ;
    skos:example "Simultaneous high CPU on web servers, high network traffic on edge routers, and multiple firewall blocked attempts."@en .

noria:AnomalyPattern_DatabaseCorruption a noria:AnomalyPattern ;
    rdfs:label "Database Corruption Pattern"@en ;
    rdfs:comment "Pattern indicating potential database corruption, characterized by disk full alerts, application errors, and slow queries."@en ;
    skos:example "Critical disk space alert on DB server, application errors referencing database, and slow response times for database-dependent applications."@en .

# =============================================================================
# Connecting entities to demonstrate density and completeness
# =============================================================================

# Connect Trouble Tickets to Operation Plans (as potential solutions)
noria:TroubleTicket_TT_001 noria:troubleTicketCharacteristic noria:OperationPlan_WebSrvScaleUp . # This is a bit of a stretch for characteristic, but shows a link
noria:TroubleTicket_TT_002 noria:troubleTicketCharacteristic noria:OperationPlan_DatabaseCleanup .

# Connect Change Requests to Operation Plans
noria:ChangeRequest_CR_001 noria:actionCorrelatedOperationPlan noria:OperationPlan_RouterFirmwareUpgrade .

# Connect Event Records to Anomaly Patterns (as potential indicators)
noria:EventRecord_WebSrv_CPU_High folio:hasFailureMode noria:AnomalyPattern_DDoSAttack .
noria:EventRecord_Firewall_Blocked_Attempt folio:hasFailureMode noria:AnomalyPattern_DDoSAttack .
noria:EventRecord_DB_Srv_Disk_Full folio:hasFailureMode noria:AnomalyPattern_DatabaseCorruption .
noria:EventRecord_VM_App_Error folio:hasFailureMode noria:AnomalyPattern_DatabaseCorruption .

# Connect Agents to Resources they manage (beyond primary resourceManagedBy)
foaf:Agent_IT_Ops_Team noria:agentManagesResource noria:Resource_Switch_Access_01 .
foaf:Agent_Network_Team noria:agentManagesResource noria:Resource_Firewall_Edge_01 .
foaf:Agent_Security_Team noria:agentManagesResource noria:Resource_Router_Core_01 .

# Connect Application Modules to Resources they utilize
noria:ApplicationModule_CustomerPortal_Prod seas:subSystemOf noria:Resource_WebSrv_01 .
noria:ApplicationModule_CustomerPortal_Prod seas:subSystemOf noria:Resource_DB_Srv_01 .
noria:ApplicationModule_CustomerPortal_Prod seas:subSystemOf noria:Resource_VM_App_01 .
noria:ApplicationModule_CustomerPortal_Prod seas:subSystemOf noria:Resource_VM_App_02 .

# Connect Event Records to potential mitigation actions (ProcedureExecutionContainer)
# For simplicity, we'll link to a ChangeRequest as a container for actions
noria:EventRecord_DB_Srv_Disk_Full noria:alarmMitigatedBy noria:ChangeRequest_CR_003 . # Database cleanup might be part of a CR
noria:EventRecord_WebSrv_CPU_High noria:alarmMitigatedBy noria:ChangeRequest_CR_002 . # Scaling up resources is a change

# Document Status History (linking EventRecords to TroubleTickets/ChangeRequests)
noria:TroubleTicket_TT_001 noria:documentStatusHistory noria:EventRecord_WebSrv_CPU_High .
noria:TroubleTicket_TT_002 noria:documentStatusHistory noria:EventRecord_DB_Srv_Disk_Full .
noria:ChangeRequest_CR_001 noria:documentStatusHistory noria:EventRecord_Router_Interface_Down . # Example: interface down during CR execution

# Additional connections for density
noria:Resource_WebSrv_01 noria:virtualServerStatus <kos/Resource/OperationalState/up> .
noria:Resource_VM_App_01 noria:virtualServerStatus <kos/Resource/OperationalState/up> .
noria:Resource_VM_App_02 noria:virtualServerStatus <kos/Resource/OperationalState/up> .

noria:TroubleTicket_TT_001 noria:troubleTicketPartyIntervention foaf:Agent_John_Doe .
noria:TroubleTicket_TT_001 noria:troubleTicketPartyIntervention foaf:Agent_Eve_Blue .
noria:TroubleTicket_TT_002 noria:troubleTicketPartyIntervention foaf:Agent_Charlie_Green .

noria:ChangeRequest_CR_001 dcterms:contributor foaf:Agent_Network_Team .
noria:ChangeRequest_CR_002 dcterms:contributor foaf:Agent_App_Dev_Team .
noria:ChangeRequest_CR_003 dcterms:contributor foaf:Agent_Database_Admin .

# Example of a freeze item for a trouble ticket
