@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@base <https://w3id.org/noria/> .

# =============================================================================
# 1. Agents and Organizations
# =============================================================================

noria:Agent1 a foaf:Agent ;
    rdfs:label "Network Operations Center Team"@en, "Équipe du Centre d'Opérations Réseau"@fr ;
    rdfs:comment "Primary team responsible for monitoring and maintaining network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Contact via dedicated hotline for critical issues."@en .

noria:Agent2 a foaf:Agent ;
    rdfs:label "Application Support Team A"@en, "Équipe Support Application A"@fr ;
    rdfs:comment "Team responsible for the support of critical business applications."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Submit a ticket via the ITSM portal for all requests."@en .

noria:Agent3 a foaf:Agent ;
    rdfs:label "Jean Dupont"@en, "Jean Dupont"@fr ;
    rdfs:comment "Lead engineer for network infrastructure."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

noria:Agent4 a foaf:Agent ;
    rdfs:label "Marie Curie"@en, "Marie Curie"@fr ;
    rdfs:comment "Application architect for the CRM system."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> .

noria:Agent5 a foaf:Agent ;
    rdfs:label "Security Operations Center Team"@en, "Équipe du Centre d'Opérations de Sécurité"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/secure-chat> ;
    noria:agentInstructions "Escalate all detected threats immediately."@en .

noria:OrgUnit1 a org:OrganizationalUnit ;
    rdfs:label "IT Infrastructure Department"@en, "Département Infrastructure IT"@fr ;
    rdfs:comment "Department overseeing all IT infrastructure operations."@en ;
    org:hasMember noria:Agent3 ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en .

noria:OrgUnit2 a org:OrganizationalUnit ;
    rdfs:label "Business Applications Department"@en, "Département Applications Métier"@fr ;
    rdfs:comment "Department managing all business-critical applications."@en ;
    org:hasMember noria:Agent4 ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en .

noria:OrgUnit3 a org:OrganizationalUnit ;
    rdfs:label "Customer Service Department"@en, "Département Service Client"@fr ;
    rdfs:comment "First line support for customer inquiries and issues."@en ;
    noria:agentWorkingHours "8:00-20:00 Mon-Sat"@en .

noria:CUid1 a noria:CorporateUserIdentifier ;
    rdfs:label "jdupont_corp"@en ;
    rdfs:comment "Corporate User ID for Jean Dupont."@en ;
    foaf:accountName "jdupont" ;
    observable:accountLogin "jdupont" ;
    observable:accountIdentifier "jdupont_corp_id_12345" .

noria:CUid2 a noria:CorporateUserIdentifier ;
    rdfs:label "mcurie_corp"@en ;
    rdfs:comment "Corporate User ID for Marie Curie."@en ;
    foaf:accountName "mcurie" ;
    observable:accountLogin "mcurie" ;
    observable:accountIdentifier "mcurie_corp_id_67890" .

noria:Agent3 foaf:holdsAccount noria:CUid1 .
noria:Agent4 foaf:holdsAccount noria:CUid2 .

# =============================================================================
# 2. Locations
# =============================================================================

noria:Site1 a bot:Site ;
    rdfs:label "Main Data Center Paris"@en, "Centre de Données Principal Paris"@fr ;
    rdfs:comment "Primary data center facility located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Site2 a bot:Site ;
    rdfs:label "Regional Office Lyon"@en, "Bureau Régional Lyon"@fr ;
    rdfs:comment "Regional office building in Lyon."@en ;
    noria:siteId "RO-LYO-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddressStreet "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room1 a noria:Room ;
    rdfs:label "Server Room A01"@en, "Salle Serveurs A01"@fr ;
    rdfs:comment "Main server room within Data Center Paris."@en ;
    bot:hasSpace noria:Site1 .

noria:Room2 a noria:Room ;
    rdfs:label "Network Equipment Room B03"@en, "Salle Équipements Réseau B03"@fr ;
    rdfs:comment "Room dedicated to network devices in Data Center Paris."@en ;
    bot:hasSpace noria:Site1 .

noria:Room3 a noria:Room ;
    rdfs:label "Edge Node Room LYO-01"@en, "Salle Nœud Edge LYO-01"@fr ;
    rdfs:comment "Room for edge computing infrastructure in Lyon office."@en ;
    bot:hasSpace noria:Site2 .

noria:Locus1 a noria:Locus ;
    rdfs:label "Rack R01-U10"@en, "Baie R01-U10"@fr ;
    rdfs:comment "Location for server rack R01, unit 10."@en ;
    noria:locusLine "R01" ;
    noria:locusRow "U10" ;
    bot:containsZone noria:Room1 .

noria:Locus2 a noria:Locus ;
    rdfs:label "Rack N05-U01"@en, "Baie N05-U01"@fr ;
    rdfs:comment "Location for network device rack N05, unit 01."@en ;
    noria:locusLine "N05" ;
    noria:locusRow "U01" ;
    bot:containsZone noria:Room2 .

noria:Locus3 a noria:Locus ;
    rdfs:label "Rack E01-U05"@en, "Baie E01-U05"@fr ;
    rdfs:comment "Location for edge server rack E01, unit 05."@en ;
    noria:locusLine "E01" ;
    noria:locusRow "U05" ;
    bot:containsZone noria:Room3 .

# =============================================================================
# 3. Product Models
# =============================================================================

noria:ProductModel1 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy noria:OrgDell .

noria:ProductModel2 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Enterprise-class network switch."@en ;
    noria:productManufacturedBy noria:OrgCisco .

noria:ProductModel3 a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform software."@en .

noria:ProductModel4 a noria:ProductModel ;
    rdfs:label "Juniper MX204 Router"@en ;
    rdfs:comment "Compact, high-density universal routing platform."@en ;
    noria:productManufacturedBy noria:OrgJuniper .

noria:OrgDell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en .

noria:OrgCisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

noria:OrgJuniper a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "Manufacturer of networking products."@en .

# =============================================================================
# 4. Resources (IT Assets)
# =============================================================================

noria:Resource1 a noria:Resource ;
    rdfs:label "Web Server Prod-01"@en, "Serveur Web Prod-01"@fr ;
    rdfs:comment "Production web server hosting critical applications."@en ;
    noria:resourceHostName "webprod01.corp.example.com" ;
    noria:resourceLogisticId "ASSET-WEB-001" ;
    noria:resourceSerialNumber "SN-WEB-001-XYZ" ;
    noria:resourceProductModel noria:ProductModel1 ;
    noria:resourceType <kos/Resource/type/physical-server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent2 ;
    noria:locatedAtLocus noria:Locus1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

noria:Resource2 a noria:Resource ;
    rdfs:label "Core Router R01"@en, "Routeur Cœur R01"@fr ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceHostName "corerouter01.corp.example.com" ;
    noria:resourceLogisticId "ASSET-RTR-001" ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" ;
    noria:resourceProductModel noria:ProductModel4 ;
    noria:resourceType <kos/Resource/type/network-router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent1 ;
    noria:locatedAtLocus noria:Locus2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

noria:Resource3 a noria:Resource ;
    rdfs:label "Virtual Machine DB-01"@en, "Machine Virtuelle DB-01"@fr ;
    rdfs:comment "Virtual machine hosting the main database for CRM."@en ;
    noria:resourceHostName "dbvm01.corp.example.com" ;
    noria:resourceLogisticId "ASSET-VM-001" ;
    noria:resourceSerialNumber "SN-VM-001-DEF" ;
    noria:resourceProductModel noria:ProductModel3 ; # Hypervisor is the product model for a VM
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.20> ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Running> .

noria:Resource4 a noria:Resource ;
    rdfs:label "Edge Server LYO-01"@en, "Serveur Edge LYO-01"@fr ;
    rdfs:comment "Edge computing server in Lyon regional office."@en ;
    noria:resourceHostName "edgesrvlyo01.corp.example.com" ;
    noria:resourceLogisticId "ASSET-EDGE-001" ;
    noria:resourceSerialNumber "SN-EDGE-001-GHI" ;
    noria:resourceProductModel noria:ProductModel1 ;
    noria:resourceType <kos/Resource/type/physical-server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-02-10T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent1 ;
    noria:locatedAtLocus noria:Locus3 ;
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.1> .

noria:NetworkInterface1 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on Web Server Prod-01"@en ;
    rdfs:comment "Primary network interface for web traffic on Web Server Prod-01."@en ;
    noria:networkInterfaceOf noria:Resource1 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to core switch" .

noria:NetworkInterface2 a noria:NetworkInterface ;
    rdfs:label "TenGigabitEthernet0/0/0 on Core Router R01"@en ;
    rdfs:comment "High-speed uplink interface on Core Router R01."@en ;
    noria:networkInterfaceOf noria:Resource2 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to ISP backbone" ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetworkInterface3 a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on Virtual Machine DB-01"@en ;
    rdfs:comment "Virtual network interface for database access on VM DB-01."@en ;
    noria:networkInterfaceOf noria:Resource3 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceDescription "Database network access" .

noria:NetworkInterface4 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/0 on Edge Server LYO-01"@en ;
    rdfs:comment "Primary network interface for edge server in Lyon."@en ;
    noria:networkInterfaceOf noria:Resource4 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to regional network" .

noria:NetworkLink1 a noria:NetworkLink ;
    rdfs:label "DC-PAR-01 Internal Uplink"@en ;
    rdfs:comment "Internal network link connecting Web Server Prod-01 to the core network."@en ;
    noria:networkLinkId "NL-DC-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface1 ;
    noria:networkLinkTerminationResource noria:Resource1 ;
    noria:networkLinkTerminationResource noria:Resource2 . # Connects to Core Router

noria:NetworkLink2 a noria:NetworkLink ;
    rdfs:label "ISP Backbone Link"@en ;
    rdfs:comment "External link to the Internet Service Provider backbone."@en ;
    noria:networkLinkId "NL-ISP-001" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface2 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource2 ;
    noria:networkLinkTerminationResourceDestination <http://example.com/isp/router-a> .

noria:NetworkLink3 a noria:NetworkLink ;
    rdfs:label "Internal DB Link"@en ;
    rdfs:comment "Internal network link for database communication."@en ;
    noria:networkLinkId "NL-DB-001" ;
    noria:networkLinkType "Virtual Ethernet" ;
    noria:networkLinkInstallationDate "2022-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface3 ;
    noria:networkLinkTerminationResource noria:Resource3 .

noria:NetworkLink4 a noria:NetworkLink ;
    rdfs:label "Regional Uplink LYO-DC"@en ;
    rdfs:comment "Uplink from Lyon Edge Server to Main Data Center."@en ;
    noria:networkLinkId "NL-LYO-DC-001" ;
    noria:networkLinkType "MPLS VPN" ;
    noria:networkLinkInstallationDate "2023-02-10T11:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface4 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource4 ;
    noria:networkLinkTerminationResourceDestination noria:Resource2 . # Connects to Core Router

# =============================================================================
# 5. Applications and Services
# =============================================================================

noria:Application1 a noria:Application ;
    rdfs:label "Corporate CRM System"@en, "Système CRM d'Entreprise"@fr ;
    rdfs:comment "Customer Relationship Management system, critical for sales and support."@en ;
    noria:applicationModelIdentifier "CRM-PROD" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Sales and Support" .

noria:Application2 a noria:Application ;
    rdfs:label "Internal Monitoring Platform"@en, "Plateforme de Supervision Interne"@fr ;
    rdfs:comment "Platform for monitoring IT infrastructure and applications."@en ;
    noria:applicationModelIdentifier "MON-PLAT" ;
    noria:applicationNumericalIdentifier 2002 ;
    noria:applicationShortIdentifier "MON" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Monitoring and Alerting" .

noria:Application3 a noria:Application ;
    rdfs:label "Corporate DNS Service"@en, "Service DNS d'Entreprise"@fr ;
    rdfs:comment "Provides DNS resolution for all internal and external corporate services."@en ;
    noria:applicationModelIdentifier "DNS-CORP" ;
    noria:applicationNumericalIdentifier 3003 ;
    noria:applicationShortIdentifier "DNS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Domain Name Resolution" .

noria:ApplicationModule1 a noria:ApplicationModule ;
    rdfs:label "CRM Production Module"@en, "Module de Production CRM"@fr ;
    rdfs:comment "Production instance of the Corporate CRM System."@en ;
    noria:applicationModuleOf noria:Application1 ;
    noria:applicationModuleName "CRM_PROD_INSTANCE" ;
    noria:applicationModuleIdentifier "CRM-PROD-01" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam noria:OrgUnit2 ;
    noria:applicationModuleSupportTeam noria:Agent2 ;
    noria:applicationModuleSupportLeader noria:Agent4 ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

noria:ApplicationModule2 a noria:ApplicationModule ;
    rdfs:label "Monitoring Platform Backend"@en, "Backend Plateforme de Supervision"@fr ;
    rdfs:comment "Backend services for the Internal Monitoring Platform."@en ;
    noria:applicationModuleOf noria:Application2 ;
    noria:applicationModuleName "MON_PLAT_BACKEND" ;
    noria:applicationModuleIdentifier "MON-BACK-01" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam noria:OrgUnit1 ;
    noria:applicationModuleSupportTeam noria:Agent1 ;
    noria:applicationModuleSupportLeader noria:Agent3 ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-03-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled false .

noria:Service1 a noria:Service ;
    rdfs:label "Customer Facing Web Service"@en, "Service Web Client"@fr ;
    rdfs:comment "End-to-end service providing web access to customers, relying on CRM and web servers."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:ApplicationModule1 ; # Service composed of Application Modules
    seas:subSystemOf noria:Resource1 . # Service also directly uses resources

noria:Service2 a noria:Service ;
    rdfs:label "Internal Network Connectivity"@en, "Connectivité Réseau Interne"@fr ;
    rdfs:comment "Core network connectivity service for all internal applications."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:Resource2 ; # Service relies on Core Router
    seas:subSystemOf noria:NetworkLink1 . # And on internal links

noria:Resource1 noria:resourceForApplication noria:Application1 .
noria:Resource3 noria:resourceForApplication noria:Application1 .
noria:Resource2 noria:resourceForApplication noria:Application2 .
noria:Resource4 noria:resourceForApplication noria:Application2 .
noria:Resource2 noria:resourceForApplication noria:Application3 .

# =============================================================================
# 6. Dynamic Elements (Events, Tickets, Changes)
# =============================================================================

noria:EventRecord1 a noria:EventRecord ;
    rdfs:label "Web Server CPU High Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server Prod-01."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU usage on webprod01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application2 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    dcterms:type <kos/Notification/EventType/threshold-exceeded> .

noria:EventRecord2 a noria:EventRecord ;
    rdfs:label "Network Interface Down Alert"@en ;
    rdfs:comment "Alert indicating that a network interface on Core Router R01 went down."@en ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logText "Interface TenGigabitEthernet0/0/0 on corerouter01.corp.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingManagementSystem noria:Application2 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    dcterms:type <kos/Notification/EventType/stateChange> .

noria:EventRecord3 a noria:EventRecord ;
    rdfs:label "CRM Database Connection Error"@en ;
    rdfs:comment "Log entry indicating a connection error to the CRM database."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "Failed to connect to database 'CRM_DB' from application server."@en ;
    noria:logOriginatingManagedObject noria:ApplicationModule1 ;
    noria:logOriginatingManagementSystem noria:Application1 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> ;
    dcterms:type <kos/Notification/EventType/application-error> .

noria:EventRecord4 a noria:EventRecord ;
    rdfs:label "Successful Configuration Change"@en ;
    rdfs:comment "Log entry confirming a successful configuration change on Core Router R01."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logText "Configuration committed by jdupont from console."@en ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingAgent noria:Agent3 ;
    noria:logOriginatingManagementSystem noria:Application2 ;
    dcterms:type <kos/Notification/EventType/configuration-change> .

noria:TroubleTicket1 a noria:TroubleTicket ;
    rdfs:label "Critical Network Outage - DC-PAR-01"@en ;
    rdfs:comment "Major incident affecting core network connectivity in Paris Data Center."@en ;
    dcterms:identifier "TT-20240420-001" ;
    noria:documentExternalId "CUST-INC-98765" ;
    noria:documentHRef "https://itsm.example.com/ticket/TT-20240420-001" ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord2 ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Fiber cut on ISP backbone link."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
