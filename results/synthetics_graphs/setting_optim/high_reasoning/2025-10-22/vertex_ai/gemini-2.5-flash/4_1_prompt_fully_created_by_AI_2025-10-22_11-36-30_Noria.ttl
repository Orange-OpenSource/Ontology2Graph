    noria:changeRequestActualStartTime "2024-04-20T10:38:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-04-20T10:52:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Emergency> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/PreventativeMaintenance> ; # Reroute is a preventative action for service impact
    noria:changeRequestOutageDuration "PT10M"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Implemented> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/NetworkRerouteProcedure> ;
    noria:changeRequestInitiatorParty noria:Agent1 ;
    noria:changeRequestPilotParty noria:Agent3 ;
    noria:changeRequestActorParty noria:Agent3 ;
    noria:changeRequestIsRegulated true ;
    noria:changeRequestImpact noria:NetworkLink2 ;
    noria:changeRequestImpact noria:Service2 .

