noria:ChangeRequest1 a noria:ChangeRequest ;
    rdfs:label "Emergency Traffic Reroute - DC-PAR-01"@en ;
    rdfs:comment "Emergency change to reroute network traffic due to core link failure."@en ;
    dcterms:identifier "CR-20240420-001" ;
    noria:documentExternalId "EMERG-CR-001" ;
    noria:documentHRef "https://itsm.example.com/change/CR-20240420-001" ;
    noria:changeRequestPlannedStartTime "2024-04-20T10:35:00Z"^^xsd:dateTime ;
