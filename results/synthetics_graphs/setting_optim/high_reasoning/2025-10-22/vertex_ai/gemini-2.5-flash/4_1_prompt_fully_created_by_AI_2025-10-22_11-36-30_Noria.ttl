    rdfs:comment "Report detailing CRM database performance metrics."@en ;
    dcterms:identifier "DOC-DB-PERF-01" ;
    dcterms:format "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" ;
    dcterms:isPartOf noria:TroubleTicket2 ;
    dcterms:isPartOf noria:ChangeRequest2 .

noria:TroubleTicket1 noria:documentStatusHistory noria:EventRecord2 . # Initial trigger
noria:TroubleTicket1 noria:documentStatusHistory noria:EventRecord4 . # Configuration change related to resolution
noria:ChangeRequest1 noria:documentStatusHistory noria:EventRecord4 . # Event confirming the change

noria:EventRecord2 noria:alarmMitigatedBy noria:ChangeRequest1 . # The change request mitigated the alarm

# =============================================================================
# 7. Procedural Elements
# =============================================================================

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "Emergency Network Reroute Procedure"@en ;
    rdfs:comment "Standard operating procedure for emergency network traffic rerouting."@en ;
    skos:example "Steps to follow when a critical network link fails and requires immediate rerouting."@en ;
    pep:hasStep <http://example.com/procedure/reroute-step1> ;
    pep:hasStep <http://example.com/procedure/reroute-step2> .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "CRM Database Optimization Procedure"@en ;
    rdfs:comment "Procedure for optimizing CRM database performance during maintenance windows."@en ;
    skos:example "Detailed steps for index rebuilds, statistics updates, and query optimization."@en ;
    pep:hasStep <http://example.com/procedure/db-opt-step1> ;
    pep:hasStep <http://example.com/procedure/db-opt-step2> .

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "Critical Link Failure Detected"@en ;
    rdfs:comment "Pre-condition: A critical network link is detected as being down or severely degraded."@en ;
    skos:example "Monitoring system reports link status 'down' and high packet loss."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "Traffic Rerouted and Service Restored"@en ;
    rdfs:comment "Post-condition: Network traffic is successfully rerouted, and affected services are restored."@en ;
    skos:example "Monitoring system reports traffic flowing on backup link, and application health checks are green."@en .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Database Performance Degradation Observed"@en ;
    rdfs:comment "Pre-condition: CRM database performance metrics show degradation (e.g., high query latency)."@en ;
    skos:example "APM tool alerts on average query response time exceeding threshold."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Database Performance Improved"@en ;
    rdfs:comment "Post-condition: CRM database performance metrics return to normal levels after optimization."@en ;
    skos:example "APM tool confirms average query response time is within acceptable limits."@en .

noria:OperationPlan1 noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:OperationPlan2 noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

noria:ChangeRequest1 noria:actionCorrelatedOperationPlan noria:OperationPlan1 .
noria:ChangeRequest2 noria:actionCorrelatedOperationPlan noria:OperationPlan2 .

noria:AnomalyPattern1 a noria:AnomalyPattern ;
    rdfs:label "Network Congestion Pattern"@en ;
    rdfs:comment "Pattern indicating network congestion: high latency, packet loss, and interface buffer drops."@en ;
    skos:example "Correlation of multiple EventRecords showing these symptoms on a specific network segment."@en .

noria:AnomalyPattern2 a noria:AnomalyPattern ;
    rdfs:label "Database Deadlock Pattern"@en ;
    rdfs:comment "Pattern indicating database deadlocks: repeated transaction failures, high CPU on DB server, and specific error logs."@en ;
    skos:example "Correlation of EventRecords from application and database logs showing deadlock errors."@en .

noria:TroubleTicket1 dcterms:relation noria:AnomalyPattern1 . # TroubleTicket is related to an anomaly pattern
noria:TroubleTicket2 dcterms:relation noria:AnomalyPattern2 .

# =============================================================================
# Additional Interconnections for Density
# =============================================================================

noria:Agent1 noria:agentManagesResource noria:Resource2 .
noria:Agent1 noria:agentManagesResource noria:Resource4 .
noria:Agent2 noria:agentManagesResource noria:Resource1 .
noria:Agent2 noria:agentManagesResource noria:Resource3 .

noria:Resource1 noria:clusterController noria:Resource3 . # Example: Resource1 might be a master node for Resource3 (VM)

noria:OrgUnit1 org:hasMember noria:Agent1 .
noria:OrgUnit2 org:hasMember noria:Agent2 .

noria:ApplicationModule1 noria:applicationModuleAdministrationTeam noria:OrgUnit2 .
noria:ApplicationModule2 noria:applicationModuleAdministrationTeam noria:OrgUnit1 .

noria:ApplicationModule1 noria:applicationModuleSupportGroup noria:OrgUnit3 . # Customer service as L1 support

noria:ApplicationModule1 noria:applicationModuleHotlineGroup noria:Agent2 . # Specific team for hotline

noria:TroubleTicket1 noria:troubleTicketPartyIntervention noria:Agent1 .
noria:TroubleTicket1 noria:troubleTicketPartyIntervention noria:Agent3 .
noria:TroubleTicket2 noria:troubleTicketPartyIntervention noria:Agent2 .
noria:TroubleTicket2 noria:troubleTicketPartyIntervention noria:Agent4 .

noria:EventRecord1 noria:alarmProposedRepairAction noria:OperationPlan2 . # Suggest DB optimization for high CPU on web server (indirectly related)
noria:EventRecord2 noria:alarmProposedRepairAction noria:OperationPlan1 . # Suggest network reroute for interface down

noria:EventRecord1 noria:alarmMonitoredAttribute <http://example.com/metric/cpu-usage> .
noria:EventRecord2 noria:alarmMonitoredAttribute <http://example.com/metric/interface-status> .

