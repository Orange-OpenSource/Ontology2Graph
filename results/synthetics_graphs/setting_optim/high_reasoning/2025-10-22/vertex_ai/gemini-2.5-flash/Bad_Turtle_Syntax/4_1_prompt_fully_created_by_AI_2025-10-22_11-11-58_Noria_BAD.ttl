    rdfs:label "Main Data Center Paris"@en ;
    rdfs:comment "Primary data center location."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    wgs84_pos:lat "48.867"^^xsd:float ;
    wgs84_pos:long "2.333"^^xsd:float .

bot:Site_RO_Lyon a bot:Site ;
    rdfs:label "Regional Office Lyon"@en ;
    rdfs:comment "Regional office in Lyon."@en ;
    noria:siteId "RO-LYO-01"^^xsd:string ;
    noria:siteType "office building"^^xsd:string ;
    noria:sitePrincipalAddressStreet "45 Avenue Jean Jaurès"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Lyon"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "69007"^^xsd:string ;
