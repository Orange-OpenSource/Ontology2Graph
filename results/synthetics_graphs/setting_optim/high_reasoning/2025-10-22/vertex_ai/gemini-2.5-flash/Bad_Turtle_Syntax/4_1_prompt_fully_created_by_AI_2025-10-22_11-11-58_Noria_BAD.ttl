# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_DNS_CPU_Spike a noria:EventRecord ;
    rdfs:label "DNS Server CPU Spike Alert"@en ;
    rdfs:comment "Alert: High CPU utilization detected on DNS Server 01."@en ;
    dcterms:identifier "EVT-20240423-001-CPU"^^xsd:string ;
    noria:loggingTime "2024-04-23T08:50:00Z"^^xsd:dateTime ;
    noria:logText "CPU usage on dns01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNSServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:troubleTicketTrigger noria:TroubleTicket_DNSOutage001 .

noria:EventRecord_CR01_InterfaceDown a noria:EventRecord ;
    rdfs:label "Core Router Interface Down Alert"@en ;
    rdfs:comment "Alert: GigabitEthernet 0/0/1 on Core Router 01 went down."@en ;
    dcterms:identifier "EVT-20240423-002-IFDOWN"^^xsd:string ;
    noria:loggingTime "2024-04-23T08:54:00Z"^^xsd:dateTime ;
    noria:logText "Interface Gi0/0/1 on cr01.dc1.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:troubleTicketTrigger noria:TroubleTicket_DNSOutage001 . # This event could be the root cause for the DNS outage.

noria:EventRecord_WebServer_HighLoad a noria:EventRecord ;
    rdfs:label "Web Server High Load Alert"@en ;
    rdfs:comment "Alert: High load average detected on E-commerce Web Server 03."@en ;
    dcterms:identifier "EVT-20240423-003-LOAD"^^xsd:string ;
    noria:loggingTime "2024-04-23T11:10:00Z"^^xsd:dateTime ;
    noria:logText "Load average on web03.ecommerce.example.com is 15.0 (threshold 10.0)."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebServer03 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:troubleTicketTrigger noria:TroubleTicket_EcommercePerf002 .

noria:EventRecord_CR01_ConfigChange a noria:EventRecord ;
    rdfs:label "Core Router Configuration Change Log"@en ;
    rdfs:comment "Log: Configuration change applied to Core Router 01."@en ;
    dcterms:identifier "EVT-20240501-001-CONF"^^xsd:string ;
    noria:loggingTime "2024-05-01T02:30:00Z"^^xsd:dateTime ;
    noria:logText "Configuration updated by jdoe from console."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:documentStatusHistory noria:ChangeRequest_RouterOSUpgrade001 .

noria:EventRecord_FW01_RuleUpdate a noria:EventRecord ;
    rdfs:label "Firewall Rule Update Log"@en ;
    rdfs:comment "Log: Firewall rules updated on Perimeter Firewall 01."@en ;
    dcterms:identifier "EVT-20240425-002-FW"^^xsd:string ;
    noria:loggingTime "2024-04-25T22:15:00Z"^^xsd:dateTime ;
    noria:logText "New payment gateway rules applied to fw01.perimeter.example.com."@en ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingAgent foaf:Agent_SecurityTeam ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:documentStatusHistory noria:ChangeRequest_FirewallRuleUpdate002 .

# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan_DNS_Restart a noria:OperationPlan ;
    rdfs:label "DNS Server Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a corporate DNS server."@en ;
    skos:example "Steps include checking network, stopping service, starting service, verifying resolution."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSUnreachable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSReachable .

noria:ActionPreCondition_DNSUnreachable a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unreachable Pre-condition"@en ;
    rdfs:comment "Condition: DNS service is not responding to queries or server is unreachable."@en ;
    skos:example "Ping to DNS server fails, nslookup queries fail."@en .

noria:ActionPostCondition_DNSReachable a noria:ActionPostCondition ;
    rdfs:label "DNS Service Reachable Post-condition"@en ;
    rdfs:comment "Expected outcome: DNS service is responding to queries and server is reachable."@en ;
    skos:example "Ping to DNS server succeeds, nslookup queries succeed."@en .

noria:OperationPlan_NetworkTroubleshoot a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Guide"@en ;
    rdfs:comment "Guide for diagnosing and resolving issues with network interfaces."@en ;
    skos:example "Steps include checking cable, interface status, logs, and restarting interface."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp .

noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Pre-condition"@en ;
    rdfs:comment "Condition: A network interface is reported as administratively or operationally down."@en ;
    skos:example "Monitoring system reports interface down, 'show interface status' command shows down."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up Post-condition"@en ;
    rdfs:comment "Expected outcome: The network interface is operational and administratively up."@en ;
    skos:example "Monitoring system reports interface up, 'show interface status' command shows up."@en .

# =============================================================================
# Additional Connections and Density
# =============================================================================

# Connect agents to resources they manage (inverse of resourceManagedBy)
foaf:Agent_ITOpsTeam noria:agentManagesResource noria:Resource_DNSServer01, noria:Resource_VMHost01 .
foaf:Agent_NetworkOpsTeam noria:agentManagesResource noria:Resource_CoreRouter01, noria:NetworkLink_CR01_FW01 .
foaf:Agent_AppSupportTeam noria:agentManagesResource noria:Resource_WebServer03 .
foaf:Agent_SecurityTeam noria:agentManagesResource noria:Resource_Firewall01 .

# Connect applications to resources (resourceForApplication)
noria:Resource_DNSServer01 noria:resourceForApplication noria:Application_CorporateDNS .
noria:Resource_WebServer03 noria:resourceForApplication noria:Application_EcommercePlatform .
noria:Resource_Firewall01 noria:resourceForApplication noria:Application_MonitoringSystem . # Firewall might be monitored by the monitoring system

# Connect application modules to resources (implicitly via resourceForApplication on resources)
# For example, WebServer03 is for E-commerce Platform, and E-commerce Frontend is a module of that platform.
# We can explicitly state that a resource supports a module if it's specific enough.
noria:Resource_WebServer03 noria:resourceForApplication noria:ApplicationModule_EcommerceFrontend .

# Connect TroubleTickets to EventRecords that triggered them
noria:TroubleTicket_DNSOutage001 noria:troubleTicketTrigger noria:EventRecord_DNS_CPU_Spike, noria:EventRecord_CR01_InterfaceDown .
noria:TroubleTicket_EcommercePerf002 noria:troubleTicketTrigger noria:EventRecord_WebServer_HighLoad .

# Connect ChangeRequests to EventRecords that log their execution
noria:ChangeRequest_RouterOSUpgrade001 noria:documentStatusHistory noria:EventRecord_CR01_ConfigChange .
noria:ChangeRequest_FirewallRuleUpdate002 noria:documentStatusHistory noria:EventRecord_FW01_RuleUpdate .

# Connect EventRecords to the procedure that mitigated the alarm (if applicable)
# For example, the DNS outage was mitigated by actions related to the DNS Server Restart Procedure.
# We can link the resolution note to the procedure execution container.
noria:TroubleTicketNote_DNSRes1 noria:troubleTicketNoteCorrelatedExecution noria:TroubleTicket_DNSOutage001 . # The TT itself acts as a ProcedureExecutionContainer

# Example of a DocumentAttachment
noria:DocumentAttachment_DNSLog a noria:DocumentAttachment ;
    rdfs:label "DNS Server Log Excerpt"@en ;
    rdfs:comment "Excerpt from DNS server logs during the outage."@en ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage001 ;
    dcterms:format "text/plain"^^xsd:string ;
    dcterms:description "Relevant log entries showing service failure and recovery."@en .

noria:DocumentAttachment_CRPlan a noria:DocumentAttachment ;
    rdfs:label "Core Router Upgrade Plan"@en ;
    rdfs:comment "Detailed plan for the Core Router OS upgrade."@en ;
    dcterms:isPartOf noria:ChangeRequest_RouterOSUpgrade001 ;
    dcterms:format "application/pdf"^^xsd:string ;
    dcterms:description "PDF document outlining steps, rollback plan, and impact assessment."@en .

# Further enrich resources with observables
noria:Resource_DNSServer01 noria:virtualServerStatus <kos/Resource/OperationalState/Up> . # Assuming DNS server is a virtual server for this property

noria:NetworkInterface_CR01_Gi0_0_1 noria:networkInterfaceLaserTxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int .

noria:NetworkInterface_CR01_Gi0_0_2 noria:networkInterfaceLaserTxOpticalPower "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-4"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-1"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-9"^^xsd:int .

# Connect a service to its underlying application modules
noria:Service_CustomerInternetAccess seas:subSystemOf noria:ApplicationModule_EcommerceFrontend .
noria:Service_InternalBusinessServices seas:subSystemOf noria:Application_CorporateDNS .

# Connect a TroubleTicket to a specific OperationPlan that might be used for resolution
noria:TroubleTicket_DNSOutage001 noria:troubleTicketCharacteristic noria:OperationPlan_DNS_Restart . # Using characteristic to link to a potential plan

# Connect a ChangeRequest to a specific OperationPlan that describes the change
noria:ChangeRequest_RouterOSUpgrade001 noria:changeRequestSpecification noria:OperationPlan_NetworkTroubleshoot . # Using specification to link to a relevant plan

# Example of a CorporateUserIdentifier being used by an agent
foaf:Agent_JohnDoe foaf:holdsAccount noria:CUid_JohnDoe .
foaf:Agent_JaneSmith foaf:holdsAccount noria:CUid_JaneSmith .

# Example of an agent being a leader for an application module
noria:ApplicationModule_EcommerceFrontend noria:applicationModuleAdministrationLeader foaf:Agent_JaneSmith .
noria:ApplicationModule_EcommerceBackend noria:applicationModuleSupportLeader foaf:Agent_JaneSmith .

# Example of a hotline group for an application module
noria:ApplicationModule_EcommerceFrontend noria:applicationModuleHotlineGroup foaf:Agent_AppSupportTeam .

# Example of a resource being a cluster controller for another resource
noria:Resource_VMHost01 noria:clusterController noria:Resource_DNSServer01 . # Hypothetically, VMHost01 controls the VM for DNS01

# Example of a TroubleTicket having a problem category and responsibility
<kos/TroubleTicket/trouble-category/NetworkFailure> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Network Failure"@en ;
    rdfs:comment "Category for network-related issues."@en .

<kos/TroubleTicket/problemResponsibility/NetworkTeam> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Network Team Responsibility"@en ;
    rdfs:comment "Responsibility lies with the Network Operations Team."@en .

noria:TroubleTicket_DNSOutage001 noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/NetworkFailure> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/NetworkFailure> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/NetworkTeam> .

# Example of a TroubleTicket with urgency and supervision tool
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Requires immediate action."@en .

noria:TroubleTicket_DNSOutage001 noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"^^xsd:string .

# Example of a ChangeRequest with a specification
<kos/ChangeRequest/specification/StandardOSUpgrade> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:label "Standard OS Upgrade Procedure"@en ;
    rdfs:comment "A predefined procedure for operating system upgrades."@en .

noria:ChangeRequest_RouterOSUpgrade001 noria:changeRequestSpecification <kos/ChangeRequest/specification/StandardOSUpgrade> .

# Example of a ChangeRequest with actual start/end times
noria:ChangeRequest_RouterOSUpgrade001 noria:changeRequestActualStartTime "2024-05-01T02:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-05-01T03:45:00Z"^^xsd:dateTime .

# Example of a TroubleTicket with planned and committed restoration times
noria:TroubleTicket_DNSOutage001 noria:troubleTicketTargetRestorationDateTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-23T09:50:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean .

# Example of a TroubleTicket freeze item (represented by an EventRecord)
noria:EventRecord_TT_Freeze a noria:EventRecord ;
    rdfs:label "Trouble Ticket Freeze Event"@en ;
    rdfs:comment "Event indicating a trouble ticket was put on hold."@en ;
    dcterms:identifier "EVT-20240423-001-FREEZE"^^xsd:string ;
    noria:loggingTime "2024-04-23T09:30:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-20240423-001 frozen due to external dependency."@en ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:TroubleTicket_DNSOutage001 noria:troubleTicketFreezeItem noria:EventRecord_TT_Freeze .

# Example of a TroubleTicketPartyIntervention (can be a blank node or a specific class if defined)
noria:TroubleTicket_DNSOutage001 noria:troubleTicketPartyIntervention [
    a noria:TroubleTicketPartyIntervention ; # Assuming this class exists or using a blank node for a specific intervention event
    rdfs:label "Initial Network Team Intervention"@en ;
    dcterms:created "2024-04-23T09:05:00Z"^^xsd:dateTime ;
    dcterms:contributor foaf:Agent_NetworkOpsTeam ;
    rdfs:comment "Network team started investigation."@en
] .

# Example of an EventRecord being mitigated by a TroubleTicket (as a ProcedureExecutionContainer)
noria:EventRecord_CR01_InterfaceDown noria:alarmMitigatedBy noria:TroubleTicket_DNSOutage001 .

# Example of an EventRecord with a proposed repair action
noria:EventRecord_CR01_InterfaceDown noria:alarmProposedRepairAction noria:OperationPlan_NetworkTroubleshoot .

# Example of an EventRecord with monitored attributes (as a blank node or specific class if defined)
noria:EventRecord_DNS_CPU_Spike noria:alarmMonitoredAttribute [
    rdfs:label "CPU Usage Metric"@en ;
    rdfs:comment "Monitored attribute: CPU usage percentage."@en ;
    rdf:value "95"^^xsd:int ;
    qudt:unit qudt-unit:PERCENT ; # Assuming QUDT units are available
] .

