    dcterms:created "2024-04-24T09:15:00Z"^^xsd:dateTime ;
    dcterms:format "application/pdf" ;
    dcterms:isPartOf :CR_20240424_001 ;
    dcterms:source "https://changemgmt.example.com/attachments/cr_001_ram_plan.pdf" .

# =============================================================================
# Anomaly Patterns
# =============================================================================

:Anomaly_HighCPU_Webserver a noria:AnomalyPattern ;
    rdfs:label "High CPU on Web Server Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a potential issue: sustained high CPU usage on a web server, often correlated with slow application response times."@en ;
    skos:example "EventRecord (High CPU) + TroubleTicket (Slow Response) + Resource (Web Server)."@en ;
    folio:hasCause :PreCondition_HighCPU_Apache .

:Anomaly_NetworkLinkFlap a noria:AnomalyPattern ;
    rdfs:label "Network Link Flapping Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating an unstable network link, characterized by frequent up/down transitions of an interface."@en ;
    skos:example "Multiple EventRecords (Interface State Change) for the same NetworkInterface within a short period."@en ;
    folio:hasCause :PreCondition_WANLinkFlapping .

