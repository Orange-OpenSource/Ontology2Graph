# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/instances/> .

# =============================================================================
# Agents and Organizations
# =============================================================================

# Organizations
:OrangeSA a org:Organization ;
    rdfs:label "Orange S.A."@en, "Orange S.A."@fr ;
    rdfs:comment "Major telecommunications company providing various services including IT and network infrastructure."@en ;
    org:hasUnit :ITOperationsDept, :NetworkEngineeringDept, :CustomerSupportDept .

:ITOperationsDept a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en, "Département Opérations IT"@fr ;
    rdfs:comment "Department responsible for managing IT infrastructure and applications, ensuring their smooth operation."@en ;
    org:unitOf :OrangeSA ;
    org:hasMember :WebOpsTeam, :DBATeam, :NOCteam, :SecurityOpsTeam .

:NetworkEngineeringDept a org:OrganizationalUnit ;
    rdfs:label "Network Engineering Department"@en, "Département Ingénierie Réseau"@fr ;
    rdfs:comment "Department responsible for designing, implementing, and maintaining the core network infrastructure."@en ;
    org:unitOf :OrangeSA ;
    org:hasMember :CoreNetworkTeam, :AccessNetworkTeam .

:CustomerSupportDept a org:OrganizationalUnit ;
    rdfs:label "Customer Support Department"@en, "Département Support Client"@fr ;
    rdfs:comment "Department handling customer inquiries, issues, and service requests."@en ;
    org:unitOf :OrangeSA ;
    org:hasMember :CustomerServiceTeam .

# Teams (foaf:Agent, org:OrganizationalUnit)
:WebOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Web Operations Team"@en, "Équipe Opérations Web"@fr ;
    rdfs:comment "Team responsible for the E-commerce platform and related web services, including deployment and monitoring."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri, on-call rotation"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all non-critical issues. For critical issues, use emergency hotline and escalate to John Doe."@en ;
    org:unitOf :ITOperationsDept ;
    noria:agentManagesResource :WebServer01, :LoadBalancer01, :AppServer01 ;
    noria:agentManagesResource :ECommercePlatformApp, :PaymentGatewayAppModule .

:DBATeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en, "Équipe Administration Bases de Données"@fr ;
    rdfs:comment "Team responsible for managing and maintaining all database servers and ensuring data integrity and performance."@en ;
    noria:agentWorkingHours "24/7 On-call for critical databases"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Pager> ;
    noria:agentInstructions "For database performance issues, open a P1 ticket. For routine maintenance, schedule via change request."@en ;
    org:unitOf :ITOperationsDept ;
    noria:agentManagesResource :DatabaseServer01, :DatabaseServer02 .

:NOCteam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center Team"@en, "Équipe Centre d'Opérations Réseau"@fr ;
    rdfs:comment "First-line support for network incidents, monitoring network health and responding to alerts."@en ;
    noria:agentWorkingHours "24/7 Shift-based"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Follow standard operating procedures for all network alerts. Escalate to Core Network Team for L2/L3 issues."@en ;
    org:unitOf :ITOperationsDept ;
    noria:agentManagesResource :CoreRouter01, :EdgeRouter01, :CoreNetworkLink01, :WANLink01 .

:CoreNetworkTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Core Network Team"@en, "Équipe Réseau Cœur"@fr ;
    rdfs:comment "Team responsible for the core network infrastructure, including routing, switching, and backbone connectivity."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri, on-call for major incidents"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "All changes require a change request. For critical network outages, engage via NOC escalation."@en ;
    org:unitOf :NetworkEngineeringDept ;
    noria:agentManagesResource :CoreRouter01, :CoreSwitch01, :CoreNetworkLink01 .

:AccessNetworkTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Access Network Team"@en, "Équipe Réseau d'Accès"@fr ;
    rdfs:comment "Team managing the network infrastructure connecting end-users and customer sites to the core network."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    org:unitOf :NetworkEngineeringDept ;
    noria:agentManagesResource :EdgeRouter01, :CustomerRouter01 .

:SecurityOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Team"@en, "Équipe Opérations Sécurité"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents, managing firewalls and intrusion detection systems."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/SecureChat> ;
    org:unitOf :ITOperationsDept ;
    noria:agentManagesResource :Firewall01, :IDS01 ;
    noria:agentManagesResource :SIEMApp .

:CustomerServiceTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Customer Service Team"@en, "Équipe Service Client"@fr ;
    rdfs:comment "Front-line support for customer inquiries and initial incident reporting."@en ;
    noria:agentWorkingHours "8:00-20:00 Mon-Sat"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    org:unitOf :CustomerSupportDept .

# Individual Agents (foaf:Agent)
:JohnDoe a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Lead Engineer for Web Operations Team, specializing in E-commerce platform reliability."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+33123456789" ;
    org:memberOf :WebOpsTeam .

:JaneSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Senior Network Engineer in Core Network Team, responsible for backbone routing."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:phone "+33198765432" ;
    org:memberOf :CoreNetworkTeam .

:AliceJohnson a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Johnson"@en, "Alice Durand"@fr ;
    rdfs:comment "Database Administrator in DBA Team, expert in SQL performance tuning."@en ;
    foaf:mbox <mailto:alice.johnson@example.com> ;
    foaf:phone "+33112233445" ;
    org:memberOf :DBATeam .

:BobWhite a foaf:Person, foaf:Agent ;
    rdfs:label "Bob White"@en, "Bob Leblanc"@fr ;
    rdfs:comment "Security Analyst in Security Operations Team, focusing on threat detection."@en ;
    foaf:mbox <mailto:bob.white@example.com> ;
    foaf:phone "+33155667788" ;
    org:memberOf :SecurityOpsTeam .

# Corporate User Identifiers
:JohnDoeCUid a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    foaf:accountName "jdoe" ;
    foaf:accountServiceHomepage <https://intranet.example.com/profile/jdoe> ;
    foaf:holdsAccount :JohnDoe .

:JaneSmithCUid a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    foaf:accountName "jsmith" ;
    foaf:accountServiceHomepage <https://intranet.example.com/profile/jsmith> ;
    foaf:holdsAccount :JaneSmith .

# =============================================================================
# Locations
# =============================================================================

:DataCenterParis a bot:Site ;
    rdfs:label "Paris Data Center"@en, "Centre de Données Paris"@fr ;
    rdfs:comment "Primary data center located in Paris, France, hosting critical IT infrastructure."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" ;
    bot:containsZone :ServerRoomA, :NetworkRoomB, :StorageRoomC .

:DataCenterLyon a bot:Site ;
    rdfs:label "Lyon Data Center"@en, "Centre de Données Lyon"@fr ;
    rdfs:comment "Secondary data center located in Lyon, France, serving as a disaster recovery site and regional hub."@en ;
    noria:siteId "DC-LYN-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès"@en ;
    noria:sitePrincipalAddressCityName "Lyon"@en ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" ;
    bot:containsZone :ServerRoomDR, :NetworkRoomDR .

:ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within Paris Data Center, hosting web, application, and database servers."@en ;
    bot:hasSpace :RackA1, :RackA2, :RackA3 ;
    bot:hasBuilding :DataCenterParis .

:NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en, "Salle Réseau B"@fr ;
    rdfs:comment "Room within Paris Data Center hosting core network equipment, firewalls, and load balancers."@en ;
    bot:hasSpace :RackB1, :RackB2 ;
    bot:hasBuilding :DataCenterParis .

:StorageRoomC a noria:Room ;
    rdfs:label "Storage Room C"@en, "Salle Stockage C"@fr ;
    rdfs:comment "Room dedicated to storage area network (SAN) equipment and backup systems."@en ;
    bot:hasSpace :RackC1 ;
    bot:hasBuilding :DataCenterParis .

:ServerRoomDR a noria:Room ;
    rdfs:label "Server Room DR"@en, "Salle Serveurs DR"@fr ;
    rdfs:comment "Disaster recovery server room in Lyon Data Center."@en ;
    bot:hasSpace :RackDR1 ;
    bot:hasBuilding :DataCenterLyon .

:NetworkRoomDR a noria:Room ;
    rdfs:label "Network Room DR"@en, "Salle Réseau DR"@fr ;
    rdfs:comment "Disaster recovery network room in Lyon Data Center."@en ;
    bot:hasSpace :RackDR2 ;
    bot:hasBuilding :DataCenterLyon .

:RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en, "Baie A1"@fr ;
    rdfs:comment "Specific rack in Server Room A, hosting Web Server 01 and App Server 01."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace :ServerRoomA .

:RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en, "Baie A2"@fr ;
    rdfs:comment "Specific rack in Server Room A, hosting Database Server 01 and 02."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
    bot:hasSpace :ServerRoomA .

:RackA3 a noria:Locus ;
    rdfs:label "Rack A3"@en, "Baie A3"@fr ;
    rdfs:comment "Specific rack in Server Room A, hosting monitoring and logging infrastructure."@en ;
    noria:locusLine "A" ;
    noria:locusRow "3" ;
    bot:hasSpace :ServerRoomA .

:RackB1 a noria:Locus ;
    rdfs:label "Rack B1"@en, "Baie B1"@fr ;
    rdfs:comment "Specific rack in Network Room B, hosting Core Router 01 and Core Switch 01."@en ;
    noria:locusLine "B" ;
    noria:locusRow "1" ;
    bot:hasSpace :NetworkRoomB .

:RackB2 a noria:Locus ;
    rdfs:label "Rack B2"@en, "Baie B2"@fr ;
    rdfs:comment "Specific rack in Network Room B, hosting Firewall 01 and Load Balancer 01."@en ;
    noria:locusLine "B" ;
    noria:locusRow "2" ;
    bot:hasSpace :NetworkRoomB .

:RackC1 a noria:Locus ;
    rdfs:label "Rack C1"@en, "Baie C1"@fr ;
    rdfs:comment "Specific rack in Storage Room C, hosting SAN storage arrays."@en ;
    noria:locusLine "C" ;
    noria:locusRow "1" ;
    bot:hasSpace :StorageRoomC .

:RackDR1 a noria:Locus ;
    rdfs:label "Rack DR1"@en, "Baie DR1"@fr ;
    rdfs:comment "Specific rack in Server Room DR, hosting DR web and app servers."@en ;
    noria:locusLine "DR" ;
    noria:locusRow "1" ;
    bot:hasSpace :ServerRoomDR .

:RackDR2 a noria:Locus ;
    rdfs:label "Rack DR2"@en, "Baie DR2"@fr ;
    rdfs:comment "Specific rack in Network Room DR, hosting DR network equipment."@en ;
    noria:locusLine "DR" ;
    noria:locusRow "2" ;
    bot:hasSpace :NetworkRoomDR .

