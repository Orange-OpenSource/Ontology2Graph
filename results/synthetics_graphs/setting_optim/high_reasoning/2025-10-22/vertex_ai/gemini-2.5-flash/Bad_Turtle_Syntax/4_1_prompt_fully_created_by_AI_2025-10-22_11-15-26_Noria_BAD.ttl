# =============================================================================
# Operation Plans and Conditions
# =============================================================================

:OperationPlan_RestartApache a noria:OperationPlan ;
    rdfs:label "Restart Apache Service Procedure"@en, "Procédure de Redémarrage du Service Apache"@fr ;
    rdfs:comment "Standard operating procedure for restarting the Apache HTTP Server service on a Linux server."@en ;
    skos:example "Steps: 1. SSH to server. 2. Check service status. 3. Restart service. 4. Verify service status and accessibility."@en ;
    noria:operationPlanPreCondition :PreCondition_HighCPU_Apache ;
    noria:operationPlanPostCondition :PostCondition_ApacheRunning_LowCPU .

:OperationPlan_ReplaceSFP a noria:OperationPlan ;
    rdfs:label "Replace SFP Module Procedure"@en, "Procédure de Remplacement Module SFP"@fr ;
    rdfs:comment "Procedure for replacing a Small Form-Factor Pluggable (SFP) module on a network router interface."@en ;
    skos:example "Steps: 1. Identify faulty SFP. 2. Verify spare SFP availability. 3. Schedule maintenance window. 4. Replace SFP. 5. Verify link status."@en ;
    noria:operationPlanPreCondition :PreCondition_WANLinkFlapping ;
    noria:operationPlanPostCondition :PostCondition_WANLinkStable .

:OperationPlan_UpgradeRAM a noria:OperationPlan ;
    rdfs:label "Server RAM Upgrade Procedure"@en, "Procédure de Mise à Niveau RAM Serveur"@fr ;
    rdfs:comment "Standard procedure for upgrading RAM modules in a Dell PowerEdge R740 server."@en ;
    skos:example "Steps: 1. Backup data. 2. Shutdown server. 3. Install new RAM. 4. Power on and verify."@en ;
    noria:operationPlanPreCondition :PreCondition_ServerShutdown ;
    noria:operationPlanPostCondition :PostCondition_RAMRecognized_ServerOnline .

# Action Pre-Conditions
:PreCondition_HighCPU_Apache a noria:ActionPreCondition ;
    rdfs:label "High CPU on Apache Server Pre-condition"@en ;
    rdfs:comment "Condition: Web server CPU usage > 80% for 5 minutes, and Apache process is top consumer."@en ;
    skos:example "Monitoring alert for high CPU, `top` command shows httpd processes consuming most CPU."@en .

:PreCondition_WANLinkFlapping a noria:ActionPreCondition ;
    rdfs:label "WAN Link Flapping Pre-condition"@en ;
    rdfs:comment "Condition: Network interface status repeatedly changes between up and down, indicating instability."@en ;
    skos:example "Router logs show 'LINEPROTO-5-UPDOWN' messages for the same interface multiple times within a short period."@en .

:PreCondition_ServerShutdown a noria:ActionPreCondition ;
    rdfs:label "Server Shutdown Pre-condition"@en ;
    rdfs:comment "Condition: The target server must be gracefully shut down before hardware changes."@en ;
    skos:example "Server is powered off and disconnected from power source."@en .

# Action Post-Conditions
:PostCondition_ApacheRunning_LowCPU a noria:ActionPostCondition ;
    rdfs:label "Apache Running with Low CPU Post-condition"@en ;
    rdfs:comment "Expected outcome: Apache service is running, and server CPU usage is below 50%."@en ;
    skos:example "Service status 'running', CPU usage graph shows significant drop."@en .

:PostCondition_WANLinkStable a noria:ActionPostCondition ;
    rdfs:label "WAN Link Stable Post-condition"@en ;
    rdfs:comment "Expected outcome: Network interface remains in 'up' state without flapping for at least 30 minutes."@en ;
    skos:example "No 'LINEPROTO-5-UPDOWN' messages in router logs for 30 minutes, ping tests successful."@en .

:PostCondition_RAMRecognized_ServerOnline a noria:ActionPostCondition ;
    rdfs:label "RAM Recognized and Server Online Post-condition"@en ;
    rdfs:comment "Expected outcome: Server boots successfully, new RAM capacity is recognized by OS, and all services are online."@en ;
    skos:example "OS reports correct RAM size, application health checks pass."@en .

