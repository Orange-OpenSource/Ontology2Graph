# Physical Servers
:WebServer01 a noria:Resource ;
    rdfs:label "Web Server 01"@en, "Serveur Web 01"@fr ;
    rdfs:comment "Primary web server for the E-commerce platform, running Apache and PHP."@en ;
    noria:resourceLogisticId "WS-PAR-A1-01" ;
    noria:resourceHostName "web01.ecommerce.corp" ;
    noria:resourceProductModel :DellPowerEdgeR740 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/PhysicalServer> ;
    noria:resourceSerialNumber "SN-WEB01-XYZ123" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication :ECommercePlatformApp ;
    noria:resourceManagedBy :WebOpsTeam ;
