# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan_RestartWebServer
    a noria:OperationPlan ;
    rdfs:label "Restart Web Server Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a web server instance."@en ;
    skos:example "Steps include checking logs, gracefully stopping service, starting service, and verifying accessibility."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_WebServerCPUHigh ;
    noria:operationPlanPostCondition noria:ActionPostCondition_WebServerAccessible .

noria:OperationPlan_NetworkInterfaceTroubleshoot
    a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving issues with network interfaces."@en ;
    skos:example "Steps include checking physical connection, administrative status, optical power levels, and routing metrics."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_NetworkInterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_NetworkInterfaceUp .

noria:ActionPreCondition_WebServerCPUHigh
    a noria:ActionPreCondition ;
    rdfs:label "Web Server CPU High Pre-Condition"@en ;
    rdfs:comment "Condition where web server CPU utilization is consistently high, indicating potential resource exhaustion or stuck process."@en .

noria:ActionPostCondition_WebServerAccessible
    a noria:ActionPostCondition ;
    rdfs:label "Web Server Accessible Post-Condition"@en ;
    rdfs:comment "Expected outcome: Web server is reachable and responding to requests after intervention."@en .

noria:ActionPreCondition_NetworkInterfaceDown
    a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Pre-Condition"@en ;
    rdfs:comment "Condition where a critical network interface is reporting an operational 'down' state."@en .

noria:ActionPostCondition_NetworkInterfaceUp
    a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up Post-Condition"@en ;
    rdfs:comment "Expected outcome: Network interface is operational and traffic is flowing."@en .

noria:OperationPlan_SoftwareUpgradeRouter
    a noria:OperationPlan ;
    rdfs:label "Router Software Upgrade Plan"@en ;
    rdfs:comment "Detailed plan for upgrading the operating system software on a network router."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_RouterMaintenanceWindow ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterSoftwareUpdated .

noria:ActionPreCondition_RouterMaintenanceWindow
    a noria:ActionPreCondition ;
    rdfs:label "Router Maintenance Window Pre-Condition"@en ;
    rdfs:comment "Scheduled maintenance window is active, minimizing impact on production services."@en .

noria:ActionPostCondition_RouterSoftwareUpdated
    a noria:ActionPostCondition ;
    rdfs:label "Router Software Updated Post-Condition"@en ;
    rdfs:comment "Expected outcome: Router software is successfully upgraded to the target version, and all services are restored."@en .

noria:ChangeRequest_CR20240425_001 noria:actionCorrelatedOperationPlan noria:OperationPlan_SoftwareUpgradeRouter .
noria:TroubleTicketNote_TT20240420_001_Note2 noria:actionCorrelatedOperationPlan noria:OperationPlan_NetworkInterfaceTroubleshoot .
noria:EventRecord_WebSrv01_CPUHigh noria:alarmProposedRepairAction noria:OperationPlan_RestartWebServer .

# Anomaly Patterns
noria:AnomalyPattern_HighCPU_SlowResponse
    a noria:AnomalyPattern ;
    rdfs:label "High CPU and Slow Response Pattern"@en ;
    rdfs:comment "Pattern indicating a potential issue where high CPU usage on a server correlates with slow application response times."@en ;
    folio:hasCause noria:ActionPreCondition_WebServerCPUHigh ;
    folio:hasEffect noria:TroubleTicket_TT20240420_002 .

noria:AnomalyPattern_InterfaceDown_ServiceOutage
    a noria:AnomalyPattern ;
    rdfs:label "Interface Down and Service Outage Pattern"@en ;
    rdfs:comment "Pattern where a critical network interface going down leads to a complete service outage."@en ;
    folio:hasCause noria:ActionPreCondition_NetworkInterfaceDown ;
    folio:hasEffect noria:TroubleTicket_TT20240420_001 .

