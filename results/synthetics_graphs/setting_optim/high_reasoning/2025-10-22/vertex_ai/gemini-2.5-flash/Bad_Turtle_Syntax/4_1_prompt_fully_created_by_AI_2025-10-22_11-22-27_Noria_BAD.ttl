# Document Attachments
noria:DocumentAttachment_CR20240425_001_Plan
    a noria:DocumentAttachment ;
    rdfs:label "Upgrade Plan for CR20240425-001"@en ;
    rdfs:comment "Detailed plan for the Core Router 01 software upgrade."@en ;
    dcterms:isPartOf noria:ChangeRequest_CR20240425_001 ;
    dcterms:format "application/pdf" ;
    dcterms:source "https://docs.example.com/CR20240425-001_Plan.pdf"^^xsd:anyURI .

noria:DocumentAttachment_TT20240420_001_Screenshot
    a noria:DocumentAttachment ;
    rdfs:label "Screenshot of Interface Status"@en ;
    rdfs:comment "Screenshot showing the down status of Core Router 01 Gi0/0/0 interface."@en ;
