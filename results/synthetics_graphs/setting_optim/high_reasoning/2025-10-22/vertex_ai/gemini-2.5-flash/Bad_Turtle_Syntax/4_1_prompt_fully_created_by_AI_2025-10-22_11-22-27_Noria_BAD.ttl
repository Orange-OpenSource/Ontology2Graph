# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS Concepts (used as ranges for various properties)
# =============================================================================

<https://w3id.org/noria/kos/application/type/infrastructure>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "Represents an application that provides core infrastructure services."@en .

<https://w3id.org/noria/kos/application/type/business>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Business Application"@en ;
    rdfs:comment "Represents an application directly supporting business operations."@en .

<https://w3id.org/noria/kos/application/business-importance/high>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Indicates a critical application with significant business impact."@en .

<https://w3id.org/noria/kos/application/business-importance/medium>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Indicates an application with moderate business impact."@en .

<https://w3id.org/noria/kos/application/status/InProduction>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently live and serving users."@en .

<https://w3id.org/noria/kos/application/status/Development>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Development"@en ;
    rdfs:comment "The application module is currently under development."@en .

<https://w3id.org/noria/kos/TroubleTicket/severity/Critical>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Indicates a critical incident with severe impact on services."@en .

<https://w3id.org/noria/kos/TroubleTicket/severity/Major>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Indicates a major incident with significant impact on services."@en .

<https://w3id.org/noria/kos/TroubleTicket/type/Failure>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> ;
    rdfs:label "Failure Ticket"@en ;
    rdfs:comment "Trouble ticket type indicating a system or service failure."@en .

<https://w3id.org/noria/kos/TroubleTicket/type/Assistance>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> ;
    rdfs:label "Assistance Ticket"@en ;
    rdfs:comment "Trouble ticket type for user assistance requests."@en .

<https://w3id.org/noria/kos/TroubleTicket/priority/P1>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> ;
    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority, immediate action required."@en .

<https://w3id.org/noria/kos/TroubleTicket/priority/P2>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> ;
    rdfs:label "Priority 2"@en ;
    rdfs:comment "High priority, urgent action required."@en .

<https://w3id.org/noria/kos/TroubleTicket/origin/Supervision>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> ;
    rdfs:label "Supervision Origin"@en ;
    rdfs:comment "Trouble ticket originated from a monitoring or supervision system."@en .

<https://w3id.org/noria/kos/TroubleTicket/origin/Customer>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> ;
    rdfs:label "Customer Origin"@en ;
    rdfs:comment "Trouble ticket originated from a customer report."@en .

<https://w3id.org/noria/kos/TroubleTicket/urgency/ImmediateIntervention>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Urgency level requiring immediate action."@en .

<https://w3id.org/noria/kos/TroubleTicket/status/InProgress>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "The trouble ticket is currently being worked on."@en .

<https://w3id.org/noria/kos/TroubleTicket/status/Resolved>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> ;
    rdfs:label "Resolved"@en ;
    rdfs:comment "The issue described in the trouble ticket has been resolved."@en .

<https://w3id.org/noria/kos/TroubleTicket/trouble-category/TotalBreakdown>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/trouble-category> ;
    rdfs:label "Total Breakdown"@en ;
    rdfs:comment "Indicates a complete failure of a system or service."@en .

<https://w3id.org/noria/kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Managed Backbone Networks"@en ;
    rdfs:comment "Responsibility for the problem lies with the team managing backbone networks."@en .

<https://w3id.org/noria/kos/TroubleTicket/commentType/Internal>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment intended for internal team use."@en .

<https://w3id.org/noria/kos/TroubleTicket/operationType/Diagnosis>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis Operation"@en ;
    rdfs:comment "Operation type related to diagnosing the issue."@en .

<https://w3id.org/noria/kos/ChangeRequest/category/InternalIntervention>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/category> ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "Change request for an internal intervention."@en .

<https://w3id.org/noria/kos/ChangeRequest/type/Standard>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "A pre-approved change with low risk."@en .

<https://w3id.org/noria/kos/ChangeRequest/cause/SoftwareUpgrade>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade Cause"@en ;
    rdfs:comment "Change request caused by a software upgrade."@en .

<https://w3id.org/noria/kos/ChangeRequest/status/Approved>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> ;
    rdfs:label "Approved Change"@en ;
    rdfs:comment "The change request has been approved."@en .

<https://w3id.org/noria/kos/Resource/type/Server>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> ;
    rdfs:label "Server Resource"@en ;
    rdfs:comment "Represents a physical or virtual server."@en .

<https://w3id.org/noria/kos/Resource/type/Router>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> ;
    rdfs:label "Router Resource"@en ;
    rdfs:comment "Represents a network router device."@en .

<https://w3id.org/noria/kos/Resource/LifecycleState/InUse>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> ;
    rdfs:label "In Use"@en ;
    rdfs:comment "The resource is currently active and in use."@en .

<https://w3id.org/noria/kos/Resource/OperationalState/Up>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> ;
    rdfs:label "Operational State Up"@en ;
    rdfs:comment "The resource or interface is currently operational."@en .

<https://w3id.org/noria/kos/Resource/OperationalState/Down>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> ;
    rdfs:label "Operational State Down"@en ;
    rdfs:comment "The resource or interface is currently not operational."@en .

<https://w3id.org/noria/kos/Resource/AdministrativeState/Up>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> ;
    rdfs:label "Administrative State Up"@en ;
    rdfs:comment "The resource or interface is administratively enabled."@en .

<https://w3id.org/noria/kos/Resource/AdministrativeState/Down>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> ;
    rdfs:label "Administrative State Down"@en ;
    rdfs:comment "The resource or interface is administratively disabled."@en .

<https://w3id.org/noria/kos/service/type/CustomerFacingService>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly visible and usable by a customer."@en .

<https://w3id.org/noria/kos/service/type/ResourceFacingService>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service that supports customer-facing services but is not directly exposed to customers."@en .

<https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical Perceived Severity"@en ;
    rdfs:comment "Highest severity for an event record, indicating a critical issue."@en .

<https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Warning>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning Perceived Severity"@en ;
    rdfs:comment "Moderate severity for an event record, indicating a potential issue."@en .

# =============================================================================
# Agents and Organizations
# =============================================================================

# Teams (Organizational Units)
noria:Team_NetworkOperations
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:label "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for the day-to-day operation and maintenance of the network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

noria:Team_ApplicationSupport
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:label "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing technical support for business applications."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Open a ticket via the portal. Call only for P1/P2 incidents."@en .

noria:Team_SecurityOperations
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:label "Centre des Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/SIEMAlert> ;
    noria:agentInstructions "Automated alerts from SIEM. Manual contact for high-priority investigations."@en .

noria:Team_DatabaseAdmin
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:label "Équipe Administration Bases de Données"@fr ;
    rdfs:comment "Team managing and maintaining all corporate databases."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit requests via the internal service desk."@en .

# Individuals (Agents)
noria:Agent_AliceSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer in the Network Operations Team."@en ;
    foaf:mbox "mailto:alice.smith@example.com" ;
    foaf:phone "+33123456789" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentManagesResource noria:Resource_CoreRouter01, noria:Resource_EdgeRouter02 .

noria:Agent_BobJohnson
    a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Support Specialist for the CRM application."@en ;
    foaf:mbox "mailto:bob.johnson@example.com" ;
    foaf:phone "+33198765432" ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"@en ;
    noria:agentManagesResource noria:Resource_CRMServer01 .

noria:Agent_CharlieBrown
    a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "SOC Analyst responsible for incident response."@en ;
    foaf:mbox "mailto:charlie.brown@example.com" ;
    foaf:phone "+33112233445" ;
    noria:agentWorkingHours "Shift-based (24/7)"@en .

# Corporate User Identifier
noria:CUid_ASmith
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Alice Smith's corporate accounts."@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount noria:Agent_AliceSmith .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellPowerEdgeR740
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model from Dell."@en ;
    noria:productManufacturedBy noria:Org_Dell .

noria:ProductModel_CiscoCatalyst9300
    a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Enterprise-grade network switch series from Cisco."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:ProductModel_JuniperMX204
    a noria:ProductModel ;
    rdfs:label "Juniper MX204"@en ;
    rdfs:comment "Compact, high-density universal routing platform from Juniper Networks."@en ;
    noria:productManufacturedBy noria:Org_Juniper .

noria:ProductModel_PaloAltoPA500
    a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-500"@en ;
    rdfs:comment "Next-generation firewall appliance."@en ;
    noria:productManufacturedBy noria:Org_PaloAlto .

# Manufacturers (Organizations)
noria:Org_Dell
    a org:Organization, foaf:Agent ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

noria:Org_Cisco
    a org:Organization, foaf:Agent ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "American multinational technology conglomerate corporation that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

noria:Org_Juniper
    a org:Organization, foaf:Agent ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "American multinational corporation that develops and markets networking products, including routers, switches, network management software, network security products, and software-defined networking technology."@en .

noria:Org_PaloAlto
    a org:Organization, foaf:Agent ;
    rdfs:label "Palo Alto Networks"@en ;
    rdfs:comment "American multinational cybersecurity company."@en .

# =============================================================================
# Locations
# =============================================================================

noria:Site_ParisDC01
    a bot:Site ;
    rdfs:label "Paris Data Center 01"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Fibre" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Site_LyonOffice
    a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office building in Lyon."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddressStreet "456 Avenue des Lumières" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:label "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within Paris Data Center 01."@en ;
    bot:hasSpace noria:Site_ParisDC01 .

noria:Room_NetworkClosetB
    a noria:Room ;
    rdfs:label "Network Closet B"@en ;
    rdfs:label "Local Réseau B"@fr ;
    rdfs:comment "Network equipment closet in Lyon Office."@en ;
    bot:hasSpace noria:Site_LyonOffice .

noria:Locus_RackA12
    a noria:Locus ;
    rdfs:label "Rack A12 in Server Room A"@en ;
    rdfs:comment "Specific rack location for servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "12" ;
    bot:containsZone noria:Room_ServerRoomA .

noria:Locus_RackB05
    a noria:Locus ;
    rdfs:label "Rack B05 in Network Closet B"@en ;
    rdfs:comment "Specific rack location for network devices."@en ;
    noria:locusLine "B" ;
    noria:locusRow "05" ;
    bot:containsZone noria:Room_NetworkClosetB .

# =============================================================================
# Resources
# =============================================================================

noria:Resource_WebSrv01
    a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Primary web server hosting the corporate website."@en ;
    noria:resourceLogisticId "SRV-WEB-01-PAR" ;
    noria:resourceHostName "websrv01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellPowerEdgeR740 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB-01-XYZ" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Team_ApplicationSupport ;
    noria:locatedAtLocus noria:Locus_RackA12 ;
    noria:resourceManagementIPAddress "10.0.0.10"^^observable:IPAddress ;
    noria:resourceForApplication noria:Application_CorporateWebsite .

noria:Resource_DBSrv01
    a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Primary database server for critical business applications."@en ;
    noria:resourceLogisticId "SRV-DB-01-PAR" ;
