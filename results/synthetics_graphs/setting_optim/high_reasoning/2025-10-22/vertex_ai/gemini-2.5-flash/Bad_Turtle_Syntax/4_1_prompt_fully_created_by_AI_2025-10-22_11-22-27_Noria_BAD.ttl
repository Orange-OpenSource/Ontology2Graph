noria:ChangeRequest_CR20240425_001
    a noria:ChangeRequest ;
    rdfs:label "Core Router 01 Software Upgrade"@en ;
    rdfs:comment "Planned software upgrade for Core Router 01 to enhance security and performance."@en ;
    dcterms:identifier "CR20240425-001" ;
    dcterms:created "2024-04-15T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-25T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-25T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <https://w3id.org/noria/kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <https://w3id.org/noria/kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <https://w3id.org/noria/kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_CoreRouter01, noria:Application_CorporateInternetAccess ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ; # 2 hours
    noria:changeRequestStatusCurrent <https://w3id.org/noria/kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty noria:Agent_AliceSmith ;
    noria:changeRequestPilotParty noria:Agent_AliceSmith ;
    noria:changeRequestActorParty noria:Team_NetworkOperations ;
    noria:changeRequestIsRegulated false^^xsd:boolean ;
    noria:documentHRef "https://ticketing.example.com/CR20240425-001"^^xsd:anyURI .

