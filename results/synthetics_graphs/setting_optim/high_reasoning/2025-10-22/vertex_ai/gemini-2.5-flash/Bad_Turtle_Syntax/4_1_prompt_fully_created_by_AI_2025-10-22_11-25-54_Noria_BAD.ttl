    rdfs:comment "Virtualization hypervisor software model."@en ;
    noria:productManufacturedBy org:ManufacturerVMware .

org:ManufacturerCisco a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Leading networking hardware manufacturer."@en .

org:ManufacturerDell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational computer technology company."@en .

org:ManufacturerJuniper a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "Networking and cybersecurity solutions provider."@en .

org:ManufacturerVMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Cloud computing and virtualization technology company."@en .

# --- 3. Locations ---
# -----------------------------------------------------------------------------

bot:Site1 a bot:Site ;
    rdfs:label "Main Data Center Paris"@en ;
    rdfs:label "Centre de Données Principal Paris"@fr ;
    rdfs:comment "Primary data center facility located in Paris."@en ;
