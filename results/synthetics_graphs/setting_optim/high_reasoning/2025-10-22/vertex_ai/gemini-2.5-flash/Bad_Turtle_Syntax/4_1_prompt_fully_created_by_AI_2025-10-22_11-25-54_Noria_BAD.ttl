    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string .

bot:Site2 a bot:Site ;
    rdfs:label "Secondary Data Center Lyon"@en ;
    rdfs:label "Centre de Données Secondaire Lyon"@fr ;
    rdfs:comment "Secondary data center facility located in Lyon for disaster recovery."@en ;
    noria:siteId "DC-LYO-02"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "456 Avenue des Lumières"@en ;
    noria:sitePrincipalAddressPostalCode "69007"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Lyon"@en ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string .

noria:Room1 a noria:Room ;
    rdfs:label "Server Room A01"@en ;
    rdfs:label "Salle Serveurs A01"@fr ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace noria:Locus1, noria:Locus2, noria:Locus3 ;
    bot:hasBuilding bot:Site1 .

noria:Room2 a noria:Room ;
    rdfs:label "Network Room B02"@en ;
    rdfs:label "Salle Réseau B02"@fr ;
    rdfs:comment "Network equipment room within the Paris Data Center."@en ;
    bot:hasSpace noria:Locus4, noria:Locus5 ;
    bot:hasBuilding bot:Site1 .

noria:Locus1 a noria:Locus ;
    rdfs:label "Rack R01-A01"@en ;
    rdfs:label "Baie R01-A01"@fr ;
    rdfs:comment "Location for network equipment rack R01 in Server Room A01."@en ;
    noria:locusLine "R01"^^xsd:string ;
    noria:locusRow "A01"^^xsd:string .

noria:Locus2 a noria:Locus ;
    rdfs:label "Rack R02-A01"@en ;
    rdfs:label "Baie R02-A01"@fr ;
    rdfs:comment "Location for server equipment rack R02 in Server Room A01."@en ;
    noria:locusLine "R02"^^xsd:string ;
    noria:locusRow "A01"^^xsd:string .

noria:Locus3 a noria:Locus ;
    rdfs:label "Rack R03-A01"@en ;
    rdfs:label "Baie R03-A01"@fr ;
    rdfs:comment "Location for virtualization hosts rack R03 in Server Room A01."@en ;
    noria:locusLine "R03"^^xsd:string ;
    noria:locusRow "A01"^^xsd:string .

noria:Locus4 a noria:Locus ;
    rdfs:label "Rack N01-B02"@en ;
    rdfs:label "Baie N01-B02"@fr ;
    rdfs:comment "Location for core network router N01 in Network Room B02."@en ;
    noria:locusLine "N01"^^xsd:string ;
    noria:locusRow "B02"^^xsd:string .

noria:Locus5 a noria:Locus ;
    rdfs:label "Rack N02-B02"@en ;
    rdfs:label "Baie N02-B02"@fr ;
    rdfs:comment "Location for distribution switch N02 in Network Room B02."@en ;
    noria:locusLine "N02"^^xsd:string ;
    noria:locusRow "B02"^^xsd:string .

# --- 4. Resources and Network Topology ---
# -----------------------------------------------------------------------------

noria:Resource1 a noria:Resource ;
    rdfs:label "Core Router 1"@en ;
    rdfs:label "Routeur Central 1"@fr ;
    rdfs:comment "Primary core router for the corporate network, located in Paris DC."@en ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:resourceHostName "cr01.dc-par-01.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel3 ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "JNP-MX204-ABC123DEF"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus4 ;
    noria:resourceManagementIPAddress <observable/ip/10.0.0.1> .

noria:Resource2 a noria:Resource ;
    rdfs:label "Application Server 1"@en ;
    rdfs:label "Serveur Applicatif 1"@fr ;
    rdfs:comment "Server hosting critical business applications, located in Paris DC."@en ;
    noria:resourceManagedBy foaf:Agent2 ;
    noria:resourceHostName "appserv01.dc-par-01.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel2 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "DEL-R750-GHI456JKL"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus2 ;
    noria:resourceManagementIPAddress <observable/ip/10.0.0.10> .

noria:Resource3 a noria:Resource ;
    rdfs:label "Database Server 1"@en ;
    rdfs:label "Serveur Base de Données 1"@fr ;
    rdfs:comment "Server hosting the main application database, located in Paris DC."@en ;
    noria:resourceManagedBy foaf:Agent2 ;
    noria:resourceHostName "db01.dc-par-01.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel2 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "DEL-R750-MNO789PQR"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-20T15:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus2 ;
    noria:resourceManagementIPAddress <observable/ip/10.0.0.11> .

noria:Resource4 a noria:Resource ;
    rdfs:label "Virtualization Host 1"@en ;
    rdfs:label "Hôte de Virtualisation 1"@fr ;
    rdfs:comment "Physical server acting as a virtualization host for multiple VMs."@en ;
    noria:resourceManagedBy foaf:Agent2 ;
    noria:resourceHostName "esxi01.dc-par-01.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel4 ;
    noria:resourceType <kos/Resource/type/hypervisor> ;
    noria:resourceSerialNumber "VMW-ESXI-STU101VWX"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus3 ;
    noria:resourceManagementIPAddress <observable/ip/10.0.0.20> .

noria:Resource5 a noria:Resource ;
    rdfs:label "Web Server VM 1"@en ;
    rdfs:label "VM Serveur Web 1"@fr ;
    rdfs:comment "Virtual machine hosting web services for the main application."@en ;
    noria:resourceManagedBy foaf:Agent2 ;
    noria:resourceHostName "webvm01.dc-par-01.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel4 ; # Representing the VM's underlying platform
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-06-10T11:00:00Z"^^xsd:dateTime ;
    noria:clusterController noria:Resource4 ; # VM is controlled by the hypervisor
    noria:resourceManagementIPAddress <observable/ip/10.0.0.21> .

noria:Resource6 a noria:Resource ;
    rdfs:label "Distribution Switch 1"@en ;
    rdfs:label "Commutateur de Distribution 1"@fr ;
    rdfs:comment "Distribution layer switch connecting servers to the core network."@en ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:resourceHostName "distsw01.dc-par-01.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel1 ;
    noria:resourceType <kos/Resource/type/switch> ;
    noria:resourceSerialNumber "CIS-CAT9300-YZ123ABC"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-04-01T08:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus5 ;
    noria:resourceManagementIPAddress <observable/ip/10.0.0.2> .

# Network Interfaces
noria:NetworkInterface1 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/0.100"@en ;
    rdfs:comment "Interface connecting Core Router 1 to Distribution Switch 1."@en ;
    noria:networkInterfaceOf noria:Resource1 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100^^xsd:int .

noria:NetworkInterface2 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/1"@en ;
    rdfs:comment "Interface connecting Distribution Switch 1 to Application Server 1."@en ;
    noria:networkInterfaceOf noria:Resource6 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface3 a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
    rdfs:comment "Primary network interface for Application Server 1."@en ;
    noria:networkInterfaceOf noria:Resource2 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface4 a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
    rdfs:comment "Primary network interface for Database Server 1."@en ;
    noria:networkInterfaceOf noria:Resource3 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface5 a noria:NetworkInterface ;
    rdfs:label "vmnic0"@en ;
    rdfs:comment "Physical network interface for Virtualization Host 1."@en ;
    noria:networkInterfaceOf noria:Resource4 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface6 a noria:NetworkInterface ;
    rdfs:label "ens192"@en ;
    rdfs:comment "Virtual network interface for Web Server VM 1."@en ;
    noria:networkInterfaceOf noria:Resource5 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/virtual> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# Network Links
noria:NetworkLink1 a noria:NetworkLink ;
    rdfs:label "Core-Dist Link 1"@en ;
    rdfs:comment "High-speed link between Core Router 1 and Distribution Switch 1."@en ;
    noria:networkLinkId "LINK-CR01-DS01-01"^^xsd:string ;
    noria:networkLinkType "Ethernet 10Gbps"^^xsd:string ;
    noria:networkLinkInstallationDate "2022-03-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource1 ;
    noria:networkLinkTerminationResourceDestination noria:Resource6 ;
    noria:networkInterfaceConnects noria:NetworkInterface1, noria:NetworkInterface2 .

noria:NetworkLink2 a noria:NetworkLink ;
    rdfs:label "Dist-AppServ Link 1"@en ;
    rdfs:comment "Link between Distribution Switch 1 and Application Server 1."@en ;
    noria:networkLinkId "LINK-DS01-AS01-01"^^xsd:string ;
    noria:networkLinkType "Ethernet 1Gbps"^^xsd:string ;
    noria:networkLinkInstallationDate "2023-01-20T14:45:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource6 ;
    noria:networkLinkTerminationResourceDestination noria:Resource2 ;
    noria:networkInterfaceConnects noria:NetworkInterface2, noria:NetworkInterface3 .

noria:NetworkLink3 a noria:NetworkLink ;
    rdfs:label "Dist-DBServ Link 1"@en ;
    rdfs:comment "Link between Distribution Switch 1 and Database Server 1."@en ;
    noria:networkLinkId "LINK-DS01-DB01-01"^^xsd:string ;
    noria:networkLinkType "Ethernet 1Gbps"^^xsd:string ;
    noria:networkLinkInstallationDate "2023-01-20T15:15:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource6 ;
    noria:networkLinkTerminationResourceDestination noria:Resource3 ;
    noria:networkInterfaceConnects noria:NetworkInterface2, noria:NetworkInterface4 .

noria:NetworkLink4 a noria:NetworkLink ;
    rdfs:label "Dist-ESXi Link 1"@en ;
    rdfs:comment "Link between Distribution Switch 1 and Virtualization Host 1."@en ;
    noria:networkLinkId "LINK-DS01-ESXI01-01"^^xsd:string ;
    noria:networkLinkType "Ethernet 10Gbps"^^xsd:string ;
    noria:networkLinkInstallationDate "2023-05-01T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource6 ;
    noria:networkLinkTerminationResourceDestination noria:Resource4 ;
    noria:networkInterfaceConnects noria:NetworkInterface2, noria:NetworkInterface5 .

# --- 5. Applications and Services ---
# -----------------------------------------------------------------------------

noria:Application1 a noria:Application ;
    rdfs:label "Corporate ERP System"@en ;
    rdfs:label "Système ERP d'Entreprise"@fr ;
    rdfs:comment "Enterprise Resource Planning system, critical for business operations."@en ;
    noria:applicationModelIdentifier "ERP-CORE"^^xsd:string ;
    noria:applicationNumericalIdentifier 1001^^xsd:int ;
    noria:applicationShortIdentifier "ERP"^^xsd:string ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Enterprise Management"@en ;
    noria:applicationFunctionalSubDomain "Financial Management"@en ;
    noria:resourceForApplication noria:Resource2, noria:Resource3, noria:Resource5 .

noria:Application2 a noria:Application ;
    rdfs:label "Internal Monitoring Platform"@en ;
    rdfs:label "Plateforme de Supervision Interne"@fr ;
    rdfs:comment "Platform for monitoring IT infrastructure and applications."@en ;
    noria:applicationModelIdentifier "MON-PLAT"^^xsd:string ;
    noria:applicationNumericalIdentifier 1002^^xsd:int ;
    noria:applicationShortIdentifier "MON"^^xsd:string ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "IT Operations Management"@en ;
    noria:applicationFunctionalSubDomain "Monitoring and Alerting"@en .

noria:Application3 a noria:Application ;
    rdfs:label "Corporate DNS Service"@en ;
    rdfs:label "Service DNS d'Entreprise"@fr ;
    rdfs:comment "Internal DNS resolution service for all corporate systems."@en ;
    noria:applicationModelIdentifier "DNS-CORP"^^xsd:string ;
    noria:applicationNumericalIdentifier 1003^^xsd:int ;
    noria:applicationShortIdentifier "DNS"^^xsd:string ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Services"@en ;
    noria:applicationFunctionalSubDomain "Name Resolution"@en .

noria:ApplicationModule1 a noria:ApplicationModule ;
    rdfs:label "ERP Production Module"@en ;
    rdfs:label "Module ERP Production"@fr ;
    rdfs:comment "Production instance of the Corporate ERP System."@en ;
    noria:applicationModuleOf noria:Application1 ;
    noria:applicationModuleName "ERP_PROD_DC-PAR-01"^^xsd:string ;
    noria:applicationModuleIdentifier "PROD-01"^^xsd:string ;
    noria:applicationModuleAdministrationTeam org:OrgUnit2 ;
    noria:applicationModuleSupportTeam foaf:Agent2 ;
    noria:applicationModuleSupportLeader foaf:Agent4 ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true^^xsd:boolean ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

noria:ApplicationModule2 a noria:ApplicationModule ;
