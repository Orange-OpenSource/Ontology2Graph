# Event Records
noria:EventRecord1 a noria:EventRecord ;
    rdfs:label "DB Server High CPU Alert"@en ;
    rdfs:comment "Alert: CPU usage on db01.dc-par-01.example.com exceeded 90% for 5 minutes."@en ;
    dcterms:identifier "EVT-20240320-001-CPU"^^xsd:string ;
    noria:loggingTime "2024-03-20T08:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource3 ;
    noria:logOriginatingManagementSystem noria:Application2 ;
    noria:logText "CPU_HIGH: db01.dc-par-01.example.com CPU usage 95%."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:troubleTicketTrigger noria:TroubleTicket1 .

noria:EventRecord2 a noria:EventRecord ;
    rdfs:label "Interface Down Alert CR01"@en ;
    rdfs:comment "Alert: Interface ge-0/0/0.100 on cr01.dc-par-01.example.com went down."@en ;
    dcterms:identifier "EVT-20240320-002-IFDOWN"^^xsd:string ;
    noria:loggingTime "2024-03-20T10:25:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application2 ;
    noria:logText "LINK_STATUS_CHANGE: Interface ge-0/0/0.100 on cr01.dc-par-01.example.com changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:troubleTicketTrigger noria:TroubleTicket2 .

noria:EventRecord3 a noria:EventRecord ;
    rdfs:label "Interface Up Event CR01"@en ;
    rdfs:comment "Event: Interface ge-0/0/0.100 on cr01.dc-par-01.example.com came back up."@en ;
    dcterms:identifier "EVT-20240320-003-IFUP"^^xsd:string ;
    noria:loggingTime "2024-03-20T10:26:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application2 ;
    noria:logText "LINK_STATUS_CHANGE: Interface ge-0/0/0.100 on cr01.dc-par-01.example.com changed state to up."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:documentStatusHistory noria:TroubleTicket2 .

noria:EventRecord4 a noria:EventRecord ;
    rdfs:label "DB Server Restart Log"@en ;
    rdfs:comment "Log entry for manual restart of Database Server 1."@en ;
    dcterms:identifier "EVT-20240320-004-RESTART"^^xsd:string ;
    noria:loggingTime "2024-03-20T10:50:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource3 ;
    noria:logOriginatingAgent foaf:Agent4 ;
    noria:logText "System reboot initiated by user 'marie.curie'."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    noria:alarmMitigatedBy noria:TroubleTicket1 . # This action is part of resolving TT1

noria:EventRecord5 a noria:EventRecord ;
    rdfs:label "Configuration Change Log CR01"@en ;
    rdfs:comment "Log entry for configuration change on Core Router 1."@en ;
    dcterms:identifier "EVT-20240325-001-CONFIG"^^xsd:string ;
    noria:loggingTime "2024-03-25T01:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingAgent foaf:Agent3 ;
    noria:logText "Configuration updated by user 'jean.dupont' via SSH."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    noria:documentStatusHistory noria:ChangeRequest2 .

noria:EventRecord6 a noria:EventRecord ;
    rdfs:label "Security Alert: Unauthorized Access Attempt"@en ;
    rdfs:comment "Alert from SIEM: Multiple failed login attempts on appserv01.dc-par-01.example.com from unknown IP."@en ;
    dcterms:identifier "EVT-20240321-001-SEC"^^xsd:string ;
    noria:loggingTime "2024-03-21T14:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingManagementSystem noria:Application2 ; # Assuming monitoring platform also handles security logs
    noria:logText "Unauthorized access attempt detected on appserv01.dc-par-01.example.com from 192.168.5.10."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

# --- 7. Procedural Elements ---
# -----------------------------------------------------------------------------

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "ERP Database Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the ERP database server in case of unresponsiveness."@en ;
    skos:example "Steps include checking logs, attempting graceful shutdown, forced reboot if necessary, and post-restart verification."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Guide"@en ;
    rdfs:comment "Guide for diagnosing and resolving flapping network interfaces on Juniper routers."@en ;
    skos:example "Steps include checking physical layer, SFP diagnostics, cable replacement, and port bounce."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "DB Server Unresponsive"@en ;
    rdfs:comment "Condition: Database server is not responding to queries or SSH access."@en ;
    skos:example "High CPU/memory usage, network connectivity issues, application errors."@en .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Network Interface Flapping Detected"@en ;
    rdfs:comment "Condition: A network interface is intermittently changing its operational status (up/down)."@en ;
    skos:example "Repeated 'link up/down' messages in logs, packet loss on the link."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "DB Service Restored"@en ;
    rdfs:comment "Expected outcome: Database service is fully operational and accessible, CPU/memory usage is normal."@en ;
    skos:example "Application can connect to DB, queries are processed, no error logs."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Network Interface Stable"@en ;
    rdfs:comment "Expected outcome: Network interface maintains a stable 'up' operational status."@en ;
    skos:example "No 'link up/down' messages for an extended period, full connectivity restored."@en .

noria:AnomalyPattern1 a noria:AnomalyPattern ;
    rdfs:label "High CPU leading to DB Unresponsiveness"@en ;
    rdfs:comment "Pattern: Sustained high CPU usage on a database server often precedes unresponsiveness and service outage."@en ;
    skos:example "Correlation of EventRecord1 (High CPU Alert) with TroubleTicket1 (ERP Outage)."@en .

noria:AnomalyPattern2 a noria:AnomalyPattern ;
    rdfs:label "Flapping Interface due to Faulty SFP"@en ;
    rdfs:comment "Pattern: Intermittent link flapping on network interfaces is frequently caused by a faulty SFP module."@en ;
    skos:example "Correlation of EventRecord2 (Interface Down) and EventRecord3 (Interface Up) with TroubleTicket2 (Interface Flapping)."@en .

# --- Additional Connections for Density ---
# -----------------------------------------------------------------------------

# Link agents to resources they manage (inverse of resourceManagedBy)
foaf:Agent1 noria:agentManagesResource noria:Resource1, noria:Resource6 .
foaf:Agent2 noria:agentManagesResource noria:Resource2, noria:Resource3, noria:Resource4, noria:Resource5 .

# Link EventRecords to TroubleTickets/ChangeRequests via documentStatusHistory
noria:TroubleTicket1 noria:documentStatusHistory noria:EventRecord4 . # DB server restart was part of resolving TT1
noria:ChangeRequest2 noria:documentStatusHistory noria:EventRecord5 . # Config change log is part of CR2 history

# Link TroubleTickets to EventRecords that triggered them
noria:TroubleTicket1 noria:troubleTicketTrigger noria:EventRecord1 .
noria:TroubleTicket2 noria:troubleTicketTrigger noria:EventRecord2 .

# Link OperationPlans to actions that might use them
noria:TroubleTicket1 noria:troubleTicketCharacteristic noria:OperationPlan1 . # Operation plan used to resolve TT1
noria:TroubleTicket2 noria:troubleTicketCharacteristic noria:OperationPlan2 . # Operation plan used to resolve TT2

# Link ChangeRequests to OperationPlans
noria:ChangeRequest1 noria:changeRequestSpecification noria:OperationPlan1 . # CR1 might involve OP1 for DB upgrade
noria:ChangeRequest2 noria:changeRequestSpecification noria:OperationPlan2 . # CR2 might involve OP2 for network config

# Link applications to resources they use
noria:Application1 noria:resourceForApplication noria:Resource2, noria:Resource3, noria:Resource5 .
noria:Application2 noria:resourceForApplication noria:Resource2 . # Monitoring platform runs on appserv01
noria:Application3 noria:resourceForApplication noria:Resource1 . # DNS service uses core router for routing

# Link a TroubleTicketNote to a correlated execution (e.g., an EventRecord)
noria:TroubleTicketNote1 noria:troubleTicketNoteCorrelatedExecution noria:EventRecord4 . # The diagnosis led to the restart event

# Link a TroubleTicket to an AnomalyPattern
noria:TroubleTicket1 dcterms:conformsTo noria:AnomalyPattern1 .
noria:TroubleTicket2 dcterms:conformsTo noria:AnomalyPattern2 .

# Link an EventRecord to a proposed repair action
noria:EventRecord1 noria:alarmProposedRepairAction noria:OperationPlan1 .
noria:EventRecord2 noria:alarmProposedRepairAction noria:OperationPlan2 .

# Link a CorporateUserIdentifier to an Agent
noria:CUid1 a noria:CorporateUserIdentifier ;
    rdfs:label "jdupont_account"@en ;
    rdfs:comment "Corporate user account for Jean Dupont."@en ;
    foaf:accountName "jdupont"^^xsd:string ;
    foaf:holdsAccount foaf:Agent3 .

noria:CUid2 a noria:CorporateUserIdentifier ;
    rdfs:label "mcurie_account"@en ;
    rdfs:comment "Corporate user account for Marie Curie."@en ;
    foaf:accountName "mcurie"^^xsd:string ;
    foaf:holdsAccount foaf:Agent4 .

# --- End of Graph ---
