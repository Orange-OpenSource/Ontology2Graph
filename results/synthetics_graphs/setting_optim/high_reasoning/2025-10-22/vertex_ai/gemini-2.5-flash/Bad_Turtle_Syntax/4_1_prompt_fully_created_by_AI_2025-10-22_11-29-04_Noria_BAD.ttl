# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan/dns-service-restart-procedure
    a noria:OperationPlan ;
    rdfs:label "DNS Service Restart Procedure"@en, "Procédure de Redémarrage Service DNS"@fr ;
    rdfs:comment "Standard operating procedure for restarting the DNS service on a server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition/dns-service-down ;
    noria:operationPlanPostCondition noria:ActionPostCondition/dns-service-up .

noria:OperationPlan/router-os-upgrade-procedure
    a noria:OperationPlan ;
    rdfs:label "Router OS Upgrade Procedure"@en, "Procédure de Mise à Jour OS Routeur"@fr ;
    rdfs:comment "Detailed steps for upgrading the operating system of a core router."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition/router-maintenance-window ;
    noria:operationPlanPostCondition noria:ActionPostCondition/router-os-updated .

noria:ActionPreCondition/dns-service-down
    a noria:ActionPreCondition ;
    rdfs:label "DNS Service is Down"@en, "Service DNS Hors Service"@fr ;
    rdfs:comment "Condition: DNS resolution is failing or DNS daemon is not running."@en .

noria:ActionPostCondition/dns-service-up
    a noria:ActionPostCondition ;
    rdfs:label "DNS Service is Up"@en, "Service DNS Actif"@fr ;
    rdfs:comment "Outcome: DNS resolution is successful and DNS daemon is running normally."@en .

noria:ActionPreCondition/router-maintenance-window
    a noria:ActionPreCondition ;
    rdfs:label "Router Maintenance Window"@en, "Fenêtre de Maintenance Routeur"@fr ;
    rdfs:comment "Condition: Approved maintenance window is active for the router."@en .

noria:ActionPostCondition/router-os-updated
    a noria:ActionPostCondition ;
    rdfs:label "Router OS Updated and Operational"@en, "OS Routeur Mis à Jour et Opérationnel"@fr ;
    rdfs:comment "Outcome: Router OS is successfully updated, and all interfaces are operational."@en .

# Linking EventRecord to OperationPlan (via pep:usedProcedure)
noria:EventRecord/dns-restored-log-01 pep:usedProcedure noria:OperationPlan/dns-service-restart-procedure .
noria:EventRecord/config-change-cr01-01 pep:usedProcedure noria:OperationPlan/router-os-upgrade-procedure .

