# Linking agents to resources they manage (inverse of resourceManagedBy)
noria:Agent/dns-admin-team noria:agentManagesResource noria:Resource/dns-server-01, noria:Resource/dns-server-02 .
noria:Agent/network-ops-team noria:agentManagesResource noria:Resource/core-router-01, noria:Resource/core-router-02, noria:Resource/firewall-dmz-01, noria:NetworkLink/isp-uplink-paris, noria:NetworkLink/lan-backbone-paris, noria:NetworkLink/dmz-external-link, noria:NetworkLink/isp-uplink-paris-redundant .
noria:Agent/app-support-team noria:agentManagesResource noria:Resource/web-server-vm-01, noria:Resource/load-balancer-01, noria:NetworkLink/app-server-link .

# Linking resources to applications (inverse of resourceForApplication)
noria:Application/corporate-internet-access seas:hasSubSystem noria:Resource/core-router-01, noria:Resource/firewall-dmz-01, noria:Resource/core-router-02 .
noria:Application/corporate-web-portal seas:hasSubSystem noria:Resource/web-server-vm-01, noria:Resource/load-balancer-01 .
noria:Application/dns-service-app seas:hasSubSystem noria:Resource/dns-server-01, noria:Resource/dns-server-02 .

# Linking application modules to services (inverse of seas:subSystemOf)
noria:Service/enterprise-connectivity seas:hasSubSystem noria:ApplicationModule/cia-prod-module, noria:ApplicationModule/dns-prod-module .
noria:Service/employee-productivity-suite seas:hasSubSystem noria:ApplicationModule/cwp-prod-module .

