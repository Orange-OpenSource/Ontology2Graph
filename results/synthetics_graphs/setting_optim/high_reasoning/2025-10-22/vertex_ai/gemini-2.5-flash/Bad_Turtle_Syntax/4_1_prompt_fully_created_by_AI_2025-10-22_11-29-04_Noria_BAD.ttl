# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord/dns-outage-log-01
    a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en, "Journal Serveur DNS Inaccessible"@fr ;
    rdfs:comment "Log entry indicating DNS server 01 became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS resolution failed."^^xsd:string ;
    noria:logOriginatingManagedObject noria:Resource/dns-server-01 ;
    noria:logOriginatingManagementSystem noria:Application/monitoring-platform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord/router-interface-down-log-01
    a noria:EventRecord ;
    rdfs:label "Router Interface Down Log"@en, "Journal Interface Routeur Hors Service"@fr ;
    rdfs:comment "Log entry from core router indicating an interface went down."@en ;
    noria:loggingTime "2024-04-20T08:58:30Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/0, changed state to down."^^xsd:string ;
    noria:logOriginatingManagedObject noria:Resource/core-router-01 ;
    noria:logOriginatingManagementSystem noria:Application/monitoring-platform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord/web-server-cpu-alert-01
    a noria:EventRecord ;
    rdfs:label "Web Server CPU High Alert"@en, "Alerte CPU Serveur Web Élevée"@fr ;
    rdfs:comment "Alert indicating high CPU utilization on web server VM 01."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "WARNING: CPU utilization on web01.app.example.com exceeded 90% for 5 minutes."^^xsd:string ;
    noria:logOriginatingManagedObject noria:Resource/web-server-vm-01 ;
    noria:logOriginatingManagementSystem noria:Application/monitoring-platform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord/config-change-cr01-01
    a noria:EventRecord ;
    rdfs:label "Core Router Configuration Change Log"@en, "Journal Changement Config Routeur Cœur"@fr ;
    rdfs:comment "Log entry for a configuration change applied to Core Router 01 by Jane Smith."@en ;
    noria:loggingTime "2024-04-19T16:30:00Z"^^xsd:dateTime ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by jane.smith@example.com from 192.168.1.50."^^xsd:string ;
    noria:logOriginatingManagedObject noria:Resource/core-router-01 ;
    noria:logOriginatingAgent noria:Agent/jane-smith ;
    noria:logOriginatingManagementSystem noria:Application/monitoring-platform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord/dns-restored-log-01
    a noria:EventRecord ;
    rdfs:label "DNS Server Restored Log"@en, "Journal Serveur DNS Restauré"@fr ;
    rdfs:comment "Log entry indicating DNS server 01 became reachable again."@en ;
    noria:loggingTime "2024-04-20T09:45:00Z"^^xsd:dateTime ;
    noria:logText "OK: Host dns01.corp.example.com is UP - DNS resolution successful."^^xsd:string ;
    noria:logOriginatingManagedObject noria:Resource/dns-server-01 ;
    noria:logOriginatingManagementSystem noria:Application/monitoring-platform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

