<kos/ChangeRequest/specification/RoutineMaintenance> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/specification> ; rdfs:label "Routine Maintenance"@en, "Maintenance Routinière"@fr .

# Resource Types
<kos/Resource/type/Server> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> ; rdfs:label "Server"@en, "Serveur"@fr .
<kos/Resource/type/Router> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> ; rdfs:label "Router"@en, "Routeur"@fr .
<kos/Resource/type/Firewall> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> ; rdfs:label "Firewall"@en, "Pare-feu"@fr .
<kos/Resource/type/VirtualMachine> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> ; rdfs:label "Virtual Machine"@en, "Machine Virtuelle"@fr .
<kos/Resource/type/LoadBalancer> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> ; rdfs:label "Load Balancer"@en, "Équilibreur de Charge"@fr .

# Resource Lifecycle State
<kos/Resource/LifecycleState/InProduction> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> ; rdfs:label "In Production"@en, "En Production"@fr .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> ; rdfs:label "Decommissioned"@en, "Hors Service"@fr .

# Resource Operational State
<kos/Resource/OperationalState/Up> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> ; rdfs:label "Up"@en, "Actif"@fr .
<kos/Resource/OperationalState/Down> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> ; rdfs:label "Down"@en, "Inactif"@fr .
<kos/Resource/OperationalState/Degraded> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> ; rdfs:label "Degraded"@en, "Dégradé"@fr .

# Resource Administrative State
<kos/Resource/AdministrativeState/Enabled> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> ; rdfs:label "Enabled"@en, "Activé"@fr .
<kos/Resource/AdministrativeState/Disabled> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> ; rdfs:label "Disabled"@en, "Désactivé"@fr .

# Notification Severity
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> ; rdfs:label "Critical"@en, "Critique"@fr .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> ; rdfs:label "Warning"@en, "Avertissement"@fr .
<Notification/Severity/PerceivedSeverity/Informational> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> ; rdfs:label "Informational"@en, "Informationnel"@fr .

# Agent Contact Method
<kos/org/agent-contact-method/Email> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> ; rdfs:label "Email"@en, "Courriel"@fr .
<kos/org/agent-contact-method/Phone> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> ; rdfs:label "Phone"@en, "Téléphone"@fr .

# =============================================================================
# Agents and Organizations
# =============================================================================

noria:Agent/dns-admin-team
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en, "Équipe Admin DNS"@fr ;
    rdfs:comment "Team responsible for corporate DNS server management and resolution."@en ;
    noria:agentWorkingHours "08:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for L2 issues, direct phone for critical P1 incidents."@en .

noria:Agent/network-ops-team
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team managing core network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7 On-Call"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Emergency hotline for network outages, ticketing for planned changes."@en .

noria:Agent/app-support-team
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en, "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing L2/L3 support for critical business applications."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Use internal ticketing system for all application-related issues."@en .

noria:Agent/john-doe
    a foaf:Agent, foaf:Person ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Lead engineer for DNS infrastructure."@en ;
    foaf:mbox "john.doe@example.com" ;
    foaf:phone "+33123456789" ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:Agent/jane-smith
    a foaf:Agent, foaf:Person ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Network architect and incident manager."@en ;
    foaf:mbox "jane.smith@example.com" ;
    foaf:phone "+33987654321" ;
    noria:agentWorkingHours "08:30-17:30 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

noria:Agent/customer-service
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Customer Service Department"@en, "Service Client"@fr ;
    rdfs:comment "First line of contact for customer inquiries and incident reporting."@en ;
    noria:agentWorkingHours "07:00-22:00 (Mon-Sun)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

# =============================================================================
# Locations
# =============================================================================

noria:Site/paris-datacenter
    a bot:Site ;
    rdfs:label "Paris Datacenter"@en, "Centre de Données de Paris"@fr ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "Data Center"^^xsd:string ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string .

noria:Site/london-office
    a bot:Site ;
    rdfs:label "London Head Office"@en, "Siège Social de Londres"@fr ;
    noria:siteId "HO-LDN-01"^^xsd:string ;
    noria:siteType "Office Building"^^xsd:string ;
    noria:sitePrincipalAddressStreet "456 Baker Street"^^xsd:string ;
    noria:sitePrincipalAddressCityName "London"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "NW1 6XE"^^xsd:string ;
    noria:sitePrincipalAddressCountry "UK"^^xsd:string .

noria:Room/server-room-a
    a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room in Paris Datacenter."@en ;
    bot:hasSubSpace noria:Locus/rack-a1, noria:Locus/rack-a2 ;
    bot:hasZone noria:Site/paris-datacenter . # Using bot:hasZone to link Room to Site.

noria:Room/network-room-b
    a noria:Room ;
    rdfs:label "Network Room B"@en, "Salle Réseau B"@fr ;
    rdfs:comment "Network equipment room in Paris Datacenter."@en ;
    bot:hasSubSpace noria:Locus/rack-b1 ;
    bot:hasZone noria:Site/paris-datacenter .

noria:Locus/rack-a1
    a noria:Locus ;
    rdfs:label "Rack A1"@en, "Baie A1"@fr ;
    rdfs:comment "First rack in Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasZone noria:Room/server-room-a .

noria:Locus/rack-a2
    a noria:Locus ;
