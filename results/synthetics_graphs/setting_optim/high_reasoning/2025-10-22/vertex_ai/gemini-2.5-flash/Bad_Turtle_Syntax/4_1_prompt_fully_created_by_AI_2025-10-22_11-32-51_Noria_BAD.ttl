# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS Concepts (invented for demonstration)
# =============================================================================

<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure Application"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/business-critical> a skos:Concept ; rdfs:label "Business Critical Application"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/customer-facing> a skos:Concept ; rdfs:label "Customer Facing Application"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/monitoring> a skos:Concept ; rdfs:label "Monitoring Application"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .

<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High Business Importance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium Business Importance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .
<kos/application/business-importance/critical> a skos:Concept ; rdfs:label "Critical Business Importance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production"@en ; rdfs:label "En Production"@fr ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; rdfs:label "Development"@en ; rdfs:label "En Développement"@fr ; skos:inScheme <https://w3id.org/noria/kos/application/status> .

<kos/service/type/CustomerFacingService> a skos:Concept ; rdfs:label "Customer Facing Service"@en ; skos:inScheme <https://w3id.org/noria/kos/service/type> .
<kos/service/type/BusinessService> a skos:Concept ; rdfs:label "Business Service"@en ; skos:inScheme <https://w3id.org/noria/kos/service/type> .
<kos/service/type/InternalService> a skos:Concept ; rdfs:label "Internal Service"@en ; skos:inScheme <https://w3id.org/noria/kos/service/type> .

<kos/TroubleTicket/severity/Critical> a skos:Concept ; rdfs:label "Critical Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Major> a skos:Concept ; rdfs:label "Major Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; rdfs:label "Minor Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .

<kos/TroubleTicket/type/Failure> a skos:Concept ; rdfs:label "Failure Ticket"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; rdfs:label "Assistance Ticket"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ; rdfs:label "Supervision System Origin"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; rdfs:label "Customer Origin"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> .

<kos/TroubleTicket/status/InProgress> a skos:Concept ; rdfs:label "In Progress"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Closed> a skos:Concept ; rdfs:label "Closed"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .

<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal Comment"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/commentType> .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; rdfs:label "Customer Comment"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/commentType> .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis Operation"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> .
<kos/TroubleTicket/operationType/Escalation> a skos:Concept ; rdfs:label "Escalation Operation"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> .

<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard Change"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; rdfs:label "Emergency Change"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> .

<kos/ChangeRequest/category/Configuration> a skos:Concept ; rdfs:label "Configuration Change"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/category> .
<kos/ChangeRequest/category/Upgrade> a skos:Concept ; rdfs:label "Software Upgrade"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/category> .

<kos/ChangeRequest/status/Approved> a skos:Concept ; rdfs:label "Approved"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; rdfs:label "Implemented"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> .

<kos/Resource/type/Server> a skos:Concept ; rdfs:label "Server Resource"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<kos/Resource/type/Router> a skos:Concept ; rdfs:label "Router Resource"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<kos/Resource/type/Firewall> a skos:Concept ; rdfs:label "Firewall Resource"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<kos/Resource/type/LoadBalancer> a skos:Concept ; rdfs:label "Load Balancer Resource"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<kos/Resource/type/VirtualMachineHost> a skos:Concept ; rdfs:label "Virtual Machine Host Resource"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .

<kos/Resource/LifecycleState/InUse> a skos:Concept ; rdfs:label "In Use"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> .
<kos/Resource/LifecycleState/Maintenance> a skos:Concept ; rdfs:label "Under Maintenance"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> .

<kos/Resource/OperationalState/Up> a skos:Concept ; rdfs:label "Operational Up"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> .
<kos/Resource/OperationalState/Down> a skos:Concept ; rdfs:label "Operational Down"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> .

<kos/Resource/AdministrativeState/Up> a skos:Concept ; rdfs:label "Administrative Up"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; rdfs:label "Administrative Down"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; rdfs:label "Critical Perceived Severity"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; rdfs:label "Major Perceived Severity"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; rdfs:label "Warning Perceived Severity"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .

# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent1 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:label "Équipe Admin DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via ticketing system for routine issues, direct call for critical outages."@en .

foaf:Agent2 a foaf:Agent ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:label "Centre d'Opérations Réseau"@fr ;
    rdfs:comment "24/7 team monitoring network infrastructure."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Use dedicated hotline for immediate network incidents."@en .

foaf:Agent3 a foaf:Agent ;
    rdfs:label "Application Support L2"@en ;
    rdfs:label "Support Applicatif N2"@fr ;
    rdfs:comment "Second-level support for business applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string .

foaf:Agent4 a foaf:Agent ;
    rdfs:label "Security Operations Team"@en ;
    rdfs:label "Équipe Opérations Sécurité"@fr ;
    rdfs:comment "Manages and monitors security infrastructure."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "All security incidents must be reported via the dedicated security incident platform."@en .

foaf:Agent5 a foaf:Agent ;
    rdfs:label "Database Admin Team"@en ;
    rdfs:label "Équipe Admin Base de Données"@fr ;
    rdfs:comment "Manages and maintains all corporate databases."@en ;
    noria:agentWorkingHours "8:30 am - 5:30 pm (Mon-Fri)"^^xsd:string .

org:OrgUnit1 a org:OrganizationalUnit ;
    rdfs:label "Infrastructure Management Department"@en ;
    rdfs:label "Département Gestion d'Infrastructure"@fr ;
    rdfs:comment "Oversees all IT infrastructure components."@en ;
    org:hasMember foaf:Agent1, foaf:Agent2 .

org:OrgUnit2 a org:OrganizationalUnit ;
    rdfs:label "DevOps Team A"@en ;
    rdfs:label "Équipe DevOps A"@fr ;
    rdfs:comment "Responsible for development and operations of key business applications."@en ;
    org:hasMember foaf:Agent3 .

org:OrgUnit3 a org:OrganizationalUnit ;
    rdfs:label "Customer Service Center"@en ;
    rdfs:label "Centre de Service Client"@fr ;
    rdfs:comment "First point of contact for customer inquiries and issues."@en .

org:OrgUnit4 a org:OrganizationalUnit ;
    rdfs:label "Security Audit Department"@en ;
    rdfs:label "Département Audit Sécurité"@fr ;
    rdfs:comment "Conducts regular security audits and ensures compliance."@en ;
    org:hasMember foaf:Agent4 .

org:OrgUnit5 a org:OrganizationalUnit ;
    rdfs:label "Cloud Operations Team"@en ;
    rdfs:label "Équipe Opérations Cloud"@fr ;
    rdfs:comment "Manages cloud-based infrastructure and services."@en .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel1 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for DNS and database services."@en ;
    noria:productManufacturedBy <https://www.dell.com/> .

noria:ProductModel2 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Cisco enterprise-class stackable access layer switch."@en ;
    noria:productManufacturedBy <https://www.cisco.com/> .

noria:ProductModel3 a noria:ProductModel ;
    rdfs:label "Juniper MX204"@en ;
    rdfs:comment "Juniper universal routing platform for edge and core networks."@en ;
    noria:productManufacturedBy <https://www.juniper.net/> .

noria:ProductModel4 a noria:ProductModel ;
    rdfs:label "VMware ESXi Host"@en ;
    rdfs:comment "Virtualization platform for hosting virtual machines."@en ;
    noria:productManufacturedBy <https://www.vmware.com/> .

noria:ProductModel5 a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380"@en ;
    rdfs:comment "HP server model commonly used for web server farms."@en ;
    noria:productManufacturedBy <https://www.hpe.com/> .

# =============================================================================
# Locations
# =============================================================================

bot:Site1 a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:label "Centre de Données Principal"@fr ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddressStreet "123 Rue de la Fibre"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75001"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    bot:containsZone noria:Room1, noria:Room2 .

noria:Room1 a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:label "Salle Serveurs A"@fr ;
    rdfs:comment "Dedicated room for server racks within the main data center."@en ;
    bot:hasSubSpace noria:Locus1, noria:Locus3, noria:Locus5, noria:Locus7 .

noria:Room2 a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:label "Salle Réseau B"@fr ;
    rdfs:comment "Dedicated room for network equipment within the main data center."@en ;
    bot:hasSubSpace noria:Locus2, noria:Locus4, noria:Locus6 .

noria:Locus1 a noria:Locus ;
    rdfs:label "Rack A1, Unit 10"@en ;
    rdfs:comment "Location of DNS Server in Rack A1, Unit 10."@en ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "10"^^xsd:string .

noria:Locus2 a noria:Locus ;
    rdfs:label "Rack B5, Unit 2"@en ;
    rdfs:comment "Location of Core Router 1 in Rack B5, Unit 2."@en ;
    noria:locusLine "B5"^^xsd:string ;
    noria:locusRow "2"^^xsd:string .

noria:Locus3 a noria:Locus ;
    rdfs:label "Rack A2, Unit 5"@en ;
    rdfs:comment "Location of a Web Server in Rack A2, Unit 5."@en ;
    noria:locusLine "A2"^^xsd:string ;
    noria:locusRow "5"^^xsd:string .

noria:Locus4 a noria:Locus ;
    rdfs:label "Rack B3, Unit 1"@en ;
    rdfs:comment "Location of Database Server in Rack B3, Unit 1."@en ;
    noria:locusLine "B3"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

noria:Locus5 a noria:Locus ;
    rdfs:label "Rack A1, Unit 1"@en ;
    rdfs:comment "Location of Firewall Cluster in Rack A1, Unit 1."@en ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

noria:Locus6 a noria:Locus ;
    rdfs:label "Rack B4, Unit 8"@en ;
    rdfs:comment "Location of Virtual Machine Host 1 in Rack B4, Unit 8."@en ;
    noria:locusLine "B4"^^xsd:string ;
    noria:locusRow "8"^^xsd:string .

noria:Locus7 a noria:Locus ;
    rdfs:label "Rack A2, Unit 1"@en ;
    rdfs:comment "Location of Load Balancer in Rack A2, Unit 1."@en ;
    noria:locusLine "A2"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

# =============================================================================
# Resources
# =============================================================================

noria:Resource1 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:label "Serveur DNS Entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, critical for internal and external name resolution."@en ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:resourceHostName "dns01.corp.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel1 ;
    noria:resourceLogisticId "ASSET-DNS-001"^^xsd:string ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application1 ;
    noria:locatedAtLocus noria:Locus1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

noria:Resource2 a noria:Resource ;
    rdfs:label "Core Router 1"@en ;
    rdfs:label "Routeur Cœur 1"@fr ;
    rdfs:comment "Main router for the corporate network, handling all internal and external traffic routing."@en ;
    noria:resourceManagedBy foaf:Agent2 ;
    noria:resourceHostName "router-core-01.corp.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel2 ;
    noria:resourceLogisticId "ASSET-RTR-001"^^xsd:string ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2019-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application1 ;
    noria:locatedAtLocus noria:Locus2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

noria:Resource3 a noria:Resource ;
    rdfs:label "Web Server Farm Node 05"@en ;
    rdfs:label "Nœud Ferme Serveurs Web 05"@fr ;
    rdfs:comment "One of multiple web servers hosting the e-commerce platform."@en ;
    noria:resourceManagedBy org:OrgUnit2 ;
    noria:resourceHostName "web-app-05.corp.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel5 ;
    noria:resourceLogisticId "ASSET-WEB-005"^^xsd:string ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-07-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application3 ;
    noria:locatedAtLocus noria:Locus3 ;
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.5> .

noria:Resource4 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:label "Serveur Base de Données 01"@fr ;
    rdfs:comment "Primary database server for the e-commerce platform, hosting critical customer data."@en ;
    noria:resourceManagedBy foaf:Agent5 ;
    noria:resourceHostName "db-prod-01.corp.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel1 ;
    noria:resourceLogisticId "ASSET-DB-001"^^xsd:string ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2020-05-10T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application3 ;
    noria:locatedAtLocus noria:Locus4 ;
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.10> .

noria:Resource5 a noria:Resource ;
    rdfs:label "Perimeter Firewall Cluster"@en ;
    rdfs:label "Cluster Pare-feu Périmétrique"@fr ;
    rdfs:comment "High-availability firewall cluster protecting the corporate network perimeter."@en ;
    noria:resourceManagedBy foaf:Agent4 ;
    noria:resourceHostName "fw-perimeter-cluster.corp.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel3 ;
    noria:resourceLogisticId "ASSET-FW-001"^^xsd:string ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2018-11-01T16:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application1 ;
    noria:locatedAtLocus noria:Locus5 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.100.1> .

