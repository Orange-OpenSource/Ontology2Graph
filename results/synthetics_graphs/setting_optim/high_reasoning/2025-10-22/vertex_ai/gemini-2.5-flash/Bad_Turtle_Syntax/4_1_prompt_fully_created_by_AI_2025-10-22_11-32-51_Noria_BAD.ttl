# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "DNS Server Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a corporate DNS server."@en ;
    skos:example "Steps include checking service status, attempting graceful restart, force restart if necessary, and verifying resolution."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Firewall Rule Deployment Guide"@en ;
    rdfs:comment "Detailed guide for deploying new or updated firewall rules on the perimeter cluster."@en ;
    skos:example "Includes steps for rule validation, staging, deployment, and post-deployment verification."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

noria:OperationPlan3 a noria:OperationPlan ;
    rdfs:label "Database Patching Procedure"@en ;
    rdfs:comment "Procedure for applying security patches and updates to production database servers."@en ;
    skos:example "Steps involve backup, patch application, testing, and rollback plan."@en ;
    noria:operationPlanPreCondition <http://example.com/precondition/DB_Backup_Complete> ;
    noria:operationPlanPostCondition <http://example.com/postcondition/DB_Patched_Verified> .

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unreachable"@en ;
    rdfs:comment "Condition: DNS service is not responding to queries."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "DNS Service Reachable"@en ;
    rdfs:comment "Outcome: DNS service is responding to queries and name resolution is functional."@en .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Firewall Policy Outdated"@en ;
    rdfs:comment "Condition: Existing firewall policy does not meet new service requirements."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Firewall Policy Updated and Verified"@en ;
    rdfs:comment "Outcome: New firewall policy is active, correctly applied, and verified to allow required traffic."@en .

<http://example.com/precondition/DB_Backup_Complete> a noria:ActionPreCondition ;
    rdfs:label "Database Backup Complete"@en ;
    rdfs:comment "Condition: A full backup of the database has been successfully completed and verified."@en .

<http://example.com/postcondition/DB_Patched_Verified> a noria:ActionPostCondition ;
    rdfs:label "Database Patched and Verified"@en ;
    rdfs:comment "Outcome: Database server has been successfully patched, and all critical services are functional."@en .

# =============================================================================
# Additional Connections for Density
# =============================================================================

# Connect more agents to resources/applications
foaf:Agent1 noria:agentManagesResource noria:Resource1 .
foaf:Agent2 noria:agentManagesResource noria:Resource2, noria:NetworkLink1, noria:NetworkLink2 .
foaf:Agent3 noria:agentManagesResource noria:ApplicationModule2, noria:ApplicationModule3 .
foaf:Agent4 noria:agentManagesResource noria:Resource5, noria:NetworkLink5 .
foaf:Agent5 noria:agentManagesResource noria:Resource4, noria:NetworkLink4, noria:ApplicationModule4 .
org:OrgUnit1 noria:agentManagesResource noria:Resource7, noria:NetworkLink3, noria:NetworkLink7 .
org:OrgUnit2 noria:agentManagesResource noria:Resource3 .
org:OrgUnit5 noria:agentManagesResource noria:Resource6, noria:NetworkLink6, noria:ApplicationModule5 .

# Connect applications to services
noria:Application1 seas:subSystemOf noria:Service1 .
noria:Application2 seas:subSystemOf noria:Service2 . # CRM is part of order processing in a broader sense
noria:Application3 seas:subSystemOf noria:Service2 .
noria:Application4 seas:subSystemOf noria:Service3 .

# Connect trouble tickets to operation plans (as proposed repair actions)
noria:EventRecord1 noria:alarmProposedRepairAction noria:OperationPlan1 .
noria:TroubleTicket1 noria:troubleTicketCause "DNS service process crashed due to memory leak."@en .
noria:TroubleTicket1 noria:problemCategory <kos/TroubleTicket/trouble-category/SoftwareFailure> .
noria:TroubleTicket1 noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/InternalIT> .

noria:TroubleTicket4 noria:troubleTicketCause "Misconfiguration during recent policy update."@en .
noria:TroubleTicket4 noria:problemCategory <kos/TroubleTicket/trouble-category/ConfigurationError> .
noria:TroubleTicket4 noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/InternalIT> .

# Connect change requests to operation plans (as specifications)
noria:ChangeRequest1 noria:changeRequestSpecification <http://example.com/kos/ChangeRequest/specification/FirewallPolicyUpdateSOP> .
noria:ChangeRequest2 noria:changeRequestSpecification <http://example.com/kos/ChangeRequest/specification/OSUpgradeSOP> .

<http://example.com/kos/ChangeRequest/specification/FirewallPolicyUpdateSOP> a skos:Concept ; rdfs:label "Firewall Policy Update SOP"@en ; skos:inScheme <kos/ChangeRequest/specification> .
<http://example.com/kos/ChangeRequest/specification/OSUpgradeSOP> a skos:Concept ; rdfs:label "OS Upgrade SOP"@en ; skos:inScheme <kos/ChangeRequest/specification> .

# Add more observable properties
noria:Resource1 noria:virtualServerStatus <kos/Resource/OperationalState/Down> .
noria:Resource3 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .
noria:NetworkInterface2 noria:networkInterfaceLaserTxOpticalPower -2^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower -5^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10^^xsd:int .

noria:NetworkInterface3 noria:networkInterfaceLaserTxOpticalPower -1.5^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower -4.8^^xsd:int .

# Example of a correlated execution for a trouble ticket note
noria:TroubleTicketNote1 noria:troubleTicketNoteCorrelatedExecution <http://example.com/pep/execution/DNS_Restart_20240423> .

<http://example.com/pep/execution/DNS_Restart_20240423> a pep:ProcedureExecutionContainer ;
    rdfs:label "DNS Service Restart Execution"@en ;
    dcterms:description "Execution record of the DNS service restart procedure."@en ;
    pep:usedProcedure noria:OperationPlan1 ;
    pep:hasInput noria:ActionPreCondition1 ;
    pep:hasOutput noria:ActionPostCondition1 ;
    # Example of a member event record within this execution container
    pep:member <http://example.com/event/DNS_Service_Restart_Command> .

<http://example.com/event/DNS_Service_Restart_Command> a noria:EventRecord ;
    rdfs:label "DNS Service Restart Command Log"@en ;
    noria:loggingTime "2024-04-23T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingAgent foaf:Agent1 ;
    noria:logText "Executed 'systemctl restart named' on dns01.corp.example.com."@en .

# Example of a trouble ticket freeze item
noria:TroubleTicket1 noria:troubleTicketFreezeItem <http://example.com/event/TT1_Freeze_Start>, <http://example.com/event/TT1_Freeze_End> .

<http://example.com/event/TT1_Freeze_Start> a noria:EventRecord ;
    rdfs:label "Trouble Ticket 1 Freeze Start"@en ;
    noria:loggingTime "2024-04-23T09:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "Trouble Ticket INC-DNS-20240423-001 status changed to Frozen due to external dependency."@en ;
    dcterms:type <kos/Notification/EventType/stateChange> .

<http://example.com/event/TT1_Freeze_End> a noria:EventRecord ;
    rdfs:label "Trouble Ticket 1 Freeze End"@en ;
    noria:loggingTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "Trouble Ticket INC-DNS-20240423-001 status changed from Frozen to InProgress."@en ;
    dcterms:type <kos/Notification/EventType/stateChange> .

# Example of a document attachment
<http://example.com/doc/DNS_Server_Config_Report> a noria:DocumentAttachment ;
    rdfs:label "DNS Server Configuration Report"@en ;
    rdfs:comment "Configuration report generated before the DNS server outage."@en ;
    dcterms:isPartOf noria:TroubleTicket1 ;
    dcterms:created "2024-04-22T23:00:00Z"^^xsd:dateTime ;
    dcterms:format "application/pdf"^^xsd:string ;
    dcterms:source <http://docs.example.com/reports/dns_config_20240422.pdf> .

# Example of a Corporate User Identifier
<http://example.com/cuid/jdoe> a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for John Doe within the corporate IT systems."@en ;
    foaf:accountName "jdoe"^^xsd:string ;
    observable:accountLogin "jdoe"^^xsd:string ;
    observable:accountIdentifier "CUID-JD-001"^^xsd:string ;
    foaf:holdsAccount <http://example.com/person/johndoe> .

<http://example.com/person/johndoe> a foaf:Person ;
    rdfs:label "John Doe"@en ;
    foaf:mbox "mailto:jdoe@example.com" .

# Example of an application module support leader
noria:ApplicationModule1 noria:applicationModuleAdministrationLeader foaf:Agent1 .
noria:ApplicationModule2 noria:applicationModuleSupportLeader foaf:Agent3 .

# Example of an application module support group
noria:ApplicationModule1 noria:applicationModuleSupportGroup org:OrgUnit3 .

# Example of an application module hotline group
noria:ApplicationModule3 noria:applicationModuleHotlineGroup org:OrgUnit2 .

# Example of a trouble ticket characteristic
noria:TroubleTicket1 noria:troubleTicketCharacteristic <http://example.com/ttchar/DNS_Cache_Poisoning_Risk> .

<http://example.com/ttchar/DNS_Cache_Poisoning_Risk> a noria:Property ;
    rdfs:label "DNS Cache Poisoning Risk"@en ;
    rdfs:comment "Characteristic indicating a potential risk of DNS cache poisoning during the outage."@en .

# Example of an anomaly pattern
<http://example.com/anomaly/HighCPULowTraffic> a noria:AnomalyPattern ;
    rdfs:label "High CPU, Low Traffic Anomaly"@en ;
    rdfs:comment "Pattern indicating a potential resource exhaustion or deadlock: high CPU usage with unexpectedly low network traffic."@en ;
    folio:hasCause <http://example.com/cause/SoftwareBug> .

<http://example.com/cause/SoftwareBug> a folio:FailureCause ;
    rdfs:label "Software Bug"@en .

# Connect EventRecord to AnomalyPattern
noria:EventRecord3 noria:elementProperty <http://example.com/anomaly/HighCPULowTraffic> .

