# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord1 a noria:EventRecord ;
    rdfs:label "DNS Service Down Alert"@en ;
    rdfs:comment "Automated alert indicating that the corporate DNS service is unreachable."@en ;
    noria:loggingTime "2024-04-23T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "DNS service on dns01.corp.example.com is down. Port 53 unreachable."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord2 a noria:EventRecord ;
    rdfs:label "CRM Login Failure Log"@en ;
    rdfs:comment "Log entry indicating multiple failed login attempts on the CRM frontend."@en ;
    noria:loggingTime "2024-04-23T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:ApplicationModule2 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "User 'jdoe' failed to log in 5 times from IP 192.168.5.10."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logOriginatingAgent <http://example.com/user/jdoe> .

noria:EventRecord3 a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert indicating sustained high CPU utilization on a web server."@en ;
    noria:loggingTime "2024-04-23T09:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource3 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "CPU utilization on web-app-05.corp.example.com exceeded 90% for 10 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord4 a noria:EventRecord ;
    rdfs:label "Firewall Deny Log - Suspicious Traffic"@en ;
    rdfs:comment "Log entry showing traffic denied by firewall due to suspicious activity."@en ;
    noria:loggingTime "2024-04-23T09:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource5 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "Traffic from 203.0.113.42 to 172.16.0.5 on port 8080 denied by security policy."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord5 a noria:EventRecord ;
    rdfs:label "DNS Service Restored Notification"@en ;
    rdfs:comment "Notification indicating that the corporate DNS service has been restored."@en ;
    noria:loggingTime "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "DNS service on dns01.corp.example.com is now up and responding."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord6 a noria:EventRecord ;
    rdfs:label "CRM DB Connection Error"@en ;
    rdfs:comment "Log entry indicating a failure to connect to the CRM database."@en ;
    noria:loggingTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource4 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "Failed to establish connection to CRM database 'crm_db' on db-prod-01."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord7 a noria:EventRecord ;
    rdfs:label "Network Interface Gi0/0/1 Down"@en ;
    rdfs:comment "Alert indicating that network interface Gi0/0/1 on Core Router 1 went down."@en ;
    noria:loggingTime "2024-04-23T11:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:NetworkInterface2 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "Interface Gi0/0/1 on router-core-01 changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord8 a noria:EventRecord ;
    rdfs:label "Network Interface Gi0/0/1 Up"@en ;
    rdfs:comment "Alert indicating that network interface Gi0/0/1 on Core Router 1 came back up."@en ;
    noria:loggingTime "2024-04-23T11:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:NetworkInterface2 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "Interface Gi0/0/1 on router-core-01 changed state to up."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

