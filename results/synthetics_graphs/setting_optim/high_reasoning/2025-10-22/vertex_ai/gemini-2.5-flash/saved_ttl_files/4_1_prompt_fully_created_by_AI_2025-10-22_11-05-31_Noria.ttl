# --- Network Interfaces ---
noria:NI_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on DNS Server 01"@en ;
    rdfs:comment "Primary network interface for Corporate DNS Server 01."@en ;
    noria:networkInterfaceOf noria:CorporateDNSServer01 ;
    noria:networkInterfaceDescription "Management and DNS traffic interface."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_DNS02_Eth0 a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on DNS Server 02"@en ;
    rdfs:comment "Primary network interface for Corporate DNS Server 02."@en ;
    noria:networkInterfaceOf noria:CorporateDNSServer02 ;
    noria:networkInterfaceDescription "Management and DNS traffic interface."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_CR01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on Core Router 01"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the Edge Firewall."@en ;
    noria:networkInterfaceOf noria:CoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to Edge Firewall."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NI_FW01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on Edge Firewall 01"@en ;
    rdfs:comment "Interface connecting Edge Firewall 01 to the Core Router."@en ;
    noria:networkInterfaceOf noria:EdgeFirewall01 ;
    noria:networkInterfaceDescription "Downlink to Core Router."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_WebServer01_vNIC a noria:NetworkInterface ;
    rdfs:label "Virtual NIC on Web Server 01"@en ;
    rdfs:comment "Virtual network interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:WebServer01 ;
    noria:networkInterfaceDescription "Connects to internal web segment."@en ;
    noria:networkInterfaceType "virtual"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# --- Network Links ---
noria:Link_DNS01_Switch a noria:NetworkLink ;
    rdfs:label "Link DNS01 to Core Switch"@en ;
    rdfs:comment "Physical link connecting Corporate DNS Server 01 to the core network switch."@en ;
    noria:networkLinkId "LINK-DNS01-SW"@en ;
    noria:networkLinkType "Ethernet"@en ;
    noria:networkLinkInstallationDate "2022-01-15T10:05:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:CorporateDNSServer01 ;
    noria:networkLinkTerminationResourceDestination noria:CoreRouter01 ; # Assuming CoreRouter01 has a switch module or is acting as a L3 switch
    noria:resourceManagedBy noria:NOC_Team ;
    noria:networkInterfaceConnects noria:NI_DNS01_Eth0 .

noria:Link_DNS02_Switch a noria:NetworkLink ;
    rdfs:label "Link DNS02 to Core Switch"@en ;
    rdfs:comment "Physical link connecting Corporate DNS Server 02 to the core network switch."@en ;
    noria:networkLinkId "LINK-DNS02-SW"@en ;
    noria:networkLinkType "Ethernet"@en ;
    noria:networkLinkInstallationDate "2022-01-15T10:35:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:CorporateDNSServer02 ;
    noria:networkLinkTerminationResourceDestination noria:CoreRouter01 ;
    noria:resourceManagedBy noria:NOC_Team ;
    noria:networkInterfaceConnects noria:NI_DNS02_Eth0 .

noria:Link_CR01_FW01 a noria:NetworkLink ;
    rdfs:label "Link Core Router 01 to Edge Firewall 01"@en ;
    rdfs:comment "High-speed link between the core router and the edge firewall."@en ;
    noria:networkLinkId "LINK-CR01-FW01"@en ;
    noria:networkLinkType "Fiber Optic"@en ;
    noria:networkLinkInstallationDate "2021-06-20T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:EdgeFirewall01 ;
    noria:resourceManagedBy noria:NOC_Team ;
    noria:networkInterfaceConnects noria:NI_CR01_Gi0_0_1, noria:NI_FW01_Gi0_0_1 .

# --- Applications ---
noria:CorporateDNSService a noria:Application ;
    rdfs:label "Corporate DNS Service"@en ;
    rdfs:comment "Provides name resolution services for all internal corporate systems."@en ;
    noria:applicationModelIdentifier "CORP-DNS"@en ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "DNS-CORP"@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Network Services"@en ;
    noria:applicationFunctionalSubDomain "Name Resolution"@en .

noria:EcommercePlatform a noria:Application ;
    rdfs:label "E-commerce Platform"@en ;
    rdfs:comment "Online platform for customer sales and product catalog."@en ;
    noria:applicationModelIdentifier "ECOMMERCE"@en ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "ECOMM"@en ;
    noria:applicationType <kos/application/type/business> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Online Sales"@en .

noria:InternalCRM a noria:Application ;
    rdfs:label "Internal CRM"@en ;
    rdfs:comment "Customer Relationship Management system for internal sales and support teams."@en ;
    noria:applicationModelIdentifier "INTERNAL-CRM"@en ;
    noria:applicationNumericalIdentifier 3001 ;
    noria:applicationShortIdentifier "CRM-INT"@en ;
    noria:applicationType <kos/application/type/business> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Sales & Support"@en .

noria:MonitoringSystem a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:comment "Application responsible for collecting and analyzing logs and metrics from IT infrastructure."@en ;
    noria:applicationModelIdentifier "MONITORING"@en ;
    noria:applicationNumericalIdentifier 4001 ;
    noria:applicationShortIdentifier "MONSYS"@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations Management"@en ;
    noria:applicationFunctionalSubDomain "Monitoring & Alerting"@en .

# --- Application Modules ---
noria:DNSPRODModule a noria:ApplicationModule ;
    rdfs:label "Corporate DNS Production Module"@en ;
    rdfs:comment "Production instance of the Corporate DNS Service."@en ;
    noria:applicationModuleOf noria:CorporateDNSService ;
    noria:applicationModuleName "CORP-DNS_PROD"@en ;
    noria:applicationModuleIdentifier "PROD"@en ;
    noria:applicationModuleAdministrationTeam noria:DNSAdminTeam ;
    noria:applicationModuleAdministrationLeader noria:JohnDoe ;
    noria:applicationModuleSupportTeam noria:NOC_Team ;
    noria:applicationModuleSupportLeader noria:JohnDoe ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

noria:EcommerceFrontendProdModule a noria:ApplicationModule ;
    rdfs:label "E-commerce Frontend Production Module"@en ;
    rdfs:comment "Production instance of the E-commerce platform's frontend."@en ;
    noria:applicationModuleOf noria:EcommercePlatform ;
    noria:applicationModuleName "ECOMMERCE_FRONTEND_PROD"@en ;
    noria:applicationModuleIdentifier "FRONTEND-PROD"@en ;
    noria:applicationModuleAdministrationTeam noria:AppSupportTeam ;
    noria:applicationModuleSupportTeam noria:AppSupportTeam ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

noria:CRMBackendDevModule a noria:ApplicationModule ;
    rdfs:label "Internal CRM Backend Development Module"@en ;
    rdfs:comment "Development instance of the Internal CRM's backend."@en ;
    noria:applicationModuleOf noria:InternalCRM ;
    noria:applicationModuleName "INTERNAL-CRM_BACKEND_DEV"@en ;
    noria:applicationModuleIdentifier "BACKEND-DEV"@en ;
    noria:applicationModuleAdministrationTeam noria:AppSupportTeam ;
    noria:applicationModuleSupportTeam noria:AppSupportTeam ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Bronze> ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> .

# --- Services ---
noria:CriticalBusinessService a noria:Service ;
    rdfs:label "Critical Business Service"@en ;
    rdfs:comment "An aggregated service representing critical business functions, including DNS and E-commerce."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:EcommerceFrontendProdModule, noria:DNSPRODModule . # Example of how ApplicationModules can be part of a Service

noria:InternetAccessService a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:CorporateDNSService . # DNS is a component of internet access

# --- Event Records ---
noria:Event_DNS_Outage_Alert_20240315 a noria:EventRecord ;
    rdfs:label "DNS Server 01 Unreachable Alert"@en ;
    rdfs:comment "Alert generated by monitoring system indicating Corporate DNS Server 01 is unreachable."@en ;
    noria:loggingTime "2024-03-15T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:CorporateDNSServer01 ;
    noria:logOriginatingManagementSystem noria:MonitoringSystem ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service not responding."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:DNSFailoverProcedure .

noria:Event_Router_Interface_Down_20240315 a noria:EventRecord ;
    rdfs:label "Core Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a critical interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-03-15T08:58:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:MonitoringSystem ;
    noria:logText "INTERFACE_STATUS_CHANGE: GigabitEthernet0/0/1 on cr01.dc-par-01.example.com changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmMonitoredAttribute noria:NI_CR01_Gi0_0_1 .

noria:Event_WebServer_CPU_Spike_20240316 a noria:EventRecord ;
    rdfs:label "Web Server CPU Spike Warning"@en ;
    rdfs:comment "Warning alert for high CPU utilization on E-commerce Web Server 01."@en ;
    noria:loggingTime "2024-03-16T14:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:WebServer01 ;
    noria:logOriginatingManagementSystem noria:MonitoringSystem ;
    noria:logText "WARNING: CPU usage on web01.ecommerce.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:Event_Firewall_Login_Attempt_20240317 a noria:EventRecord ;
    rdfs:label "Firewall Failed Login Attempt"@en ;
    rdfs:comment "Security event: multiple failed login attempts on Edge Firewall 01."@en ;
    noria:loggingTime "2024-03-17T02:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:EdgeFirewall01 ;
    noria:logOriginatingManagementSystem noria:MonitoringSystem ;
    noria:logText "SECURITY: Multiple failed login attempts detected from IP 203.0.113.42 on fw01.dc-par-01.example.com."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

noria:Event_DNS_Service_Restored_20240315 a noria:EventRecord ;
    rdfs:label "DNS Service Restored Notification"@en ;
    rdfs:comment "Notification indicating Corporate DNS Service has been restored."@en ;
    noria:loggingTime "2024-03-15T09:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:CorporateDNSServer01 ;
    noria:logOriginatingManagementSystem noria:MonitoringSystem ;
    noria:logText "INFO: Host dns01.corp.example.com is UP - DNS service responding normally."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

# --- Trouble Tickets ---
noria:TT_DNS_OUTAGE_20240315 a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:comment "Critical incident: Corporate DNS Server 01 became unreachable, impacting internal services."@en ;
    noria:documentExternalId "INC-20240315-001"@en ;
    noria:documentHRef <http://ticketing.example.com/ticket/INC-20240315-001> ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:Event_DNS_Outage_Alert_20240315 ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Hardware failure on primary DNS server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-03-15T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-03-15T09:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-03-15T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ;
    noria:troubleTicketRelatedParty noria:DNSAdminTeam, noria:NOC_Team ;
    noria:troubleTicketRelatedService noria:CorporateDNSService, noria:DNSPRODModule, noria:InternetAccessService ;
    noria:troubleTicketRelatedResource noria:CorporateDNSServer01 ;
    noria:troubleTicketImpacts noria:CorporateDNSServer01, noria:CorporateDNSService, noria:InternetAccessService ;
    noria:documentStatusHistory noria:Event_DNS_Outage_Alert_20240315, noria:Event_DNS_Service_Restored_20240315 ;
    noria:alarmMitigatedBy noria:Event_DNS_Service_Restored_20240315 . # This is a bit of a stretch, but EventRecord is a pep:ProcedureExecution, and TT is a pep:ProcedureExecutionContainer.

noria:TT_CRM_DB_ISSUE_20240316 a noria:TroubleTicket ;
    rdfs:label "CRM Database Performance Issue"@en ;
    rdfs:comment "Performance degradation observed on the Internal CRM database server."@en ;
    noria:documentExternalId "INC-20240316-002"@en ;
    noria:documentHRef <http://ticketing.example.com/ticket/INC-20240316-002> ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/User> ;
    noria:troubleTicketDetectionDateTime "2024-03-16T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty noria:AppSupportTeam ;
    noria:troubleTicketRelatedService noria:InternalCRM ;
    noria:troubleTicketRelatedResource noria:DatabaseServer01 ;
    noria:troubleTicketImpacts noria:DatabaseServer01, noria:InternalCRM .

# --- Trouble Ticket Notes ---
noria:TTN_DNS_DIAGNOSIS_20240315 a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Diagnosis Note"@en ;
    rdfs:comment "Initial diagnosis: Primary DNS server unresponsive. Initiated failover to secondary."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:created "2024-03-15T09:10:00Z"^^xsd:dateTime ;
    dcterms:creator noria:NOC_Team ;
    dcterms:isPartOf noria:TT_DNS_OUTAGE_20240315 .

noria:TTN_DNS_RESOLUTION_20240315 a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Resolution Note"@en ;
    rdfs:comment "Failover to secondary DNS server successful. Service restored. Investigating root cause of primary server failure."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:created "2024-03-15T09:40:00Z"^^xsd:dateTime ;
    dcterms:creator noria:DNSAdminTeam ;
    dcterms:isPartOf noria:TT_DNS_OUTAGE_20240315 ;
    noria:troubleTicketNoteCorrelatedExecution noria:TT_DNS_OUTAGE_20240315 . # The TT itself is a ProcedureExecutionContainer

# --- Change Requests ---
noria:CR_DNS_HA_UPGRADE_20240317 a noria:ChangeRequest ;
    rdfs:label "DNS High Availability Upgrade"@en ;
    rdfs:comment "Upgrade primary DNS server hardware and implement advanced HA features to prevent future outages."@en ;
    noria:documentExternalId "CR-20240317-001"@en ;
    noria:documentHRef <http://changemanagement.example.com/cr/CR-20240317-001> ;
    noria:changeRequestPlannedStartTime "2024-04-01T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-02T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/PreventativeMaintenance> ;
    noria:changeRequestImpact noria:CorporateDNSServer01, noria:CorporateDNSService ;
    noria:changeRequestOutageDuration "PT4H"^^xsd:duration ; # 4 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty noria:DNSAdminTeam ;
    noria:changeRequestPilotParty noria:JohnDoe ;
    noria:changeRequestActorParty noria:DNSAdminTeam ;
    noria:changeRequestIsRegulated false ;
    noria:documentStatusHistory noria:Event_DNS_Outage_Alert_20240315 . # Link to the event that triggered the CR

noria:CR_FIREWALL_RULE_ADD_20240318 a noria:ChangeRequest ;
    rdfs:label "Add Firewall Rule for New Application"@en ;
    rdfs:comment "Add new firewall rules on Edge Firewall 01 to allow traffic for a new internal application."@en ;
    noria:documentExternalId "CR-20240318-002"@en ;
    noria:documentHRef <http://changemanagement.example.com/cr/CR-20240318-002> ;
    noria:changeRequestPlannedStartTime "2024-03-20T18:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-03-20T18:30:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Normal> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/NetworkExtension> ;
    noria:changeRequestImpact noria:EdgeFirewall01 ;
    noria:changeRequestOutageDuration "PT0S"^^xsd:duration ; # No expected outage
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty noria:AppSupportTeam ;
    noria:changeRequestPilotParty noria:SecurityTeam ;
    noria:changeRequestActorParty noria:SecurityTeam ;
    noria:changeRequestIsRegulated true .

# --- Operation Plans, Pre/Post Conditions ---
noria:DNSFailoverProcedure a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for failing over primary DNS to secondary in case of outage."@en ;
    skos:example "Steps include verifying primary server status, activating secondary, and updating monitoring."@en ;
    noria:operationPlanPreCondition noria:DNS_Primary_Down_PreCond ;
    noria:operationPlanPostCondition noria:DNS_Secondary_Active_PostCond .

noria:FirewallRuleUpdatePlan a noria:OperationPlan ;
    rdfs:label "Firewall Rule Update Plan"@en ;
    rdfs:comment "Procedure for safely adding or modifying firewall rules."@en ;
    skos:example "Steps include rule review, staging, deployment, and verification."@en ;
    noria:operationPlanPreCondition noria:Firewall_Change_Approved_PreCond ;
    noria:operationPlanPostCondition noria:Firewall_Rule_Applied_PostCond .

noria:DNS_Primary_Down_PreCond a noria:ActionPreCondition ;
    rdfs:label "Primary DNS Server Down Pre-Condition"@en ;
    rdfs:comment "Condition: Corporate DNS Server 01 is unresponsive or unreachable."@en ;
    skos:example "Monitoring alert for dns01.corp.example.com reports critical status."@en .

noria:DNS_Secondary_Active_PostCond a noria:ActionPostCondition ;
    rdfs:label "Secondary DNS Server Active Post-Condition"@en ;
    rdfs:comment "Expected outcome: Corporate DNS Server 02 is actively serving DNS requests, and services are restored."@en ;
    skos:example "Monitoring reports dns02.corp.example.com is up, and internal services resolve names correctly."@en .

noria:Firewall_Change_Approved_PreCond a noria:ActionPreCondition ;
    rdfs:label "Firewall Change Approved Pre-Condition"@en ;
    rdfs:comment "Condition: The change request for firewall rule modification has been formally approved."@en ;
    skos:example "CR-20240318-002 status is 'Approved'."@en .

noria:Firewall_Rule_Applied_PostCond a noria:ActionPostCondition ;
    rdfs:label "Firewall Rule Applied Post-Condition"@en ;
    rdfs:comment "Expected outcome: New firewall rules are correctly applied and verified, allowing intended traffic."@en ;
    skos:example "Connectivity tests for the new application succeed through the firewall."@en .

# --- Document Attachments ---
noria:DNS_Topology_Diagram a noria:DocumentAttachment ;
    rdfs:label "DNS Topology Diagram"@en ;
    rdfs:comment "Diagram illustrating the architecture and connectivity of the corporate DNS service."@en ;
    dcterms:isPartOf noria:CR_DNS_HA_UPGRADE_20240317 ;
    dcterms:format "image/png"@en .

noria:Firewall_Change_Log a noria:DocumentAttachment ;
    rdfs:label "Firewall Configuration Change Log"@en ;
    rdfs:comment "Log file detailing the configuration changes applied to Edge Firewall 01."@en ;
    dcterms:isPartOf noria:CR_FIREWALL_RULE_ADD_20240318 ;
    dcterms:format "text/plain"@en .

noria:IncidentReport_DNS_Outage a noria:DocumentAttachment ;
    rdfs:label "DNS Outage Incident Report"@en ;
    rdfs:comment "Post-mortem report for the DNS server outage incident."@en ;
    dcterms:isPartOf noria:TT_DNS_OUTAGE_20240315 ;
    dcterms:format "application/pdf"@en .

# --- Additional connections for density ---
noria:DNSAdminTeam noria:agentManagesResource noria:CorporateDNSServer01, noria:CorporateDNSServer02 .
noria:NOC_Team noria:agentManagesResource noria:CoreRouter01, noria:Link_CR01_FW01 .
noria:AppSupportTeam noria:agentManagesResource noria:WebServer01, noria:DatabaseServer01 .
noria:SecurityTeam noria:agentManagesResource noria:EdgeFirewall01 .

noria:CorporateDNSServer01 noria:resourceForApplication noria:CorporateDNSService .
noria:CorporateDNSServer02 noria:resourceForApplication noria:CorporateDNSService .

noria:CoreRouter01 noria:clusterController noria:CoreRouter01 . # Self-referential for simplicity, or could point to a virtual controller.
noria:WebServer01 noria:clusterController noria:VMwareESXi . # Assuming ESXi host is the controller for VMs.

noria:NI_DNS01_Eth0 noria:networkInterfaceConnects noria:Link_DNS01_Switch .
noria:NI_DNS02_Eth0 noria:networkInterfaceConnects noria:Link_DNS02_Switch .

noria:CorporateDNSService seas:subSystemOf noria:CriticalBusinessService .
noria:EcommercePlatform seas:subSystemOf noria:CriticalBusinessService .

noria:TT_DNS_OUTAGE_20240315 noria:troubleTicketPartyIntervention noria:NOC_Team, noria:DNSAdminTeam .
noria:CR_DNS_HA_UPGRADE_20240317 dcterms:created "2024-03-17T11:00:00Z"^^xsd:dateTime .
noria:CR_FIREWALL_RULE_ADD_20240318 dcterms:created "2024-03-18T09:00:00Z"^^xsd:dateTime .

# Example of using noria:troubleTicketFreezeItem (linking to an EventRecord that describes a freeze)
noria:Event_TT_Freeze_20240315 a noria:EventRecord ;
    rdfs:label "Trouble Ticket Freeze Event"@en ;
    rdfs:comment "Event indicating that TT-DNS-OUTAGE-20240315 was temporarily frozen for external communication."@en ;
    noria:loggingTime "2024-03-15T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:MonitoringSystem ;
    noria:logText "Trouble Ticket INC-20240315-001 status changed to Frozen (awaiting vendor response)."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:TT_DNS_OUTAGE_20240315 noria:troubleTicketFreezeItem noria:Event_TT_Freeze_20240315 .

# Example of noria:troubleTicketCharacteristic (using a blank node for a characteristic)
noria:TT_DNS_OUTAGE_20240315 noria:troubleTicketCharacteristic [
    rdfs:label "Customer Impact Level"@en ;
    rdf:value "High"@en ;
    rdfs:comment "The level of impact on customer-facing services."@en
] .

noria:CR_DNS_HA_UPGRADE_20240317 noria:changeRequestSpecification <kos/ChangeRequest/specification/HardwareUpgrade> .
noria:CR_FIREWALL_RULE_ADD_20240318 noria:changeRequestSpecification <kos/ChangeRequest/specification/NetworkConfiguration> .

