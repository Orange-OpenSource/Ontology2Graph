# --- Trouble Ticket Notes ---
noria:TroubleTicketNote1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis for DNS Outage"@en, "Diagnostic Initial Panne DNS"@fr ;
    rdfs:comment "Initial investigation shows no network connectivity to dns01.corp.example.com. Pinging from core router fails."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:created "2024-03-20T10:10:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Person1 ;
