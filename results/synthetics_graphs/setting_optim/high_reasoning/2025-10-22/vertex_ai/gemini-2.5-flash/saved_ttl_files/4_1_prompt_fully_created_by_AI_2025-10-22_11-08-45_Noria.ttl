# --- Event Records ---
noria:EventRecord1 a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en, "Journal Serveur DNS Inaccessible"@fr ;
    rdfs:comment "Log entry indicating that the primary DNS server became unreachable."@en ;
    noria:loggingTime "2024-03-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: DNS server dns01.corp.example.com is unreachable via ICMP."@en ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:ApplicationModule1 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord2 a noria:EventRecord ;
    rdfs:label "High CPU on Web Server Alert"@en, "Alerte CPU Élevé sur Serveur Web"@fr ;
    rdfs:comment "Alert generated due to sustained high CPU utilization on a web server host."@en ;
    noria:loggingTime "2024-03-20T14:15:30Z"^^xsd:dateTime ;
    noria:logText "WARNING: CPU utilization on webhost03.corp.example.com exceeded 90% for 15 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource3 ;
    noria:logOriginatingManagementSystem noria:ApplicationModule3 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord3 a noria:EventRecord ;
    rdfs:label "Interface Down Alert R1-ge-0/0/1"@en, "Alerte Interface Hors Service R1-ge-0/0/1"@fr ;
    rdfs:comment "Alert indicating that network interface ge-0/0/1 on Core Router R1 went down."@en ;
    noria:loggingTime "2024-03-21T08:00:10Z"^^xsd:dateTime ;
    noria:logText "INTERFACE_STATUS_CHANGE: Interface ge-0/0/1 on router-core-r1 changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingManagementSystem noria:ApplicationModule2 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction noria:OperationPlan2 .

noria:EventRecord4 a noria:EventRecord ;
    rdfs:label "Router Firmware Upgrade Start Log"@en, "Journal Début Mise à Jour Firmware Routeur"@fr ;
    rdfs:comment "Log entry indicating the start of a firmware upgrade procedure on Core Router R1."@en ;
    noria:loggingTime "2024-03-22T02:00:00Z"^^xsd:dateTime ;
    noria:logText "SYSTEM_MAINTENANCE: Firmware upgrade initiated on router-core-r1 by asmith."@en ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingAgent foaf:Person1 ;
    noria:logOriginatingManagementSystem noria:ApplicationModule2 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord5 a noria:EventRecord ;
    rdfs:label "Database Connection Error Log"@en, "Journal Erreur Connexion Base de Données"@fr ;
    rdfs:comment "Log entry showing repeated database connection errors from the application."@en ;
    noria:loggingTime "2024-03-20T14:16:00Z"^^xsd:dateTime ;
    noria:logText "ERROR: Failed to connect to database db01.corp.example.com from webhost03."@en ;
    noria:logOriginatingManagedObject noria:Resource4 ;
    noria:logOriginatingManagementSystem noria:ApplicationModule3 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord6 a noria:EventRecord ;
    rdfs:label "DNS Service Restored Log"@en, "Journal Service DNS Restauré"@fr ;
    rdfs:comment "Log entry confirming the restoration of the primary DNS service."@en ;
    noria:loggingTime "2024-03-20T10:35:00Z"^^xsd:dateTime ;
    noria:logText "INFO: DNS server dns01.corp.example.com is now reachable and responding to queries."@en ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:ApplicationModule1 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    noria:alarmMitigatedBy noria:TroubleTicket1 . # Linking the resolution event to the TT

# --- Trouble Tickets ---
noria:TroubleTicket1 a noria:TroubleTicket ;
