    noria:networkLinkInstallationDate "2021-11-01T16:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "MPLS VPN"@en ;
    noria:resourceManagedBy foaf:Agent4 .

# --- Applications ---
noria:Application1 a noria:Application ;
