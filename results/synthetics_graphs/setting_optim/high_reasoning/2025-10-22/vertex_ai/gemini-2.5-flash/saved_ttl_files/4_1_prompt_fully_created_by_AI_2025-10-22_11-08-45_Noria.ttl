noria:TroubleTicket3 a noria:TroubleTicket ;
    rdfs:label "Core Router Interface Down"@en, "Interface Routeur Cœur Hors Service"@fr ;
    rdfs:comment "Network interface ge-0/0/1 on Core Router R1 went down, impacting connectivity to DNS server."@en ;
