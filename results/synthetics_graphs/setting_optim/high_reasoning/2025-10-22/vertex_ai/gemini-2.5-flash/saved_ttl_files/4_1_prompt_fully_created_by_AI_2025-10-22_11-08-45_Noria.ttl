# --- Operation Plans ---
noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "DNS Server Restart Procedure"@en, "Procédure de Redémarrage Serveur DNS"@fr ;
    rdfs:comment "Standard operating procedure for restarting a corporate DNS server in case of unresponsiveness."@en ;
    skos:example "Steps include checking network connectivity, attempting graceful shutdown, forced reboot if necessary, and post-restart verification."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Router Interface Troubleshooting Guide"@en, "Guide de Dépannage Interface Routeur"@fr ;
    rdfs:comment "Procedure for diagnosing and resolving issues with a network interface on a core router."@en ;
    skos:example "Includes checking cable, interface status, configuration, and physical layer tests."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

noria:OperationPlan3 a noria:OperationPlan ;
    rdfs:label "Web Server Scaling Guide"@en, "Guide de Mise à l'Échelle Serveur Web"@fr ;
    rdfs:comment "Procedure for dynamically scaling web server resources in response to high load."@en ;
    skos:example "Steps involve deploying new VM instances, configuring load balancers, and monitoring performance metrics."@en .

# --- Action Pre/Post Conditions ---
noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unresponsive"@en, "Service DNS Non Répondant"@fr ;
    rdfs:comment "Condition where the DNS service is not responding to queries or is unreachable."@en ;
    skos:example "Ping to DNS server fails, DNS queries timeout."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en, "Service DNS Restauré"@fr ;
    rdfs:comment "Expected outcome: DNS service is fully operational and responsive."@en ;
    skos:example "Ping to DNS server succeeds, DNS queries resolve correctly."@en .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down"@en, "Interface Réseau Hors Service"@fr ;
    rdfs:comment "Condition where a network interface reports an 'administratively down' or 'operationally down' status."@en ;
    skos:example "Interface status command shows 'down', no link light."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up"@en, "Interface Réseau Active"@fr ;
    rdfs:comment "Expected outcome: Network interface is operational and passing traffic."@en ;
    skos:example "Interface status command shows 'up', link light is solid green."@en .

# --- Additional connections for density ---
foaf:Agent1 noria:agentManagesResource noria:Resource1, noria:ApplicationModule1 .
foaf:Agent2 noria:agentManagesResource noria:Resource2, noria:NetworkLink1, noria:NetworkLink2, noria:ApplicationModule2 .
foaf:Agent3 noria:agentManagesResource noria:Resource3, noria:ApplicationModule3, noria:ApplicationModule4 .
foaf:Agent4 noria:agentManagesResource noria:Resource5, noria:NetworkLink3 .
foaf:Agent5 noria:agentManagesResource noria:Resource4 .

noria:Application1 seas:subSystemOf noria:Service1 .
noria:Application2 seas:subSystemOf noria:Service1 .
noria:Application3 seas:subSystemOf noria:Service2 .

noria:Resource1 noria:resourceForApplication noria:Application1 .
noria:Resource2 noria:resourceForApplication noria:Application2 .
noria:Resource3 noria:resourceForApplication noria:Application3 .
noria:Resource4 noria:resourceForApplication noria:Application3 .
noria:Resource5 noria:resourceForApplication noria:Application2 .

noria:TroubleTicket1 noria:troubleTicketCharacteristic <http://example.com/characteristic/HighImpact> .
noria:TroubleTicket2 noria:troubleTicketCharacteristic <http://example.com/characteristic/CustomerVisible> .
noria:TroubleTicket3 noria:troubleTicketCharacteristic <http://example.com/characteristic/NetworkCritical> .

noria:ChangeRequest1 noria:actionCorrelatedOperationPlan noria:OperationPlan1 . # Example, assuming a restart is part of firmware upgrade
noria:ChangeRequest2 noria:actionCorrelatedOperationPlan noria:OperationPlan3 . # Example, assuming scaling is part of migration

# --- Example of observable properties for NetworkInterface ---
noria:NetworkInterface2 noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetworkInterface3 noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -4 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

