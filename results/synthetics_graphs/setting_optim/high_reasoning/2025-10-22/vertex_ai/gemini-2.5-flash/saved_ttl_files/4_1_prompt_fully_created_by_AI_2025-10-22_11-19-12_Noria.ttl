# =============================================================================
# Dynamic Elements (Trouble Tickets, Event Records, Change Requests, Notes)
# =============================================================================

# Event Records
noria:EventRecordDNSFailure
    a noria:EventRecord ;
    rdfs:label "DNS Resolution Failure Alert"@en, "Alerte Échec Résolution DNS"@fr ;
    rdfs:comment "Automated alert indicating a failure in DNS resolution for dns01.corp.example.com."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "DNS server dns01.corp.example.com is not responding to queries. High latency detected."@en ;
    noria:logOriginatingManagedObject noria:ResourceDNS01 ;
    noria:logOriginatingManagementSystem noria:ApplicationMonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlanRestartDNS .

noria:EventRecordWebSrvHighCPU
    a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en, "Alerte CPU Élevé Serveur Web"@fr ;
    rdfs:comment "Alert indicating sustained high CPU utilization on websrv01."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on websrv01.corp.example.com exceeded 90% for 15 minutes."@en ;
    noria:logOriginatingManagedObject noria:ResourceWebSrv01 ;
    noria:logOriginatingManagementSystem noria:ApplicationMonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecordFirewallConfigChange
    a noria:EventRecord ;
    rdfs:label "Firewall Configuration Change Log"@en, "Journal Modification Configuration Pare-feu"@fr ;
    rdfs:comment "Log entry for a configuration change applied to Firewall 01."@en ;
    noria:loggingTime "2024-04-19T16:45:00Z"^^xsd:dateTime ;
    noria:logText "User 'admin' applied new security policy 'Internet_Access_V2'."@en ;
    noria:logOriginatingManagedObject noria:ResourceFirewall01 ;
    noria:logOriginatingAgent noria:CUidAlice ; # Assuming Alice might have admin access for some tasks
    noria:logOriginatingManagementSystem noria:ApplicationMonitoringSystem .

noria:EventRecordDBSrvDiskFull
    a noria:EventRecord ;
    rdfs:label "Database Server Disk Full Alert"@en, "Alerte Disque Plein Serveur BD"@fr ;
    rdfs:comment "Alert indicating that the database server's disk space is critically low."@en ;
    noria:loggingTime "2024-04-21T02:15:00Z"^^xsd:dateTime ;
    noria:logText "Disk usage on /var/lib/mysql on dbsrv01.corp.example.com is at 98%."@en ;
    noria:logOriginatingManagedObject noria:ResourceDBSrv01 ;
    noria:logOriginatingManagementSystem noria:ApplicationMonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

# Trouble Tickets
noria:TroubleTicketDNSOutage
    a noria:TroubleTicket ;
    rdfs:label "Critical DNS Outage"@en, "Panne DNS Critique"@fr ;
    rdfs:comment "DNS server dns01.corp.example.com is unresponsive, impacting all services relying on name resolution."@en ;
    dcterms:created "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:documentExternalId "INC-20240420-001" ;
    noria:documentHRef "https://itsm.example.com/ticket/INC-20240420-001"^^xsd:anyURI ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecordDNSFailure ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/InaccessibleDestination> ;
    noria:troubleTicketCause "Unidentified process consuming all CPU resources on DNS01."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ; # Assuming DNS is part of backbone
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty org:TeamDNSAdmin, foaf:PersonAlice ;
    noria:troubleTicketRelatedService noria:ApplicationInternalDNS, noria:ApplicationModuleInternalDNSProd ;
    noria:troubleTicketRelatedResource noria:ResourceDNS01 ;
    noria:troubleTicketImpacts noria:ApplicationCorporateWeb, noria:ServiceInternetAccess ;
    noria:documentStatusHistory noria:EventRecordTTDNSOutageStatusChange1 .

noria:TroubleTicketWebSrvPerformance
    a noria:TroubleTicket ;
    rdfs:label "Web Server Performance Degradation"@en, "Dégradation Performance Serveur Web"@fr ;
    rdfs:comment "Users report slow response times for the corporate web application due to high CPU on websrv01."@en ;
    dcterms:created "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:documentExternalId "INC-20240420-002" ;
    noria:documentHRef "https://itsm.example.com/ticket/INC-20240420-002"^^xsd:anyURI ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/CorruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/User> ;
    noria:troubleTicketTrigger noria:EventRecordWebSrvHighCPU ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "Prometheus" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/DowngradingEquipment> ;
    noria:troubleTicketCause "Unoptimized database queries leading to high CPU load on web server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty org:TeamWebOps, foaf:PersonBob ;
    noria:troubleTicketRelatedService noria:ApplicationCorporateWeb, noria:ApplicationModuleCWAProd ;
    noria:troubleTicketRelatedResource noria:ResourceWebSrv01, noria:ResourceDBSrv01 ;
    noria:troubleTicketImpacts noria:ServiceWebHosting .

# Trouble Ticket Notes
noria:TroubleTicketNoteDNSOutage1
    a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Initial Diagnosis"@en, "Diagnostic Initial Panne DNS"@fr ;
    rdfs:comment "Initial diagnosis: High CPU on DNS01, no specific process identified yet. Restarting DNS service."@en ;
    dcterms:created "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:PersonAlice ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicketDNSOutage .

noria:TroubleTicketNoteDNSOutage2
    a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Resolution Update"@en, "Mise à Jour Résolution Panne DNS"@fr ;
    rdfs:comment "DNS service restarted, resolution restored. Monitoring for stability. Root cause still under investigation."@en ;
    dcterms:created "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:PersonAlice ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:isPartOf noria:TroubleTicketDNSOutage ;
    noria:troubleTicketNoteCorrelatedExecution noria:EventRecordDNSOutageStatusChange2 .

# Change Requests
noria:ChangeRequestWebAppUpgrade
    a noria:ChangeRequest ;
    rdfs:label "Corporate Web App Major Upgrade"@en, "Mise à Jour Majeure App Web Entreprise"@fr ;
