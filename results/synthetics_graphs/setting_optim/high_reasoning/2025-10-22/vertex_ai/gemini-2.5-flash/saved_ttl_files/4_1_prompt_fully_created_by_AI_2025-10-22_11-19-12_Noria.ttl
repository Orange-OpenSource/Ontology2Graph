bot:SiteParisDC
    a bot:Site ;
    rdfs:label "Paris Data Center"@en, "Centre de Données de Paris"@fr ;
    rdfs:comment "Primary data center for corporate IT infrastructure."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressStreet "Rue de la Paix" .

bot:SiteLyonDR
    a bot:Site ;
    rdfs:label "Lyon Disaster Recovery Site"@en, "Site de Reprise après Sinistre de Lyon"@fr ;
    rdfs:comment "Secondary data center for disaster recovery and backup services."@en ;
    noria:siteId "DR-LYN-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressStreet "Avenue Jean Jaurès" .

noria:RoomServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace noria:LocusRackA1, noria:LocusRackA2 ;
    bot:hasSpace bot:SiteParisDC . # Assuming bot:hasSpace can link a room to its site.

noria:RoomNetworkRoomB
    a noria:Room ;
    rdfs:label "Network Room B"@en, "Salle Réseau B"@fr ;
    rdfs:comment "Dedicated room for network equipment in Paris Data Center."@en ;
    bot:hasSpace noria:LocusRackB1 ;
    bot:hasSpace bot:SiteParisDC .

noria:LocusRackA1
    a noria:Locus ;
    rdfs:label "Rack A1"@en, "Baie A1"@fr ;
    rdfs:comment "First rack in Server Room A, hosting critical servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

noria:LocusRackA2
    a noria:Locus ;
    rdfs:label "Rack A2"@en, "Baie A2"@fr ;
    rdfs:comment "Second rack in Server Room A, hosting database servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" .

noria:LocusRackB1
    a noria:Locus ;
    rdfs:label "Rack B1"@en, "Baie B1"@fr ;
    rdfs:comment "First rack in Network Room B, hosting core routers."@en ;
    noria:locusLine "B" ;
    noria:locusRow "1" .

