    noria:changeRequestActorParty org:TeamSecurityOps ;
    noria:changeRequestIsRegulated false .

# Document Attachments
noria:DocumentAttachmentDNSDiagReport
    a noria:DocumentAttachment ;
    rdfs:label "DNS Outage Diagnostic Report"@en ;
    rdfs:comment "Detailed diagnostic report for the DNS outage, including packet captures and system logs."@en ;
    dcterms:created "2024-04-20T11:15:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:TroubleTicketDNSOutage ;
    dcterms:format "application/pdf" .

# Event Records for Status Changes (part of documentStatusHistory)
noria:EventRecordTTDNSOutageStatusChange1
    a noria:EventRecord ;
    rdfs:label "Trouble Ticket DNS Outage Status Change: Initialised"@en ;
    rdfs:comment "Status change for TroubleTicketDNSOutage to Initialised."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logText "Status changed from New to Initialised."@en ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    dcterms:references noria:TroubleTicketDNSOutage .

noria:EventRecordTTDNSOutageStatusChange2
    a noria:EventRecord ;
    rdfs:label "Trouble Ticket DNS Outage Status Change: InProgress"@en ;
    rdfs:comment "Status change for TroubleTicketDNSOutage to InProgress."@en ;
    noria:loggingTime "2024-04-20T09:20:00Z"^^xsd:dateTime ;
    noria:logText "Status changed from Initialised to InProgress."@en ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    dcterms:references noria:TroubleTicketDNSOutage .

noria:EventRecordCRWebAppUpgradeStatusChange1
    a noria:EventRecord ;
    rdfs:label "Change Request Web App Upgrade Status Change: Approved"@en ;
    rdfs:comment "Status change for ChangeRequestWebAppUpgrade to Approved."@en ;
    noria:loggingTime "2024-04-18T14:00:00Z"^^xsd:dateTime ;
    noria:logText "Status changed from Pending Approval to Approved."@en ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    dcterms:references noria:ChangeRequestWebAppUpgrade .

# =============================================================================
# Procedural Elements (Operation Plans, Pre/Post Conditions)
# =============================================================================

# Operation Plans
noria:OperationPlanRestartDNS
    a noria:OperationPlan ;
    rdfs:label "Restart DNS Service Procedure"@en, "Procédure Redémarrage Service DNS"@fr ;
    rdfs:comment "Standard operating procedure for restarting the corporate DNS service on a server."@en ;
    skos:example "Steps include checking process status, attempting graceful restart, forced restart if necessary, and verification."@en ;
    noria:operationPlanPreCondition noria:ActionPreConditionDNSUnresponsive ;
    noria:operationPlanPostCondition noria:ActionPostConditionDNSRestored .

noria:OperationPlanWebAppRollback
    a noria:OperationPlan ;
    rdfs:label "Web Application Rollback Procedure"@en, "Procédure Retour Arrière Application Web"@fr ;
    rdfs:comment "Procedure to revert the Corporate Web Application to a previous stable version in case of critical issues after an upgrade."@en ;
    skos:example "Steps include database rollback, code deployment of previous version, and service restart."@en ;
    noria:operationPlanPreCondition noria:ActionPreConditionWebAppBroken ;
    noria:operationPlanPostCondition noria:ActionPostConditionWebAppFunctional .

# Action Pre-Conditions
noria:ActionPreConditionDNSUnresponsive
    a noria:ActionPreCondition ;
    rdfs:label "DNS Server Unresponsive"@en, "Serveur DNS Ne Répond Pas"@fr ;
    rdfs:comment "Condition: DNS server is not responding to queries or showing high latency."@en ;
    skos:example "Ping to DNS server fails, dig queries timeout."@en .

noria:ActionPreConditionWebAppBroken
    a noria:ActionPreCondition ;
    rdfs:label "Web Application Broken"@en, "Application Web Cassée"@fr ;
    rdfs:comment "Condition: Web application is returning 5xx errors or is completely inaccessible after a change."@en ;
    skos:example "HTTP 500 errors, application logs show critical errors."@en .

# Action Post-Conditions
noria:ActionPostConditionDNSRestored
    a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en, "Service DNS Restauré"@fr ;
    rdfs:comment "Expected outcome: DNS server is responding to queries, resolution is successful, and latency is normal."@en ;
    skos:example "Ping to DNS server succeeds, dig queries return correct results within acceptable latency."@en .

noria:ActionPostConditionWebAppFunctional
    a noria:ActionPostCondition ;
    rdfs:label "Web Application Functional"@en, "Application Web Fonctionnelle"@fr ;
    rdfs:comment "Expected outcome: Web application is accessible, responding with 200 OK, and performing as expected."@en ;
    skos:example "HTTP 200 OK, user login successful, page load times are normal."@en .

# Linking Operation Plans to Actions (example)
noria:TroubleTicketDNSOutage
    noria:troubleTicketCharacteristic noria:OperationPlanRestartDNS . # This is a bit of a stretch, but noria:troubleTicketCharacteristic is a generic object property. A more direct link would be via pep:ProcedureExecution.

# Example of an EventRecord being part of a ProcedureExecutionContainer (TroubleTicket)
# This is implicitly handled by noria:documentStatusHistory, but let's add a direct pep:member for demonstration.
noria:TroubleTicketDNSOutage
    pep:member noria:EventRecordDNSFailure .

noria:ChangeRequestWebAppUpgrade
    pep:member noria:EventRecordCRWebAppUpgradeStatusChange1 .

# Example of actionCorrelatedOperationPlan
noria:EventRecordFirewallConfigChange
    a pep:ChangeAction ; # Assuming this log represents a change action
    noria:actionCorrelatedOperationPlan noria:OperationPlanFirewallUpdate .

noria:OperationPlanFirewallUpdate
    a noria:OperationPlan ;
    rdfs:label "Firewall Rule Update Procedure"@en ;
    rdfs:comment "Standard procedure for updating firewall rules."@en .

# End of Graph
