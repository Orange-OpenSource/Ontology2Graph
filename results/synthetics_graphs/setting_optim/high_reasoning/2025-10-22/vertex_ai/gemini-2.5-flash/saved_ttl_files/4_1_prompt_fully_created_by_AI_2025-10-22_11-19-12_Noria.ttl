    rdfs:comment "Management IP address for Perimeter Firewall 01."@en ;
    observable:ipAddressValue "10.0.0.254" .

# Network Interfaces
noria:NetworkInterfaceDNS01Eth0
    a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en, "DNS01 Ethernet 0"@fr ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:ResourceDNS01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to corporate LAN."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterfaceWebSrv01Eth0
    a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en, "WebSrv01 Ethernet 0"@fr ;
    rdfs:comment "Primary network interface for WebSrv01."@en ;
    noria:networkInterfaceOf noria:ResourceWebSrv01 ;
    noria:networkInterfaceDescription "Ethernet interface for web application traffic."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterfaceDBSrv01Eth0
    a noria:NetworkInterface ;
    rdfs:label "DBSrv01 Ethernet 0"@en, "DBSrv01 Ethernet 0"@fr ;
    rdfs:comment "Primary network interface for DBSrv01."@en ;
    noria:networkInterfaceOf noria:ResourceDBSrv01 ;
    noria:networkInterfaceDescription "Ethernet interface for database traffic."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterfaceCR01GigE0_0_0
    a noria:NetworkInterface ;
    rdfs:label "CR01 GigE 0/0/0"@en, "CR01 GigE 0/0/0"@fr ;
    rdfs:comment "Gigabit Ethernet interface on Core Router 01, connected to internal LAN."@en ;
    noria:networkInterfaceOf noria:ResourceCoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to server network."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterfaceFW01Eth1
    a noria:NetworkInterface ;
    rdfs:label "FW01 Ethernet 1"@en, "FW01 Ethernet 1"@fr ;
    rdfs:comment "External interface of Firewall 01, connected to ISP."@en ;
    noria:networkInterfaceOf noria:ResourceFirewall01 ;
    noria:networkInterfaceDescription "WAN interface to Internet."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# Network Links
noria:NetworkLinkLANServer
    a noria:NetworkLink ;
    rdfs:label "LAN Server Segment"@en, "Segment LAN Serveurs"@fr ;
    rdfs:comment "Local Area Network segment connecting servers in Rack A1 and A2."@en ;
    noria:networkLinkId "LAN-SRV-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-01T08:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterfaceDNS01Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterfaceWebSrv01Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterfaceDBSrv01Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterfaceCR01GigE0_0_0 ;
    noria:resourceManagedBy org:TeamNetworkOps .

noria:NetworkLinkWANInternet
    a noria:NetworkLink ;
    rdfs:label "WAN Internet Uplink"@en, "Liaison WAN Internet"@fr ;
    rdfs:comment "Wide Area Network link providing Internet access."@en ;
    noria:networkLinkId "WAN-INT-001" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2021-10-01T10:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterfaceFW01Eth1 ;
    noria:networkLinkTerminationResourceOrigin noria:ResourceFirewall01 ;
    noria:resourceManagedBy org:TeamNetworkOps .

# =============================================================================
# Functional Elements (Applications, Application Modules, Services)
# =============================================================================

# Applications
noria:ApplicationCorporateWeb
    a noria:Application ;
    rdfs:label "Corporate Web Application"@en, "Application Web d'Entreprise"@fr ;
    rdfs:comment "The main public-facing web application of the company."@en ;
    noria:applicationModelIdentifier "CWA-V1" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CWA" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
