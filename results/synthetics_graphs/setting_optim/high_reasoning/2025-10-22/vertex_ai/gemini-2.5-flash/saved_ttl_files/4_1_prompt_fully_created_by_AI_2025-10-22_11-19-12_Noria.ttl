    noria:changeRequestSpecification <kos/ChangeRequest/specification/StandardUpgradeProcedure> ;
    noria:changeRequestInitiatorParty foaf:PersonBob ;
    noria:changeRequestPilotParty foaf:PersonBob ;
    noria:changeRequestActorParty org:TeamWebOps ;
    noria:changeRequestIsRegulated true ;
    noria:documentStatusHistory noria:EventRecordCRWebAppUpgradeStatusChange1 .

noria:ChangeRequestFirewallPolicyUpdate
    a noria:ChangeRequest ;
    rdfs:label "Firewall Policy Update for New Service"@en, "Mise à Jour Politique Pare-feu pour Nouveau Service"@fr ;
    rdfs:comment "Update firewall rules to allow traffic for a new internal service."@en ;
    dcterms:created "2024-04-17T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-18T10:00:00Z"^^xsd:dateTime ;
    noria:documentExternalId "CR-20240422-002" ;
    noria:documentHRef "https://itsm.example.com/change/CR-20240422-002"^^xsd:anyURI ;
    noria:changeRequestPlannedStartTime "2024-04-22T14:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-22T15:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/NetworkExtension> ;
    noria:changeRequestImpact noria:ResourceFirewall01 ;
    noria:changeRequestOutageDuration "PT0H"^^xsd:duration ; # 0 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/FirewallRuleAddProcedure> ;
    noria:changeRequestInitiatorParty org:TeamNetworkOps ;
