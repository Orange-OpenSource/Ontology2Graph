# Adding more operation plans and conditions
noria:OperationPlan_TroubleshootPortFlap a noria:OperationPlan ;
    rdfs:label "Troubleshoot Port Flap Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving network port flapping issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_PortFlapping ;
    noria:operationPlanPostCondition noria:ActionPostCondition_PortStable .

noria:ActionPreCondition_PortFlapping a noria:ActionPreCondition ;
    rdfs:label "Port Flapping Pre-Condition"@en ;
    rdfs:comment "Network interface repeatedly changes operational state (up/down) in a short period."@en ;
    skos:example "Interface_status_changes_per_minute > 5" .

noria:ActionPostCondition_PortStable a noria:ActionPostCondition ;
    rdfs:label "Port Stable Post-Condition"@en ;
    rdfs:comment "Network interface operational state remains stable for an extended period."@en ;
    skos:example "Interface_status_changes_per_minute = 0 for 30 minutes" .

