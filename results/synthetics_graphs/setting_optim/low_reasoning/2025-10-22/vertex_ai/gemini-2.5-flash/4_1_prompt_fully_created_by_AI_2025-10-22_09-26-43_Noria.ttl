noria:TroubleTicket_DNSOutage a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:comment "Critical incident: Corporate DNS server is down, impacting internet access."@en ;
    dcterms:identifier "TT-20240420-001" ;
    dcterms:created "2024-04-20T09:01:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketRelatedService noria:Application_CorporateInternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketRelatedParty org:Team_NetworkOperations ;
    noria:troubleTicketDescription "DNS server unreachable causing internet access issues for all users. Services relying on DNS are affected."@en ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_DNSOutageLog ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketImpacts noria:Application_CorporateInternetAccess, noria:Resource_DNS01, noria:Service_CustomerFacingWebPortal .

noria:TroubleTicket_WebSrvPerformance a noria:TroubleTicket ;
    rdfs:label "Corporate Website Performance Degradation"@en ;
