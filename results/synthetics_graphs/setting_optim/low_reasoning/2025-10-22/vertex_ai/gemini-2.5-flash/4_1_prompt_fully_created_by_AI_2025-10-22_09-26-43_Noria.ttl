    noria:operationPlanPostCondition noria:ActionPostCondition_UserCanLogin .

noria:ActionPreCondition_UserCannotLogin a noria:ActionPreCondition ;
    rdfs:label "User Cannot Login Pre-Condition"@en ;
    rdfs:comment "User reports inability to log into any system, and account is not locked."@en ;
    skos:example "User_status = 'active' AND Login_attempts_failed > 3" .

noria:ActionPostCondition_UserCanLogin a noria:ActionPostCondition ;
    rdfs:label "User Can Login Post-Condition"@en ;
    rdfs:comment "User successfully logs into a corporate system after password reset."@en ;
    skos:example "User_login_status = 'success'" .

