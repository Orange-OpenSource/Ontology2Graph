# --- Operation Plans, Pre/Post Conditions ---

noria:OperationPlan_CheckFiberLink a noria:OperationPlan ;
    rdfs:label "Check Fiber Link Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing fiber optic link issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_FiberLinkDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_FiberLinkRestored, noria:ActionPostCondition_FiberLinkConfirmedBroken .

noria:ActionPreCondition_FiberLinkDown a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Down Pre-Condition"@en ;
    rdfs:comment "Network interface operational status is 'down' and administrative status is 'up'."@en ;
    skos:example "noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/down> AND noria:networkInterfaceAdministrativeStatus = <kos/Resource/AdministrativeState/up>" .

noria:ActionPostCondition_FiberLinkRestored a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Restored Post-Condition"@en ;
    rdfs:comment "Network interface operational status is 'up' and traffic flows normally."@en ;
    skos:example "noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/up> AND traffic_flow_normal = true" .

noria:ActionPostCondition_FiberLinkConfirmedBroken a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Confirmed Broken Post-Condition"@en ;
    rdfs:comment "Physical inspection confirms fiber damage, requiring replacement."@en ;
    skos:example "Physical inspection result = 'fiber cut' OR 'damaged connector'" .

noria:OperationPlan_RestartVM a noria:OperationPlan ;
    rdfs:label "Restart Virtual Machine Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a virtual machine."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_VMUnresponsive ;
    noria:operationPlanPostCondition noria:ActionPostCondition_VMRunningNormally .

noria:ActionPreCondition_VMUnresponsive a noria:ActionPreCondition ;
    rdfs:label "VM Unresponsive Pre-Condition"@en ;
    rdfs:comment "Virtual machine is not responding to ping or application requests."@en ;
    skos:example "VM_ping_status = 'unreachable' OR application_health_check = 'failed'" .

noria:ActionPostCondition_VMRunningNormally a noria:ActionPostCondition ;
    rdfs:label "VM Running Normally Post-Condition"@en ;
    rdfs:comment "Virtual machine is powered on, responsive, and applications are functional."@en ;
    skos:example "VM_ping_status = 'reachable' AND application_health_check = 'passed'" .

