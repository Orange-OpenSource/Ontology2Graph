    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceDescription "Web traffic interface" .

noria:NetworkInterface_DB01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DB01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DB01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DB01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceDescription "Database traffic interface" .

noria:NetworkInterface_RouterCore01_Ge0_0_0 a noria:NetworkInterface ;
    rdfs:label "CR01 GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Uplink interface from Core Router 01 to ISP."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceDescription "ISP Uplink 1" .

noria:NetworkInterface_RouterCore01_Ge0_0_1 a noria:NetworkInterface ;
    rdfs:label "CR01 GigabitEthernet 0/0/1"@en ;
