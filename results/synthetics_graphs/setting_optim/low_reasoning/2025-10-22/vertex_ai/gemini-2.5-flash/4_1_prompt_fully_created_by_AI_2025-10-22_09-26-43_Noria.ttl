# More Operation Plans
noria:OperationPlan_DiagnoseHighCPULoad a noria:OperationPlan ;
    rdfs:label "Diagnose High CPU Load Procedure"@en ;
    rdfs:comment "Procedure for investigating and resolving high CPU utilization on servers."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_HighCPULoad ;
    noria:operationPlanPostCondition noria:ActionPostCondition_CPULoadNormalized .

noria:ActionPreCondition_HighCPULoad a noria:ActionPreCondition ;
    rdfs:label "High CPU Load Pre-Condition"@en ;
    rdfs:comment "Server CPU utilization consistently above 80% for more than 5 minutes."@en ;
    skos:example "CPU_utilization > 80% for duration > 5m" .

noria:ActionPostCondition_CPULoadNormalized a noria:ActionPostCondition ;
    rdfs:label "CPU Load Normalized Post-Condition"@en ;
    rdfs:comment "Server CPU utilization returned to normal levels (below 50%)."@en ;
    skos:example "CPU_utilization < 50%" .

noria:OperationPlan_TroubleshootDBConnectivity a noria:OperationPlan ;
    rdfs:label "Troubleshoot Database Connectivity Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving database connection issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DBConnectionErrors ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DBConnectionsRestored .

noria:ActionPreCondition_DBConnectionErrors a noria:ActionPreCondition ;
    rdfs:label "Database Connection Errors Pre-Condition"@en ;
    rdfs:comment "Applications report database connection failures or timeouts."@en ;
    skos:example "Application_logs contain 'DB connection failed' OR 'SQL timeout'" .

noria:ActionPostCondition_DBConnectionsRestored a noria:ActionPostCondition ;
    rdfs:label "Database Connections Restored Post-Condition"@en ;
    rdfs:comment "Applications can successfully connect to the database."@en ;
    skos:example "Application_health_check = 'DB connected' AND no_new_DB_errors" .

