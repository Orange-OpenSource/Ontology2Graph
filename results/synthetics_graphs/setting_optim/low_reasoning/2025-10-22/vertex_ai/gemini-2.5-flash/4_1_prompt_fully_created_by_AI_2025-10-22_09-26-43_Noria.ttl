# --- Locations (bot:Site, noria:Room, noria:Locus) ---

bot:Site_DataCenterParis a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris, France."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" ;
    wgs84_pos:lat "48.8699"^^xsd:float ;
    wgs84_pos:long "2.3333"^^xsd:float .

bot:Site_OfficeLondon a bot:Site ;
    rdfs:label "London Office"@en ;
    rdfs:comment "Main corporate office in London, UK."@en ;
    noria:siteId "OFF-LDN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Baker Street" ;
    noria:sitePrincipalAddressPostalCode "NW1 6XE" ;
    noria:sitePrincipalAddressCityName "London" ;
    noria:sitePrincipalAddressCountry "UK" ;
    wgs84_pos:lat "51.5237"^^xsd:float ;
    wgs84_pos:long "-0.1585"^^xsd:float .

noria:Room_ServerRoomA bot:containsZone noria:Locus_RackA1, noria:Locus_RackA2, noria:Locus_RackA3 ;
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace bot:Site_DataCenterParis .

noria:Room_NetworkClosetB a noria:Room ;
    rdfs:label "Network Closet B"@en ;
    rdfs:comment "Network equipment closet in London Office."@en ;
    bot:hasSpace bot:Site_OfficeLondon .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "First rack in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasZone noria:Room_ServerRoomA .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Second rack in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
    bot:hasZone noria:Room_ServerRoomA .

noria:Locus_RackA3 a noria:Locus ;
    rdfs:label "Rack A3"@en ;
    rdfs:comment "Third rack in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "3" ;
    bot:hasZone noria:Room_ServerRoomA .

noria:Locus_CabinetB1 a noria:Locus ;
    rdfs:label "Cabinet B1"@en ;
    rdfs:comment "Network cabinet in Network Closet B."@en ;
    noria:locusLine "B" ;
    noria:locusRow "1" ;
    bot:hasZone noria:Room_NetworkClosetB .

