# --- Event Records (noria:EventRecord) ---

noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Outage Log"@en ;
    rdfs:comment "Log entry indicating DNS server dns01.corp.example.com became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_InterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry for a network interface going down on Core Router 01."@en ;
    noria:loggingTime "2024-04-20T08:58:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_NetworkManagementSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction noria:OperationPlan_CheckFiberLink .

noria:EventRecord_WebSrvHighCPU a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "WARNING: CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_DBErrorLog a noria:EventRecord ;
    rdfs:label "Database Error Log Entry"@en ;
    rdfs:comment "Error log from DB01 indicating connection issues."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DB01 ;
    noria:logOriginatingManagementSystem noria:Application_LogManagementSystem ;
    noria:logText "ERROR: Database connection pool exhausted for application CRM." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_FirewallBlockedTraffic a noria:EventRecord ;
    rdfs:label "Firewall Blocked Traffic Alert"@en ;
    rdfs:comment "Firewall alert for suspicious traffic blocked from DMZ."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_FirewallDMZ01 ;
    noria:logOriginatingManagementSystem noria:Application_SIEMSystem ;
    noria:logText "ALERT: High severity traffic from 192.168.1.100 to DMZ blocked." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logOriginatingAgent foaf:Person_CharlieBrown .

noria:EventRecord_ConfigChangeRouter a noria:EventRecord ;
