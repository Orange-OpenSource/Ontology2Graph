# --- Event Records ---
noria:EventRecord_DNS_Down_Log
    a noria:EventRecord ;
    rdfs:label "DNS Server 01 Interface Down Log"@en ;
    rdfs:comment "Log entry indicating a network interface on DNS server went down."@en ;
    noria:loggingTime "2023-10-26T09:00:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down"@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS_Server_01 ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_Platform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_Web_CPU_High_Alert
    a noria:EventRecord ;
    rdfs:label "Web Server CPU High Alert"@en ;
    rdfs:comment "Monitoring alert for high CPU utilization on web server."@en ;
    noria:loggingTime "2023-10-26T09:15:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on web01.app.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_Web_Server_01 ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_Platform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_DB_Login_Failure
    a noria:EventRecord ;
    rdfs:label "Database Login Failure Alert"@en ;
    rdfs:comment "Security alert for multiple failed login attempts on database server."@en ;
    noria:loggingTime "2023-10-26T09:30:00Z"^^xsd:dateTime ;
    noria:logText "Multiple failed login attempts detected for user 'admin' on db01.app.example.com from IP 192.168.1.100."@en ;
    noria:logOriginatingManagedObject noria:Resource_DB_Server_01 ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_Platform ;
    noria:logOriginatingAgent foaf:Agent_Security_Team ; # Assuming security team configured the alert
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_Firewall_Config_Change
    a noria:EventRecord ;
    rdfs:label "Firewall Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change applied to Firewall 01."@en ;
    noria:loggingTime "2023-10-25T15:00:00Z"^^xsd:dateTime ;
    noria:logText "Configuration committed by user 'jdoe' from 10.0.0.100. Added new rule for port 8443."@en ;
    noria:logOriginatingManagedObject noria:Resource_Firewall_01 ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_Platform ;
    noria:logOriginatingAgent foaf:Agent_John_Doe ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord_VPN_Tunnel_Down
    a noria:EventRecord ;
    rdfs:label "VPN Tunnel Down Alert Lyon"@en ;
    rdfs:comment "Alert indicating the VPN tunnel from Lyon office is down."@en ;
    noria:loggingTime "2023-10-26T10:00:00Z"^^xsd:dateTime ;
    noria:logText "IPsec VPN tunnel 'Lyon-DC-Main' to 10.0.0.1 is down."@en ;
    noria:logOriginatingManagedObject noria:Resource_VPN_Gateway_Lyon ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_Platform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_LB_Health_Check_Failure
    a noria:EventRecord ;
    rdfs:label "Load Balancer Health Check Failure"@en ;
    rdfs:comment "Load balancer detected a backend server as unhealthy."@en ;
    noria:loggingTime "2023-10-26T09:14:00Z"^^xsd:dateTime ;
    noria:logText "Health check failed for backend server web01.app.example.com on port 80."@en ;
    noria:logOriginatingManagedObject noria:Resource_LoadBalancer_01 ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_Platform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

# --- Trouble Tickets ---
noria:TroubleTicket_DNS_Outage_TT001
    a noria:TroubleTicket ;
    rdfs:label "DNS Server 01 Interface Down Incident"@en ;
    rdfs:comment "Critical incident: Primary DNS server interface went down, impacting corporate network access."@en ;
    dcterms:identifier "TT-2023-10-26-001" ;
    dcterms:created "2023-10-26T09:05:00Z"^^xsd:dateTime ;
    dcterms:modified "2023-10-26T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
