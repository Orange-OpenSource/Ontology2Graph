# --- Operation Plans and Conditions ---
noria:OperationPlan_Restart_Interface
    a noria:OperationPlan ;
    rdfs:label "Network Interface Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a network interface on a server or network device."@en .

noria:ActionPreCondition_Interface_Down
    a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: The network interface's operational status is 'down'."@en .

noria:ActionPostCondition_Interface_Up
    a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Outcome: The network interface's operational status is 'up' and stable."@en .

noria:OperationPlan_Restart_Interface
    noria:operationPlanPreCondition noria:ActionPreCondition_Interface_Down ;
    noria:operationPlanPostCondition noria:ActionPostCondition_Interface_Up .

noria:OperationPlan_Scale_Web_Server
    a noria:OperationPlan ;
    rdfs:label "Web Server Scaling Procedure"@en ;
    rdfs:comment "Procedure to scale up resources (CPU/RAM) for a web server or add new instances."@en .

noria:ActionPreCondition_High_CPU
    a noria:ActionPreCondition ;
    rdfs:label "High CPU Utilization"@en ;
    rdfs:comment "Condition: CPU utilization exceeds 80% for more than 5 minutes."@en .

noria:ActionPostCondition_CPU_Normal
    a noria:ActionPostCondition ;
    rdfs:label "CPU Utilization Normal"@en ;
    rdfs:comment "Outcome: CPU utilization is below 50% and application response time is normal."@en .

noria:OperationPlan_Scale_Web_Server
    noria:operationPlanPreCondition noria:ActionPreCondition_High_CPU ;
    noria:operationPlanPostCondition noria:ActionPostCondition_CPU_Normal .

