    noria:agentInstructions "Contact for issues related to Customer Portal backend."@en .

foaf:Agent_Customer_Support
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Customer Support Center"@en ;
    rdfs:comment "First line of support for all customer inquiries and issues."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
