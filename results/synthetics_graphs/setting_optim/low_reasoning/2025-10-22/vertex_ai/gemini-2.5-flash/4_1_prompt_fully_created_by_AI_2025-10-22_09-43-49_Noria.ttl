# =============================================================================
# Services
# =============================================================================

noria:Service_InternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "Provides internet access for all corporate users and applications."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:Application_CorpNetwork ; # Service is composed of network application modules
    seas:subSystemOf noria:ApplicationModule_CNI_DC1 ;
    seas:subSystemOf noria:ApplicationModule_CSS_Prod .

noria:Service_InternalDatabaseAccess a noria:Service ;
    rdfs:label "Internal Database Access Service"@en ;
    rdfs:comment "Provides access to the corporate database for internal applications."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:Application_CorporateDatabase ;
    seas:subSystemOf noria:ApplicationModule_CDB_Prod ;
    seas:subSystemOf noria:ApplicationModule_VIRT_DC1 .

noria:Service_MonitoringAndAlerting a noria:Service ;
    rdfs:label "Monitoring and Alerting Service"@en ;
    rdfs:comment "Provides proactive monitoring and alerting for IT infrastructure."@en ;
    noria:serviceType <kos/service/type/InternalService> ;
    seas:subSystemOf noria:Application_MonitoringSystem ;
    seas:subSystemOf noria:ApplicationModule_CMS_Prod .

# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_Router1_LinkDown a noria:EventRecord ;
    rdfs:label "Router1 Link Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface went down on Router1."@en ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Router1 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface ge-0/0/1, changed state to down"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_Server1_CPUHigh a noria:EventRecord ;
    rdfs:label "Server1 High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Application Server 01."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Server1 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_Firewall1_BlockedAttack a noria:EventRecord ;
    rdfs:label "Firewall Blocked Attack Event"@en ;
    rdfs:comment "Log entry showing a blocked malicious attempt by Firewall1."@en ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Firewall1 ;
    noria:logOriginatingManagementSystem noria:Application_SecurityServices ;
    noria:logText "Blocked SQL Injection attempt from 203.0.113.42 on web application."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_VM1_DiskFull a noria:EventRecord ;
    rdfs:label "VM1 Disk Full Alert"@en ;
    rdfs:comment "Alert indicating that the disk space on the database VM is nearly full."@en ;
