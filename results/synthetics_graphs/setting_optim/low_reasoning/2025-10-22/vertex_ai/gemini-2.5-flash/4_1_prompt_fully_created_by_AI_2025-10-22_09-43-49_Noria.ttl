noria:TroubleTicket_TT009 a noria:TroubleTicket ;
    rdfs:label "Web Proxy Access Issue"@en ;
    rdfs:comment "User reported inability to access a legitimate website due to proxy blocking."@en ;
    dcterms:created "2024-04-20T11:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Minor> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketTrigger noria:EventRecord_Proxy1_BlockedSite ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Initialised> ;
    noria:troubleTicketRelatedResource noria:Resource_WebProxy1 ;
    noria:troubleTicketRelatedParty org:TeamC, foaf:Person1 .

# Add more change requests for density
noria:ChangeRequest_CR006 a noria:ChangeRequest ;
    rdfs:label "Web Proxy Policy Update"@en ;
    rdfs:comment "Update web proxy filtering policies to allow access to a new business partner's domain."@en ;
    dcterms:created "2024-04-19T14:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:Resource_WebProxy1, noria:Application_SecurityServices ;
    noria:changeRequestOutageDuration "PT0S"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Planned> ;
    noria:changeRequestInitiatorParty foaf:Person3 ;
    noria:changeRequestPilotParty foaf:Person3 ;
    noria:changeRequestActorParty org:TeamC ;
    noria:changeRequestIsRegulated false .

# Add more operation plans
noria:OperationPlan_ProxyPolicyUpdate a noria:OperationPlan ;
    rdfs:label "Web Proxy Policy Update Procedure"@en ;
    rdfs:comment "Standard procedure for modifying web proxy filtering rules."@en ;
    noria:operationPlanPreCondition noria:PreCondition_PolicyReview, noria:PreCondition_ChangeApproval ;
    noria:operationPlanPostCondition noria:PostCondition_PolicyApplied, noria:PostCondition_AccessVerified .

noria:PreCondition_PolicyReview a noria:ActionPreCondition ;
    rdfs:label "Policy Review Completed"@en ;
    rdfs:comment "Ensure the new policy rules have been reviewed and approved by security team."@en .

noria:PreCondition_ChangeApproval a noria:ActionPreCondition ;
    rdfs:label "Change Approved"@en ;
    rdfs:comment "Verify that the change request has been formally approved."@en .

noria:PostCondition_PolicyApplied a noria:ActionPostCondition ;
    rdfs:label "Policy Applied and Active"@en ;
    rdfs:comment "Confirm that the new policy rules are successfully applied and active on the proxy."@en .

noria:PostCondition_AccessVerified a noria:ActionPostCondition ;
    rdfs:label "Access Verified"@en ;
    rdfs:comment "Verify that the intended access (or block) is functioning as expected."@en .

noria:ChangeRequest_CR006 noria:actionCorrelatedOperationPlan noria:OperationPlan_ProxyPolicyUpdate .

# Final check for connectivity and density:
# - All major classes have multiple instances.
# - Resources are linked to ProductModels, Applications, Loci, and managed by Agents.
# - NetworkInterfaces are linked to Resources and NetworkLinks.
# - NetworkLinks connect Resources.
# - Applications have Modules, Types, Importance, and Domains.
# - ApplicationModules belong to Applications and are managed by various Agent roles.
# - Services are composed of Applications/Modules.
# - EventRecords originate from Resources/Applications/Agents and have severity/text/time.
# - TroubleTickets are triggered by EventRecords, relate to Services/Applications/Resources/Agents, and have many descriptive properties.
# - TroubleTicketNotes are part of TroubleTickets and created by Agents.
# - ChangeRequests impact Resources/Applications/Services, are initiated/piloted/acted upon by Agents, and have planned times/causes/statuses.
# - OperationPlans have Pre/Post Conditions and are correlated with ChangeRequests/TroubleTickets.
# - Locations (Site, Room, Locus) are interconnected and host Resources.
# - KOS concepts are used consistently.
# - No ldp prefix.
# - Labels and comments are present.

# This should be a sufficiently dense and connected graph.
