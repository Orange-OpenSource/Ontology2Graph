    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_Router1_Switch1 .

noria:NetworkInterface_Router1_Eth1 a noria:NetworkInterface ;
    rdfs:label "core-rtr01.dc1.example.com:ge-0/0/1"@en ;
    rdfs:comment "GigabitEthernet interface connecting Router1 to the external network (WAN)."@en ;
    noria:networkInterfaceOf noria:Resource_Router1 ;
    noria:networkInterfaceType "physical"@en ;
