# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

# Sites
bot:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    noria:siteId "PAR-DC-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddressStreet "10 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" ;
    wgs84_pos:lat "48.8700"^^xsd:float ;
    wgs84_pos:long "2.3300"^^xsd:float .

bot:Site_LondonOffice a bot:Site ;
    rdfs:label "London Head Office"@en ;
    noria:siteId "LON-HO-01" ;
    noria:siteType "office building"@en ;
    noria:sitePrincipalAddressStreet "20 Baker Street" ;
    noria:sitePrincipalAddressCityName "London" ;
    noria:sitePrincipalAddressPostalCode "NW1 5RT" ;
    noria:sitePrincipalAddressCountry "UK" ;
    wgs84_pos:lat "51.5200"^^xsd:float ;
    wgs84_pos:long "-0.1500"^^xsd:float .

# Rooms
noria:Room_DC1_ServerRoom1 a noria:Room ;
    rdfs:label "Server Room 1, Paris DC"@en ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace noria:Locus_DC1_SR1_RackA1, noria:Locus_DC1_SR1_RackB2 ;
    bot:hasElement noria:Resource_Server1, noria:Resource_Router1 ;
    seas:subSystemOf bot:Site_ParisDC .

noria:Room_DC1_NetworkRoom a noria:Room ;
    rdfs:label "Network Room, Paris DC"@en ;
    rdfs:comment "Room dedicated to network equipment in Paris Data Center."@en ;
    bot:hasSpace noria:Locus_DC1_NR_RackC3 ;
    bot:hasElement noria:Resource_Switch1, noria:Resource_Firewall1 ;
    seas:subSystemOf bot:Site_ParisDC .

noria:Room_LON_ServerCloset a noria:Room ;
    rdfs:label "Server Closet, London Office"@en ;
    rdfs:comment "Small server closet in London Head Office."@en ;
    bot:hasSpace noria:Locus_LON_SC_RackD4 ;
    bot:hasElement noria:Resource_Server2 ;
    seas:subSystemOf bot:Site_LondonOffice .

# Loci (Specific locations within rooms)
noria:Locus_DC1_SR1_RackA1 a noria:Locus ;
    rdfs:label "Rack A1 in Server Room 1"@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasElement noria:Resource_Server1, noria:Resource_Storage1 ;
    seas:subSystemOf noria:Room_DC1_ServerRoom1 .

noria:Locus_DC1_SR1_RackB2 a noria:Locus ;
    rdfs:label "Rack B2 in Server Room 1"@en ;
    noria:locusLine "B" ;
    noria:locusRow "2" ;
    bot:hasElement noria:Resource_Server3 ;
    seas:subSystemOf noria:Room_DC1_ServerRoom1 .

noria:Locus_DC1_NR_RackC3 a noria:Locus ;
    rdfs:label "Rack C3 in Network Room"@en ;
    noria:locusLine "C" ;
    noria:locusRow "3" ;
    bot:hasElement noria:Resource_Router1, noria:Resource_Switch1, noria:Resource_Firewall1 ;
    seas:subSystemOf noria:Room_DC1_NetworkRoom .

noria:Locus_LON_SC_RackD4 a noria:Locus ;
    rdfs:label "Rack D4 in Server Closet"@en ;
    noria:locusLine "D" ;
    noria:locusRow "4" ;
    bot:hasElement noria:Resource_Server2 ;
    seas:subSystemOf noria:Room_LON_ServerCloset .

