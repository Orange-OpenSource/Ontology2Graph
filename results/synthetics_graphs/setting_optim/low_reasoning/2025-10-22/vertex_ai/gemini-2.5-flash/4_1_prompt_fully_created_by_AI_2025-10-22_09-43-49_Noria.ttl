<kos/Resource/OperationalState> a skos:ConceptScheme ; rdfs:label "Resource Operational State Scheme"@en .
<kos/Resource/OperationalState/Up> a skos:Concept ; skos:prefLabel "Up"@en ; skos:inScheme <kos/Resource/OperationalState> .
<kos/Resource/OperationalState/Down> a skos:Concept ; skos:prefLabel "Down"@en ; skos:inScheme <kos/Resource/OperationalState> .
<kos/Resource/OperationalState/Degraded> a skos:Concept ; skos:prefLabel "Degraded"@en ; skos:inScheme <kos/Resource/OperationalState> .
<kos/Resource/OperationalState/Unknown> a skos:Concept ; skos:prefLabel "Unknown"@en ; skos:inScheme <kos/Resource/OperationalState> .

# Network Interface Administrative State
<kos/Resource/AdministrativeState> a skos:ConceptScheme ; rdfs:label "Network Interface Administrative State Scheme"@en .
<kos/Resource/AdministrativeState/up> a skos:Concept ; skos:prefLabel "Up"@en ; skos:inScheme <kos/Resource/AdministrativeState> .
<kos/Resource/AdministrativeState/down> a skos:Concept ; skos:prefLabel "Down"@en ; skos:inScheme <kos/Resource/AdministrativeState> .

# Notification Severity
<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ; rdfs:label "Perceived Severity Scheme"@en .
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; skos:prefLabel "Critical"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; skos:prefLabel "Major"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; skos:prefLabel "Minor"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; skos:prefLabel "Warning"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Indeterminate> a skos:Concept ; skos:prefLabel "Indeterminate"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Cleared> a skos:Concept ; skos:prefLabel "Cleared"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .

# Application SLA Level
<https://w3id.org/noria/kos/application/sla-level> a skos:ConceptScheme ; rdfs:label "Application SLA Level Scheme"@en .
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; skos:prefLabel "Gold"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ; skos:prefLabel "Silver"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .
<https://w3id.org/noria/kos/application/sla-level/Bronze> a skos:Concept ; skos:prefLabel "Bronze"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit, foaf:Person)
# =============================================================================

# Organizational Units (Teams)
org:TeamA a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Center (NOC) Team A"@en ;
    rdfs:comment "First-line support team for network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call hotline for critical issues, use ticketing system for non-critical."@en .

org:TeamB a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team B"@en ;
    rdfs:comment "Specialized team for business application support."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Submit a ticket via the portal. For emergencies, contact Team A first."@en .

org:TeamC a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Center (SOC) Team C"@en ;
    rdfs:comment "Responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email security-alert@example.com for all security-related events."@en .

org:TeamD a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team D"@en ;
    rdfs:comment "Manages and maintains all corporate database systems."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Open a ticket for database requests or issues."@en .

org:TeamE a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Cloud Infrastructure Team E"@en ;
    rdfs:comment "Manages cloud-based resources and services."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Use the cloud portal for self-service, or open a ticket for support."@en .

