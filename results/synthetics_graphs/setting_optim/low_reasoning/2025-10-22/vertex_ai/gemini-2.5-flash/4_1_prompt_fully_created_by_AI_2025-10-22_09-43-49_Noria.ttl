noria:NetworkInterface_Router1_Eth0 a noria:NetworkInterface ;
    rdfs:label "core-rtr01.dc1.example.com:ge-0/0/0"@en ;
    rdfs:comment "GigabitEthernet interface connecting Router1 to the internal network."@en ;
