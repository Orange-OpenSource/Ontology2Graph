    noria:logOriginatingManagedObject noria:Resource_VM1 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "Disk usage on /dev/sda1 on db01.corp.example.com is 95%."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_DNS01_ServiceDown a noria:EventRecord ;
