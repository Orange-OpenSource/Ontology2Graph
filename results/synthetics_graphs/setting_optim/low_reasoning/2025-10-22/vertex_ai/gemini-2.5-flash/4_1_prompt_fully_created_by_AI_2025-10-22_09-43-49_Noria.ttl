# Document Attachments
# =============================================================================

noria:DocumentAttachment_TT001_Diagram a noria:DocumentAttachment ;
    rdfs:label "Network Diagram for DC1"@en ;
    rdfs:comment "Diagram showing the network topology of Paris Data Center, attached to TT001."@en ;
    dcterms:isPartOf noria:TroubleTicket_TT001 ;
    dcterms:format "application/pdf" ;
    dcterms:identifier "network_diagram_dc1.pdf" .

noria:DocumentAttachment_CR001_Plan a noria:DocumentAttachment ;
    rdfs:label "Router OS Upgrade Plan"@en ;
    rdfs:comment "Detailed plan for the Router1 OS upgrade, attached to CR001."@en ;
    dcterms:isPartOf noria:ChangeRequest_CR001 ;
    dcterms:format "application/vnd.openxmlformats-officedocument.wordprocessingml.document" ;
    dcterms:identifier "router_os_upgrade_plan.docx" .

