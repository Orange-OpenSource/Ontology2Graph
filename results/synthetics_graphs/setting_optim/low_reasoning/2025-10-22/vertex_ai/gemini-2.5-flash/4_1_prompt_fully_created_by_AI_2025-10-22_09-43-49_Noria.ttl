# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OperationPlan_RouterOSUpgrade a noria:OperationPlan ;
    rdfs:label "Router OS Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading Juniper router operating systems."@en ;
    noria:operationPlanPreCondition noria:PreCondition_RouterBackup, noria:PreCondition_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:PostCondition_RouterOnline, noria:PostCondition_OSVersionVerified .

noria:PreCondition_RouterBackup a noria:ActionPreCondition ;
    rdfs:label "Router Configuration Backup Completed"@en ;
    rdfs:comment "Ensure a full configuration backup of the router is taken before starting the upgrade."@en .

noria:PreCondition_MaintenanceWindow a noria:ActionPreCondition ;
    rdfs:label "Approved Maintenance Window"@en ;
    rdfs:comment "Verify that the upgrade is scheduled within an approved maintenance window to minimize impact."@en .

noria:PostCondition_RouterOnline a noria:ActionPostCondition ;
    rdfs:label "Router Online and Routing Restored"@en ;
    rdfs:comment "Confirm that the router is online, all interfaces are up, and routing protocols have converged."@en .

noria:PostCondition_OSVersionVerified a noria:ActionPostCondition ;
    rdfs:label "New OS Version Verified"@en ;
    rdfs:comment "Verify that the router is running the new, upgraded operating system version."@en .

noria:OperationPlan_DBDiskCleanup a noria:OperationPlan ;
    rdfs:label "Database Disk Cleanup Procedure"@en ;
    rdfs:comment "Procedure for clearing old log files and temporary data from database servers."@en ;
    noria:operationPlanPreCondition noria:PreCondition_DBBackup, noria:PreCondition_LowActivity ;
    noria:operationPlanPostCondition noria:PostCondition_DiskSpaceFreed, noria:PostCondition_DBPerformanceNormal .

noria:PreCondition_DBBackup a noria:ActionPreCondition ;
    rdfs:label "Database Backup Completed"@en ;
    rdfs:comment "Ensure a recent backup of the database is available before performing cleanup."@en .

noria:PreCondition_LowActivity a noria:ActionPreCondition ;
    rdfs:label "Low Database Activity Period"@en ;
    rdfs:comment "Perform cleanup during periods of low database activity to avoid performance impact."@en .

noria:PostCondition_DiskSpaceFreed a noria:ActionPostCondition ;
    rdfs:label "Sufficient Disk Space Freed"@en ;
    rdfs:comment "Verify that at least 20% of disk space has been freed on the database server."@en .

noria:PostCondition_DBPerformanceNormal a noria:ActionPostCondition ;
    rdfs:label "Database Performance Normal"@en ;
    rdfs:comment "Confirm that database performance metrics are within normal operating parameters after cleanup."@en .

