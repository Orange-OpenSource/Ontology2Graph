noria:TroubleTicketNote_002_02 a noria:TroubleTicketNote ;
    rdfs:label "ISP Update for TT-002"@en ;
    rdfs:comment "ISP confirmed fiber cut at a junction box. Estimated repair time 3 hours. Initiating temporary satellite link for critical services."@en ;
