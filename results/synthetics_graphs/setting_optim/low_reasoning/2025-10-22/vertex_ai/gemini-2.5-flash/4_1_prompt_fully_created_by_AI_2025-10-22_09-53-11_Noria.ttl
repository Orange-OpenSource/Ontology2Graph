# --- Operation Plans ---

noria:OperationPlan_RouterFirmwareUpgrade a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading Cisco ASR 9000 series router firmware."@en ;
    skos:example "Steps include: pre-checks, backup configuration, upload new image, reload, post-checks."@en ;
    noria:operationPlanPreCondition noria:PreCondition_RouterBackup, noria:PreCondition_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:PostCondition_RouterOnline, noria:PostCondition_FirmwareVersion .

noria:OperationPlan_DBQueryOptimization a noria:OperationPlan ;
    rdfs:label "Database Query Optimization Procedure"@en ;
    rdfs:comment "Procedure for identifying and optimizing slow database queries."@en ;
    skos:example "Steps include: identify slow queries, analyze execution plan, rewrite query, test, deploy."@en ;
    noria:operationPlanPreCondition noria:PreCondition_DBAccess, noria:PreCondition_PerformanceBaseline ;
    noria:operationPlanPostCondition noria:PostCondition_QueryPerformance, noria:PostCondition_SystemStability .

# --- Action Pre/Post Conditions ---

noria:PreCondition_RouterBackup a noria:ActionPreCondition ;
    rdfs:label "Router Configuration Backup Completed"@en ;
    rdfs:comment "Ensure a full backup of the router configuration is completed and verified before starting the upgrade."@en .

noria:PreCondition_MaintenanceWindow a noria:ActionPreCondition ;
    rdfs:label "Approved Maintenance Window"@en ;
    rdfs:comment "The change must be executed within an approved maintenance window to minimize impact."@en .

noria:PreCondition_DBAccess a noria:ActionPreCondition ;
    rdfs:label "Database Admin Access"@en ;
    rdfs:comment "Required administrative access to the database server and schema."@en .

noria:PreCondition_PerformanceBaseline a noria:ActionPreCondition ;
    rdfs:label "Performance Baseline Available"@en ;
    rdfs:comment "Recent performance metrics baseline available for comparison after optimization."@en .

noria:PostCondition_RouterOnline a noria:ActionPostCondition ;
    rdfs:label "Router Online and Functional"@en ;
    rdfs:comment "Router is online, all interfaces are up, and routing protocols are converged."@en .

noria:PostCondition_FirmwareVersion a noria:ActionPostCondition ;
    rdfs:label "New Firmware Version Verified"@en ;
    rdfs:comment "Verify that the router is running the new firmware version."@en .

noria:PostCondition_QueryPerformance a noria:ActionPostCondition ;
    rdfs:label "Query Performance Improved"@en ;
    rdfs:comment "Optimized query execution time is significantly reduced, and CPU usage is within normal limits."@en .

noria:PostCondition_SystemStability a noria:ActionPostCondition ;
    rdfs:label "System Stability Maintained"@en ;
    rdfs:comment "No new errors or performance issues introduced after query optimization."@en .

# --- Document Attachments ---

noria:DocumentAttachment_TT001_SQLReport a noria:DocumentAttachment ;
    rdfs:label "SQL Performance Report for TT-001"@en ;
    rdfs:comment "Detailed report of slow SQL queries and their execution plans related to TT-001."@en ;
    dcterms:created "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:TroubleTicket_001 ;
    dcterms:format "application/pdf" ;
    dcterms:source <https://docs.example.com/reports/TT001_SQL_Report.pdf> .

noria:DocumentAttachment_CR001_MOP a noria:DocumentAttachment ;
    rdfs:label "Method of Procedure for CR-001"@en ;
    rdfs:comment "Detailed step-by-step guide for the router firmware upgrade."@en ;
    dcterms:created "2024-04-12T14:00:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:ChangeRequest_001 ;
    dcterms:format "application/vnd.openxmlformats-officedocument.wordprocessingml.document" ;
    dcterms:source <https://docs.example.com/mops/CR001_Router_Upgrade_MOP.docx> .

