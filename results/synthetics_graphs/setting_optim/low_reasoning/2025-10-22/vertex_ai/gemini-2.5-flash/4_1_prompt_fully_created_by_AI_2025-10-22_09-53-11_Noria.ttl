noria:OperationPlan_OSPatching a noria:OperationPlan ;
    rdfs:label "Operating System Patching Procedure"@en ;
    rdfs:comment "Standard procedure for applying OS patches to production servers."@en ;
    skos:example "Steps include: pre-patch checks, backup, apply patches, reboot, post-patch checks."@en ;
    noria:operationPlanPreCondition noria:PreCondition_ServerBackup, noria:PreCondition_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:PostCondition_ServerOnline, noria:PostCondition_PatchesApplied .

noria:PreCondition_ServerBackup a noria:ActionPreCondition ;
    rdfs:label "Server Backup Completed"@en ;
    rdfs:comment "Ensure a full backup of the server is completed before patching."@en .

noria:PostCondition_PatchesApplied a noria:ActionPostCondition ;
    rdfs:label "Patches Applied and Verified"@en ;
    rdfs:comment "Verify that all scheduled patches have been successfully applied."@en .

noria:PostCondition_ServerOnline a noria:ActionPostCondition ;
    rdfs:label "Server Online and Functional"@en ;
    rdfs:comment "Server is online, services are running, and accessible."@en .

noria:ChangeRequest_005 noria:actionCorrelatedOperationPlan noria:OperationPlan_OSPatching .

# Adding more agents and linking them to resources and applications
foaf:Agent_Charlie a foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Application Developer, responsible for the Corporate Website."@en ;
    foaf:mbox <mailto:charlie.brown@example.com> ;
    org:memberOf org:AppSupportTeam ;
    noria:agentManagesResource noria:Server_Web_04 ;
    noria:agentManagesResource noria:Application_CorporateWebsite .

noria:CUid_Charlie a noria:CorporateUserIdentifier ;
    rdfs:label "Charlie Brown's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Charlie Brown."@en ;
    foaf:accountName "cbrown" ;
    foaf:holdsAccount foaf:Agent_Charlie .

# Adding more network interfaces and links for density
noria:NI_NYC_DNS_09_ETH0 a noria:NetworkInterface ;
    rdfs:label "NYC-DNS-09 Ethernet0"@en ;
    rdfs:comment "Network interface for Corporate DNS Server 09."@en ;
    noria:networkInterfaceOf noria:Server_DNS_09 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects noria:NetworkLink_CS_DNS_01 .

noria:NetworkLink_CS_DNS_01 a noria:NetworkLink ;
    rdfs:label "Link Core Switch to DNS Server 09"@en ;
    rdfs:comment "Link between NYC Core Switch and Corporate DNS Server 09."@en ;
    noria:resourceManagedBy org:NetworkTeam ;
    noria:networkLinkId "INT-007-CS-DNS" ;
    noria:networkLinkTerminationResourceOrigin noria:Switch_Core_05 ;
    noria:networkLinkTerminationResourceDestination noria:Server_DNS_09 ;
    noria:networkLinkInstallationDate "2023-05-01T00:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 1Gbps" .

# Adding more EventRecords for different types of events
noria:EventRecord_Login_Failure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Multiple failed login attempts detected on a corporate application."@en ;
    noria:loggingTime "2024-04-25T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Server_Web_04 ;
    noria:logOriginatingManagementSystem <https://siem.example.com> ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logText "AUTH_FAIL: User 'unknown' failed login 5 times from IP 1.2.3.4" ;
    dcterms:type <kos/Notification/EventType/securityEvent> .

noria:EventRecord_Disk_Full a noria:EventRecord ;
    rdfs:label "Disk Full Alert"@en ;
    rdfs:comment "Disk space on a server reached critical levels."@en ;
    noria:loggingTime "2024-04-25T11:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DB_Prod_01 ;
    noria:logOriginatingManagementSystem <https://monitoring.example.com/nagios> ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Minor> ;
    noria:logText "DISK_FULL: /var/log partition on nyc-db-01 at 98% capacity." ;
    dcterms:type <kos/Notification/EventType/thresholdExceeded> .

# Adding more TroubleTickets for these events
noria:TroubleTicket_007 a noria:TroubleTicket ;
    rdfs:label "Disk Space Critical on DB Server"@en ;
    rdfs:comment "Database server running out of disk space, impacting logging and potential database operations."@en ;
    dcterms:created "2024-04-25T11:45:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-25T12:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Minor> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Maintenance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P3> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/DowngradingEquipment> ;
    noria:troubleTicketCause "Excessive log file growth."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-25T11:35:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable false ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_David ;
    noria:troubleTicketRelatedResource noria:Resource_DB_Prod_01 ;
    noria:troubleTicketImpacts noria:Application_CRM_Prod ;
    noria:documentExternalId "DISK-FULL-007" ;
    noria:documentHRef <https://ticketing.example.com/ticket/TT-007> .

noria:TroubleTicket_007 noria:documentStatusHistory noria:EventRecord_Disk_Full .

# Adding a ChangeRequest for a new application deployment
noria:ChangeRequest_006 a noria:ChangeRequest ;
    rdfs:label "Deploy New HR Portal"@en ;
    rdfs:comment "Deployment of a new HR self-service portal application."@en ;
    dcterms:created "2024-04-01T10:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T14:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-20T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-20T17:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Major> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/NetworkExtension> ; # Using for new service deployment
    noria:changeRequestImpact noria:Server_VMHost_03, noria:Application_HR_Portal ;
    noria:changeRequestOutageDuration "PT0S"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty foaf:Agent_Carol ;
    noria:changeRequestPilotParty foaf:Agent_Bob ;
    noria:changeRequestActorParty org:AppSupportTeam, org:ServerTeam ;
    noria:changeRequestIsRegulated true ;
    noria:documentExternalId "CR-HR-006" ;
    noria:documentHRef <https://changemanagement.example.com/cr/CR-006> .

noria:Application_HR_Portal a noria:Application ;
    rdfs:label "Human Resources Portal"@en ;
    rdfs:comment "Self-service portal for employees to manage HR-related tasks."@en ;
    noria:applicationModelIdentifier "HR-PORTAL" ;
    noria:applicationNumericalIdentifier 8001 ;
    noria:applicationShortIdentifier "HRP" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Human Resources" ;
    noria:applicationFunctionalSubDomain "Employee Self-Service" .

noria:ApplicationModule_HR_Portal_Prod a noria:ApplicationModule ;
    rdfs:label "HR Portal Production Module"@en ;
    rdfs:comment "Production instance of the HR Portal."@en ;
    noria:applicationModuleOf noria:Application_HR_Portal ;
    noria:applicationModuleName "HR_PORTAL_PROD" ;
    noria:applicationModuleIdentifier "HRP-PROD-01" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InDevelopment> ; # Initially in development
    noria:applicationModuleAdministrationTeam org:AppSupportTeam ;
    noria:applicationModuleSupportTeam org:AppSupportTeam ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2024-05-20T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled false .

noria:Service_HR_SelfService a noria:Service ;
    rdfs:label "HR Self-Service Portal"@en ;
    rdfs:comment "Service enabling employees to access HR functionalities."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:Application_HR_Portal ;
    seas:subSystemOf noria:ApplicationModule_HR_Portal_Prod .

# Adding more Operation Plans and conditions
noria:OperationPlan_NewAppDeployment a noria:OperationPlan ;
    rdfs:label "New Application Deployment Procedure"@en ;
    rdfs:comment "Standard procedure for deploying a new business application."@en ;
    skos:example "Steps include: environment setup, code deployment, database setup, testing, go-live."@en ;
    noria:operationPlanPreCondition noria:PreCondition_EnvironmentReady, noria:PreCondition_CodeReview ;
    noria:operationPlanPostCondition noria:PostCondition_AppFunctional, noria:PostCondition_MonitoringActive .

noria:PreCondition_EnvironmentReady a noria:ActionPreCondition ;
    rdfs:label "Deployment Environment Ready"@en ;
    rdfs:comment "All infrastructure components for the new application are provisioned and configured."@en .

noria:PreCondition_CodeReview a noria:ActionPreCondition ;
    rdfs:label "Code Review Completed"@en ;
    rdfs:comment "Application code has passed security and quality reviews."@en .

noria:PostCondition_AppFunctional a noria:ActionPostCondition ;
    rdfs:label "Application Fully Functional"@en ;
    rdfs:comment "The new application is accessible and all features are working as expected."@en .

noria:PostCondition_MonitoringActive a noria:ActionPostCondition ;
    rdfs:label "Monitoring Active"@en ;
    rdfs:comment "Monitoring and alerting for the new application are fully configured and active."@en .

noria:ChangeRequest_006 noria:actionCorrelatedOperationPlan noria:OperationPlan_NewAppDeployment .

# Final check for connectivity and density:
# - All major entities (Resource, Application, TT, CR, Event) are created.
# - Agents and OrgUnits are linked to resources and tickets.
# - Resources are linked to ProductModels, Locations, NetworkInterfaces.
# - NetworkInterfaces are linked to Resources and NetworkLinks.
# - NetworkLinks connect Resources.
# - Applications are linked to ApplicationModules.
# - ApplicationModules are linked to Applications and Agents/OrgUnits.
# - Services are linked to Applications/ApplicationModules.
# - TroubleTickets are linked to Services/Applications/Resources, Agents, and EventRecords.
# - ChangeRequests are linked to Services/Applications/Resources, Agents, and OperationPlans.
# - OperationPlans are linked to Pre/Post Conditions.
# - EventRecords are linked to Resources/Applications and TroubleTickets/Notes.
# - All entities have rdf:type, rdfs:label, and rdfs:comment/skos:example.
# - No ldp prefix used.
# - Maximize entities: Many instances of each class are created and interconnected.

# This graph is now quite dense and covers a wide range of NORIA concepts.

