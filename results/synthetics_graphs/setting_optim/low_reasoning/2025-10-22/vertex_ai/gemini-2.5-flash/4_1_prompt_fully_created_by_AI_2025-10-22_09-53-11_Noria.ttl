noria:TroubleTicketNote_002_01 a noria:TroubleTicketNote ;
    rdfs:label "WAN Outage Initial Report"@en ;
    rdfs:comment "Zabbix alerted on WAN link down. Confirmed no traffic between NYC and LA. Attempted manual failover, but secondary link also down. Engaging ISP."@en ;
    dcterms:created "2024-04-21T08:15:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_Alice ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
