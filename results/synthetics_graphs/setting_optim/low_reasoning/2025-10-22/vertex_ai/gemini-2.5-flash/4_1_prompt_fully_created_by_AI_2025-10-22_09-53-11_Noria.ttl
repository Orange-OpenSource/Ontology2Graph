noria:TroubleTicketNote_001_02 a noria:TroubleTicketNote ;
    rdfs:label "DBA investigation for TT-001"@en ;
    rdfs:comment "Identified a long-running query from the reporting module causing contention. Killed the query and initiated performance tuning. CPU usage normalized."@en ;
