noria:OperationPlan_CloudGatewayPolicyUpdate a noria:OperationPlan ;
    rdfs:label "Cloud Gateway Policy Update Procedure"@en ;
    rdfs:comment "Procedure for updating security policies on the cloud gateway with minimal disruption."@en ;
    skos:example "Steps include: review policy changes, stage new policy, test in staging, deploy to production, verify."@en ;
    noria:operationPlanPreCondition noria:PreCondition_PolicyReview, noria:PreCondition_StagingEnvironment ;
    noria:operationPlanPostCondition noria:PostCondition_PolicyActive, noria:PostCondition_TrafficFlow .

noria:PreCondition_PolicyReview a noria:ActionPreCondition ;
    rdfs:label "Security Policy Review Completed"@en ;
    rdfs:comment "New security policies must be reviewed and approved by the security team."@en .

noria:PreCondition_StagingEnvironment a noria:ActionPreCondition ;
    rdfs:label "Staging Environment Available"@en ;
    rdfs:comment "A dedicated staging environment is available for testing policy changes."@en .

noria:PostCondition_PolicyActive a noria:ActionPostCondition ;
    rdfs:label "New Policy Active and Verified"@en ;
    rdfs:comment "The updated security policy is active on the cloud gateway and its rules are verified."@en .

noria:PostCondition_TrafficFlow a noria:ActionPostCondition ;
    rdfs:label "Cloud Traffic Flow Uninterrupted"@en ;
    rdfs:comment "Traffic to and from cloud services remains uninterrupted after policy update."@en .

# Connecting ChangeRequest to OperationPlan
noria:ChangeRequest_001 noria:actionCorrelatedOperationPlan noria:OperationPlan_RouterFirmwareUpgrade .
noria:ChangeRequest_004 noria:actionCorrelatedOperationPlan noria:OperationPlan_CloudGatewayPolicyUpdate .

# Adding more complex relationships and entities for density

# Anomaly Patterns
noria:AnomalyPattern_HighCPUDegradation a noria:AnomalyPattern ;
    rdfs:label "High CPU Degradation Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high CPU usage leading to performance degradation."@en ;
    folio:hasCause "Unoptimized code, resource contention, malicious activity."@en .

noria:AnomalyPattern_NetworkLinkFlap a noria:AnomalyPattern ;
    rdfs:label "Network Link Flap Pattern"@en ;
    rdfs:comment "Pattern indicating frequent up/down transitions on a network interface, suggesting physical layer issues or faulty transceivers."@en ;
    folio:hasCause "Faulty cable, transceiver, or port; power issues; misconfiguration."@en .

# Linking EventRecords to AnomalyPatterns (implicitly, as EventRecord is a log:Event and folio:FailureMode is a noria:AnomalyPattern)
# This is more conceptual, but we can link an EventRecord to a TroubleTicket which might be associated with an AnomalyPattern.
# For direct linking, we'd need a property like `noria:indicatesAnomalyPattern` or similar, but sticking to NORIA.
# The `noria:troubleTicketCategory` and `noria:troubleTicketCause` can be seen as instances of `noria:AnomalyPattern` or related concepts.

# Example of a CorporateUserIdentifier with more details
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe, a new intern."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount <https://example.com/agents/JohnDoe> . # Assuming John Doe is another foaf:Agent

<https://example.com/agents/JohnDoe> a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    org:memberOf org:ITOperations . # General membership

