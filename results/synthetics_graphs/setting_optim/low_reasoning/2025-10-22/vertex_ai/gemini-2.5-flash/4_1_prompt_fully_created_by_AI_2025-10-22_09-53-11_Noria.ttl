# More Operation Plans
noria:OperationPlan_AppServerRestart a noria:OperationPlan ;
    rdfs:label "Application Server Restart Procedure"@en ;
    rdfs:comment "Standard procedure for safely restarting an application server."@en ;
    skos:example "Steps include: notify users, gracefully shut down application, restart OS, verify application startup, notify users."@en ;
    noria:operationPlanPreCondition noria:PreCondition_UserNotification, noria:PreCondition_AppStatusCheck ;
    noria:operationPlanPostCondition noria:PostCondition_AppOnline, noria:PostCondition_NoErrors .

noria:PreCondition_UserNotification a noria:ActionPreCondition ;
    rdfs:label "User Notification Sent"@en ;
    rdfs:comment "Users impacted by the restart must be notified in advance."@en .

noria:PreCondition_AppStatusCheck a noria:ActionPreCondition ;
    rdfs:label "Application Status Checked"@en ;
    rdfs:comment "Verify current application status before initiating restart."@en .

noria:PostCondition_AppOnline a noria:ActionPostCondition ;
    rdfs:label "Application Online and Functional"@en ;
    rdfs:comment "Application is accessible and responding correctly after restart."@en .

noria:PostCondition_NoErrors a noria:ActionPostCondition ;
    rdfs:label "No New Errors in Logs"@en ;
    rdfs:comment "Verify application logs for any new errors after restart."@en .

