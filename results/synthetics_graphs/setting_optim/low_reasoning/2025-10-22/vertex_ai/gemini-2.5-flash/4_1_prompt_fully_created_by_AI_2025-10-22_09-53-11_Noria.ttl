# --- Change Requests ---

noria:ChangeRequest_001 a noria:ChangeRequest ;
    rdfs:label "Upgrade Core Router Firmware NYC-CR-01"@en ;
    rdfs:comment "Planned firmware upgrade for NYC-CR-01 to address security vulnerabilities and improve performance."@en ;
    dcterms:created "2024-04-10T10:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-18T15:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Router_Core_01, noria:Application_CorporateWAN ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty foaf:Agent_Alice ;
    noria:changeRequestPilotParty foaf:Agent_Alice ;
    noria:changeRequestActorParty org:NetworkTeam ;
    noria:changeRequestIsRegulated true ;
    noria:documentExternalId "CR-NET-001" ;
    noria:documentHRef <https://changemanagement.example.com/cr/CR-001> .

noria:ChangeRequest_002 a noria:ChangeRequest ;
