# --- Operation Plans, Pre/Post Conditions ---
noria:OP_RouterSoftwareUpgrade a noria:OperationPlan ;
    rdfs:label "Router Software Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router software."@en ;
    noria:operationPlanPreCondition noria:PreCond_RouterBackup ;
    noria:operationPlanPreCondition noria:PreCond_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:PostCond_RouterOnline ;
    noria:operationPlanPostCondition noria:PostCond_SoftwareVersionVerified .

noria:PreCond_RouterBackup a noria:ActionPreCondition ;
    rdfs:label "Router Configuration Backup Completed"@en ;
    rdfs:comment "Ensure a full backup of the router configuration is completed and verified."@en .

noria:PreCond_MaintenanceWindow a noria:ActionPreCondition ;
    rdfs:label "Approved Maintenance Window"@en ;
    rdfs:comment "Verify that the change is scheduled within an approved maintenance window."@en .

noria:PostCond_RouterOnline a noria:ActionPostCondition ;
    rdfs:label "Router Online and Functional"@en ;
    rdfs:comment "Confirm router is online, interfaces are up, and routing protocols are stable."@en .

noria:PostCond_SoftwareVersionVerified a noria:ActionPostCondition ;
    rdfs:label "Software Version Verified"@en ;
    rdfs:comment "Verify that the new software version is correctly installed and active."@en .

noria:OP_DBQueryOptimization a noria:OperationPlan ;
    rdfs:label "Database Query Optimization Procedure"@en ;
    rdfs:comment "Procedure for identifying and optimizing inefficient database queries."@en ;
    noria:operationPlanPreCondition noria:PreCond_DBMonitoringActive ;
    noria:operationPlanPostCondition noria:PostCond_PerformanceImprovement .

noria:PreCond_DBMonitoringActive a noria:ActionPreCondition ;
    rdfs:label "Database Performance Monitoring Active"@en ;
    rdfs:comment "Ensure database performance monitoring tools are active and collecting data."@en .

noria:PostCond_PerformanceImprovement a noria:ActionPostCondition ;
    rdfs:label "Application Performance Improved"@en ;
    rdfs:comment "Verify that the application's response time has improved and CPU utilization is normalized."@en .

# --- Actions (Procedure Executions) ---
noria:Action_DNS_CheckInterface a pep:ProcedureExecution ;
    rdfs:label "Check DNS01 Interface Status"@en ;
    rdfs:comment "Command executed to check the status of eth0 on dns01.corp.example.com."@en ;
    pep:madeBy foaf:AliceJohnson ;
    pep:hasCommand "show interface eth0"^^xsd:string ;
    pep:hasSimpleResult "eth0 is administratively down, line protocol is down"^^xsd:string ;
    dcterms:created "2024-04-23T09:10:00Z"^^xsd:dateTime ;
    noria:actionCorrelatedOperationPlan noria:OP_NetworkTroubleshooting .

noria:Action_DNS_BringUpInterface a pep:ProcedureExecution ;
    rdfs:label "Bring Up DNS01 Interface"@en ;
    rdfs:comment "Command executed to bring up eth0 on dns01.corp.example.com."@en ;
    pep:madeBy foaf:AliceJohnson ;
    pep:hasCommand "interface eth0; no shutdown"^^xsd:string ;
    pep:hasSimpleResult "eth0 changed state to up"^^xsd:string ;
    dcterms:created "2024-04-23T10:50:00Z"^^xsd:dateTime ;
    noria:actionCorrelatedOperationPlan noria:OP_NetworkTroubleshooting .

noria:OP_NetworkTroubleshooting a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard procedure for diagnosing and resolving network interface issues."@en .

