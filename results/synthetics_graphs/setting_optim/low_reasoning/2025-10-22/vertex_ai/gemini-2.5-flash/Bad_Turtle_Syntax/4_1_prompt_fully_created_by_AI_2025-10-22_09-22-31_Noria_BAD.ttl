# --- Locations ---
bot:DataCenter_Paris a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string .

bot:Office_London a bot:Site ;
    rdfs:label "London Office"@en ;
    noria:siteId "OFF-LDN-01"^^xsd:string ;
    noria:siteType "office building"^^xsd:string ;
    noria:sitePrincipalAddress "456 Baker Street"@en ;
    noria:sitePrincipalAddressCityName "London"@en ;
    noria:sitePrincipalAddressPostalCode "NW1 6XE"^^xsd:string ;
    noria:sitePrincipalAddressCountry "UK"^^xsd:string .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace noria:Locus_RackA1 ;
    bot:hasSpace noria:Locus_RackA2 ;
    bot:hasSpace noria:Locus_RackA3 ;
    seas:subSystemOf bot:DataCenter_Paris .

noria:Room_NetworkClosetB a noria:Room ;
    rdfs:label "Network Closet B"@en ;
    rdfs:comment "Network equipment closet in London Office."@en ;
    bot:hasSpace noria:Locus_RackB1 ;
    seas:subSystemOf bot:Office_London .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "First rack in Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasElement noria:Resource_DNS01 ;
    bot:hasElement noria:Resource_WebSrv01 ;
    bot:hasElement noria:Resource_DB01 ;
    seas:subSystemOf noria:Room_ServerRoomA .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Second rack in Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "2"^^xsd:string ;
    bot:hasElement noria:Resource_Router01 ;
    bot:hasElement noria:Resource_Switch01 ;
    seas:subSystemOf noria:Room_ServerRoomA .

noria:Locus_RackA3 a noria:Locus ;
    rdfs:label "Rack A3"@en ;
    rdfs:comment "Third rack in Server Room A, dedicated to virtualization hosts."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "3"^^xsd:string ;
    bot:hasElement noria:Resource_Hypervisor01 ;
    bot:hasElement noria:Resource_Hypervisor02 ;
    seas:subSystemOf noria:Room_ServerRoomA .

noria:Locus_RackB1 a noria:Locus ;
    rdfs:label "Rack B1"@en ;
    rdfs:comment "Main network rack in Network Closet B."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasElement noria:Resource_Router02 ;
    bot:hasElement noria:Resource_Firewall01 ;
    seas:subSystemOf noria:Room_NetworkClosetB .

