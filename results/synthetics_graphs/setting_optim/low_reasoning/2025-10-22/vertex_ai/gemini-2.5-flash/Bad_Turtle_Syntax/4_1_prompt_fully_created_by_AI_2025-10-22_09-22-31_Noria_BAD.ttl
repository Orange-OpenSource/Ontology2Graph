noria:OP_NetworkExpansion a noria:OperationPlan ;
    rdfs:label "Network Expansion Procedure"@en ;
    rdfs:comment "Procedure for expanding network infrastructure in an office environment."@en ;
    noria:operationPlanPreCondition noria:PreCond_NewHardwareStaged ;
    noria:operationPlanPreCondition noria:PreCond_NetworkDiagramUpdated ;
    noria:operationPlanPostCondition noria:PostCond_NewDevicesOnline ;
    noria:operationPlanPostCondition noria:PostCond_CoverageVerified .

noria:PreCond_NewHardwareStaged a noria:ActionPreCondition ;
    rdfs:label "New Hardware Staged"@en ;
    rdfs:comment "Ensure all new network hardware is physically staged and ready for configuration."@en .

noria:PreCond_NetworkDiagramUpdated a noria:ActionPreCondition ;
    rdfs:label "Network Diagrams Updated"@en ;
    rdfs:comment "Verify that network diagrams and documentation are updated to reflect planned changes."@en .

noria:PostCond_NewDevicesOnline a noria:ActionPostCondition ;
    rdfs:label "New Network Devices Online"@en ;
    rdfs:comment "Confirm that all newly installed switches and access points are online and configured."@en .

noria:PostCond_CoverageVerified a noria:ActionPostCondition ;
    rdfs:label "Network Coverage Verified"@en ;
    rdfs:comment "Verify that network coverage and connectivity in expanded areas are as expected."@en .

