# --- Trouble Ticket Notes (noria:TroubleTicketNote) ---
noria:TroubleTicketNote_DNS_001_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Initial diagnosis for DNS outage"@en ;
    rdfs:comment "Confirmed dns01.corp.example.com is not responding to pings. Checked network path from core router, no issues detected on physical link. Suspect OS or DNS service issue on the server itself."@en ;
    dcterms:created "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_John_Doe ;
    dcterms:isPartOf noria:TroubleTicket_DNS_Outage_001 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

noria:TroubleTicketNote_DNS_001_Note2 a noria:TroubleTicketNote ;
    rdfs:label "DNS service restarted"@en ;
    rdfs:comment "Logged into dns01.corp.example.com via console. Found DNS service stopped. Restarted service. Server now responding to pings. Monitoring for stability."@en ;
    dcterms:created "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_John_Doe ;
    dcterms:isPartOf noria:TroubleTicket_DNS_Outage_001 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> .

noria:TroubleTicketNote_Web_002_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Web app performance investigation"@en ;
    rdfs:comment "Observed high CPU on web01.app.example.com. Application logs show increased database query times. Investigating database performance."@en ;
    dcterms:created "2024-04-21T10:30:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_Alice_Brown ;
    dcterms:isPartOf noria:TroubleTicket_Web_App_Slow_002 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

noria:TroubleTicketNote_CRM_003_Note1 a noria:TroubleTicketNote ;
    rdfs:label "DB service restart for CRM"@en ;
    rdfs:comment "Database service on db01.app.example.com was found to be down. Restarted the service. CRM application is now able to connect. Root cause analysis pending."@en ;
    dcterms:created "2024-04-22T14:15:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_DBA_Team ;
    dcterms:isPartOf noria:TroubleTicket_CRM_DB_Error_003 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

