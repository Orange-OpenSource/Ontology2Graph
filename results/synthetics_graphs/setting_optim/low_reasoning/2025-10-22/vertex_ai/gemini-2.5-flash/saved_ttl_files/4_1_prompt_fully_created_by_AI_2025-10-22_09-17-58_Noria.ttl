    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Online Services" ;
    noria:resourceForApplication noria:Resource_Web_Server_01, noria:Resource_DB_Server_01, noria:Resource_DNS_Server_01 .

