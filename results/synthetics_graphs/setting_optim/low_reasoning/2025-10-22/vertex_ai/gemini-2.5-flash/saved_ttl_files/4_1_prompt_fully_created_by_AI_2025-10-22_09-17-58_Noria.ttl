# --- Operation Plans (noria:OperationPlan) ---
noria:OperationPlan_Restart_DNS_Service a noria:OperationPlan ;
    rdfs:label "Restart DNS Service Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the DNS service on a Linux server."@en ;
    skos:example "1. SSH to server. 2. Check service status: 'systemctl status named'. 3. Restart service: 'systemctl restart named'. 4. Verify service status and network connectivity."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNS_Service_Down ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNS_Service_Up .

noria:OperationPlan_Web_Server_Troubleshooting a noria:OperationPlan ;
    rdfs:label "Web Server Performance Troubleshooting Guide"@en ;
    rdfs:comment "Guide for diagnosing and resolving performance issues on web application servers."@en ;
    skos:example "1. Check CPU/Memory usage. 2. Analyze application logs for errors. 3. Review database connection metrics. 4. Scale resources if necessary."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_Web_App_Slow ;
    noria:operationPlanPostCondition noria:ActionPostCondition_Web_App_Normal .

noria:OperationPlan_Router_Firmware_Upgrade a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Detailed procedure for upgrading firmware on Cisco Nexus switches, including pre-checks and post-checks."@en ;
    skos:example "1. Backup configuration. 2. Download new firmware. 3. Install firmware. 4. Reboot device. 5. Verify connectivity and routing tables."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_Router_Ready_For_Upgrade ;
    noria:operationPlanPostCondition noria:ActionPostCondition_Router_Upgrade_Successful .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
noria:ActionPreCondition_DNS_Service_Down a noria:ActionPreCondition ;
    rdfs:label "DNS Service is Down"@en ;
    rdfs:comment "Condition: The DNS service process is not running on the server, or is unresponsive."@en .

noria:ActionPostCondition_DNS_Service_Up a noria:ActionPostCondition ;
    rdfs:label "DNS Service is Up and Responding"@en ;
    rdfs:comment "Outcome: The DNS service is running, and DNS queries are successfully resolved."@en .

noria:ActionPreCondition_Web_App_Slow a noria:ActionPreCondition ;
    rdfs:label "Web Application Response Time Exceeds Threshold"@en ;
    rdfs:comment "Condition: Average response time for key web application transactions is above 500ms."@en .

noria:ActionPostCondition_Web_App_Normal a noria:ActionPostCondition ;
    rdfs:label "Web Application Response Time Normal"@en ;
    rdfs:comment "Outcome: Average response time for key web application transactions is below 200ms."@en .

noria:ActionPreCondition_Router_Ready_For_Upgrade a noria:ActionPreCondition ;
    rdfs:label "Router Ready for Firmware Upgrade"@en ;
    rdfs:comment "Condition: Router configuration backed up, maintenance window approved, and redundant path active."@en .

noria:ActionPostCondition_Router_Upgrade_Successful a noria:ActionPostCondition ;
    rdfs:label "Router Firmware Upgrade Successful"@en ;
    rdfs:comment "Outcome: Router is operational with new firmware, all interfaces up, and routing protocols converged."@en .

# --- Anomaly Patterns (noria:AnomalyPattern) ---
noria:AnomalyPattern_High_CPU_DB_Error a noria:AnomalyPattern ;
    rdfs:label "High CPU leading to DB Errors"@en ;
    rdfs:comment "Pattern indicating that sustained high CPU on a web server often precedes database connection errors, suggesting a bottleneck or resource exhaustion."@en ;
    skos:example "If (Resource_Web_Server_01.CPU_Usage > 90% for 10min) AND (Application_Internal_CRM.DB_Connection_Errors > 5/min), then AnomalyPattern_High_CPU_DB_Error is detected."@en .

noria:AnomalyPattern_Link_Flap_Routing_Instability a noria:AnomalyPattern ;
    rdfs:label "Network Link Flap causing Routing Instability"@en ;
    rdfs:comment "Pattern where frequent up/down transitions on a network interface lead to routing protocol instability and packet loss."@en ;
    skos:example "If (NetworkInterface_CR_01_Gi0_0_1.OperationalStatus changes > 3 times in 5min) AND (Resource_Core_Router_01.RoutingTableChanges > 10/min), then AnomalyPattern_Link_Flap_Routing_Instability is detected."@en .

