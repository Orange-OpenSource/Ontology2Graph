    seas:subSystemOf noria:Application_Corporate_Web_Portal, noria:Application_Internal_CRM ; # Services can be composed of applications
    seas:subSystemOf noria:Resource_Core_Router_01, noria:Resource_Core_Router_02, noria:Resource_DNS_Server_01 . # And resources directly

