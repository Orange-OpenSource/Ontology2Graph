# --- Agents (foaf:Agent and org:OrganizationalUnit) ---
foaf:Agent_IT_Ops_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:label "Équipe Opérations IT"@fr ;
