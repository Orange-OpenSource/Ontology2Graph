# =============================================================================
# Anomaly Patterns (noria:AnomalyPattern)
# =============================================================================

noria:AnomalyPattern001 a noria:AnomalyPattern ;
    rdfs:label "Web Server Disk Full Anomaly"@en ;
    rdfs:comment "Pattern indicating a web server disk is full, leading to service outage."@en ;
    skos:example "Combination of 'Disk Full Alert' and 'HTTP Service Down Alert' from the same web server."@en ;
    folio:hasCause "Insufficient disk space allocation."@en ;
    folio:hasEffect "Web service unavailability."@en .

noria:AnomalyPattern002 a noria:AnomalyPattern ;
    rdfs:label "Database High CPU Anomaly"@en ;
    rdfs:comment "Pattern indicating sustained high CPU usage on a database server, leading to performance degradation."@en ;
    skos:example "Sustained 'High CPU Alert' on DB server, correlated with 'Slow Query' events."@en ;
    folio:hasCause "Inefficient queries or high load."@en ;
    folio:hasEffect "Application performance degradation."@en .

noria:AnomalyPattern003 a noria:AnomalyPattern ;
    rdfs:label "Firewall Misconfiguration Anomaly"@en ;
    rdfs:comment "Pattern indicating a firewall rule change immediately followed by service unavailability."@en ;
    skos:example "Firewall Rule Change Log followed by 'Service Unreachable' alerts for affected applications."@en ;
    folio:hasCause "Incorrectly applied network access control."@en ;
    folio:hasEffect "Blocked legitimate network traffic."@en .

