# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord001 a noria:EventRecord ;
    rdfs:label "Web Server 01 Disk Full Alert"@en ;
    rdfs:comment "Alert: /var partition on web01.corp.example.com is 100% full."@en ;
    noria:loggingTime "2024-04-20T09:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource001 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logText "CRITICAL - Disk usage on /var is 100%."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    dcterms:relation noria:TroubleTicket001 .

noria:EventRecord002 a noria:EventRecord ;
    rdfs:label "Web Server 01 Service Down Alert"@en ;
    rdfs:comment "Alert: HTTP service on web01.corp.example.com is down."@en ;
    noria:loggingTime "2024-04-20T09:58:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource001 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logText "CRITICAL - HTTP service not responding on web01."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    dcterms:relation noria:TroubleTicket001 .

noria:EventRecord003 a noria:EventRecord ;
    rdfs:label "Firewall Rule Change Log"@en ;
    rdfs:comment "Log: Firewall rule 'block_app_b' deployed by admin."@en ;
    noria:loggingTime "2024-04-22T10:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource013 ;
    noria:logOriginatingManagementSystem noria:Application005 ;
    noria:logOriginatingAgent foaf:Agent004 ;
    noria:logText "Firewall rule 'block_app_b' added to policy 'internet_access'."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    dcterms:relation noria:ChangeRequest002 .

noria:EventRecord004 a noria:EventRecord ;
    rdfs:label "Database Server High CPU Alert"@en ;
    rdfs:comment "Alert: CPU utilization on db01.corp.example.com is consistently above 90%."@en ;
    noria:loggingTime "2024-04-21T08:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource002 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logText "WARNING - High CPU usage (92%) on db01."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    dcterms:relation noria:TroubleTicket002 .

noria:EventRecord005 a noria:EventRecord ;
    rdfs:label "Network Interface ge-0/0/0 Down Alert"@en ;
    rdfs:comment "Alert: Interface ge-0/0/0 on cr01.corp.example.com is down."@en ;
    noria:loggingTime "2024-04-23T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource011 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logText "CRITICAL - Interface ge-0/0/0 on cr01 changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan001 .

noria:EventRecord006 a noria:EventRecord ;
    rdfs:label "Network Interface ge-0/0/0 Up Log"@en ;
    rdfs:comment "Log: Interface ge-0/0/0 on cr01.corp.example.com is up."@en ;
    noria:loggingTime "2024-04-23T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource011 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logText "INFO - Interface ge-0/0/0 on cr01 changed state to up."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Cleared> .

noria:EventRecord007 a noria:EventRecord ;
    rdfs:label "SIEM Login Failure Alert"@en ;
    rdfs:comment "Alert: Multiple failed login attempts on SIEM from unknown IP."@en ;
    noria:loggingTime "2024-04-23T14:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Application005 ;
    noria:logOriginatingManagementSystem noria:Application005 ;
    noria:logText "SECURITY - 5 failed login attempts for user 'admin' from 192.168.1.10."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OperationPlan001 a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network interface issues."@en ;
    skos:example "Check cable, verify configuration, restart interface, check adjacent device."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition001 ;
    noria:operationPlanPostCondition noria:ActionPostCondition001 .

noria:OperationPlan002 a noria:OperationPlan ;
    rdfs:label "Database Performance Tuning Guide"@en ;
    rdfs:comment "Procedure for identifying and resolving database performance bottlenecks."@en ;
    skos:example "Analyze slow query logs, check index usage, review execution plans."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition002 ;
    noria:operationPlanPostCondition noria:ActionPostCondition002 .

noria:OperationPlan003 a noria:OperationPlan ;
    rdfs:label "Firewall Rule Deployment SOP"@en ;
    rdfs:comment "Standard operating procedure for deploying new firewall rules."@en ;
    skos:example "Review change request, create rule, test in staging, deploy to production, verify."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition003 ;
    noria:operationPlanPostCondition noria:ActionPostCondition003 .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:ActionPreCondition001 a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Condition"@en ;
    rdfs:comment "Condition: Network interface operational status is 'down'."@en ;
    skos:example "noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/down>" .

noria:ActionPostCondition001 a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up Condition"@en ;
    rdfs:comment "Condition: Network interface operational status is 'up'."@en ;
    skos:example "noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up>" .

noria:ActionPreCondition002 a noria:ActionPreCondition ;
    rdfs:label "High Database CPU/Latency Condition"@en ;
    rdfs:comment "Condition: Database server CPU utilization > 80% or query latency > 500ms."@en ;
    skos:example "Resource.cpuUsage > 80, Application.queryLatency > 500ms" .

noria:ActionPostCondition002 a noria:ActionPostCondition ;
    rdfs:label "Database Performance Restored Condition"@en ;
    rdfs:comment "Condition: Database server CPU utilization < 50% and query latency < 100ms."@en ;
    skos:example "Resource.cpuUsage < 50, Application.queryLatency < 100ms" .

noria:ActionPreCondition003 a noria:ActionPreCondition ;
    rdfs:label "Approved Change Request for Firewall Rule"@en ;
    rdfs:comment "Condition: A change request for firewall rule deployment is approved and in 'Planned' status."@en ;
    skos:example "ChangeRequest.status = 'Planned', ChangeRequest.type = 'Configuration'" .

noria:ActionPostCondition003 a noria:ActionPostCondition ;
    rdfs:label "Firewall Rule Deployed and Verified"@en ;
    rdfs:comment "Condition: New firewall rule is active and verified to allow intended traffic without side effects."@en ;
    skos:example "Firewall.ruleActive = true, TrafficFlow.status = 'OK'" .

