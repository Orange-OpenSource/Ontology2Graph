    skos:prefLabel "Web Application"@en ;
    skos:inScheme <kos/application/type> .
<kos/application/type/messaging> a skos:Concept ;
    skos:prefLabel "Messaging Application"@en ;
    skos:inScheme <kos/application/type> .

