# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OperationPlan001 a noria:OperationPlan ;
    rdfs:label "Database Connection Pool Adjustment"@en ;
    rdfs:comment "Procedure to adjust database connection pool size to resolve exhaustion issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition001 ;
    noria:operationPlanPostCondition noria:ActionPostCondition001 .

noria:ActionPreCondition001 a noria:ActionPreCondition ;
    rdfs:label "DB Connection Pool Exhaustion Detected"@en ;
    rdfs:comment "Condition: Monitoring system reports database connection pool exhaustion for a critical application."@en .

noria:ActionPostCondition001 a noria:ActionPostCondition ;
    rdfs:label "DB Connection Pool Stable"@en ;
    rdfs:comment "Outcome: Database connection pool utilization is within normal limits, application is responsive."@en .

noria:OperationPlan002 a noria:OperationPlan ;
    rdfs:label "WAN Link Troubleshooting Guide"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving WAN link issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition002 ;
    noria:operationPlanPostCondition noria:ActionPostCondition002 .

noria:ActionPreCondition002 a noria:ActionPreCondition ;
    rdfs:label "WAN Link Flapping/Packet Loss"@en ;
    rdfs:comment "Condition: Intermittent connectivity or high packet loss detected on a WAN link."@en .

noria:ActionPostCondition002 a noria:ActionPostCondition ;
    rdfs:label "WAN Link Stable, No Packet Loss"@en ;
    rdfs:comment "Outcome: WAN link is stable, packet loss is zero, and connectivity is restored."@en .

noria:OperationPlan003 a noria:OperationPlan ;
    rdfs:label "Router OS Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading the operating system of network routers."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition003 ;
    noria:operationPlanPostCondition noria:ActionPostCondition003 .

noria:ActionPreCondition003 a noria:ActionPreCondition ;
    rdfs:label "Router OS Outdated"@en ;
    rdfs:comment "Condition: Router operating system is identified as outdated or vulnerable."@en .

noria:ActionPostCondition003 a noria:ActionPostCondition ;
    rdfs:label "Router OS Upgraded, Functionality Verified"@en ;
    rdfs:comment "Outcome: Router OS is successfully upgraded, and all network services are functional."@en .

# =============================================================================
# Procedure Execution Containers (for TroubleTicketNote003)
# =============================================================================

noria:ProcedureExecutionContainer001 a pep:ProcedureExecutionContainer ;
    rdfs:label "DB Connection Pool Adjustment Execution for TT001"@en ;
    rdfs:comment "Container for actions taken to resolve DB connection pool exhaustion."@en ;
    pep:hasProcedure noria:OperationPlan001 ;
    dcterms:relation noria:TroubleTicketNote003 ;
    # Example of an event record that might be part of this execution
    # (assuming it's a log of the action itself, not just an alert)
    pep:member noria:EventRecord009 .

noria:EventRecord009 a noria:EventRecord ;
    rdfs:label "DB Connection Pool Size Increased Log"@en ;
    rdfs:comment "Log entry: Database connection pool size increased from 100 to 200."@en ;
    noria:loggingTime "2023-10-26T10:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource002 ;
    noria:logOriginatingManagementSystem noria:Application003 ; # NMS
    noria:logOriginatingAgent foaf:Agent003 ;
    noria:logText "INFO: DB connection pool size for CRM_PROD_01 increased to 200." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Cleared> .

# =============================================================================
# Anomaly Patterns
# =============================================================================

noria:AnomalyPattern001 a noria:AnomalyPattern ;
    rdfs:label "Database Connection Exhaustion Pattern"@en ;
    rdfs:comment "Pattern indicating database connection pool exhaustion: high connection count, low available connections, and application errors."@en ;
    folio:hasCause "Application misconfiguration or sudden traffic surge."@en ;
    folio:hasEffect "Application unresponsiveness, service outage."@en .

noria:AnomalyPattern002 a noria:AnomalyPattern ;
    rdfs:label "WAN Link Flapping Pattern"@en ;
    rdfs:comment "Pattern indicating WAN link instability: frequent interface up/down events, high packet loss, and latency spikes."@en ;
    folio:hasCause "Physical fiber damage, faulty transceiver, or routing protocol instability."@en ;
    folio:hasEffect "Intermittent network connectivity, service degradation."@en .

noria:AnomalyPattern003 a noria:AnomalyPattern ;
    rdfs:label "High CPU Utilization Pattern"@en ;
    rdfs:comment "Pattern indicating excessive CPU usage: sustained high CPU load, slow application response, and potential service crashes."@en ;
    folio:hasCause "Application bug, traffic surge, or resource contention."@en ;
    folio:hasEffect "Application performance degradation, service unavailability."@en .

# Linking Anomaly Patterns to Trouble Tickets (as potential causes/diagnoses)
noria:TroubleTicket001 dcterms:conformsTo noria:AnomalyPattern001 .
noria:TroubleTicket002 dcterms:conformsTo noria:AnomalyPattern002 .
noria:TroubleTicket003 dcterms:conformsTo noria:AnomalyPattern003 .

# Linking Operation Plans to Anomaly Patterns (as potential solutions)
noria:OperationPlan001 noria:actionCorrelatedOperationPlan noria:AnomalyPattern001 .
noria:OperationPlan002 noria:actionCorrelatedOperationPlan noria:AnomalyPattern002 .

