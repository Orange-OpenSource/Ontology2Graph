noria:TroubleTicket001 a noria:TroubleTicket ;
    rdfs:label "CRM Production Outage"@en ;
    rdfs:comment "Critical outage affecting the production CRM system, users unable to log in."@en ;
    dcterms:created "2023-10-26T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2023-10-26T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Database connection pool exhaustion on DB Server 01."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/InternalIT> ;
    noria:troubleTicketDetectionDateTime "2023-10-26T08:55:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2023-10-26T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2023-10-26T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2023-10-26T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent002, foaf:Agent003 ;
    noria:troubleTicketRelatedService noria:ApplicationModule001, noria:Service001 ;
    noria:troubleTicketRelatedResource noria:Resource010, noria:Resource002 ;
    noria:troubleTicketImpacts noria:Application001, noria:Resource010, noria:Resource002 ;
    noria:troubleTicketTrigger noria:EventRecord001 ;
    noria:documentExternalId "CUST-INC-2023-001" ;
    noria:documentHRef "https://ticketing.example.com/ticket/TT001" .

noria:TroubleTicket002 a noria:TroubleTicket ;
