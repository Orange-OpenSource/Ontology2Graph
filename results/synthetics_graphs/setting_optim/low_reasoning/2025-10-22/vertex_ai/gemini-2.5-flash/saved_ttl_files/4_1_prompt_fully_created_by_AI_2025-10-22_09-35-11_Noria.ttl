noria:OperationPlan004 noria:actionCorrelatedOperationPlan noria:AnomalyPattern003 .

# More complex relationships and cross-linking
noria:Application001 noria:resourceForApplication noria:Resource003 . # CRM also uses Web Server
noria:Application002 noria:resourceForApplication noria:Resource011 . # ERP uses SAN Array
noria:Application003 noria:resourceForApplication noria:Resource005, noria:Resource006, noria:Resource007, noria:Resource008, noria:Resource009, noria:Resource012, noria:Resource013 . # NMS monitors all network devices
noria:Application005 noria:resourceForApplication noria:Resource006, noria:Resource012, noria:Resource013 . # SIEM monitors network devices and firewalls

noria:Resource001 noria:resourceManagedBy org:Org003 .
noria:Resource002 noria:resourceManagedBy org:Org004 .
noria:Resource003 noria:resourceManagedBy org:Org003 .
noria:Resource004 noria:resourceManagedBy org:Org001 .
noria:Resource005 noria:resourceManagedBy org:Org002 .
noria:Resource006 noria:resourceManagedBy org:Org002 .
noria:Resource007 noria:resourceManagedBy org:Org002 .
noria:Resource008 noria:resourceManagedBy org:Org002 .
noria:Resource009 noria:resourceManagedBy org:Org002 .
noria:Resource010 noria:resourceManagedBy org:Org003 .
noria:Resource011 noria:resourceManagedBy org:Org004 .
noria:Resource012 noria:resourceManagedBy org:Org005 .
noria:Resource013 noria:resourceManagedBy org:Org005 .
noria:Resource014 noria:resourceManagedBy org:Org003 .
noria:Resource015 noria:resourceManagedBy org:Org004 .
noria:Resource016 noria:resourceManagedBy org:Org002 .
noria:Resource017 noria:resourceManagedBy org:Org002 .

# Linking agents to resources they manage
foaf:Agent001 noria:agentManagesResource noria:Resource005, noria:Resource006, noria:Resource007, noria:Resource008, noria:Resource009, noria:Resource016, noria:Resource017 .
foaf:Agent002 noria:agentManagesResource noria:Resource001, noria:Resource003, noria:Resource010, noria:Resource014 .
foaf:Agent003 noria:agentManagesResource noria:Resource002, noria:Resource011, noria:Resource015 .
foaf:Agent004 noria:agentManagesResource noria:Resource012, noria:Resource013 .

# Linking Trouble Tickets to Event Records (documentStatusHistory)
noria:TroubleTicket001 noria:documentStatusHistory noria:EventRecord001 .
noria:TroubleTicket002 noria:documentStatusHistory noria:EventRecord002 .
noria:TroubleTicket003 noria:documentStatusHistory noria:EventRecord003 .
noria:TroubleTicket004 noria:documentStatusHistory noria:EventRecord010 .

# Linking Change Requests to Event Records (documentStatusHistory)
noria:ChangeRequest001 noria:documentStatusHistory noria:EventRecord007, noria:EventRecord008 .
noria:ChangeRequest002 noria:documentStatusHistory noria:EventRecord006 .

