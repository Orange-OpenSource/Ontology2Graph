    seas:subSystem noria:ApplicationModule001, noria:ApplicationModule005 ; # CRM Prod, DNS Primary
    seas:subSystem noria:Resource003, noria:Resource006, noria:Resource012 . # Web Server, Edge Router, Perimeter Firewall

noria:Service002 a noria:Service ;
    rdfs:label "Internal ERP Access"@en ;
    rdfs:comment "Internal service for employees to access ERP system."@en ;
    noria:serviceType <kos/service/type/InternalService> ;
    seas:subSystem noria:ApplicationModule003, noria:ApplicationModule005 ; # ERP Prod, DNS Primary
    seas:subSystem noria:Resource001, noria:Resource002, noria:Resource005, noria:Resource008 . # App Server, DB Server, Core Router, Core Switch

noria:Service003 a noria:Service ;
    rdfs:label "Regional Office Connectivity"@en ;
    rdfs:comment "Provides network and application access for Lyon office."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystem noria:Resource007, noria:Resource009 ; # Regional Router, Access Switch
    seas:subSystem noria:NetworkLink005 . # WAN Link Paris-Lyon

