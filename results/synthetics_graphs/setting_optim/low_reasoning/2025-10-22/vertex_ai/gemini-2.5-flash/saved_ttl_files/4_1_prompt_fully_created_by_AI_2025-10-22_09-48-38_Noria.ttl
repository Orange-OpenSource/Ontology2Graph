noria:TroubleTicket001 a noria:TroubleTicket ;
    rdfs:label "DNS Service Outage Incident"@en ;
    rdfs:comment "Critical incident: Corporate DNS service is completely unavailable."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ServerFailure> ;
    noria:troubleTicketCause "DNS daemon crashed on primary server, secondary server failed to take over."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/InternalIT> ;
    noria:troubleTicketDetectionDateTime "2024-03-15T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-03-15T09:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ; # Assuming InProgress exists
    noria:troubleTicketRelatedParty org:OrgUnit002, foaf:Person002 ;
    noria:troubleTicketRelatedService noria:App001, noria:AppModule001 ;
    noria:troubleTicketRelatedResource noria:Resource001, noria:Resource002 ;
    noria:troubleTicketImpacts noria:App001, noria:Resource001, noria:Resource002 ;
    noria:troubleTicketTrigger noria:EventRecord001 ;
    noria:documentStatusHistory noria:EventRecord001, noria:EventRecord005 ;
    noria:documentHRef <https://itsm.example.com/tt/TT001> .

noria:TroubleTicket002 a noria:TroubleTicket ;
    rdfs:label "Branch A WAN Connectivity Issue"@en ;
    rdfs:comment "Major incident: Branch Office A has lost WAN connectivity to the data center."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
