noria:AnomalyPattern001 a noria:AnomalyPattern ;
    rdfs:label "DNS Service Failure Pattern"@en ;
    rdfs:comment "Pattern indicating a DNS service failure: DNS server unreachable combined with DNS query timeouts."@en ;
    folio:hasCause "DNS daemon crash" ;
    folio:hasEffect "Service outage" .

noria:AnomalyPattern002 a noria:AnomalyPattern ;
    rdfs:label "WAN Link Outage Pattern"@en ;
    rdfs:comment "Pattern indicating a WAN link outage: Interface down on both ends of a link, high packet loss."@en ;
    folio:hasCause "Physical link damage" ;
    folio:hasEffect "Network isolation" .

# =============================================================================
# Additional Interconnections for Density
# =============================================================================

# Link Agents to Resources they manage (inverse of resourceManagedBy)
org:OrgUnit002 noria:agentManagesResource noria:Resource001, noria:Resource002, noria:Resource005, noria:Resource009, noria:Resource010 .
org:OrgUnit001 noria:agentManagesResource noria:Resource003, noria:Resource004, noria:Resource007 .
org:OrgUnit005 noria:agentManagesResource noria:Resource006 .
org:OrgUnit004 noria:agentManagesResource noria:Resource008 .

# Link Applications to Resources (resourceForApplication)
noria:Resource001 noria:resourceForApplication noria:App001 .
noria:Resource002 noria:resourceForApplication noria:App001 .
noria:Resource003 noria:resourceForApplication noria:App002 .
noria:Resource004 noria:resourceForApplication noria:App002 .
noria:Resource005 noria:resourceForApplication noria:App003 .
noria:Resource006 noria:resourceForApplication noria:App003 .
noria:Resource007 noria:resourceForApplication noria:App002 .
noria:Resource008 noria:resourceForApplication noria:App004 .
noria:Resource009 noria:resourceForApplication noria:App005 .
noria:Resource010 noria:resourceForApplication noria:App006 .

# Link Network Interfaces to Network Links
noria:NetworkInterface003 noria:networkInterfaceConnects noria:NetworkLink002 .
noria:NetworkInterface005 noria:networkInterfaceConnects noria:NetworkLink002 .
noria:NetworkInterface004 noria:networkInterfaceConnects noria:NetworkLink003 .
noria:NetworkInterface008 noria:networkInterfaceConnects noria:NetworkLink003 .
noria:NetworkInterface009 noria:networkInterfaceConnects noria:NetworkLink004 .
noria:NetworkInterface010 noria:networkInterfaceConnects noria:NetworkLink005 .

# Link Services to Application Modules
noria:Service001 seas:subSystem noria:AppModule001, noria:AppModule003 . # Example: Internet access might use DNS and Web
noria:Service002 seas:subSystem noria:AppModule004 . # Example: Internal hosting might use monitoring

# Link Trouble Tickets to Notes and Attachments
noria:TroubleTicket001 dcterms:hasPart noria:TroubleTicketNote001, noria:DocumentAttachment001 .
noria:TroubleTicket002 dcterms:hasPart noria:TroubleTicketNote002, noria:DocumentAttachment002 .
noria:TroubleTicket003 dcterms:hasPart noria:TroubleTicketNote003 .

# Link Change Requests to Attachments
noria:ChangeRequest001 dcterms:hasPart noria:DocumentAttachment003 .

# Link Event Records to Trouble Tickets (as correlated notifications)
noria:TroubleTicket001 dcterms:relation noria:EventRecord001 .
noria:TroubleTicket002 dcterms:relation noria:EventRecord002 .
noria:TroubleTicket003 dcterms:relation noria:EventRecord003 .

# Link Event Records to Change Requests (as correlated notifications)
noria:ChangeRequest003 dcterms:relation noria:EventRecord005 . # Assuming the restart was part of the patch

# Link Event Records to Procedures (alarmMitigatedBy)
noria:EventRecord001 noria:alarmMitigatedBy noria:TroubleTicket001 . # The TT itself is a ProcedureExecutionContainer
noria:EventRecord002 noria:alarmMitigatedBy noria:TroubleTicket002 .
noria:EventRecord005 noria:alarmMitigatedBy noria:ChangeRequest003 .

# Link Operation Plans to Anomaly Patterns (as control methods)
noria:OperationPlan001 folio:controls noria:AnomalyPattern001 .
noria:OperationPlan002 folio:controls noria:AnomalyPattern002 .

# Link Anomaly Patterns to Event Records (as indicators)
noria:AnomalyPattern001 folio:hasIndicator noria:EventRecord001 .
noria:AnomalyPattern002 folio:hasIndicator noria:EventRecord002 .

