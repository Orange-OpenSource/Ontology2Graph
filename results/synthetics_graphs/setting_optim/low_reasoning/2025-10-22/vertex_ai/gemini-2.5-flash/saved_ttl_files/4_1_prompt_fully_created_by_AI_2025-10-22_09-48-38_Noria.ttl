# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OperationPlan001 a noria:OperationPlan ;
    rdfs:label "DNS Server Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a corporate DNS server."@en ;
    noria:operationPlanPreCondition noria:PreCondition001 ;
    noria:operationPlanPostCondition noria:PostCondition001 ;
    noria:elementManagedBy org:OrgUnit002 .

noria:PreCondition001 a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unresponsive"@en ;
    rdfs:comment "Condition: DNS service is not responding to queries."@en .

noria:PostCondition001 a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Outcome: DNS service is responding to queries and healthy."@en .

noria:OperationPlan002 a noria:OperationPlan ;
    rdfs:label "WAN Link Failover Procedure"@en ;
    rdfs:comment "Procedure to initiate failover for a critical WAN link."@en ;
    noria:operationPlanPreCondition noria:PreCondition002 ;
    noria:operationPlanPostCondition noria:PostCondition002 ;
    noria:elementManagedBy org:OrgUnit001 .

noria:PreCondition002 a noria:ActionPreCondition ;
    rdfs:label "WAN Link Down"@en ;
    rdfs:comment "Condition: Primary WAN link is detected as down or degraded."@en .

noria:PostCondition002 a noria:ActionPostCondition ;
    rdfs:label "Traffic Rerouted Successfully"@en ;
    rdfs:comment "Outcome: Network traffic is successfully rerouted over the secondary link."@en .

