    dcterms:isPartOf noria:TroubleTicket006 ;
    dcterms:format "application/pdf" ;
    dcterms:source <file:///reports/vuln_scan_web01.pdf> .

# Add a change request to fix the vulnerability
noria:ChangeRequest005 a noria:ChangeRequest ;
    rdfs:label "Web Server Apache Upgrade"@en ;
    rdfs:comment "Emergency upgrade of Apache HTTP Server on web01 to patch critical vulnerability."@en ;
    dcterms:created "2024-03-17T14:30:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-03-17T15:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-03-17T16:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/SoftwareUpgrade> ;
    noria:changeRequestType <kos/ChangeRequest/type/Emergency> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SecurityPatch> ;
    noria:changeRequestImpact noria:Resource005, noria:App003, noria:AppModule003 ;
    noria:changeRequestOutageDuration "PT0H10M"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Completed> ;
    noria:changeRequestInitiatorParty foaf:Person004 ;
    noria:changeRequestPilotParty foaf:Person002 ;
    noria:changeRequestActorParty foaf:Person002 ;
    noria:changeRequestIsRegulated true ;
    noria:documentHRef <https://itsm.example.com/cr/CR005> .

noria:ChangeRequest005 dcterms:relation noria:TroubleTicket006 .

noria:EventRecord014 a noria:EventRecord ;
    rdfs:label "Apache Upgrade Started Log"@en ;
    rdfs:comment "Log entry indicating the start of Apache upgrade on web01."@en ;
    noria:loggingTime "2024-03-17T15:00:00Z"^^xsd:dateTime ;
    noria:logText "Starting Apache HTTP Server upgrade to version 2.4.58."@en ;
    noria:logOriginatingManagedObject noria:Resource005 ;
    noria:logOriginatingAgent foaf:Person002 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord015 a noria:EventRecord ;
    rdfs:label "Apache Upgrade Completed Log"@en ;
    rdfs:comment "Log entry indicating completion of Apache upgrade on web01."@en ;
    noria:loggingTime "2024-03-17T15:55:00Z"^^xsd:dateTime ;
    noria:logText "Apache HTTP Server upgraded to 2.4.58 and restarted successfully."@en ;
    noria:logOriginatingManagedObject noria:Resource005 ;
    noria:logOriginatingAgent foaf:Person002 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:ChangeRequest005 noria:documentStatusHistory noria:EventRecord014, noria:EventRecord015 .
noria:EventRecord014 noria:alarmMitigatedBy noria:ChangeRequest005 .
noria:EventRecord015 noria:alarmMitigatedBy noria:ChangeRequest005 .

# Final check for connectivity and density:
# - All major classes have multiple instances.
# - Instances are linked to each other using NORIA properties.
# - Agents are linked to organizations and resources.
# - Resources are linked to locations, product models, applications, and network interfaces.
# - Network interfaces are linked to resources and network links.
# - Applications are linked to modules and services.
# - Trouble tickets are linked to services, resources, parties, event records, and notes/attachments.
# - Change requests are linked to impacts, parties, and event records.
# - Event records are linked to originating objects/systems/agents, and related to tickets/CRs.
# - KOS concepts are used for classification.
# - rdfs:label, rdfs:comment, skos:example are used.
# - No ldp prefix.
# - Maximize entities within token limits.

# This graph is now quite dense and interconnected, covering various aspects of IT operations.
