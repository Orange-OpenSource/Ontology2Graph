    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Zabbix" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/NetworkOutage> ;
    noria:troubleTicketCause "Fiber cut on primary WAN link to Branch A."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/Vendor> ;
    noria:troubleTicketDetectionDateTime "2024-03-15T09:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-03-15T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-03-15T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-03-15T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ; # Assuming Resolved exists
    noria:troubleTicketRelatedParty org:OrgUnit001, org:Org002, foaf:Person001 ;
    noria:troubleTicketRelatedService noria:Service001 ;
    noria:troubleTicketRelatedResource noria:Resource003, noria:Resource007, noria:NetworkLink003 ;
    noria:troubleTicketImpacts noria:Service001, noria:Resource007 ;
    noria:troubleTicketTrigger noria:EventRecord002 ;
    noria:documentStatusHistory noria:EventRecord002, noria:EventRecord006 ;
    noria:documentHRef <https://itsm.example.com/tt/TT002> .

noria:TroubleTicket003 a noria:TroubleTicket ;
    rdfs:label "Corporate Website Slow Performance"@en ;
    rdfs:comment "Minor incident: Users reporting slow loading times for the corporate website."@en ;
