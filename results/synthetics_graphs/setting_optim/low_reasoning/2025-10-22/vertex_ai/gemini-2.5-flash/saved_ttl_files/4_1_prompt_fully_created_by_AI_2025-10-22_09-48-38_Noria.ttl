# Add a trouble ticket for a security vulnerability found by SOC
noria:EventRecord013 a noria:EventRecord ;
    rdfs:label "Vulnerability Scan Alert - Web01"@en ;
    rdfs:comment "Alert from vulnerability scanner: high severity vulnerability detected on Web Server 01."@en ;
    noria:loggingTime "2024-03-17T14:00:00Z"^^xsd:dateTime ;
    noria:logText "CVE-2023-XXXX detected on web01.corp.example.com (Apache HTTP Server)."@en ;
    noria:logOriginatingManagedObject noria:Resource005 ;
    noria:logOriginatingManagementSystem noria:App004 ; # Security app
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:TroubleTicket006 a noria:TroubleTicket ;
    rdfs:label "Web Server Vulnerability Remediation"@en ;
    rdfs:comment "Major incident: High severity vulnerability found on public-facing web server."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Maintenance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nessus" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ApplicationError> ;
    noria:troubleTicketCause "Outdated Apache version."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/InternalIT> ;
    noria:troubleTicketDetectionDateTime "2024-03-17T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-03-17T18:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty org:OrgUnit002, org:OrgUnit004 ;
    noria:troubleTicketRelatedService noria:App003, noria:AppModule003 ;
    noria:troubleTicketRelatedResource noria:Resource005 ;
    noria:troubleTicketTrigger noria:EventRecord013 ;
    noria:documentHRef <https://itsm.example.com/tt/TT006> .

noria:TroubleTicket006 dcterms:hasPart noria:DocumentAttachment005 .

noria:DocumentAttachment005 a noria:DocumentAttachment ;
    rdfs:label "Vulnerability Scan Report Excerpt"@en ;
    rdfs:comment "Excerpt from the vulnerability scan report detailing CVE-2023-XXXX."@en ;
