# Add a change request for storage expansion
noria:ChangeRequest004 a noria:ChangeRequest ;
    rdfs:label "Backup Storage Expansion"@en ;
    rdfs:comment "Request to expand storage capacity for the backup array due to increasing data volume."@en ;
    dcterms:created "2024-03-10T14:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-03-25T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-03-25T12:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/HardwareReplacement> ;
    noria:changeRequestType <kos/ChangeRequest/type/Normal> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/PerformanceImprovement> ; # Capacity is a form of performance
    noria:changeRequestImpact noria:Resource012, noria:App007, noria:Service003 ;
    noria:changeRequestOutageDuration "PT0H0M"^^xsd:duration ;
