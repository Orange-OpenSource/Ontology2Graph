    noria:changeRequestInitiatorParty foaf:Person006 ;
    noria:changeRequestPilotParty foaf:Person006 ;
    noria:changeRequestActorParty foaf:Person006 ;
    noria:documentHRef <https://itsm.example.com/cr/CR004> .

noria:ChangeRequest004 dcterms:relation noria:TroubleTicket005 . # This CR is a proactive measure related to the TT.

