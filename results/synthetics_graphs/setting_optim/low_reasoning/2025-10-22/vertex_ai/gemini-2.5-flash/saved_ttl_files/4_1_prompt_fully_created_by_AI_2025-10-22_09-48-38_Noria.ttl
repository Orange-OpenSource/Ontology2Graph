# Event Records
# =============================================================================

noria:EventRecord001 a noria:EventRecord ;
    rdfs:label "DNS Server 01 Unreachable Alert"@en ;
    rdfs:comment "Alert from monitoring system indicating DNS server 01 is unreachable."@en ;
    noria:loggingTime "2024-03-15T09:00:00Z"^^xsd:dateTime ;
    noria:logText "Host dns01.corp.example.com is unreachable via ICMP."@en ;
    noria:logOriginatingManagedObject noria:Resource001 ;
    noria:logOriginatingManagementSystem noria:App006 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord002 a noria:EventRecord ;
    rdfs:label "WAN Link DC-BOA Down Alert"@en ;
    rdfs:comment "Alert from monitoring system indicating WAN link to Branch A is down."@en ;
    noria:loggingTime "2024-03-15T09:15:00Z"^^xsd:dateTime ;
    noria:logText "Interface ge-0/0/1 on cr01 changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource003 ;
    noria:logOriginatingManagementSystem noria:App006 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord003 a noria:EventRecord ;
    rdfs:label "Web Server CPU High Alert"@en ;
    rdfs:comment "Alert from monitoring system indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-03-15T10:30:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource005 ;
    noria:logOriginatingManagementSystem noria:App006 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord004 a noria:EventRecord ;
    rdfs:label "Firewall Login Attempt Alert"@en ;
    rdfs:comment "Security alert for multiple failed login attempts on Firewall DC01."@en ;
    noria:loggingTime "2024-03-15T11:00:00Z"^^xsd:dateTime ;
    noria:logText "Multiple failed login attempts detected on fw01 from IP 203.0.113.42."@en ;
    noria:logOriginatingManagedObject noria:Resource008 ;
    noria:logOriginatingManagementSystem noria:App004 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logOriginatingAgent foaf:Person004 . # SOC analyst might be involved in reviewing this

noria:EventRecord005 a noria:EventRecord ;
    rdfs:label "DNS Server 01 Restarted Log"@en ;
    rdfs:comment "Log entry confirming restart of DNS Server 01 by Bob Johnson."@en ;
    noria:loggingTime "2024-03-15T09:10:00Z"^^xsd:dateTime ;
    noria:logText "System reboot initiated by bjohnson."@en ;
    noria:logOriginatingManagedObject noria:Resource001 ;
    noria:logOriginatingAgent foaf:Person002 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord006 a noria:EventRecord ;
    rdfs:label "WAN Link Status Up Log"@en ;
    rdfs:comment "Log entry confirming WAN link to Branch A is back up."@en ;
    noria:loggingTime "2024-03-15T09:25:00Z"^^xsd:dateTime ;
    noria:logText "Interface ge-0/0/1 on cr01 changed state to up."@en ;
    noria:logOriginatingManagedObject noria:Resource003 ;
    noria:logOriginatingManagementSystem noria:App006 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Cleared> .

