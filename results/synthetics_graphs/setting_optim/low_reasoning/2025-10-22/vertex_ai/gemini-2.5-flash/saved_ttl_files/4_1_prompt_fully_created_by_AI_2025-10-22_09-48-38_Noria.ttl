# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# NORIA Ontology Metadata (as provided in the schema)
# =============================================================================

<https://w3id.org/noria/ontology/>
	a voaf:Vocabulary, owl:Ontology ;
	dcterms:title "The NORIA Ontology"@en ;
    dcterms:description """The NORIA-O project is a data model for IT networks, events and operations information.
The ontology is developed using web technologies (e.g. RDF, OWL, SKOS) and is intended as a structure for realizing an IT Service Management (ITSM) Knowledge Graph (KG) for Anomaly Detection (AD) and Risk Management applications.
The model has been developed in collaboration with operational teams, and in connection with third parties linked vocabularies.

Alignment with third parties vocabularies is implemented on a per class or per property basis when relevant (e.g. with `rdfs:subClassOf`, `owl:equivalentClass`).
Directions for direct instanciation of these vocabularies are provided for cases where implementing a class/property alignment is redundant.
Alignment holds for the following vocabulary releases:
- [BBO](https://hal.archives-ouvertes.fr/hal-02365012/) 1.0.0
- [BOT](https://w3id.org/bot/) 0.3.2
- [DevOps-Infra](https://oeg-upm.github.io/devops-infra/) 1.0.0
- [FOLIO](https://github.com/IBCNServices/Folio-Ontology) 1.0.0
- [ORG](https://www.w3.org/TR/vocab-org/) 0.8
- [PEP](https://w3id.org/pep/) 1.1
- [SEAS](https://w3id.org/seas/) 1.1
- [SLOGERT](https://sepses.ifs.tuwien.ac.at/ns/log/index-en.html) 1.1.0
- [UCO](https://unifiedcyberontology.org/ontology/uco) Release-0.8.0
"""@en ;
    foaf:depiction <https://github.com/Orange-OpenSource/noria-ontology/raw/master/dataset/noria-0.2/noria-ontology-UC.png> ;
    bibo:status <http://purl.org/ontology/bibo/status/accepted> ;
	dcterms:creator "Lionel Tailhardat (https://orcid.org/0000-0001-5887-899X)" ;
	dcterms:creator "Yoan Chabot (https://orcid.org/0000-0001-5639-1504)" ;
	dcterms:creator "Raphaël Troncy (https://orcid.org/0000-0003-0457-1436)" ;
    dcterms:publisher <https://www.orange.com/> ;
    dcterms:license <https://spdx.org/licenses/BSD-4-Clause> ;
    vann:preferredNamespacePrefix "noria" ;
    vann:preferredNamespaceUri "https://w3id.org/noria/ontology/" ;
    dcterms:issued "2022-05-10"^^xsd:date ;
	dcterms:modified "2024-03-15"^^xsd:date ;
	skos:changeNote """Changes in v0.3:

- Changed the ontology architecture from micro-architecture to single file.
- Removed owl:imports for NORIA foundations.

2024-03-15:

- Changed bibo:status
"""@en ;
	owl:versionInfo "v0.3" ;
	owl:versionIRI <ontology/noria-0.3> ;
	owl:priorVersion <ontology/noria-0.2> ;
    rdfs:seeAlso <https://w3id.org/noria/doc/> ;
.

# =============================================================================
# KOS (Knowledge Organization System) Concepts
# =============================================================================

# Application Types
<kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    dcterms:description "A scheme for classifying types of applications."@en .

<kos/application/type/infrastructure> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "Applications that provide core infrastructure services."@en .

<kos/application/type/business> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Business Application"@en ;
    rdfs:comment "Applications directly supporting business operations."@en .

<kos/application/type/monitoring> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Monitoring Application"@en ;
    rdfs:comment "Applications used for system monitoring and alerting."@en .

<kos/application/type/security> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Security Application"@en ;
    rdfs:comment "Applications related to cybersecurity and threat detection."@en .

# Application Business Importance
<kos/application/business-importance> a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    dcterms:description "A scheme for classifying the business importance of applications."@en .

<kos/application/business-importance/critical> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Application is critical for business operations, outage causes severe impact."@en .

<kos/application/business-importance/high> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High"@en ;
    rdfs:comment "Application is important for business operations, outage causes significant impact."@en .

<kos/application/business-importance/medium> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Medium"@en ;
    rdfs:comment "Application supports business operations, outage causes moderate impact."@en .

<kos/application/business-importance/low> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Low"@en ;
    rdfs:comment "Application has minor impact on business operations if unavailable."@en .

# Application Module Status
<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ;
    rdfs:label "Application Module Status Scheme"@en ;
    dcterms:description "A scheme for classifying the operational status of application modules."@en .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently active and serving users."@en .

<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Development"@en ;
    rdfs:comment "The application module is under active development."@en .

<https://w3id.org/noria/kos/application/status/Staging> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Staging"@en ;
    rdfs:comment "The application module is in a testing or pre-production environment."@en .

<https://w3id.org/noria/kos/application/status/Decommissioned> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Decommissioned"@en ;
    rdfs:comment "The application module has been retired and is no longer in use."@en .

# Service Type
<kos/service/type> a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    dcterms:description "A scheme for classifying types of services."@en .

<kos/service/type/CustomerFacingService> a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "Service directly consumed by external customers."@en .

<kos/service/type/ResourceFacingService> a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "Service that supports other services or internal operations, not directly exposed to customers."@en .

# Trouble Ticket Severity
<kos/TroubleTicket/severity> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    dcterms:description "A scheme for classifying the severity of trouble tickets."@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Service completely down or major business impact."@en .

<kos/TroubleTicket/severity/Major> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major"@en ;
    rdfs:comment "Significant service degradation or partial outage affecting many users."@en .

<kos/TroubleTicket/severity/Minor> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Minor"@en ;
    rdfs:comment "Minor service degradation or localized issue affecting few users."@en .

<kos/TroubleTicket/severity/Informational> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Informational"@en ;
    rdfs:comment "No immediate service impact, but requires attention."@en .

# Trouble Ticket Type
<kos/TroubleTicket/type> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    dcterms:description "A scheme for classifying types of trouble tickets."@en .

<kos/TroubleTicket/type/Failure> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Failure"@en ;
    rdfs:comment "Ticket related to a system or service failure."@en .

<kos/TroubleTicket/type/Assistance> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Assistance"@en ;
    rdfs:comment "Ticket requesting user assistance or support."@en .

<kos/TroubleTicket/type/Maintenance> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Maintenance"@en ;
    rdfs:comment "Ticket related to scheduled or unscheduled maintenance."@en .

# Trouble Ticket Priority
<kos/TroubleTicket/priority> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme"@en ;
    dcterms:description "A scheme for classifying the priority of trouble tickets."@en .

<kos/TroubleTicket/priority/P1> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 1 (Critical)"@en ;
    rdfs:comment "Highest priority, immediate action required."@en .

<kos/TroubleTicket/priority/P2> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 2 (High)"@en ;
    rdfs:comment "High priority, urgent action required."@en .

<kos/TroubleTicket/priority/P3> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 3 (Medium)"@en ;
    rdfs:comment "Medium priority, action required within a reasonable timeframe."@en .

<kos/TroubleTicket/priority/P4> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 4 (Low)"@en ;
    rdfs:comment "Low priority, action can be deferred."@en .

# Trouble Ticket Origin
<kos/TroubleTicket/origin> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    dcterms:description "A scheme for classifying the origin of trouble tickets."@en .

<kos/TroubleTicket/origin/Customer> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Customer"@en ;
    rdfs:comment "Ticket initiated by an external customer."@en .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Supervision System"@en ;
    rdfs:comment "Ticket automatically generated by a monitoring or supervision system."@en .

<kos/TroubleTicket/origin/Internal> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Internal User"@en ;
    rdfs:comment "Ticket initiated by an internal employee or department."@en .

# Trouble Ticket Urgency
<kos/TroubleTicket/urgency> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Scheme"@en ;
    dcterms:description "A scheme for classifying the urgency of trouble tickets."@en .

<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Requires immediate action to prevent further damage or service loss."@en .

<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Deferred Intervention"@en ;
    rdfs:comment "Action can be scheduled, but should be addressed soon."@en .

# Trouble Ticket Category
<kos/TroubleTicket/trouble-category> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Category Scheme"@en ;
    dcterms:description "A scheme for classifying the technical category of trouble tickets."@en .

<kos/TroubleTicket/trouble-category/NetworkOutage> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Network Outage"@en ;
    rdfs:comment "Complete loss of network connectivity."@en .

<kos/TroubleTicket/trouble-category/ServerFailure> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Server Failure"@en ;
    rdfs:comment "A server is unresponsive or crashed."@en .

<kos/TroubleTicket/trouble-category/ApplicationError> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Application Error"@en ;
    rdfs:comment "An application is not functioning correctly."@en .

# Problem Responsibility
<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ;
    rdfs:label "Problem Responsibility Scheme"@en ;
    dcterms:description "A scheme for classifying the responsibility for a problem."@en .

<kos/TroubleTicket/problemResponsibility/InternalIT> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Internal IT"@en ;
    rdfs:comment "Responsibility lies with the internal IT department."@en .

<kos/TroubleTicket/problemResponsibility/Vendor> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Vendor"@en ;
    rdfs:comment "Responsibility lies with an external vendor or supplier."@en .

<kos/TroubleTicket/problemResponsibility/Customer> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Customer"@en ;
    rdfs:comment "Responsibility lies with the customer."@en .

# Trouble Ticket Note Comment Type
<kos/TroubleTicket/commentType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Comment Type Scheme"@en ;
    dcterms:description "A scheme for classifying the type of comments in trouble ticket notes."@en .

<kos/TroubleTicket/commentType/Internal> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment intended for internal team members only."@en .

<kos/TroubleTicket/commentType/CustomerFacing> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Customer Facing Comment"@en ;
    rdfs:comment "Comment visible to the customer."@en .

<kos/TroubleTicket/commentType/SystemGenerated> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "System Generated Comment"@en ;
    rdfs:comment "Comment automatically generated by the system."@en .

# Trouble Ticket Note Operation Type
<kos/TroubleTicket/operationType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Operation Type Scheme"@en ;
    dcterms:description "A scheme for classifying the type of operation described in trouble ticket notes."@en .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis"@en ;
    rdfs:comment "Note describing diagnostic steps taken."@en .

<kos/TroubleTicket/operationType/Resolution> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Resolution"@en ;
    rdfs:comment "Note describing actions taken to resolve the issue."@en .

<kos/TroubleTicket/operationType/Communication> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Communication"@en ;
    rdfs:comment "Note describing communication with customer or other teams."@en .

# Change Request Category
<kos/ChangeRequest/category> a skos:ConceptScheme ;
    rdfs:label "Change Request Category Scheme"@en ;
    dcterms:description "A scheme for classifying the category of change requests."@en .

<kos/ChangeRequest/category/ConfigurationChange> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Configuration Change"@en ;
    rdfs:comment "Change related to system configuration."@en .

<kos/ChangeRequest/category/SoftwareUpgrade> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change related to software version upgrade."@en .

<kos/ChangeRequest/category/HardwareReplacement> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Hardware Replacement"@en ;
    rdfs:comment "Change involving replacement of hardware components."@en .

# Change Request Type
<kos/ChangeRequest/type> a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    dcterms:description "A scheme for classifying the type of change requests based on impact/risk."@en .

<kos/ChangeRequest/type/Standard> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "Pre-approved, low-risk, routine change."@en .

<kos/ChangeRequest/type/Normal> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Normal Change"@en ;
    rdfs:comment "Requires assessment and authorization, planned change."@en .

<kos/ChangeRequest/type/Emergency> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Emergency Change"@en ;
    rdfs:comment "Urgent change to resolve an incident, minimal assessment."@en .

# Change Request Cause
<kos/ChangeRequest/cause> a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    dcterms:description "A scheme for classifying the cause or reason for change requests."@en .

<kos/ChangeRequest/cause/BugFix> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Bug Fix"@en ;
    rdfs:comment "Change to correct a software defect."@en .

<kos/ChangeRequest/cause/PerformanceImprovement> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Performance Improvement"@en ;
    rdfs:comment "Change to enhance system performance."@en .

<kos/ChangeRequest/cause/SecurityPatch> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Security Patch"@en ;
    rdfs:comment "Change to address a security vulnerability."@en .

# Change Request Status
<kos/ChangeRequest/status> a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    dcterms:description "A scheme for classifying the status of change requests."@en .

<kos/ChangeRequest/status/Planned> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Planned"@en ;
    rdfs:comment "Change is planned but not yet started."@en .

<kos/ChangeRequest/status/InProgress> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "Change implementation is currently underway."@en .

<kos/ChangeRequest/status/Completed> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Completed"@en ;
    rdfs:comment "Change implementation has been successfully completed."@en .

<kos/ChangeRequest/status/Failed> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Failed"@en ;
    rdfs:comment "Change implementation failed and was rolled back or requires further action."@en .

# Change Request Specification
<kos/ChangeRequest/specification> a skos:ConceptScheme ;
    rdfs:label "Change Request Specification Scheme"@en ;
    dcterms:description "A scheme for classifying the specification of change requests."@en .

<kos/ChangeRequest/specification/StandardOperatingProcedure> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:label "Standard Operating Procedure"@en ;
    rdfs:comment "Change follows a documented standard operating procedure."@en .

<kos/ChangeRequest/specification/CustomScript> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:label "Custom Script Execution"@en ;
    rdfs:comment "Change involves execution of a custom script."@en .

# Resource Type
<kos/Resource/type> a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    dcterms:description "A scheme for classifying types of IT resources."@en .

<kos/Resource/type/Server> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server"@en ;
    rdfs:comment "A physical or virtual server."@en .

<kos/Resource/type/Router> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network router device."@en .

<kos/Resource/type/Switch> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Switch"@en ;
    rdfs:comment "A network switch device."@en .

<kos/Resource/type/Firewall> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Firewall"@en ;
    rdfs:comment "A network security firewall device."@en .

<kos/Resource/type/LoadBalancer> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Load Balancer"@en ;
    rdfs:comment "A network load balancer device."@en .

<kos/Resource/type/DatabaseServer> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Database Server"@en ;
    rdfs:comment "A server hosting a database."@en .

<kos/Resource/type/VirtualMachine> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Virtual Machine"@en ;
    rdfs:comment "A virtualized computing instance."@en .

<kos/Resource/type/StorageArray> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Storage Array"@en ;
    rdfs:comment "A system for data storage."@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState> a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    dcterms:description "A scheme for classifying the lifecycle state of IT resources."@en .

<kos/Resource/LifecycleState/InUse> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "In Use"@en ;
    rdfs:comment "The resource is actively being used in production."@en .

<kos/Resource/LifecycleState/Standby> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Standby"@en ;
    rdfs:comment "The resource is available as a backup or for failover."@en .

<kos/Resource/LifecycleState/Maintenance> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Maintenance"@en ;
    rdfs:comment "The resource is currently undergoing maintenance."@en .

<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Decommissioned"@en ;
    rdfs:comment "The resource has been retired and removed from service."@en .

# Resource Operational State
<kos/Resource/OperationalState> a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    dcterms:description "A scheme for classifying the operational state of IT resources."@en .

<kos/Resource/OperationalState/Up> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "The resource is fully operational."@en .

<kos/Resource/OperationalState/Down> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "The resource is not operational."@en .

<kos/Resource/OperationalState/Degraded> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Degraded"@en ;
    rdfs:comment "The resource is operational but with reduced performance or functionality."@en .

# Resource Administrative State
<kos/Resource/AdministrativeState> a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    dcterms:description "A scheme for classifying the administrative state of IT resources."@en .

<kos/Resource/AdministrativeState/Up> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "The resource is administratively enabled."@en .

<kos/Resource/AdministrativeState/Down> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "The resource is administratively disabled."@en .

# Notification Severity (PerceivedSeverity)
<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ;
    rdfs:label "Perceived Severity Scheme"@en ;
    dcterms:description "A scheme for classifying the perceived severity of notifications/alarms."@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "An alarm indicating a critical condition that requires immediate corrective action."@en .

<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Major"@en ;
    rdfs:comment "An alarm indicating a major service-affecting condition."@en .

<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Minor"@en ;
    rdfs:comment "An alarm indicating a minor service-affecting condition."@en .

<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning"@en ;
    rdfs:comment "An alarm indicating a potential or impending service-affecting condition."@en .

<Notification/Severity/PerceivedSeverity/Indeterminate> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Indeterminate"@en ;
    rdfs:comment "An alarm indicating that the severity cannot be determined."@en .

<Notification/Severity/PerceivedSeverity/Cleared> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Cleared"@en ;
    rdfs:comment "An alarm indicating that the previously reported condition has been cleared."@en .

# Agent Contact Method
<kos/org/agent-contact-method> a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    dcterms:description "A scheme for classifying preferred contact methods for agents."@en .

<kos/org/agent-contact-method/Email> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method is email."@en .

<kos/org/agent-contact-method/Phone> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

<kos/org/agent-contact-method/Chat> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Chat"@en ;
    rdfs:comment "Preferred contact method is instant messaging/chat."@en .

# =============================================================================
# Organizations and Agents
# =============================================================================

# Organizations
org:Org001 a org:Organization ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Central department responsible for IT infrastructure and operations."@en ;
    org:hasUnit org:OrgUnit001, org:OrgUnit002, org:OrgUnit003 .

org:Org002 a org:Organization ;
    rdfs:label "Network Services Provider Inc."@en ;
    rdfs:comment "External vendor providing network connectivity services."@en .

org:OrgUnit001 a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center (NOC) Team"@en ;
    rdfs:comment "Team responsible for 24/7 network monitoring and initial incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical network issues, call the hotline immediately. For non-critical issues, open a trouble ticket."@en ;
    org:unitOf org:Org001 .

org:OrgUnit002 a org:OrganizationalUnit ;
    rdfs:label "Server Administration Team"@en ;
    rdfs:comment "Team managing physical and virtual servers."@en ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit requests via the ticketing system. For emergencies, contact NOC first."@en ;
    org:unitOf org:Org001 .

org:OrgUnit003 a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "8:30 AM - 6:00 PM (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    noria:agentInstructions "Use internal chat for quick queries, ticketing system for issues."@en ;
    org:unitOf org:Org001 .

org:OrgUnit004 a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC) Team"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Report all security incidents via dedicated hotline."@en ;
    org:unitOf org:Org001 .

org:OrgUnit005 a org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team responsible for managing and maintaining all database systems."@en ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For database-related issues, create a ticket and assign it to this team."@en ;
    org:unitOf org:Org001 .

