# Application Types
<kos/application/type> a skos:ConceptScheme ; rdfs:label "Application Type Scheme"@en .
<kos/application/type/infrastructure> a skos:Concept ; skos:prefLabel "Infrastructure"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/business> a skos:Concept ; skos:prefLabel "Business Application"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/monitoring> a skos:Concept ; skos:prefLabel "Monitoring System"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/security> a skos:Concept ; skos:prefLabel "Security Application"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/database> a skos:Concept ; skos:prefLabel "Database System"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/messaging> a skos:Concept ; skos:prefLabel "Messaging System"@en ; skos:inScheme <kos/application/type> .

# Application Business Importance
