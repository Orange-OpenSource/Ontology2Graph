# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OpPlan_RouterInterfaceBounce a noria:OperationPlan ;
    rdfs:label "Router Interface Bounce Procedure"@en ;
    rdfs:comment "Standard operating procedure to administratively shut down and then bring up a router interface."@en ;
    noria:operationPlanPreCondition noria:PreCond_InterfaceStatusDown ;
    noria:operationPlanPostCondition noria:PostCond_InterfaceStatusUp .

noria:PreCond_InterfaceStatusDown a noria:ActionPreCondition ;
    rdfs:label "Interface Operational Status is Down"@en ;
    rdfs:comment "The network interface must be in an operational 'down' state before attempting a bounce."@en .

noria:PostCond_InterfaceStatusUp a noria:ActionPostCondition ;
    rdfs:label "Interface Operational Status is Up"@en ;
    rdfs:comment "After the procedure, the network interface should be in an operational 'up' state."@en .

noria:OpPlan_ServerRestart a noria:OperationPlan ;
    rdfs:label "Server Restart Procedure"@en ;
    rdfs:comment "Procedure for safely restarting a server, including pre-checks and post-checks."@en ;
    noria:operationPlanPreCondition noria:PreCond_ServerAccessible ;
    noria:operationPlanPostCondition noria:PostCond_ServerServicesRunning .

noria:PreCond_ServerAccessible a noria:ActionPreCondition ;
    rdfs:label "Server is Remotely Accessible"@en ;
    rdfs:comment "The server must be accessible via SSH or console for the restart procedure."@en .

noria:PostCond_ServerServicesRunning a noria:ActionPostCondition ;
    rdfs:label "Key Services are Running on Server"@en ;
    rdfs:comment "After restart, critical services (e.g., web server, database) must be confirmed as running."@en .

noria:OpPlan_FirewallFirmwareUpgrade a noria:OperationPlan ;
    rdfs:label "Firewall Firmware Upgrade SOP"@en ;
    rdfs:comment "Standard Operating Procedure for upgrading firewall firmware."@en ;
    noria:operationPlanPreCondition noria:PreCond_BackupCompleted, noria:PreCond_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:PostCond_FirewallOperational, noria:PostCond_TrafficFlowing .

noria:PreCond_BackupCompleted a noria:ActionPreCondition ;
    rdfs:label "Configuration Backup Completed"@en ;
    rdfs:comment "A full backup of the firewall configuration must be completed before upgrade."@en .

noria:PreCond_MaintenanceWindow a noria:ActionPreCondition ;
    rdfs:label "Approved Maintenance Window"@en ;
    rdfs:comment "The upgrade must be performed within an approved maintenance window."@en .

noria:PostCond_FirewallOperational a noria:ActionPostCondition ;
    rdfs:label "Firewall Fully Operational"@en ;
    rdfs:comment "Firewall must be fully operational with all services running after upgrade."@en .

noria:PostCond_TrafficFlowing a noria:ActionPostCondition ;
    rdfs:label "Network Traffic Flowing"@en ;
    rdfs:comment "Critical network traffic must be confirmed to be flowing through the firewall."@en .

