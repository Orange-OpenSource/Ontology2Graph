# =============================================================================
# Anomaly Patterns
# =============================================================================

noria:AnomalyPattern_HighCPULoad a noria:AnomalyPattern ;
    rdfs:label "Sustained High CPU Load"@en ;
    rdfs:comment "Pattern indicating a server experiencing high CPU utilization (e.g., >90% for 15 minutes)."@en ;
    folio:hasConsequence "Application performance degradation or outage."@en .

noria:AnomalyPattern_NetworkLinkFlap a noria:AnomalyPattern ;
    rdfs:label "Repeated Network Link Flapping"@en ;
    rdfs:comment "Pattern indicating a network interface repeatedly changing between up and down states within a short period."@en ;
    folio:hasConsequence "Network instability, packet loss, and service interruptions."@en .

noria:AnomalyPattern_FailedLoginsBruteForce a noria:AnomalyPattern ;
    rdfs:label "Multiple Failed Login Attempts"@en ;
    rdfs:comment "Pattern indicating a high number of failed login attempts from a single source IP to a critical system."@en ;
    folio:hasConsequence "Potential unauthorized access, account lockout, or denial of service."@en .

