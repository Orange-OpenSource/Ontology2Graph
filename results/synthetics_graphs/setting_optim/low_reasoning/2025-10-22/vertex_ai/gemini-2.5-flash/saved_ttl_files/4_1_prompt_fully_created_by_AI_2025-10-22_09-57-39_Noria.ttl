noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server dns01.corp.example.com became unreachable."@en ;
    noria:loggingTime "2024-03-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - Network Unreachable (ICMP)."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_WebSrvHighCPU a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on web01.public.example.com."@en ;
    noria:loggingTime "2024-03-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "WARNING: CPU utilization on web01.public.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Core Router Interface Down"@en ;
    rdfs:comment "Log entry for interface Gi0/0/0 on cr01.par.example.com going down."@en ;
    noria:loggingTime "2024-03-20T11:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_FirewallBlockedTraffic a noria:EventRecord ;
    rdfs:label "Firewall Blocked Malicious Traffic"@en ;
    rdfs:comment "Firewall log showing blocked traffic from a known malicious IP."@en ;
    noria:loggingTime "2024-03-20T12:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingManagementSystem noria:App_SecurityGateway ;
    noria:logText "Blocked connection from 1.2.3.4 to 10.0.0.11 on port 80 (Malware C2)."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

noria:EventRecord_DBLoginFailure a noria:EventRecord ;
    rdfs:label "Database Login Failure Alert"@en ;
    rdfs:comment "Alert for repeated failed login attempts on db01.corp.example.com."@en ;
    noria:loggingTime "2024-03-20T13:40:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "ALERT: 5 failed login attempts for user 'admin' on db01 from 10.0.0.50."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_VMHostDiskFull a noria:EventRecord ;
    rdfs:label "VM Host Disk Full Alert"@en ;
    rdfs:comment "Alert indicating a datastore on vmhost01.par.example.com is nearly full."@en ;
    noria:loggingTime "2024-03-20T14:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_VMHost01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "WARNING: Datastore 'DS_PROD_01' on vmhost01.par.example.com is 95% full."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_LyonRouterRestart a noria:EventRecord ;
