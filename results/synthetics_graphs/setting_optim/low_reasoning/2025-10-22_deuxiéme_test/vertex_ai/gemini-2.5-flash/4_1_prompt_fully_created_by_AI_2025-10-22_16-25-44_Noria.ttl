    noria:networkInterfaceDescription "Connection to DNS server segment"@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceConnects <https://w3id.org/noria/data/networkLink/LinkDNS01-CoreSwitch> .

<https://w3id.org/noria/data/networkInterface/RouterCore01-Gi0-0-2> a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Interface connecting Core Router 01 to external network."@en ;
    noria:networkInterfaceOf <https://w3id.org/noria/data/resource/RouterCore01> ;
    noria:networkInterfaceDescription "WAN Uplink"@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
