    noria:applicationModuleSlaLevelDate "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleAdministrationTeam <http://example.com/agent/it_ops_team> ;
    noria:applicationModuleSupportTeam <http://example.com/org/noc_level2> ;
    noria:applicationModuleHotlineGroup <http://example.com/org/noc_level1> .

<http://example.com/appmodule/customer_portal_dev> a noria:ApplicationModule ;
    rdfs:label "Customer Portal Development"@en ;
    rdfs:comment "Development instance of the Customer Portal application."@en ;
    noria:applicationModuleOf <http://example.com/application/customer_portal> ;
    noria:applicationModuleName "CUSTPORT_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InDevelopment> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Bronze> ;
    noria:applicationModuleSlaLevelDate "2023-09-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled false ;
    noria:applicationModuleAdministrationTeam <http://example.com/agent/app_dev_team> .

<http://example.com/appmodule/monitoring_system_instance> a noria:ApplicationModule ;
    rdfs:label "Monitoring System Instance"@en ;
    rdfs:comment "Operational instance of the Monitoring System application."@en ;
    noria:applicationModuleOf <http://example.com/application/monitoring_system> ;
    noria:applicationModuleName "MONSYS_INST" ;
    noria:applicationModuleIdentifier "INST" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam <http://example.com/agent/it_ops_team> .

# --- Services (noria:Service) ---
<http://example.com/service/internet_access> a noria:Service ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:comment "End-to-end service providing internet access to corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <http://example.com/application/corporate_network_service> .

<http://example.com/service/database_connectivity> a noria:Service ;
    rdfs:label "Database Connectivity Service"@en ;
    rdfs:comment "Internal service ensuring connectivity to the main application database."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf <http://example.com/appmodule/customer_portal_prod> .

