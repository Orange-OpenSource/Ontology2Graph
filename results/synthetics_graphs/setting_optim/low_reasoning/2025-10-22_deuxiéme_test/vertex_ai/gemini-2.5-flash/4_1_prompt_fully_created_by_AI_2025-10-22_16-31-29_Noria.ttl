    noria:logOriginatingManagedObject <http://example.com/resource/virtual_machine_db_01> ;
    noria:logOriginatingManagementSystem <http://example.com/application/monitoring_system> ;
    noria:logText "WARNING - CPU Utilization 95%"@en ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Warning> ;
    dcterms:type <kos/Notification/EventType/ResourceUtilization> .

<http://example.com/eventrecord/er_20240320_001_port_down> a noria:EventRecord ;
    rdfs:label "Network Interface Down Log"@en ;
    rdfs:comment "Interface ge1/0/1 on asw01 changed state to down."@en ;
    noria:loggingTime "2024-03-20T09:25:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <http://example.com/resource/switch_access_01> ;
    noria:logOriginatingManagementSystem <http://example.com/application/monitoring_system> ;
    noria:logText "LINK-3-UPDOWN: Interface GigabitEthernet1/0/1, changed state to down"@en ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Major> ;
    dcterms:type <kos/Notification/EventType/stateChange> .

<http://example.com/eventrecord/er_20240320_001_port_up> a noria:EventRecord ;
    rdfs:label "Network Interface Up Log"@en ;
    rdfs:comment "Interface ge1/0/1 on asw01 changed state to up after bounce."@en ;
    noria:loggingTime "2024-03-20T09:35:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <http://example.com/resource/switch_access_01> ;
    noria:logOriginatingManagementSystem <http://example.com/application/monitoring_system> ;
    noria:logText "LINK-3-UPDOWN: Interface GigabitEthernet1/0/1, changed state to up"@en ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Minor> ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    noria:alarmMitigatedBy <http://example.com/pep/exec_bounce_port_001> .

