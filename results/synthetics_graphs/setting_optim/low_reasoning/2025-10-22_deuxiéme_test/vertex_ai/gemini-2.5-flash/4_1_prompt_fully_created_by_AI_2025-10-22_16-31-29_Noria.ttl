# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents (foaf:Agent and org:OrganizationalUnit) ---
<http://example.com/agent/it_ops_team> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for general IT infrastructure operations and maintenance."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "For critical issues, use the ticketing system and call the hotline."@en .

<http://example.com/agent/network_admin_team> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Administration Team"@en ;
    rdfs:comment "Team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Open a ticket for all requests. For outages, call directly."@en .

<http://example.com/agent/app_dev_team> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining core business applications."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> .

<http://example.com/agent/security_team> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

<http://example.com/agent/john_doe> a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual IT support engineer."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

<http://example.com/agent/jane_smith> a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead Network Architect."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

<http://example.com/org/dell_inc> a org:Organization ;
    rdfs:label "Dell Inc."@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

<http://example.com/org/cisco_systems> a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of network equipment."@en .

<http://example.com/org/vmware_inc> a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Provider of virtualization software."@en .

<http://example.com/org/noc_level1> a org:OrganizationalUnit ;
    rdfs:label "NOC Level 1 Support"@en ;
    rdfs:comment "First line of defense for network incidents."@en ;
    noria:agentWorkingHours "24/7"@en .

<http://example.com/org/noc_level2> a org:OrganizationalUnit ;
    rdfs:label "NOC Level 2 Support"@en ;
    rdfs:comment "Second line of defense for network incidents, handles complex issues."@en ;
    noria:agentWorkingHours "24/7"@en .

# --- Product Models (noria:ProductModel) ---
<http://example.com/productmodel/dell_poweredge_r740> a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy <http://example.com/org/dell_inc> .

<http://example.com/productmodel/cisco_catalyst_9300> a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Enterprise-grade network switch model."@en ;
    noria:productManufacturedBy <http://example.com/org/cisco_systems> .

<http://example.com/productmodel/vmware_esxi_host> a noria:ProductModel ;
    rdfs:label "VMware ESXi Host"@en ;
    rdfs:comment "Virtualization hypervisor platform."@en ;
    noria:productManufacturedBy <http://example.com/org/vmware_inc> .

<http://example.com/productmodel/juniper_mx480> a noria:ProductModel ;
    rdfs:label "Juniper MX480"@en ;
    rdfs:comment "Modular router for service provider and enterprise applications."@en ;
    noria:productManufacturedBy <http://example.com/org/juniper_networks> .

<http://example.com/org/juniper_networks> a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "Manufacturer of networking products."@en .

# --- Locations (bot:Site, noria:Room, noria:Locus) ---
<http://example.com/site/datacenter_paris> a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center facility in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002"@en ;
    noria:sitePrincipalAddressCountry "FR"@en .

<http://example.com/room/server_room_a> a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace <http://example.com/locus/rack_a1>, <http://example.com/locus/rack_a2> ;
    bot:hasElement <http://example.com/resource/server_web_01> . # Direct element in room

<http://example.com/locus/rack_a1> a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of servers in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en .

<http://example.com/locus/rack_a2> a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of network devices in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "2"@en .

# --- Resources (noria:Resource) ---
<http://example.com/resource/server_web_01> a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Primary web server hosting customer-facing applications."@en ;
    noria:resourceManagedBy <http://example.com/agent/it_ops_team> ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel <http://example.com/productmodel/dell_poweredge_r740> ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-WEB-01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <http://example.com/application/customer_portal> ;
    noria:locatedAtLocus <http://example.com/locus/rack_a1> ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

<http://example.com/resource/router_core_01> a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for internal network traffic."@en ;
    noria:resourceManagedBy <http://example.com/agent/network_admin_team> ;
    noria:resourceHostName "cr01.corp.example.com" ;
    noria:resourceProductModel <http://example.com/productmodel/juniper_mx480> ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "SN-CR-01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <http://example.com/application/corporate_network_service> ;
    noria:locatedAtLocus <http://example.com/locus/rack_a2> ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

<http://example.com/resource/switch_access_01> a noria:Resource ;
    rdfs:label "Access Switch 01"@en ;
    rdfs:comment "Network switch providing access layer connectivity."@en ;
    noria:resourceManagedBy <http://example.com/agent/network_admin_team> ;
    noria:resourceHostName "asw01.corp.example.com" ;
    noria:resourceProductModel <http://example.com/productmodel/cisco_catalyst_9300> ;
    noria:resourceType <kos/Resource/type/switch> ;
    noria:resourceSerialNumber "SN-ASW-01-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <http://example.com/application/corporate_network_service> ;
    noria:locatedAtLocus <http://example.com/locus/rack_a2> ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.100> .

<http://example.com/resource/virtual_machine_db_01> a noria:Resource ;
    rdfs:label "Database VM 01"@en ;
    rdfs:comment "Virtual machine hosting the main application database."@en ;
    noria:resourceManagedBy <http://example.com/agent/it_ops_team> ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceProductModel <http://example.com/productmodel/vmware_esxi_host> ; # The host product model
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceSerialNumber "VM-DB-01-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-02-20T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <http://example.com/application/customer_portal> ;
    noria:clusterController <http://example.com/resource/server_web_01> ; # Assuming web01 is also a hypervisor host
    noria:virtualServerStatus <kos/Resource/OperationalState/up> ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.20> .

<http://example.com/ip/192.168.1.10> a observable:IPAddress ; rdfs:label "192.168.1.10"@en .
<http://example.com/ip/10.0.0.1> a observable:IPAddress ; rdfs:label "10.0.0.1"@en .
<http://example.com/ip/10.0.0.100> a observable:IPAddress ; rdfs:label "10.0.0.100"@en .
<http://example.com/ip/192.168.1.20> a observable:IPAddress ; rdfs:label "192.168.1.20"@en .

# --- Network Interfaces (noria:NetworkInterface) ---
<http://example.com/networkinterface/web01_eth0> a noria:NetworkInterface ;
    rdfs:label "web01_eth0"@en ;
    rdfs:comment "Ethernet interface for Web Server 01."@en ;
    noria:networkInterfaceOf <http://example.com/resource/server_web_01> ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceDescription "Uplink to corporate network"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects <http://example.com/networklink/web01_to_asw01> .

<http://example.com/networkinterface/cr01_ge0_0_0> a noria:NetworkInterface ;
    rdfs:label "cr01_ge0/0/0"@en ;
    rdfs:comment "Gigabit Ethernet interface for Core Router 01, connecting to access switch."@en ;
    noria:networkInterfaceOf <http://example.com/resource/router_core_01> ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceDescription "Connection to ASW01"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceConnects <http://example.com/networklink/cr01_to_asw01> .

<http://example.com/networkinterface/cr01_ge0_0_1> a noria:NetworkInterface ;
    rdfs:label "cr01_ge0/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface for Core Router 01, connecting to external network."@en ;
    noria:networkInterfaceOf <http://example.com/resource/router_core_01> ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceDescription "External WAN link"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceConnects <http://example.com/networklink/cr01_to_wan> .

<http://example.com/networkinterface/asw01_ge1_0_1> a noria:NetworkInterface ;
    rdfs:label "asw01_ge1/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface for Access Switch 01, connecting to web server."@en ;
    noria:networkInterfaceOf <http://example.com/resource/switch_access_01> ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceDescription "Connection to WEB01"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects <http://example.com/networklink/web01_to_asw01> .

<http://example.com/networkinterface/asw01_ge1_0_2> a noria:NetworkInterface ;
    rdfs:label "asw01_ge1/0/2"@en ;
    rdfs:comment "Gigabit Ethernet interface for Access Switch 01, connecting to core router."@en ;
    noria:networkInterfaceOf <http://example.com/resource/switch_access_01> ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceDescription "Connection to CR01"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects <http://example.com/networklink/cr01_to_asw01> .

# --- Network Links (noria:NetworkLink) ---
<http://example.com/networklink/web01_to_asw01> a noria:NetworkLink ;
    rdfs:label "Link WEB01-ASW01"@en ;
    rdfs:comment "Network link between Web Server 01 and Access Switch 01."@en ;
    noria:networkLinkId "NL-WEB01-ASW01" ;
    noria:networkLinkTerminationResourceOrigin <http://example.com/resource/server_web_01> ;
    noria:networkLinkTerminationResourceDestination <http://example.com/resource/switch_access_01> ;
    noria:networkLinkInstallationDate "2023-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet"@en ;
    noria:resourceManagedBy <http://example.com/agent/network_admin_team> .

<http://example.com/networklink/cr01_to_asw01> a noria:NetworkLink ;
    rdfs:label "Link CR01-ASW01"@en ;
    rdfs:comment "Network link between Core Router 01 and Access Switch 01."@en ;
    noria:networkLinkId "NL-CR01-ASW01" ;
    noria:networkLinkTerminationResourceOrigin <http://example.com/resource/router_core_01> ;
    noria:networkLinkTerminationResourceDestination <http://example.com/resource/switch_access_01> ;
    noria:networkLinkInstallationDate "2022-03-20T14:45:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic"@en ;
    noria:resourceManagedBy <http://example.com/agent/network_admin_team> .

<http://example.com/networklink/cr01_to_wan> a noria:NetworkLink ;
    rdfs:label "Link CR01-WAN"@en ;
    rdfs:comment "External WAN link from Core Router 01."@en ;
    noria:networkLinkId "NL-CR01-WAN" ;
    noria:networkLinkTerminationResourceOrigin <http://example.com/resource/router_core_01> ;
    noria:networkLinkInstallationDate "2022-03-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "MPLS VPN"@en ;
    noria:resourceManagedBy <http://example.com/agent/network_admin_team> .

# --- Applications (noria:Application) ---
<http://example.com/application/customer_portal> a noria:Application ;
    rdfs:label "Customer Portal"@en ;
    rdfs:comment "Web application for customer self-service."@en ;
    noria:applicationModelIdentifier "CP-V2" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CUSTPORT" ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Online Self-Service"@en .

<http://example.com/application/corporate_network_service> a noria:Application ;
    rdfs:label "Corporate Network Service"@en ;
    rdfs:comment "Provides internal network connectivity for all corporate users."@en ;
    noria:applicationModelIdentifier "CORP-NET-V1" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "CORPNET" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Resource Development, Management and Operations"@en ;
    noria:applicationFunctionalSubDomain "Network Connectivity Management"@en .

<http://example.com/application/monitoring_system> a noria:Application ;
    rdfs:label "Monitoring System"@en ;
    rdfs:comment "Application for collecting and analyzing system metrics and logs."@en ;
    noria:applicationModelIdentifier "MON-V3" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "MONSYS" ;
    noria:applicationType <kos/application/type/management-tool> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Service Development, Management and Operations"@en ;
    noria:applicationFunctionalSubDomain "Service Assurance"@en .

