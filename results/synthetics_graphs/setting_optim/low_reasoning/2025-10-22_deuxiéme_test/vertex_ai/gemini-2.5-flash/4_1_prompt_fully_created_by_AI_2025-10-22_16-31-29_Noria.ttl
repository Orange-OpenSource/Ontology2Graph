# --- Operation Plans (noria:OperationPlan) ---
<http://example.com/operationplan/bounce_network_port> a noria:OperationPlan ;
    rdfs:label "Bounce Network Port Procedure"@en ;
    rdfs:comment "Standard operating procedure to administratively shut down and then bring up a network interface."@en ;
    skos:example "CLI commands: 'shutdown', 'no shutdown'"@en ;
    noria:operationPlanPreCondition <http://example.com/actionprecondition/port_down_diagnosis> ;
    noria:operationPlanPostCondition <http://example.com/actionpostcondition/port_up_confirmation> .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
<http://example.com/actionprecondition/port_down_diagnosis> a noria:ActionPreCondition ;
    rdfs:label "Network Port Down Diagnosis"@en ;
    rdfs:comment "Condition: Network interface is reported as 'down' and no physical damage is observed."@en .

<http://example.com/actionpostcondition/port_up_confirmation> a noria:ActionPostCondition ;
    rdfs:label "Network Port Up Confirmation"@en ;
    rdfs:comment "Expected outcome: Network interface status changes to 'up' and connectivity is restored."@en .

# --- Procedure Execution Containers (pep:ProcedureExecutionContainer) ---
<http://example.com/pep/exec_bounce_port_001> a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of Bounce Network Port on ASW01 ge1/0/1"@en ;
    rdfs:comment "Record of the execution of the 'Bounce Network Port Procedure' on Access Switch 01 interface ge1/0/1."@en ;
    noria:actionCorrelatedOperationPlan <http://example.com/operationplan/bounce_network_port> ;
    # In a real scenario, this would contain ldp:member links to EventRecords detailing the commands and their results.
    # For this exercise, we link it to the relevant EventRecord directly.
    # The EventRecord er_20240320_001_port_up is mitigated by this execution.
    .

