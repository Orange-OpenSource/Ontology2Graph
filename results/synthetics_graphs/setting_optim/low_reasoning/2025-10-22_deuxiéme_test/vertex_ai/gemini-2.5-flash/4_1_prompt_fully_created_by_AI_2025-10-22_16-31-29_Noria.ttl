# --- Event Records (noria:EventRecord) ---
<http://example.com/eventrecord/er_20240320_001> a noria:EventRecord ;
    rdfs:label "Web Server Unreachable Alert"@en ;
    rdfs:comment "Alert: Host web01.corp.example.com is UNREACHABLE."@en ;
    noria:loggingTime "2024-03-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <http://example.com/resource/server_web_01> ;
    noria:logOriginatingManagementSystem <http://example.com/application/monitoring_system> ;
    noria:logText "CRITICAL - Host Unreachable (ping)"@en ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Critical> ;
    dcterms:type <kos/Notification/EventType/HostUnreachable> .

<http://example.com/eventrecord/er_20240321_002> a noria:EventRecord ;
    rdfs:label "High CPU Alert DB VM"@en ;
    rdfs:comment "Alert: High CPU utilization on db01.corp.example.com (95%)."@en ;
