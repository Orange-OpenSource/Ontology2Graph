<https://w3id.org/noria/data/organization/HotlineService> a org:OrganizationalUnit ;
    rdfs:label "Hotline Service"@en ;
    rdfs:comment "Emergency contact point for critical incidents."@en ;
    org:unitOf <https://w3id.org/noria/data/agent/ITOperationsTeam> .

