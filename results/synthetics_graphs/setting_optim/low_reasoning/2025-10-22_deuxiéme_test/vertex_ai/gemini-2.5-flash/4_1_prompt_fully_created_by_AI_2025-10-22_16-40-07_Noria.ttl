<https://w3id.org/noria/data/agent/JaneSmith> a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Network Engineer, member of Network Administration Team."@en ;
    noria:agentWorkingHours "On-call"@en .

<https://w3id.org/noria/data/organization/DellInc> a org:Organization ;
    rdfs:label "Dell Inc."@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

<https://w3id.org/noria/data/organization/Level2Support> a org:OrganizationalUnit ;
    rdfs:label "Level 2 Support"@en ;
    rdfs:comment "Second-line support for complex issues."@en ;
