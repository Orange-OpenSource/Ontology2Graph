    rdfs:comment "Procedure for safely replacing a Small Form-Factor Pluggable (SFP) module on a network router."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/ActionPreCondition/InterfaceFlapping> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/ActionPostCondition/InterfaceStable> .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
<https://w3id.org/noria/ActionPreCondition/HypervisorUnresponsive> a noria:ActionPreCondition ;
    rdfs:label "Hypervisor Unresponsive"@en ;
    rdfs:comment "Condition where a hypervisor host is not responding to management commands or network pings."@en .

<https://w3id.org/noria/ActionPostCondition/HypervisorOnline> a noria:ActionPostCondition ;
    rdfs:label "Hypervisor Online"@en ;
    rdfs:comment "Expected outcome: Hypervisor host is reachable and virtual machines are running."@en .

<https://w3id.org/noria/ActionPreCondition/HighCPULoad> a noria:ActionPreCondition ;
    rdfs:label "High CPU Load on Web Server"@en ;
    rdfs:comment "Condition where web server CPU utilization consistently exceeds a predefined threshold."@en .

<https://w3id.org/noria/ActionPostCondition/CPULoadReduced> a noria:ActionPostCondition ;
    rdfs:label "CPU Load Reduced"@en ;
    rdfs:comment "Expected outcome: Web server CPU utilization returns to normal operating levels."@en .

<https://w3id.org/noria/ActionPreCondition/InterfaceFlapping> a noria:ActionPreCondition ;
    rdfs:label "Network Interface Flapping"@en ;
    rdfs:comment "Condition where a network interface repeatedly changes between up and down states."@en .

<https://w3id.org/noria/ActionPostCondition/InterfaceStable> a noria:ActionPostCondition ;
    rdfs:label "Network Interface Stable"@en ;
    rdfs:comment "Expected outcome: Network interface maintains a stable 'up' operational state."@en .

