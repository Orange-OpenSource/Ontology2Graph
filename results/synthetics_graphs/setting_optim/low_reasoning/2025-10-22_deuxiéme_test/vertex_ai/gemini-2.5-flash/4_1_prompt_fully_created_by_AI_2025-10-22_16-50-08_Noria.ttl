# --- Trouble Tickets (noria:TroubleTicket) ---
<https://w3id.org/noria/data/troubleticket/TT-20240423-001> a noria:TroubleTicket ;
    rdfs:label "DNS Server Unreachable"@en ;
    rdfs:comment "Incident: Primary DNS server (dns01.corp.example.com) is unreachable, impacting corporate internet access."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Network interface on DNS01 server went down."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty <https://w3id.org/noria/data/agent/NetworkAdminTeam> ;
    noria:troubleTicketRelatedService <https://w3id.org/noria/data/service/CorporateInternetAccess>,
                                      <https://w3id.org/noria/data/service/DNSResolutionService> ;
    noria:troubleTicketRelatedResource <https://w3id.org/noria/data/resource/DNS01> ;
    noria:troubleTicketImpacts <https://w3id.org/noria/data/resource/DNS01>,
                               <https://w3id.org/noria/data/service/CorporateInternetAccess> ;
    noria:documentHRef "http://ticketing.example.com/TT-20240423-001" .

<https://w3id.org/noria/data/troubleticket/TT-20240423-002> a noria:TroubleTicket ;
    rdfs:label "CRM Application Slow Performance"@en ;
    rdfs:comment "Users reporting slow response times for the CRM application."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/CorruptedService> ;
    noria:troubleTicketCause "High CPU utilization on AppServer01."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty <https://w3id.org/noria/data/agent/AppSupportTeam> ;
    noria:troubleTicketRelatedService <https://w3id.org/noria/data/applicationmodule/CRM-Prod-Module> ;
    noria:troubleTicketRelatedResource <https://w3id.org/noria/data/resource/AppServer01> ;
    noria:documentHRef "http://ticketing.example.com/TT-20240423-002" .

# --- Trouble Ticket Notes (noria:TroubleTicketNote) ---
<https://w3id.org/noria/data/troubleticketnote/TT-20240423-001-Note1> a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis DNS Outage"@en ;
    rdfs:comment "Confirmed network interface CR01-Gi0-0-1 is down. Attempting to bring it up."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:created "2024-04-23T09:15:00Z"^^xsd:dateTime ;
    dcterms:creator <https://w3id.org/noria/data/agent/JohnDoe> .

<https://w3id.org/noria/data/troubleticketnote/TT-20240423-001-Note2> a noria:TroubleTicketNote ;
    rdfs:label "Interface brought up"@en ;
    rdfs:comment "Interface CR01-Gi0-0-1 successfully brought up. DNS resolution restored. Monitoring service stability."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:created "2024-04-23T09:45:00Z"^^xsd:dateTime ;
    dcterms:creator <https://w3id.org/noria/data/agent/JohnDoe> .

# --- Event Records (noria:EventRecord) ---
<https://w3id.org/noria/data/eventrecord/ER-20240423-001> a noria:EventRecord ;
    rdfs:label "CR01 Interface Down Alert"@en ;
    rdfs:comment "Alert: Interface GigabitEthernet0/0/1 on cr01.corp.example.com changed state to down."@en ;
    noria:loggingTime "2024-04-23T09:00:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/data/resource/CoreRouter01> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/data/application/MonitoringPlatform> ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction <https://w3id.org/noria/data/operationplan/InterfaceTroubleshooting> ;
    noria:troubleTicketTrigger <https://w3id.org/noria/data/troubleticket/TT-20240423-001> .

<https://w3id.org/noria/data/eventrecord/ER-20240423-002> a noria:EventRecord ;
    rdfs:label "CR01 Interface Up Event"@en ;
    rdfs:comment "Event: Interface GigabitEthernet0/0/1 on cr01.corp.example.com changed state to up."@en ;
    noria:loggingTime "2024-04-23T09:40:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to up"@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/data/resource/CoreRouter01> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/data/application/MonitoringPlatform> ;
    noria:logOriginatingAgent <https://w3id.org/noria/data/agent/JohnDoe> ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Informational> .

<https://w3id.org/noria/data/eventrecord/ER-20240423-003> a noria:EventRecord ;
    rdfs:label "AppServer01 High CPU Alert"@en ;
    rdfs:comment "Alert: CPU utilization on app01.corp.example.com exceeded 90%."@en ;
    noria:loggingTime "2024-04-23T10:25:00Z"^^xsd:dateTime ;
    noria:logText "CPU_UTILIZATION_HIGH: app01.corp.example.com CPU usage 95%"@en ;
