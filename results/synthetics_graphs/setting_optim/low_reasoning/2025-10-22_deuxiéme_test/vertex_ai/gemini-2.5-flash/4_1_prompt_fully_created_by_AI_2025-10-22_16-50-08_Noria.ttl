# --- Agents (foaf:Agent, org:Organization, org:OrganizationalUnit) ---
<https://w3id.org/noria/data/agent/ITOperationsTeam> a foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for the day-to-day operation of IT infrastructure."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical incidents, use emergency hotline."@en .

<https://w3id.org/noria/data/agent/NetworkAdminTeam> a foaf:Agent ;
    rdfs:label "Network Administration Team"@en ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Escalate network-related trouble tickets directly to this team."@en ;
    noria:agentManagesResource <https://w3id.org/noria/data/resource/CoreRouter01>,
                               <https://w3id.org/noria/data/networklink/WANLinkParisLyon> .

<https://w3id.org/noria/data/agent/AppSupportTeam> a foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "8:30 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> .

<https://w3id.org/noria/data/agent/SecurityTeam> a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlerts> .

<https://w3id.org/noria/data/agent/JohnDoe> a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual IT technician, member of IT Operations Team."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en .

<https://w3id.org/noria/data/agent/JaneSmith> a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en .

<https://w3id.org/noria/data/organization/Dell> a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

<https://w3id.org/noria/data/organizationalunit/Level2Support> a org:OrganizationalUnit ;
    rdfs:label "Level 2 Application Support"@en ;
    rdfs:comment "Second-line support for complex application issues."@en ;
