# --- Change Requests (noria:ChangeRequest) ---
<https://w3id.org/noria/data/changerequest/CR-20240425-001> a noria:ChangeRequest ;
    rdfs:label "Upgrade AppServer01 RAM"@en ;
    rdfs:comment "Planned upgrade of RAM for AppServer01 to improve CRM performance."@en ;
    noria:changeRequestPlannedStartTime "2024-04-25T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-26T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/HardwareUpgrade> ;
    noria:changeRequestImpact <https://w3id.org/noria/data/resource/AppServer01>,
                              <https://w3id.org/noria/data/applicationmodule/CRM-Prod-Module> ;
    noria:changeRequestOutageDuration "PT4H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty <https://w3id.org/noria/data/agent/AppSupportTeam> ;
    noria:changeRequestPilotParty <https://w3id.org/noria/data/agent/JaneSmith> ;
    noria:changeRequestActorParty <https://w3id.org/noria/data/agent/JohnDoe> ;
    noria:changeRequestIsRegulated false ;
    noria:documentHRef "http://changemanagement.example.com/CR-20240425-001" .

# --- Operation Plans (noria:OperationPlan) ---
<https://w3id.org/noria/data/operationplan/InterfaceTroubleshooting> a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network interface issues."@en ;
    skos:example "Steps include checking cable, port status, configuration, and physical inspection."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/data/actionprecondition/InterfaceDownDetected> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/data/actionpostcondition/InterfaceUpConfirmed> .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
<https://w3id.org/noria/data/actionprecondition/InterfaceDownDetected> a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Detected"@en ;
    rdfs:comment "Condition: A network interface's operational status is reported as 'down'."@en .

<https://w3id.org/noria/data/actionpostcondition/InterfaceUpConfirmed> a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up Confirmed"@en ;
    rdfs:comment "Outcome: A network interface's operational status is confirmed as 'up' and traffic is flowing."@en .

# --- Document Attachments (noria:DocumentAttachment) ---
<https://w3id.org/noria/data/documentattachment/NetworkDiagram-TT-001> a noria:DocumentAttachment ;
    rdfs:label "Network Diagram for TT-20240423-001"@en ;
    rdfs:comment "Attached network diagram showing the affected segment for Trouble Ticket TT-20240423-001."@en ;
    dcterms:isPartOf <https://w3id.org/noria/data/troubleticket/TT-20240423-001> ;
    dcterms:format "image/png" ;
    dcterms:source "http://docs.example.com/network_diagram_tt001.png"^^xsd:anyURI .

<https://w3id.org/noria/data/documentattachment/UpgradePlan-CR-001> a noria:DocumentAttachment ;
    rdfs:label "RAM Upgrade Plan for CR-20240425-001"@en ;
    rdfs:comment "Detailed plan for the RAM upgrade on AppServer01."@en ;
    dcterms:isPartOf <https://w3id.org/noria/data/changerequest/CR-20240425-001> ;
    dcterms:format "application/pdf" ;
    dcterms:source "http://docs.example.com/ram_upgrade_plan_cr001.pdf"^^xsd:anyURI .

