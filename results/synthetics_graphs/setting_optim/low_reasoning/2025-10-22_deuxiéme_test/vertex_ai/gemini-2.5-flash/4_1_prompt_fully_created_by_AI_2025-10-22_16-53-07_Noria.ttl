# --- Operation Plans, Pre/Post Conditions ---
noria:OperationPlan_InterfaceTroubleshoot a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network interface issues."@en .

noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Interface is Down"@en ;
    rdfs:comment "Pre-condition: A network interface reports an operational status of 'down'."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Interface is Up"@en ;
    rdfs:comment "Post-condition: The network interface operational status is 'up' and traffic is flowing."@en .

noria:OperationPlan_InterfaceTroubleshoot noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp .

# Link EventRecord to OperationPlan (as proposed repair action)
noria:EventRecord_InterfaceDown noria:alarmProposedRepairAction noria:OperationPlan_InterfaceTroubleshoot .

# Link TroubleTicketNote to correlated execution (e.g., a procedure execution container)
# For simplicity, we'll link it to a hypothetical procedure execution container.
# In a real scenario, this would be a specific instance of pep:ProcedureExecutionContainer.
noria:TroubleTicketNote_DNSDiag noria:troubleTicketNoteCorrelatedExecution <http://example.com/pep/ProcExecContainer_DNSFix> .

<http://example.com/pep/ProcExecContainer_DNSFix> a pep:ProcedureExecutionContainer ;
    rdfs:label "DNS Interface Fix Execution"@en ;
    rdfs:comment "Container for actions taken to fix the DNS server's network interface."@en .

# Link ChangeRequest to OperationPlan
noria:ChangeRequest_CoreSwitchUpgrade noria:actionCorrelatedOperationPlan <http://example.com/op/FirmwareUpgradeProcedure> .

<http://example.com/op/FirmwareUpgradeProcedure> a noria:OperationPlan ;
    rdfs:label "Core Switch Firmware Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading Cisco Nexus 9000 series firmware."@en .

# --- Corporate User Identifier ---
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

# --- Additional connections for density ---
foaf:Agent_ITOpsTeam noria:agentManagesResource noria:Resource_WebSrv01, noria:Resource_VirtualHost01, noria:Resource_VM_AppDB .
foaf:Agent_NetworkAdmin noria:agentManagesResource noria:Resource_DNS01, noria:Resource_CoreSwitch01, noria:NL_DNS01_CoreSwitch01, noria:NL_WebSrv01_CoreSwitch01, noria:NL_VirtualHost01_CoreSwitch01 .
foaf:Agent_AppSupportTeam noria:agentManagesResource noria:AppModule_CorpWebProd, noria:AppModule_CRMProd .

noria:Resource_DNS01 noria:virtualServerStatus <kos/Resource/OperationalState/up> .
noria:Resource_WebSrv01 noria:virtualServerStatus <kos/Resource/OperationalState/up> .
noria:Resource_VM_AppDB noria:virtualServerStatus <kos/Resource/OperationalState/up> .

noria:NI_CoreSwitch01_Gi0_1 noria:networkInterfaceRoutingPriorityMetric 100 .
noria:NI_CoreSwitch01_Gi0_2 noria:networkInterfaceRoutingPriorityMetric 100 .
noria:NI_CoreSwitch01_Gi0_3 noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NI_DNS01_Eth0 noria:networkInterfaceDescription "Uplink to Core Switch" .
noria:NI_WebSrv01_Eth0 noria:networkInterfaceDescription "Uplink to Core Switch" .

noria:TroubleTicket_DNSOutage noria:troubleTicketIsNotificationEnable true .
noria:TroubleTicket_WebSrvPerf noria:troubleTicketIsNotificationEnable true .

noria:ChangeRequest_CoreSwitchUpgrade noria:documentStatusHistory <http://example.com/event/CR_Status_Initial> .
<http://example.com/event/CR_Status_Initial> a noria:EventRecord ;
    rdfs:label "CR Status Change: Initialized"@en ;
    noria:loggingTime "2024-04-11T10:00:00Z"^^xsd:dateTime ;
    noria:logText "Change Request CR-20240415-001 initialized." .

noria:TroubleTicket_DNSOutage noria:troubleTicketFreezeItem <http://example.com/event/TT_Freeze_Period1> .
<http://example.com/event/TT_Freeze_Period1> a noria:EventRecord ;
    rdfs:label "TT Freeze Period Start"@en ;
    noria:loggingTime "2024-04-10T09:15:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-20240410-001 frozen due to external dependency." .
