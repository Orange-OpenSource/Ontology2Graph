    noria:changeRequestPlannedStartTime "2024-04-12T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-12T23:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Normal> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/HardwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_VM_AppDB, noria:Application_CRMSystem ;
    noria:changeRequestOutageDuration "PT30M"^^xsd:duration ;
