# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents and Organizations ---
foaf:Agent_ITOpsTeam a foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "For critical issues, use the dedicated hotline and ticketing system."@en .

foaf:Agent_NetworkAdmin a foaf:Agent ;
    rdfs:label "Network Administration Team"@en ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Open a ticket for all non-critical requests. Call for outages."@en .

foaf:Agent_AppSupportTeam a foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/alert-system> .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual IT technician, member of IT Operations Team."@en .

org:OrgUnit_ITDept a org:OrganizationalUnit ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main IT department of the organization."@en ;
    org:hasMember foaf:Agent_ITOpsTeam, foaf:Agent_NetworkAdmin, foaf:Agent_AppSupportTeam, foaf:Agent_SecurityTeam, foaf:Agent_JohnDoe .

# --- Locations ---
bot:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Primary server room in Main Data Center."@en ;
    bot:hasSpace bot:Site_MainDC .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of critical servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of network equipment."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
    bot:hasSpace noria:Room_ServerRoomA .

# --- Product Models ---
noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy <http://www.dell.com/organization> . # Assuming Dell is an org:Organization

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Data center network switch model."@en ;
    noria:productManufacturedBy <http://www.cisco.com/organization> . # Assuming Cisco is an org:Organization

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform software."@en ;
    noria:productManufacturedBy <http://www.vmware.com/organization> . # Assuming VMware is an org:Organization

# --- Resources ---
noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for internal network resolution."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkAdmin ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Hosts the main corporate website."@en ;
    noria:resourceManagedBy foaf:Agent_ITOpsTeam ;
    noria:resourceHostName "websrv01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-WEB01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.20> .

noria:Resource_CoreSwitch01 a noria:Resource ;
    rdfs:label "Core Switch 01"@en ;
    rdfs:comment "Main network switch for the data center."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkAdmin ;
    noria:resourceHostName "coresw01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/network-device> ;
    noria:resourceSerialNumber "SN-CSW01-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-11-20T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

noria:Resource_VirtualHost01 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:comment "Physical server running VMware ESXi, hosting multiple virtual machines."@en ;
    noria:resourceManagedBy foaf:Agent_ITOpsTeam ;
    noria:resourceHostName "vhost01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/hypervisor> ;
    noria:resourceSerialNumber "SN-VHOST01-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-10T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.30> .

noria:Resource_VM_AppDB a noria:Resource ;
    rdfs:label "Virtual Machine: Application Database"@en ;
    rdfs:comment "Virtual machine hosting the database for the main application."@en ;
    noria:resourceManagedBy foaf:Agent_ITOpsTeam ;
    noria:resourceHostName "appdb-vm.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # Product model of the hypervisor it runs on
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-02-01T10:00:00Z"^^xsd:dateTime ;
    noria:clusterController noria:Resource_VirtualHost01 ;
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.10> .

# --- Network Interfaces ---
noria:NI_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "dns01-eth0"@en ;
    rdfs:comment "Ethernet interface for DNS server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "websrv01-eth0"@en ;
    rdfs:comment "Ethernet interface for Web server."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_CoreSwitch01_Gi0_1 a noria:NetworkInterface ;
    rdfs:label "coresw01-Gi0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface on Core Switch 01, connected to DNS01."@en ;
    noria:networkInterfaceOf noria:Resource_CoreSwitch01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_CoreSwitch01_Gi0_2 a noria:NetworkInterface ;
    rdfs:label "coresw01-Gi0/2"@en ;
    rdfs:comment "Gigabit Ethernet interface on Core Switch 01, connected to WebSrv01."@en ;
    noria:networkInterfaceOf noria:Resource_CoreSwitch01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_CoreSwitch01_Gi0_3 a noria:NetworkInterface ;
    rdfs:label "coresw01-Gi0/3"@en ;
    rdfs:comment "Gigabit Ethernet interface on Core Switch 01, connected to VirtualHost01."@en ;
    noria:networkInterfaceOf noria:Resource_CoreSwitch01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_VirtualHost01_vmnic0 a noria:NetworkInterface ;
    rdfs:label "vhost01-vmnic0"@en ;
    rdfs:comment "Physical network adapter on Virtual Host 01."@en ;
    noria:networkInterfaceOf noria:Resource_VirtualHost01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_VM_AppDB_Eth0 a noria:NetworkInterface ;
    rdfs:label "appdb-vm-eth0"@en ;
    rdfs:comment "Virtual Ethernet interface for Application Database VM."@en ;
    noria:networkInterfaceOf noria:Resource_VM_AppDB ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# --- Network Links ---
noria:NL_DNS01_CoreSwitch01 a noria:NetworkLink ;
    rdfs:label "Link DNS01-CoreSwitch01"@en ;
    rdfs:comment "Physical link between DNS01 and Core Switch 01."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkAdmin ;
    noria:networkLinkId "NL-DNS01-CSW01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreSwitch01 ;
    noria:networkLinkInstallationDate "2022-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" .

noria:NL_WebSrv01_CoreSwitch01 a noria:NetworkLink ;
    rdfs:label "Link WebSrv01-CoreSwitch01"@en ;
    rdfs:comment "Physical link between WebSrv01 and Core Switch 01."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkAdmin ;
    noria:networkLinkId "NL-WEB01-CSW01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_WebSrv01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreSwitch01 ;
    noria:networkLinkInstallationDate "2022-03-01T14:45:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" .

noria:NL_VirtualHost01_CoreSwitch01 a noria:NetworkLink ;
    rdfs:label "Link VirtualHost01-CoreSwitch01"@en ;
    rdfs:comment "Physical link between Virtual Host 01 and Core Switch 01."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkAdmin ;
    noria:networkLinkId "NL-VHOST01-CSW01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_VirtualHost01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreSwitch01 ;
    noria:networkLinkInstallationDate "2023-01-10T11:15:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" .

# Connect Network Interfaces to Network Links
noria:NI_DNS01_Eth0 noria:networkInterfaceConnects noria:NL_DNS01_CoreSwitch01 .
noria:NI_CoreSwitch01_Gi0_1 noria:networkInterfaceConnects noria:NL_DNS01_CoreSwitch01 .

noria:NI_WebSrv01_Eth0 noria:networkInterfaceConnects noria:NL_WebSrv01_CoreSwitch01 .
noria:NI_CoreSwitch01_Gi0_2 noria:networkInterfaceConnects noria:NL_WebSrv01_CoreSwitch01 .

noria:NI_VirtualHost01_vmnic0 noria:networkInterfaceConnects noria:NL_VirtualHost01_CoreSwitch01 .
noria:NI_CoreSwitch01_Gi0_3 noria:networkInterfaceConnects noria:NL_VirtualHost01_CoreSwitch01 .

# --- Applications ---
noria:Application_CorporateWebsite a noria:Application ;
    rdfs:label "Corporate Website"@en ;
    rdfs:comment "The official public website of the corporation."@en ;
    noria:applicationModelIdentifier "CORPWEB" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CWEB" ;
    noria:applicationType <kos/application/type/customer-facing> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Marketing and Communications" ;
    noria:applicationFunctionalSubDomain "Public Relations" .

noria:Application_InternalDNS a noria:Application ;
    rdfs:label "Internal DNS Service"@en ;
    rdfs:comment "Provides DNS resolution for all internal corporate systems."@en ;
    noria:applicationModelIdentifier "INTDNS" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "IDNS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "IT Infrastructure" ;
    noria:applicationFunctionalSubDomain "Network Services" .

noria:Application_CRMSystem a noria:Application ;
    rdfs:label "Customer Relationship Management System"@en ;
    rdfs:comment "Manages customer interactions and data."@en ;
    noria:applicationModelIdentifier "CRM" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Sales and Customer Service" ;
    noria:applicationFunctionalSubDomain "Customer Data Management" .

# --- Application Modules ---
noria:AppModule_CorpWebProd a noria:ApplicationModule ;
    rdfs:label "Corporate Website Production Module"@en ;
    rdfs:comment "Production instance of the Corporate Website application."@en ;
    noria:applicationModuleOf noria:Application_CorporateWebsite ;
    noria:applicationModuleName "CORPWEB_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam org:OrgUnit_ITDept ;
    noria:applicationModuleSupportTeam foaf:Agent_AppSupportTeam ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

noria:AppModule_IntDNSProd a noria:ApplicationModule ;
    rdfs:label "Internal DNS Production Module"@en ;
    rdfs:comment "Production instance of the Internal DNS Service application."@en ;
    noria:applicationModuleOf noria:Application_InternalDNS ;
    noria:applicationModuleName "INTDNS_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam org:OrgUnit_ITDept ;
    noria:applicationModuleSupportTeam foaf:Agent_NetworkAdmin ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

noria:AppModule_CRMProd a noria:ApplicationModule ;
    rdfs:label "CRM Production Module"@en ;
    rdfs:comment "Production instance of the CRM System application."@en ;
    noria:applicationModuleOf noria:Application_CRMSystem ;
    noria:applicationModuleName "CRM_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam org:OrgUnit_ITDept ;
    noria:applicationModuleSupportTeam foaf:Agent_AppSupportTeam ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

# Resources for Applications
noria:Resource_WebSrv01 noria:resourceForApplication noria:Application_CorporateWebsite .
noria:Resource_DNS01 noria:resourceForApplication noria:Application_InternalDNS .
noria:Resource_VM_AppDB noria:resourceForApplication noria:Application_CRMSystem .

# --- Services ---
noria:Service_PublicWebAccess a noria:Service ;
    rdfs:label "Public Web Access Service"@en ;
    rdfs:comment "End-to-end service for public access to corporate web resources."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> .

noria:Service_InternalITServices a noria:Service ;
    rdfs:label "Internal IT Services"@en ;
    rdfs:comment "Core IT services supporting internal operations."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> .

# Application Modules are sub-systems of Services
noria:AppModule_CorpWebProd seas:subSystemOf noria:Service_PublicWebAccess .
noria:AppModule_IntDNSProd seas:subSystemOf noria:Service_InternalITServices .
noria:AppModule_CRMProd seas:subSystemOf noria:Service_InternalITServices .

# --- Event Records ---
noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ; # Assuming a monitoring system application
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_WebSrvHighCPU a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on the web server."@en ;
    noria:loggingTime "2024-04-10T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "WARNING: websrv01.corp.example.com CPU usage 95% for 5 minutes" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_InterfaceDown a noria:EventRecord ;
    rdfs:label "Network Interface Down Log"@en ;
    rdfs:comment "Log entry for a network interface going down."@en ;
    noria:loggingTime "2024-04-10T09:01:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:NI_DNS01_Eth0 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "Interface dns01-eth0 changed state to down" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_ConfigChange a noria:EventRecord ;
    rdfs:label "Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on Core Switch 01."@en ;
    noria:loggingTime "2024-04-09T15:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreSwitch01 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by John Doe (10.0.0.5)" .

noria:Application_MonitoringSystem a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:comment "Application responsible for collecting and analyzing logs and metrics."@en ;
    noria:applicationType <kos/application/type/monitoring> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> .

# --- Trouble Tickets ---
noria:TroubleTicket_DNSOutage a noria:TroubleTicket ;
    rdfs:label "Critical DNS Outage"@en ;
    rdfs:comment "DNS server dns01.corp.example.com is unreachable, impacting all internal services."@en ;
    noria:documentExternalId "TT-20240410-001" ;
    noria:documentHRef "http://ticketing.example.com/TT-20240410-001"^^xsd:anyURI ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_DNSOutageLog ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Network interface failure on DNS server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-10T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_NetworkAdmin, foaf:Agent_ITOpsTeam ;
    noria:troubleTicketRelatedService noria:Application_InternalDNS ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01, noria:NI_DNS01_Eth0 .

noria:TroubleTicket_WebSrvPerf a noria:TroubleTicket ;
    rdfs:label "Web Server Performance Degradation"@en ;
    rdfs:comment "Corporate website experiencing slow response times due to high CPU."@en ;
    noria:documentExternalId "TT-20240410-002" ;
    noria:documentHRef "http://ticketing.example.com/TT-20240410-002"^^xsd:anyURI ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketTrigger noria:EventRecord_WebSrvHighCPU ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "Prometheus" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/DowngradingEquipment> ;
    noria:troubleTicketCause "Unexpected traffic surge on corporate website."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> ;
    noria:troubleTicketDetectionDateTime "2024-04-10T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-10T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_AppSupportTeam ;
    noria:troubleTicketRelatedService noria:Application_CorporateWebsite ;
    noria:troubleTicketRelatedResource noria:Resource_WebSrv01 .

# --- Trouble Ticket Notes ---
noria:TroubleTicketNote_DNSDiag a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Diagnosis Note"@en ;
    rdfs:comment "Initial diagnosis: interface on DNS01 is physically down. Investigating cable/port."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

noria:TroubleTicketNote_WebSrvScale a noria:TroubleTicketNote ;
    rdfs:label "Web Server Scaling Note"@en ;
    rdfs:comment "Recommended scaling up web server resources or adding another instance to handle traffic."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Assistance> .

# Link notes to tickets
noria:TroubleTicket_DNSOutage dcterms:hasPart noria:TroubleTicketNote_DNSDiag .
noria:TroubleTicket_WebSrvPerf dcterms:hasPart noria:TroubleTicketNote_WebSrvScale .

# --- Change Requests ---
noria:ChangeRequest_CoreSwitchUpgrade a noria:ChangeRequest ;
    rdfs:label "Core Switch Firmware Upgrade"@en ;
    rdfs:comment "Planned firmware upgrade for Core Switch 01 to enhance security and performance."@en ;
    noria:documentExternalId "CR-20240415-001" ;
    noria:documentHRef "http://changemgmt.example.com/CR-20240415-001"^^xsd:anyURI ;
    noria:changeRequestPlannedStartTime "2024-04-15T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-15T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_CoreSwitch01, noria:Application_InternalDNS, noria:Application_CorporateWebsite ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty foaf:Agent_NetworkAdmin ;
    noria:changeRequestPilotParty foaf:Agent_NetworkAdmin ;
    noria:changeRequestActorParty foaf:Agent_JohnDoe ;
    noria:changeRequestIsRegulated false .

noria:ChangeRequest_VM_Migration a noria:ChangeRequest ;
    rdfs:label "VM Migration for AppDB"@en ;
