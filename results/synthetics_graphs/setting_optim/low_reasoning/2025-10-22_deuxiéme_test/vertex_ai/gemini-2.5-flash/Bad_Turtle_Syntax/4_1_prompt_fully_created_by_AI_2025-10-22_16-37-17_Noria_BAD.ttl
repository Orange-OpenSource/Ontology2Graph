@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents (foaf:Agent) ---
# Organizational Units / Teams
noria:Team_NetworkOperations a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for the daily operation and maintenance of the core network infrastructure."@en ;
    noria:agentWorkingHours "24/7 (Mon-Sun)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical incidents, call the hotline immediately. For non-critical issues, use the ticketing system."@en .

noria:Team_ApplicationSupport a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit a ticket via the portal for all application-related issues."@en .

noria:Team_SecurityOperations a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 (Mon-Sun)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Report all suspected security breaches via the dedicated security hotline."@en .

# Individual Agents
noria:Agent_Alice a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:Agent_Bob a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

# --- Product Models (noria:ProductModel) ---
noria:ProductModel_CiscoASR9K a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series Router"@en ;
    rdfs:comment "High-end aggregation services router."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:ProductModel_DellPowerEdgeR750 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R750"@en ;
    rdfs:comment "Rack server for demanding workloads."@en ;
    noria:productManufacturedBy noria:Org_Dell .

noria:ProductModel_JuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480 Universal Routing Platform"@en ;
    rdfs:comment "Modular router for enterprise and service provider applications."@en ;
    noria:productManufacturedBy noria:Org_Juniper .

# --- Organizations (org:Organization) ---
noria:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems, Inc."@en ;
    rdfs:comment "Multinational technology conglomerate specializing in networking hardware."@en .

noria:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

noria:Org_Juniper a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "Multinational corporation that develops and sells networking products."@en .

# --- Locations (bot:Site, noria:Room, noria:Locus) ---
noria:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center facility located in Paris."@en ;
    noria:siteId "PAR-DC-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    # bot:containsZone noria:Locus_RackA1 (implicit via noria:locatedAtLocus on Resource)
    .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of servers in Server Room A, Line A, Row 1."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of network equipment in Server Room A, Line A, Row 2."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "2"^^xsd:string .

# --- Resources (noria:Resource) ---
noria:Resource_CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Primary core router for the corporate network."@en ;
    noria:resourceLogisticId "CR01-PAR-DC-01"^^xsd:string ;
    noria:resourceHostName "cr01.par.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel_CiscoASR9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "ABC12345DEF"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Team_NetworkOperations ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress <http://192.168.10.1> .

noria:Resource_AppServer01 a noria:Resource ;
    rdfs:label "Application Server 01"@en ;
    rdfs:comment "Server hosting critical business applications."@en ;
    noria:resourceLogisticId "AS01-PAR-DC-01"^^xsd:string ;
    noria:resourceHostName "app01.par.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel_DellPowerEdgeR750 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "GHI67890JKL"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Team_ApplicationSupport ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://10.0.0.10> .

noria:Resource_Firewall01 a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:comment "Main firewall protecting the corporate network perimeter."@en ;
    noria:resourceLogisticId "FW01-PAR-DC-01"^^xsd:string ;
    noria:resourceHostName "fw01.par.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel_JuniperMX480 ; # Using a router model for firewall for example purposes
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "MNO12345PQR"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-02-10T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Team_SecurityOperations ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress <http://192.168.10.2> .

noria:Resource_VirtualServer01 a noria:Resource ;
    rdfs:label "Virtual Web Server 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate website."@en ;
    noria:resourceLogisticId "VWS01-PAR-DC-01"^^xsd:string ;
    noria:resourceHostName "web01.corp.example.com"^^xsd:string ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-05T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Team_ApplicationSupport ;
    noria:clusterController noria:Resource_AppServer01 ; # Assuming AppServer01 is a hypervisor
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

# --- Network Interfaces (noria:NetworkInterface) ---
noria:NI_CR01_GE000 a noria:NetworkInterface ;
