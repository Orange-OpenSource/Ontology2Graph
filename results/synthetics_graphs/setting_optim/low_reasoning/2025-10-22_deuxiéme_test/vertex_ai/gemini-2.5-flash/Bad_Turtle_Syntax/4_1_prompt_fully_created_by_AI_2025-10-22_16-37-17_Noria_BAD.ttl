# --- Services (noria:Service) ---
noria:Service_InternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:AppModule_CorpWebProd ; # Example of linking a service to an app module
    seas:subSystemOf noria:AppModule_CRMProd .

noria:Service_VPN a noria:Service ;
    rdfs:label "Remote VPN Access Service"@en ;
    rdfs:comment "Enables secure remote access to the corporate network."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> .

# --- Event Records (noria:EventRecord) ---
noria:EventRecord_RouterDown a noria:EventRecord ;
    rdfs:label "Core Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating that a network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface ge-0/0/0, changed state to down"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_AppError a noria:EventRecord ;
    rdfs:label "Application Error Log"@en ;
    rdfs:comment "Error log from Application Server 01 indicating a critical application failure."@en ;
    noria:loggingTime "2024-04-23T10:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_AppServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "CRITICAL: Application 'Corporate Website' failed to connect to database."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_SecurityAlert a noria:EventRecord ;
    rdfs:label "Firewall Security Alert"@en ;
    rdfs:comment "Alert from Firewall 01 detecting suspicious activity."@en ;
    noria:loggingTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "ALERT: Multiple failed login attempts detected from external IP 203.0.113.42."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/High> ;
    noria:logOriginatingAgent noria:Agent_Alice . # Example of an agent being involved in the event (e.g., a security analyst's tool)

noria:EventRecord_InterfaceUp a noria:EventRecord ;
    rdfs:label "Core Router Interface Up Event"@en ;
    rdfs:comment "Log entry indicating that a network interface on Core Router 01 came back up."@en ;
    noria:loggingTime "2024-04-23T10:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface ge-0/0/0, changed state to up"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

# --- Trouble Tickets (noria:TroubleTicket) ---
noria:TroubleTicket_CR01Outage a noria:TroubleTicket ;
    rdfs:label "Core Router 01 Interface Outage"@en ;
    rdfs:comment "Incident reported due to ge-0/0/0 interface on Core Router 01 going down, impacting internet access."@en ;
    dcterms:created "2024-04-23T10:06:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_RouterDown ;
    noria:troubleTicketRelatedResource noria:Resource_CoreRouter01 ;
    noria:troubleTicketRelatedService noria:Service_InternetAccess ;
    noria:troubleTicketRelatedParty noria:Team_NetworkOperations ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true^^xsd:boolean ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketSupervisionTool "Nagios"^^xsd:string .

noria:TroubleTicket_WebsiteDown a noria:TroubleTicket ;
    rdfs:label "Corporate Website Unreachable"@en ;
    rdfs:comment "Users unable to access the corporate website due to application error."@en ;
    dcterms:created "2024-04-23T10:11:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketTrigger noria:EventRecord_AppError ;
    noria:troubleTicketRelatedService noria:Application_CorporateWebsite ;
    noria:troubleTicketRelatedParty noria:Team_ApplicationSupport ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:10:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true^^xsd:boolean ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/CorruptedService> .

# --- Trouble Ticket Notes (noria:TroubleTicketNote) ---
noria:TTNote_CR01_Diagnosis a noria:TroubleTicketNote ;
    rdfs:label "Diagnosis for CR01 Outage"@en ;
    rdfs:comment "Initial diagnosis: interface flapping detected. Investigating physical layer."@en ;
    dcterms:created "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket_CR01Outage ;
    dcterms:creator noria:Agent_Alice .

noria:TTNote_CR01_Resolution a noria:TroubleTicketNote ;
    rdfs:label "Resolution for CR01 Outage"@en ;
    rdfs:comment "Replaced faulty SFP module on ge-0/0/0. Interface is now stable."@en ;
    dcterms:created "2024-04-23T10:40:00Z"^^xsd:dateTime ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/CorrectiveAction> ;
    dcterms:isPartOf noria:TroubleTicket_CR01Outage ;
    dcterms:creator noria:Agent_Alice ;
    dcterms:relation noria:EventRecord_InterfaceUp . # Link to the event that confirms resolution

# --- Change Requests (noria:ChangeRequest) ---
noria:ChangeRequest_FWUpgrade a noria:ChangeRequest ;
    rdfs:label "Firewall Firmware Upgrade"@en ;
    rdfs:comment "Planned firmware upgrade for Perimeter Firewall 01 to enhance security and performance."@en ;
    dcterms:created "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_Firewall01 ;
    noria:changeRequestImpact noria:Service_InternetAccess ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ; # 2 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty noria:Team_SecurityOperations ;
    noria:changeRequestPilotParty noria:Agent_Alice ;
    noria:changeRequestActorParty noria:Team_NetworkOperations ;
    noria:changeRequestIsRegulated true^^xsd:boolean .

noria:ChangeRequest_AppMigration a noria:ChangeRequest ;
    rdfs:label "CRM System Database Migration"@en ;
    rdfs:comment "Migration of the Internal CRM database to a new, more powerful database server."@en ;
    dcterms:created "2024-04-15T11:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-10T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-11T06:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Major> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:AppModule_CRMProd ;
    noria:changeRequestOutageDuration "PT8H"^^xsd:duration ; # 8 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty noria:Team_ApplicationSupport ;
    noria:changeRequestPilotParty noria:Agent_Bob ;
    noria:changeRequestActorParty noria:Team_ApplicationSupport .

# --- Operation Plans (noria:OperationPlan) ---
noria:OperationPlan_SFPReplacement a noria:OperationPlan ;
    rdfs:label "SFP Module Replacement Procedure"@en ;
    rdfs:comment "Standard operating procedure for replacing a Small Form-Factor Pluggable (SFP) module in a network device."@en ;
    skos:example "Steps include identifying faulty SFP, safely removing it, inserting new SFP, and verifying link status."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_FaultySFP ;
    noria:operationPlanPostCondition noria:ActionPostCondition_LinkUp .

noria:OperationPlan_DBMigration a noria:OperationPlan ;
    rdfs:label "Database Migration Procedure"@en ;
    rdfs:comment "Detailed procedure for migrating a production database to a new server."@en ;
    skos:example "Includes backup, new server setup, data transfer, and application reconfiguration."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_NewDBServerReady ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DBOperational .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
noria:ActionPreCondition_FaultySFP a noria:ActionPreCondition ;
    rdfs:label "Faulty SFP Identified"@en ;
    rdfs:comment "Pre-condition: A specific SFP module has been identified as faulty and requires replacement."@en .

noria:ActionPostCondition_LinkUp a noria:ActionPostCondition ;
    rdfs:label "Network Link Operational"@en ;
    rdfs:comment "Post-condition: The network link associated with the replaced SFP is operational and stable."@en .

noria:ActionPreCondition_NewDBServerReady a noria:ActionPreCondition ;
    rdfs:label "New Database Server Ready"@en ;
    rdfs:comment "Pre-condition: The target database server for migration is provisioned and configured."@en .

noria:ActionPostCondition_DBOperational a noria:ActionPostCondition ;
    rdfs:label "Database Operational on New Server"@en ;
    rdfs:comment "Post-condition: The database is fully operational on the new server, and applications are connected."@en .

# --- Document Attachments (noria:DocumentAttachment) ---
noria:DocAttach_NetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Network Diagram v2.1"@en ;
    rdfs:comment "Updated network topology diagram for the Paris Data Center."@en ;
    dcterms:isPartOf noria:ChangeRequest_FWUpgrade ;
    dcterms:format "application/pdf"^^xsd:string .

noria:DocAttach_SFPInvoice a noria:DocumentAttachment ;
    rdfs:label "SFP Module Purchase Invoice"@en ;
    rdfs:comment "Invoice for the replacement SFP module."@en ;
    dcterms:isPartOf noria:TroubleTicket_CR01Outage ;
    dcterms:format "image/jpeg"^^xsd:string .

