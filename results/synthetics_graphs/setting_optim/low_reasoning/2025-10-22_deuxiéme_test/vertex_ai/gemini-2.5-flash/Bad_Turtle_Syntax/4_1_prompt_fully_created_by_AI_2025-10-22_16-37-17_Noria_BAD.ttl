# --- Network Links (noria:NetworkLink) ---
noria:NL_CR01_FW01 a noria:NetworkLink ;
    rdfs:label "Link CoreRouter01-Firewall01"@en ;
    rdfs:comment "High-speed link between Core Router 01 and Firewall 01."@en ;
    noria:networkLinkId "NL-CR01-FW01-001"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Firewall01 ;
    noria:networkInterfaceConnects noria:NI_CR01_GE000 ;
    noria:networkInterfaceConnects noria:NI_FW01_EXT ;
