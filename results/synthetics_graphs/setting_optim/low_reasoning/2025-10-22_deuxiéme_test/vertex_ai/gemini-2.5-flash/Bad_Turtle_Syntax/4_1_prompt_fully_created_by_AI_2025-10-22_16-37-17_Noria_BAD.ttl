    noria:networkLinkType "Fiber Optic"^^xsd:string ;
    noria:resourceManagedBy noria:Team_NetworkOperations .

noria:NL_CR01_AS01 a noria:NetworkLink ;
    rdfs:label "Link CoreRouter01-AppServer01"@en ;
    rdfs:comment "Internal network link between Core Router 01 and Application Server 01."@en ;
    noria:networkLinkId "NL-CR01-AS01-001"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_AppServer01 ;
    noria:networkInterfaceConnects noria:NI_CR01_GE001 ;
    noria:networkInterfaceConnects noria:NI_AS01_ETH0 ;
    noria:networkLinkInstallationDate "2022-03-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet"^^xsd:string ;
    noria:resourceManagedBy noria:Team_NetworkOperations .

# --- Applications (noria:Application) ---
noria:Application_CorporateWebsite a noria:Application ;
