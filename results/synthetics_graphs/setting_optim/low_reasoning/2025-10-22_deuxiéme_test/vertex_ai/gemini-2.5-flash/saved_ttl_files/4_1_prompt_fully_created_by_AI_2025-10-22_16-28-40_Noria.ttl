# --- Agents (foaf:Agent) ---
<https://w3id.org/noria/data/agent/dns-admin-team> a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and operations."@en ;
    noria:agentWorkingHours "08:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

<https://w3id.org/noria/data/agent/network-ops-team> a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing core network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Always call the NOC for network-related incidents."@en .

<https://w3id.org/noria/data/agent/app-support-team> a foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing L2 support for critical business applications."@en ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> .

<https://w3id.org/noria/data/agent/john-doe> a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual member of the DNS Admin Team."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"@en .

<https://w3id.org/noria/data/agent/jane-smith> a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Individual member of the Network Operations Team, specialized in routing."@en ;
    noria:agentWorkingHours "07:00-15:00 (Mon-Fri)"@en .

