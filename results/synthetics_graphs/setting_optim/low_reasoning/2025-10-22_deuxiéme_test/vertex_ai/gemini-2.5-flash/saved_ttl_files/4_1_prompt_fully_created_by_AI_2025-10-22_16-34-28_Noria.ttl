# --- Services (noria:Service) ---
noria:Service_PublicWebAccess a noria:Service ;
    rdfs:label "Public Web Access Service"@en ;
    rdfs:comment "End-to-end service providing public access to corporate web resources."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:ApplicationModule_CorporateWebsite_Prod ;
    seas:subSystemOf noria:Resource_CoreRouter_01 .

noria:Service_InternalDataProcessing a noria:Service ;
    rdfs:label "Internal Data Processing Service"@en ;
    rdfs:comment "Service for internal data management and processing, including CRM."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:ApplicationModule_CRMSystem_Prod ;
    seas:subSystemOf noria:Resource_DBServer_01 .

# --- Event Records (noria:EventRecord) ---
noria:EventRecord_CR01_InterfaceDown a noria:EventRecord ;
    rdfs:label "CR01 Interface ge-0/0/1 Down Alert"@en ;
    rdfs:comment "Alert indicating that Core Router 01's external interface went down."@en ;
    noria:loggingTime "2023-10-26T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface ge-0/0/1, changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_RestartInterface .

noria:EventRecord_WEBVM01_CPUHigh a noria:EventRecord ;
    rdfs:label "WEBVM01 CPU Usage High Alert"@en ;
    rdfs:comment "Alert indicating high CPU usage on Web Server VM 01."@en ;
    noria:loggingTime "2023-10-26T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebServer_VM01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "CPU usage on web01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_DB01_DiskFull a noria:EventRecord ;
    rdfs:label "DB01 Disk Space Low Alert"@en ;
    rdfs:comment "Alert indicating low disk space on Database Server 01."@en ;
    noria:loggingTime "2023-10-26T08:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBServer_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "Disk /data on db01.corp.example.com is 95% full."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_UserLoginFailure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Log entry for a failed login attempt on a critical system."@en ;
    noria:loggingTime "2023-10-26T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebServer_VM01 ;
    noria:logOriginatingAgent noria:Agent_MonitoringSystem ; # Could be an external attacker or internal user
    noria:logText "Failed login for user 'admin' from IP 203.0.113.42."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

# --- Trouble Tickets (noria:TroubleTicket) ---
noria:TroubleTicket_CR01_Outage a noria:TroubleTicket ;
    rdfs:label "Core Router 01 External Interface Outage"@en ;
    rdfs:comment "Critical incident: Core Router 01's external interface is down, impacting public web access."@en ;
    dcterms:identifier "TT-20231026-001" ;
    dcterms:created "2023-10-26T09:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_CR01_InterfaceDown ;
    noria:troubleTicketRelatedService noria:Service_PublicWebAccess ;
    noria:troubleTicketRelatedResource noria:Resource_CoreRouter_01 ;
    noria:troubleTicketRelatedParty noria:Agent_NetOpsTeam ;
    noria:troubleTicketRelatedParty noria:Agent_AppSupportL2 ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketDetectionDateTime "2023-10-26T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2023-10-26T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketSupervisionTool "Monitoring Platform" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Suspected fiber cut on external link."@en ;
    noria:troubleTicketImpacts noria:Application_CorporateWebsite ;
    noria:troubleTicketImpacts noria:Resource_CoreRouter_01 .

noria:TroubleTicket_WEBVM01_Performance a noria:TroubleTicket ;
    rdfs:label "Web Server VM 01 Performance Degradation"@en ;
    rdfs:comment "Performance issues on the main web server due to high CPU usage."@en ;
    dcterms:identifier "TT-20231026-002" ;
    dcterms:created "2023-10-26T09:20:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_WEBVM01_CPUHigh ;
    noria:troubleTicketRelatedService noria:Service_PublicWebAccess ;
    noria:troubleTicketRelatedResource noria:Resource_WebServer_VM01 ;
    noria:troubleTicketRelatedParty noria:Agent_JohnDoe ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketDetectionDateTime "2023-10-26T09:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2023-10-26T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketSupervisionTool "Monitoring Platform" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/PerformanceDegradation> ;
    noria:troubleTicketCause "Unexpected traffic surge or application misconfiguration."@en ;
    noria:troubleTicketImpacts noria:Application_CorporateWebsite .

# --- Trouble Ticket Notes (noria:TroubleTicketNote) ---
noria:TroubleTicketNote_TT001_Update1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis for TT-20231026-001"@en ;
    rdfs:comment "Initial check confirms interface is physically down. Escalated to field team."@en ;
