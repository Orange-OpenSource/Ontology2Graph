    dcterms:isPartOf noria:TroubleTicket_WEBVM01_Performance .

# --- Change Requests (noria:ChangeRequest) ---
noria:ChangeRequest_DBUpgrade a noria:ChangeRequest ;
    rdfs:label "Database Software Upgrade"@en ;
    rdfs:comment "Planned upgrade of the main corporate database software to a newer version."@en ;
    dcterms:identifier "CR-20231101-001" ;
    dcterms:created "2023-10-20T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2023-11-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2023-11-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_DBServer_01 ;
    noria:changeRequestImpact noria:Application_CRMSystem ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty noria:Agent_DBA_Team ;
    noria:changeRequestPilotParty noria:Agent_DBA_Team ;
    noria:changeRequestActorParty noria:Agent_DBA_Team ;
    noria:changeRequestIsRegulated false .

noria:ChangeRequest_RouterConfigUpdate a noria:ChangeRequest ;
    rdfs:label "Core Router Configuration Update"@en ;
    rdfs:comment "Scheduled configuration update for Core Router 01 to optimize routing paths."@en ;
    dcterms:identifier "CR-20231105-002" ;
    dcterms:created "2023-10-25T15:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2023-11-05T01:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2023-11-05T01:30:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Normal> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:Resource_CoreRouter_01 ;
    noria:changeRequestOutageDuration "PT10M"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty noria:Agent_NetOpsTeam ;
    noria:changeRequestPilotParty noria:Agent_NetOpsTeam ;
    noria:changeRequestActorParty noria:Agent_NetOpsTeam ;
