    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_CR01_GE0_0_1 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface on Core Router 01, connected to external network."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

noria:NetworkInterface_WEBVM01_ETH0 a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
