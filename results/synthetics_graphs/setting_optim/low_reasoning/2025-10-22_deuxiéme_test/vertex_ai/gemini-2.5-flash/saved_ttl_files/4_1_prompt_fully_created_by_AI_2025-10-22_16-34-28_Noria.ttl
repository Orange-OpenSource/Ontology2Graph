    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_DB01_ETH0 a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
    rdfs:comment "Primary network interface for Database Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DBServer_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# --- Network Links (noria:NetworkLink) ---
noria:NetworkLink_Internal_CR01_WEBVM01 a noria:NetworkLink ;
    rdfs:label "Internal Link CR01-WEBVM01"@en ;
    rdfs:comment "Logical link between Core Router 01 and Web Server VM 01."@en ;
    noria:networkLinkId "NL-INT-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter_01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_WebServer_VM01 ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR01_GE0_0_0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_WEBVM01_ETH0 .

noria:NetworkLink_Internal_CR01_DB01 a noria:NetworkLink ;
    rdfs:label "Internal Link CR01-DB01"@en ;
    rdfs:comment "Logical link between Core Router 01 and Database Server 01."@en ;
    noria:networkLinkId "NL-INT-002" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2021-06-01T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter_01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_DBServer_01 ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR01_GE0_0_0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_DB01_ETH0 .

# --- Applications (noria:Application) ---
noria:Application_CorporateWebsite a noria:Application ;
    rdfs:label "Corporate Website"@en ;
