# --- Operation Plans (noria:OperationPlan) ---
noria:OperationPlan_RestartInterface a noria:OperationPlan ;
    rdfs:label "Restart Network Interface Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a network interface on a router."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp .

noria:OperationPlan_CheckCPUUsage a noria:OperationPlan ;
    rdfs:label "Check High CPU Usage Procedure"@en ;
    rdfs:comment "Procedure to diagnose and resolve high CPU usage on a server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_CPUHigh ;
    noria:operationPlanPostCondition noria:ActionPostCondition_CPUNormal .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: A network interface's operational status is 'down'."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Expected outcome: The network interface's operational status is 'up'."@en .

noria:ActionPreCondition_CPUHigh a noria:ActionPreCondition ;
    rdfs:label "Server CPU Usage High"@en ;
    rdfs:comment "Condition: Server CPU usage consistently above 90%."@en .

noria:ActionPostCondition_CPUNormal a noria:ActionPostCondition ;
    rdfs:label "Server CPU Usage Normal"@en ;
    rdfs:comment "Expected outcome: Server CPU usage below 50%."@en .

# --- Document Attachments (noria:DocumentAttachment) ---
noria:DocumentAttachment_NetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Network Diagram v2.1"@en ;
    rdfs:comment "PDF document showing the current network topology."@en ;
    dcterms:identifier "DOC-NET-DIAG-V2.1" ;
    dcterms:created "2023-09-01T10:00:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:TroubleTicket_CR01_Outage ;
    dcterms:isPartOf noria:ChangeRequest_RouterConfigUpdate .

noria:DocumentAttachment_DBUpgradePlan a noria:DocumentAttachment ;
    rdfs:label "Database Upgrade Plan"@en ;
    rdfs:comment "Detailed plan for the database software upgrade."@en ;
    dcterms:identifier "DOC-DB-UPGRADE-PLAN" ;
    dcterms:created "2023-10-15T11:00:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:ChangeRequest_DBUpgrade .

