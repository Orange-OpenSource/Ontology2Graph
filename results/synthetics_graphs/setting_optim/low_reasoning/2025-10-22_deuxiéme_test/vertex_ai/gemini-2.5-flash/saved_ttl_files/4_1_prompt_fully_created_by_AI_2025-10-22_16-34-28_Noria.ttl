    rdfs:comment "Compact, high-density routing platform."@en ;
    noria:productManufacturedBy <https://www.juniper.net/organization> .

# --- Locations (bot:Site, noria:Room, noria:Locus) ---
noria:Site_Paris_DC1 a bot:Site ;
    rdfs:label "Paris Data Center 1"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002"@en ;
    noria:sitePrincipalAddressCountry "FR"@en .

noria:Room_ServerRoom_A a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within Paris Data Center 1."@en ;
    bot:hasSpace noria:Site_Paris_DC1 .

noria:Locus_Rack_A1_U23 a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific location within Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_ServerRoom_A .

noria:Locus_Rack_B5_U10 a noria:Locus ;
    rdfs:label "Rack B5, Unit 10"@en ;
    rdfs:comment "Specific location within Server Room A."@en ;
    noria:locusLine "B" ;
    noria:locusRow "5" ;
    bot:hasSpace noria:Room_ServerRoom_A .

# --- Resources (noria:Resource) ---
noria:Resource_CoreRouter_01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceManagedBy noria:Agent_NetOpsTeam ;
    noria:resourceHostName "cr01.paris.example.com" ;
    noria:resourceProductModel noria:ProductModel_Cisco_ASR9K ;
    noria:resourceLogisticId "LOG-CR-01-PAR" ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "CISCO-ASR9K-SN001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_A1_U23 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

noria:Resource_WebServer_VM01 a noria:Resource ;
    rdfs:label "Web Server VM 01"@en ;
    rdfs:comment "Virtual machine hosting the main corporate website."@en ;
    noria:resourceManagedBy noria:Agent_JohnDoe ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMware_ESXi ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_B5_U10 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.101> ;
    noria:clusterController noria:Resource_Hypervisor_01 .

noria:Resource_DBServer_01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Physical server hosting the main corporate database."@en ;
    noria:resourceManagedBy noria:Agent_DBA_Team ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_Dell_PowerEdge_R750 ;
    noria:resourceType <kos/Resource/type/PhysicalServer> ;
    noria:resourceSerialNumber "DELL-R750-SN002" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-06-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_A1_U23 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.10> .

noria:Resource_Hypervisor_01 a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical server running multiple virtual machines."@en ;
    noria:resourceManagedBy noria:Agent_JohnDoe ;
    noria:resourceHostName "hv01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_Dell_PowerEdge_R750 ;
    noria:resourceType <kos/Resource/type/PhysicalServer> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-05-10T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_B5_U10 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.1> .

# --- Network Interfaces (noria:NetworkInterface) ---
noria:NetworkInterface_CR01_GE0_0_0 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/0"@en ;
    rdfs:comment "Gigabit Ethernet interface on Core Router 01, connected to internal network."@en ;
