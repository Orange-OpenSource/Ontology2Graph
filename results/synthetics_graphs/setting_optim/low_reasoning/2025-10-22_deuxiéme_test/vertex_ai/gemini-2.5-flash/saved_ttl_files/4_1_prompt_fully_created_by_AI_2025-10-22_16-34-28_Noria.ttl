    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CW" ;
    noria:applicationType <kos/application/type/customer-facing> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Marketing and Sales" ;
    noria:applicationFunctionalSubDomain "Online Presence Management" ;
    noria:resourceForApplication noria:Resource_WebServer_VM01 .

noria:Application_CRMSystem a noria:Application ;
    rdfs:label "Customer Relationship Management System"@en ;
    rdfs:comment "Internal system for managing customer interactions."@en ;
    noria:applicationModelIdentifier "CRM" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType <kos/application/type/internal-business> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Service" ;
    noria:applicationFunctionalSubDomain "Customer Data Management" ;
    noria:resourceForApplication noria:Resource_DBServer_01 .

noria:Application_MonitoringPlatform a noria:Application ;
