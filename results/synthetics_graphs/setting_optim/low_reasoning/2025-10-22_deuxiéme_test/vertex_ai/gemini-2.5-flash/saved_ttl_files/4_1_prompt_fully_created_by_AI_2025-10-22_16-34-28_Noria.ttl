    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket_CR01_Outage .

noria:TroubleTicketNote_TT001_Update2 a noria:TroubleTicketNote ;
    rdfs:label "Field Team Dispatched for TT-20231026-001"@en ;
    rdfs:comment "Field team dispatched to data center to inspect physical link."@en ;
    dcterms:created "2023-10-26T09:30:00Z"^^xsd:dateTime ;
