# --- Agents (foaf:Agent and org:OrganizationalUnit) ---
<https://w3id.org/noria/data/agent/ITOperationsTeam> a foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use the dedicated hotline and ticketing system."@en .

