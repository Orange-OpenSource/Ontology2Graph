noria:Resource_WebServer01 a noria:Resource ;
    rdfs:label "E-commerce Web Server 01"@en ;
    rdfs:comment "Front-end web server for the E-commerce platform."@en ;
    noria:resourceManagedBy foaf:Agent_ITOperationsTeam ;
    noria:resourceHostName "web01.ecommerce.techcorp.com" ;
    noria:resourceProductModel noria:ProductModel_DellPowerEdgeR740 ;
    noria:resourceLogisticId "ASSET-WEB-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_ECommercePlatform ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress observable:IPAddress_WebServer01_Mgmt .

