    noria:changeRequestImpact noria:Resource_DatabaseServer01, noria:ApplicationModule_ECommerceDatabaseProd ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty foaf:Person_BobJohnson ;
    noria:changeRequestPilotParty foaf:Person_BobJohnson ;
    noria:changeRequestActorParty foaf:Agent_DatabaseAdminTeam ;
    noria:changeRequestIsRegulated true ;
    noria:documentHRef "https://itsm.techcorp.com/change/CR-2024-03-25-001" .

