    noria:troubleTicketRelatedResource noria:Resource_DatabaseServer01 ;
    noria:troubleTicketRelatedParty foaf:Agent_ITOperationsTeam, foaf:Agent_DatabaseAdminTeam, foaf:Person_BobJohnson ;
    noria:troubleTicketDetectionDateTime "2024-03-20T14:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-03-20T15:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCause "Database service crashed due to high memory usage."@en ;
    noria:documentHRef "https://itsm.techcorp.com/ticket/TT-2024-03-20-001" .

