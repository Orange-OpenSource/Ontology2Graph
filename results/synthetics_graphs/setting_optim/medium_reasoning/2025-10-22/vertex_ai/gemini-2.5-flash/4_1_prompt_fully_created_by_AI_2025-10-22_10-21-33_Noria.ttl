noria:ProductModel_DellPowerEdgeR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy <https://www.dell.com/en-us> .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series Switch"@en ;
    rdfs:comment "Data center-grade network switch series."@en ;
    noria:productManufacturedBy <https://www.cisco.com> .

noria:ProductModel_JuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480 Universal Routing Platform"@en ;
    rdfs:comment "High-capacity edge router for service providers and enterprises."@en ;
    noria:productManufacturedBy <https://www.juniper.net> .

noria:ProductModel_PaloAltoFirewall a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-5220 Firewall"@en ;
    rdfs:comment "Next-generation firewall for enterprise security."@en ;
    noria:productManufacturedBy <https://www.paloaltonetworks.com> .

# =============================================================================
# Locations (noria:Room, noria:Locus)
# =============================================================================

noria:Room_DC_A_ServerRoom1 a noria:Room ;
    rdfs:label "Data Center A - Server Room 1"@en ;
    rdfs:comment "Primary server room in Data Center A."@en ;
    bot:hasSubSpace noria:Locus_RackA1, noria:Locus_RackB2 .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "First rack in Server Room 1, Data Center A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en .

noria:Locus_RackB2 a noria:Locus ;
    rdfs:label "Rack B2"@en ;
    rdfs:comment "Second rack in Server Room 1, Data Center A."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "2"@en .

