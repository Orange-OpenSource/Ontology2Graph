# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OperationPlan_DBRestartProcedure a noria:OperationPlan ;
    rdfs:label "Database Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the PostgreSQL database service."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DBServiceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DBServiceUp .

noria:OperationPlan_FirewallUpdateProcedure a noria:OperationPlan ;
    rdfs:label "Firewall Rule Update Procedure"@en ;
    rdfs:comment "Procedure for safely updating firewall rules on Palo Alto devices."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_FirewallAccess ;
    noria:operationPlanPostCondition noria:ActionPostCondition_FirewallRulesApplied .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:ActionPreCondition_DBServiceDown a noria:ActionPreCondition ;
    rdfs:label "Database Service is Down"@en ;
    rdfs:comment "Condition: The database service process is not running or is unresponsive."@en .

noria:ActionPostCondition_DBServiceUp a noria:ActionPostCondition ;
    rdfs:label "Database Service is Up and Responsive"@en ;
    rdfs:comment "Outcome: The database service is running, accepting connections, and responding to queries."@en .

noria:ActionPreCondition_FirewallAccess a noria:ActionPreCondition ;
    rdfs:label "Firewall Management Access Available"@en ;
    rdfs:comment "Condition: Secure access to the firewall management interface is established."@en .

noria:ActionPostCondition_FirewallRulesApplied a noria:ActionPostCondition ;
    rdfs:label "New Firewall Rules Successfully Applied"@en ;
    rdfs:comment "Outcome: The new firewall rules are active and verified to allow intended traffic."@en .

# =============================================================================
# Connections between entities (further density)
# =============================================================================

# Link TroubleTicket to OperationPlan via EventRecord
noria:EventRecord_DBServiceRestart noria:alarmMitigatedBy noria:TroubleTicket_DBOutage001 . # This is a bit of a stretch, but shows a link. Ideally, a specific ProcedureExecutionContainer would be created.

# Link ChangeRequest to OperationPlan
noria:ChangeRequest_DBSoftwareUpgrade pep:usedProcedure noria:OperationPlan_DBRestartProcedure . # Assuming restart is part of upgrade
noria:ChangeRequest_FirewallRuleUpdate pep:usedProcedure noria:OperationPlan_FirewallUpdateProcedure .

# Link Agents to resources they manage (inverse of resourceManagedBy)
foaf:Agent_ITOperationsTeam noria:agentManagesResource noria:Resource_WebServer01, noria:Resource_WebServer02, noria:Resource_MonitoringServer .
foaf:Agent_DatabaseAdminTeam noria:agentManagesResource noria:Resource_DatabaseServer01 .
foaf:Agent_NetworkTeam noria:agentManagesResource noria:Resource_LoadBalancer01, noria:Resource_CoreSwitch01, noria:Resource_EdgeRouter01, noria:Resource_Firewall01 .

# Link Application Modules to their administration/support leaders
noria:ApplicationModule_ECommerceFrontendProd noria:applicationModuleAdministrationLeader foaf:Person_AliceSmith .
noria:ApplicationModule_ECommerceBackendProd noria:applicationModuleAdministrationLeader foaf:Person_AliceSmith .
noria:ApplicationModule_ECommerceDatabaseProd noria:applicationModuleSupportLeader foaf:Person_BobJohnson .
noria:ApplicationModule_InventoryProd noria:applicationModuleAdministrationLeader foaf:Person_AliceSmith .

# Link EventRecords to TroubleTickets (documentStatusHistory)
noria:TroubleTicket_DBOutage001 noria:documentStatusHistory noria:EventRecord_DBServerDown . # Initial trigger
noria:TroubleTicket_DBOutage001 noria:documentStatusHistory noria:EventRecord_DBServiceRestart . # Resolution step

# Example of a virtual server status observable
noria:Resource_WebServer01 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .
noria:Resource_DatabaseServer01 noria:virtualServerStatus <kos/Resource/OperationalState/Down> . # At the time of the outage

# Example of network interface optical power (if applicable)
noria:NetworkInterface_ER01_Gi0_1 noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -20 .

