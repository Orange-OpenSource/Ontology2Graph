noria:TroubleTicket_DBOutage001 a noria:TroubleTicket ;
    rdfs:label "Critical: E-commerce Database Outage"@en ;
    rdfs:comment "Database server db01.ecommerce.techcorp.com became unreachable, impacting E-commerce platform."@en ;
    dcterms:identifier "TT-2024-03-20-001" ;
    dcterms:created "2024-03-20T14:06:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_DBServerDown ;
