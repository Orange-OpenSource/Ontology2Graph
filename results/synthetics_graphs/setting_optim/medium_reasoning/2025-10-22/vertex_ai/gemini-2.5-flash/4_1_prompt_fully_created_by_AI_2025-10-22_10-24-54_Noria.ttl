# =============================================================================
# Operation Plans and Conditions
# =============================================================================

noria:OperationPlan_DNSFailover a noria:OperationPlan ;
    rdfs:label "DNS Server Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for failing over DNS services to a secondary server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSUnreachable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSRestored .

noria:ActionPreCondition_DNSUnreachable a noria:ActionPreCondition ;
    rdfs:label "DNS Unreachable Pre-Condition"@en ;
    rdfs:comment "Condition: Primary DNS server is not responding to queries or pings."@en ;
    skos:example "Ping to dns01.corp.example.com fails; DNS queries timeout."@en .

noria:ActionPostCondition_DNSRestored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored Post-Condition"@en ;
    rdfs:comment "Outcome: DNS service is fully operational and accessible."@en ;
    skos:example "Ping to dns01.corp.example.com succeeds; DNS queries resolve correctly."@en .

noria:OperationPlan_WebSrvOSUpgrade a noria:OperationPlan ;
    rdfs:label "Web Server OS Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading the operating system of a web server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_WebSrvBackup ;
    noria:operationPlanPostCondition noria:ActionPostCondition_WebSrvOnline .

noria:ActionPreCondition_WebSrvBackup a noria:ActionPreCondition ;
    rdfs:label "Web Server Backup Completed Pre-Condition"@en ;
    rdfs:comment "Condition: Full backup of the web server has been successfully completed."@en ;
    skos:example "Backup job 'web01_full_20231031' status: SUCCESS."@en .

noria:ActionPostCondition_WebSrvOnline a noria:ActionPostCondition ;
    rdfs:label "Web Server Online Post-Condition"@en ;
    rdfs:comment "Outcome: Web server is online, accessible, and serving content correctly."@en ;
    skos:example "HTTP GET request to web01.corp.example.com returns 200 OK; website content loads."@en .

# Link Change Request to Operation Plan
noria:ChangeRequest_WebSrvUpgrade_CR001 noria:actionCorrelatedOperationPlan noria:OperationPlan_WebSrvOSUpgrade .

