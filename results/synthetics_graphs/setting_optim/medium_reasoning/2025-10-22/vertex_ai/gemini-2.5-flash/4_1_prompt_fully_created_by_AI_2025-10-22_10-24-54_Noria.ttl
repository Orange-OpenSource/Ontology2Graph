# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server dns01.corp.example.com became unreachable."@en ;
    noria:loggingTime "2023-10-26T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service unreachable."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_DBErrorLog a noria:EventRecord ;
    rdfs:label "CRM Database Connection Error Log"@en ;
    rdfs:comment "Log entry showing connection errors to the CRM database."@en ;
    noria:loggingTime "2023-10-26T10:15:00Z"^^xsd:dateTime ;
    noria:logText "ERROR: Database connection failed for CRMINT_PROD. Max connections reached."@en ;
    noria:logOriginatingManagedObject noria:Resource_DBSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_InterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Log"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2023-10-26T09:05:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/0 on cr01.corp.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_ConfigChange a noria:EventRecord ;
    rdfs:label "Router Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on Core Router 01 by John Doe."@en ;
    noria:loggingTime "2023-10-26T09:30:00Z"^^xsd:dateTime ;
    noria:logText "Configuration changed by user 'jdoe' from console."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

