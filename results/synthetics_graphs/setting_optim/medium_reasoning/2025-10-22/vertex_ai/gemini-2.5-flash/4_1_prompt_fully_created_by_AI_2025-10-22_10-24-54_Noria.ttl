# =============================================================================
# Knowledge Organization System (KOS) Concepts
# =============================================================================

# Application Type
<kos/application/type> a skos:ConceptScheme ;
    dcterms:title "Application Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of applications."@en .

<kos/application/type/infrastructure> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "Applications that provide core infrastructure services."@en .

<kos/application/type/business> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Business Application"@en ;
    rdfs:comment "Applications directly supporting business operations."@en .

<kos/application/type/monitoring> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Monitoring Application"@en ;
    rdfs:comment "Applications used for monitoring IT systems and services."@en .

# Application Business Importance
<kos/application/business-importance> a skos:ConceptScheme ;
    dcterms:title "Application Business Importance Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the business importance of applications."@en .

<kos/application/business-importance/high> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Application is critical for core business functions."@en .

<kos/application/business-importance/medium> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Application supports important but not critical business functions."@en .

<kos/application/business-importance/low> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Low Business Importance"@en ;
    rdfs:comment "Application supports non-critical or auxiliary business functions."@en .

# Application Status
<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ;
    dcterms:title "Application Status Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for describing the operational status of application modules."@en .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently active and serving users."@en .

<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Development"@en ;
    rdfs:comment "The application module is under development."@en .

<https://w3id.org/noria/kos/application/status/Decommissioned> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Decommissioned"@en ;
    rdfs:comment "The application module has been taken out of service."@en .

# Service Type
<kos/service/type> a skos:ConceptScheme ;
    dcterms:title "Service Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of services."@en .

<kos/service/type/CustomerFacingService> a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "Service directly consumed by external customers."@en .

<kos/service/type/ResourceFacingService> a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "Service supporting internal resources, not directly exposed to customers."@en .

# TroubleTicket Severity
<kos/TroubleTicket/severity> a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Severity Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the severity of trouble tickets."@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Service completely unavailable or major business impact."@en .

<kos/TroubleTicket/severity/Major> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major"@en ;
    rdfs:comment "Significant service degradation or partial unavailability."@en .

<kos/TroubleTicket/severity/Minor> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Minor"@en ;
    rdfs:comment "Minor service impact or cosmetic issue."@en .

# TroubleTicket Type
<kos/TroubleTicket/type> a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of trouble tickets."@en .

<kos/TroubleTicket/type/Failure> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Failure"@en ;
    rdfs:comment "Ticket related to a system or service failure."@en .

<kos/TroubleTicket/type/Assistance> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Assistance"@en ;
    rdfs:comment "Ticket requesting user assistance."@en .

# TroubleTicket Priority
<kos/TroubleTicket/priority> a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Priority Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the priority of trouble tickets."@en .

<kos/TroubleTicket/priority/P1> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority, immediate attention required."@en .

<kos/TroubleTicket/priority/P2> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 2"@en ;
    rdfs:comment "High priority, requires prompt attention."@en .

# TroubleTicket Origin
<kos/TroubleTicket/origin> a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Origin Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the origin of trouble tickets."@en .

<kos/TroubleTicket/origin/Customer> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Customer"@en ;
    rdfs:comment "Ticket originated by a customer."@en .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Supervision System"@en ;
    rdfs:comment "Ticket automatically generated by a monitoring or supervision system."@en .

# TroubleTicket Urgency
<kos/TroubleTicket/urgency> a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Urgency Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the urgency of trouble tickets."@en .

<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Requires immediate action."@en .

# TroubleTicket Trouble Category
<kos/TroubleTicket/trouble-category> a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Trouble Category Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the technical category of trouble tickets."@en .

<kos/TroubleTicket/trouble-category/NetworkOutage> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Network Outage"@en ;
    rdfs:comment "Complete network connectivity loss."@en .

<kos/TroubleTicket/trouble-category/ApplicationFailure> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Application Failure"@en ;
    rdfs:comment "Application is not functioning as expected."@en .

# TroubleTicket Problem Responsibility
<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Problem Responsibility Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the responsibility for a problem."@en .

<kos/TroubleTicket/problemResponsibility/InternalIT> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Internal IT"@en ;
    rdfs:comment "Responsibility lies with internal IT teams."@en .

<kos/TroubleTicket/problemResponsibility/ExternalVendor> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "External Vendor"@en ;
    rdfs:comment "Responsibility lies with an external vendor or provider."@en .

# TroubleTicket Status
<kos/TroubleTicket/status> a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Status Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the current status of trouble tickets."@en .

<kos/TroubleTicket/status/InProgress> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "The trouble ticket is currently being worked on."@en .

<kos/TroubleTicket/status/Resolved> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "Resolved"@en ;
    rdfs:comment "The issue described in the trouble ticket has been resolved."@en .

<kos/TroubleTicket/status/Closed> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "Closed"@en ;
    rdfs:comment "The trouble ticket has been closed."@en .

# TroubleTicket Comment Type
<kos/TroubleTicket/commentType> a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Comment Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the type of comments on trouble tickets."@en .

<kos/TroubleTicket/commentType/Internal> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment visible only to internal teams."@en .

<kos/TroubleTicket/commentType/Customer> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Customer Comment"@en ;
    rdfs:comment "Comment visible to the customer."@en .

# TroubleTicket Operation Type
<kos/TroubleTicket/operationType> a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Operation Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the type of operations performed on trouble tickets."@en .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis"@en ;
    rdfs:comment "Operation related to diagnosing the problem."@en .

<kos/TroubleTicket/operationType/Resolution> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Resolution"@en ;
    rdfs:comment "Operation related to resolving the problem."@en .

# ChangeRequest Category
<kos/ChangeRequest/category> a skos:ConceptScheme ;
    dcterms:title "Change Request Category Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the category of change requests."@en .

<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "Change performed by internal teams."@en .

<kos/ChangeRequest/category/CustomerRequest> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Customer Request"@en ;
    rdfs:comment "Change requested by a customer."@en .

# ChangeRequest Type
<kos/ChangeRequest/type> a skos:ConceptScheme ;
    dcterms:title "Change Request Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the type of change requests."@en .

<kos/ChangeRequest/type/Standard> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "Pre-approved, low-risk change."@en .

<kos/ChangeRequest/type/Normal> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Normal Change"@en ;
    rdfs:comment "Requires assessment and authorization."@en .

# ChangeRequest Cause
<kos/ChangeRequest/cause> a skos:ConceptScheme ;
    dcterms:title "Change Request Cause Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the cause of change requests."@en .

<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change due to software version upgrade."@en .

<kos/ChangeRequest/cause/Configuration> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Configuration Change"@en ;
    rdfs:comment "Change due to modification of system configuration."@en .

# ChangeRequest Status
<kos/ChangeRequest/status> a skos:ConceptScheme ;
    dcterms:title "Change Request Status Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the current status of change requests."@en .

<kos/ChangeRequest/status/Planned> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Planned"@en ;
    rdfs:comment "Change is planned but not yet started."@en .

<kos/ChangeRequest/status/Implemented> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Implemented"@en ;
    rdfs:comment "Change has been successfully implemented."@en .

# ChangeRequest Specification
<kos/ChangeRequest/specification> a skos:ConceptScheme ;
    dcterms:title "Change Request Specification Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the specification of change requests."@en .

<kos/ChangeRequest/specification/StandardProcedure> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:label "Standard Procedure"@en ;
    rdfs:comment "Change follows a predefined standard operating procedure."@en .

# Resource Operational State
<kos/Resource/OperationalState> a skos:ConceptScheme ;
    dcterms:title "Resource Operational State Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the operational state of resources."@en .

<kos/Resource/OperationalState/Up> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "Resource is operational."@en .

<kos/Resource/OperationalState/Down> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "Resource is not operational."@en .

# Resource Administrative State
<kos/Resource/AdministrativeState> a skos:ConceptScheme ;
    dcterms:title "Resource Administrative State Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the administrative state of resources."@en .

<kos/Resource/AdministrativeState/Enabled> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Enabled"@en ;
    rdfs:comment "Resource is administratively enabled."@en .

<kos/Resource/AdministrativeState/Disabled> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Disabled"@en ;
    rdfs:comment "Resource is administratively disabled."@en .

# Resource Type
<kos/Resource/type> a skos:ConceptScheme ;
    dcterms:title "Resource Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of IT resources."@en .

<kos/Resource/type/Server> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server"@en ;
    rdfs:comment "A physical or virtual server."@en .

<kos/Resource/type/Router> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network router device."@en .

<kos/Resource/type/Switch> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Switch"@en ;
    rdfs:comment "A network switch device."@en .

<kos/Resource/type/DatabaseServer> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Database Server"@en ;
    rdfs:comment "A server dedicated to hosting databases."@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState> a skos:ConceptScheme ;
    dcterms:title "Resource Lifecycle State Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the lifecycle state of resources."@en .

<kos/Resource/LifecycleState/InUse> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "In Use"@en ;
    rdfs:comment "Resource is actively being used."@en .

<kos/Resource/LifecycleState/Maintenance> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "In Maintenance"@en ;
    rdfs:comment "Resource is undergoing maintenance."@en .

# Agent Contact Method
<kos/org/agent-contact-method> a skos:ConceptScheme ;
    dcterms:title "Agent Contact Method Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for preferred contact methods for agents."@en .

<kos/org/agent-contact-method/Email> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method is email."@en .

<kos/org/agent-contact-method/Phone> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

# Notification Severity Perceived Severity
<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ;
    dcterms:title "Notification Perceived Severity Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the perceived severity of notifications/alarms."@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Critical perceived severity."@en .

<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Major"@en ;
    rdfs:comment "Major perceived severity."@en .

<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Minor"@en ;
    rdfs:comment "Minor perceived severity."@en .

<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning"@en ;
    rdfs:comment "Warning perceived severity."@en .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

foaf:Agent_NetOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical network issues, call the hotline immediately. For non-critical, use ticketing system."@en .

foaf:Agent_WebDevTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Web Development Team"@en ;
    rdfs:comment "Team responsible for the corporate website and related applications."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit all requests via the internal project management tool."@en .

foaf:Agent_DBAdmins a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team responsible for managing all corporate databases."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For database outages, contact on-call DBA. For other issues, open a ticket."@en .

foaf:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Cybersecurity Operations Center (CSOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Report all suspicious activities via the dedicated security portal."@en .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox "mailto:john.doe@example.com" ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Web Developer."@en ;
    foaf:mbox "mailto:jane.smith@example.com" ;
    foaf:phone "+1-555-987-6543" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_CustomerA a foaf:Agent ;
    rdfs:label "Customer A"@en ;
    rdfs:comment "An external customer reporting an issue."@en .

