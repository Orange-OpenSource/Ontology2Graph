    rdfs:label "Cisco Nexus 9000 Series Switch"@en ;
    rdfs:comment "Data center-grade network switch."@en ;
    noria:productManufacturedBy <https://www.cisco.com> . # Assuming Cisco is an org:Organization

noria:ProductModel_JuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480 Router"@en ;
    rdfs:comment "High-capacity edge router."@en ;
    noria:productManufacturedBy <https://www.juniper.net> . # Assuming Juniper is an org:Organization

noria:ProductModel_HPProLiantDL380 a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10"@en ;
    rdfs:comment "Versatile 2U rack server."@en ;
