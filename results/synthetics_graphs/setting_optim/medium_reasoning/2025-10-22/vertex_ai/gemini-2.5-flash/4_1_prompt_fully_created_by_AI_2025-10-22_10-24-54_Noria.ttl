noria:TroubleTicket_DNSOutage_TT001 a noria:TroubleTicket ;
    rdfs:label "Critical DNS Outage Incident"@en ;
    rdfs:comment "DNS server dns01.corp.example.com is unreachable, impacting all services."@en ;
    noria:documentExternalId "INC-20231026-001" ;
    noria:documentHRef "https://ticketing.example.com/INC-20231026-001"^^xsd:anyURI ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketTrigger noria:EventRecord_DNSOutageLog ;
    noria:troubleTicketSupervisionTool "Nagios"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/NetworkOutage> ;
    noria:troubleTicketCause "Network connectivity issue to DNS server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/InternalIT> ;
    noria:troubleTicketDetectionDateTime "2023-10-26T09:00:00Z"^^xsd:dateTime ;
