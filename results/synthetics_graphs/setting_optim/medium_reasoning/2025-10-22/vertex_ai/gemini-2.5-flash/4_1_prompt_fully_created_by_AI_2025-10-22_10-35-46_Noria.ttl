@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix time: <http://www.w3.org/2006/time#> .

# =============================================================================
# Knowledge Organization System (KOS) Concepts
# =============================================================================

# Application Types
<kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .

<kos/application/type/ecommerce> a skos:Concept ;
    skos:prefLabel "E-commerce Application"@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/monitoring> a skos:Concept ;
    skos:prefLabel "Monitoring System"@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/ticketing> a skos:Concept ;
    skos:prefLabel "Ticketing System"@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/database> a skos:Concept ;
    skos:prefLabel "Database Management System"@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/infrastructure> a skos:Concept ;
    skos:prefLabel "Infrastructure Application"@en ;
    skos:inScheme <kos/application/type> .

# Application Business Importance
<kos/application/business-importance> a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A scheme for classifying the business importance of applications."@en .

<kos/application/business-importance/critical> a skos:Concept ;
    skos:prefLabel "Critical"@en ;
    skos:inScheme <kos/application/business-importance> .

<kos/application/business-importance/high> a skos:Concept ;
    skos:prefLabel "High"@en ;
    skos:inScheme <kos/application/business-importance> .

<kos/application/business-importance/medium> a skos:Concept ;
    skos:prefLabel "Medium"@en ;
    skos:inScheme <kos/application/business-importance> .

# Application Status
<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ;
    rdfs:label "Application Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational status of application modules."@en .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ;
    skos:prefLabel "In Production"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ;
    skos:prefLabel "Development"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ;
    skos:prefLabel "Maintenance"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

# Service Types
<kos/service/type> a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of services."@en .

<kos/service/type/CustomerFacingService> a skos:Concept ;
    skos:prefLabel "Customer Facing Service"@en ;
    skos:inScheme <kos/service/type> .

<kos/service/type/ResourceFacingService> a skos:Concept ;
    skos:prefLabel "Resource Facing Service"@en ;
    skos:inScheme <kos/service/type> .

# Trouble Ticket Severity
<kos/TroubleTicket/severity> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the severity of trouble tickets."@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ;
    skos:prefLabel "Critical"@en ;
    skos:inScheme <kos/TroubleTicket/severity> .

<kos/TroubleTicket/severity/Major> a skos:Concept ;
    skos:prefLabel "Major"@en ;
    skos:inScheme <kos/TroubleTicket/severity> .

<kos/TroubleTicket/severity/Minor> a skos:Concept ;
    skos:prefLabel "Minor"@en ;
    skos:inScheme <kos/TroubleTicket/severity> .

# Trouble Ticket Priority
<kos/TroubleTicket/priority> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme"@en ;
    rdfs:comment "A scheme for classifying the priority of trouble tickets."@en .

<kos/TroubleTicket/priority/P1> a skos:Concept ;
    skos:prefLabel "Priority 1"@en ;
    skos:inScheme <kos/TroubleTicket/priority> .

<kos/TroubleTicket/priority/P2> a skos:Concept ;
    skos:prefLabel "Priority 2"@en ;
    skos:inScheme <kos/TroubleTicket/priority> .

<kos/TroubleTicket/priority/P3> a skos:Concept ;
    skos:prefLabel "Priority 3"@en ;
    skos:inScheme <kos/TroubleTicket/priority> .

# Trouble Ticket Origin
<kos/TroubleTicket/origin> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "A scheme for classifying the origin of trouble tickets."@en .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    skos:prefLabel "Supervision System"@en ;
    skos:inScheme <kos/TroubleTicket/origin> .

<kos/TroubleTicket/origin/Customer> a skos:Concept ;
    skos:prefLabel "Customer Report"@en ;
    skos:inScheme <kos/TroubleTicket/origin> .

<kos/TroubleTicket/origin/Internal> a skos:Concept ;
    skos:prefLabel "Internal Report"@en ;
    skos:inScheme <kos/TroubleTicket/origin> .

# Trouble Ticket Status
<kos/TroubleTicket/status> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the current status of trouble tickets."@en .

<kos/TroubleTicket/status/InProgress> a skos:Concept ;
    skos:prefLabel "In Progress"@en ;
    skos:inScheme <kos/TroubleTicket/status> .

<kos/TroubleTicket/status/Resolved> a skos:Concept ;
    skos:prefLabel "Resolved"@en ;
    skos:inScheme <kos/TroubleTicket/status> .

<kos/TroubleTicket/status/Closed> a skos:Concept ;
    skos:prefLabel "Closed"@en ;
    skos:inScheme <kos/TroubleTicket/status> .

<kos/TroubleTicket/status/Open> a skos:Concept ;
    skos:prefLabel "Open"@en ;
    skos:inScheme <kos/TroubleTicket/status> .

# Trouble Ticket Comment Type
<kos/TroubleTicket/commentType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Comment Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the type of comments in trouble ticket notes."@en .

<kos/TroubleTicket/commentType/Internal> a skos:Concept ;
    skos:prefLabel "Internal Comment"@en ;
    skos:inScheme <kos/TroubleTicket/commentType> .

<kos/TroubleTicket/commentType/Customer> a skos:Concept ;
    skos:prefLabel "Customer Communication"@en ;
    skos:inScheme <kos/TroubleTicket/commentType> .

# Trouble Ticket Operation Type
<kos/TroubleTicket/operationType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Operation Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the type of operations recorded in trouble ticket notes."@en .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    skos:prefLabel "Diagnosis Activity"@en ;
    skos:inScheme <kos/TroubleTicket/operationType> .

<kos/TroubleTicket/operationType/Resolution> a skos:Concept ;
    skos:prefLabel "Resolution Activity"@en ;
    skos:inScheme <kos/TroubleTicket/operationType> .

# Resource Types
<kos/Resource/type> a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of IT resources."@en .

<kos/Resource/type/Server> a skos:Concept ;
    skos:prefLabel "Server"@en ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/type/LoadBalancer> a skos:Concept ;
    skos:prefLabel "Load Balancer"@en ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/type/Router> a skos:Concept ;
    skos:prefLabel "Router"@en ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/type/Switch> a skos:Concept ;
    skos:prefLabel "Switch"@en ;
    skos:inScheme <kos/Resource/type> .

# Resource Lifecycle State
<kos/Resource/LifecycleState> a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    rdfs:comment "A scheme for classifying the lifecycle state of resources."@en .

<kos/Resource/LifecycleState/InUse> a skos:Concept ;
    skos:prefLabel "In Use"@en ;
    skos:inScheme <kos/Resource/LifecycleState> .

<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ;
    skos:prefLabel "Decommissioned"@en ;
    skos:inScheme <kos/Resource/LifecycleState> .

# Resource Operational State
<kos/Resource/OperationalState> a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational state of resources or network interfaces."@en .

<kos/Resource/OperationalState/Up> a skos:Concept ;
    skos:prefLabel "Up"@en ;
    skos:inScheme <kos/Resource/OperationalState> .

<kos/Resource/OperationalState/Down> a skos:Concept ;
    skos:prefLabel "Down"@en ;
    skos:inScheme <kos/Resource/OperationalState> .

<kos/Resource/OperationalState/Degraded> a skos:Concept ;
    skos:prefLabel "Degraded"@en ;
    skos:inScheme <kos/Resource/OperationalState> .

# Resource Administrative State
<kos/Resource/AdministrativeState> a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    rdfs:comment "A scheme for classifying the administrative state of resources or network interfaces."@en .

<kos/Resource/AdministrativeState/Up> a skos:Concept ;
    skos:prefLabel "Administratively Up"@en ;
    skos:inScheme <kos/Resource/AdministrativeState> .

<kos/Resource/AdministrativeState/Down> a skos:Concept ;
    skos:prefLabel "Administratively Down"@en ;
    skos:inScheme <kos/Resource/AdministrativeState> .

# Change Request Type
<kos/ChangeRequest/type> a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of change requests."@en .

<kos/ChangeRequest/type/Standard> a skos:Concept ;
    skos:prefLabel "Standard Change"@en ;
    skos:inScheme <kos/ChangeRequest/type> .

<kos/ChangeRequest/type/Normal> a skos:Concept ;
    skos:prefLabel "Normal Change"@en ;
    skos:inScheme <kos/ChangeRequest/type> .

<kos/ChangeRequest/type/Emergency> a skos:Concept ;
    skos:prefLabel "Emergency Change"@en ;
    skos:inScheme <kos/ChangeRequest/type> .

# Change Request Status
<kos/ChangeRequest/status> a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the current status of change requests."@en .

<kos/ChangeRequest/status/Planned> a skos:Concept ;
    skos:prefLabel "Planned"@en ;
    skos:inScheme <kos/ChangeRequest/status> .

<kos/ChangeRequest/status/Implemented> a skos:Concept ;
    skos:prefLabel "Implemented"@en ;
    skos:inScheme <kos/ChangeRequest/status> .

<kos/ChangeRequest/status/Approved> a skos:Concept ;
    skos:prefLabel "Approved"@en ;
    skos:inScheme <kos/ChangeRequest/status> .

# Change Request Cause
<kos/ChangeRequest/cause> a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A scheme for classifying the causes of change requests."@en .

<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ;
    skos:prefLabel "Software Upgrade"@en ;
    skos:inScheme <kos/ChangeRequest/cause> .

<kos/ChangeRequest/cause/ConfigurationChange> a skos:Concept ;
    skos:prefLabel "Configuration Change"@en ;
    skos:inScheme <kos/ChangeRequest/cause> .

# Notification Severity (PerceivedSeverity)
<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ;
    rdfs:label "Notification Perceived Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the perceived severity of notifications/alarms."@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ;
    skos:prefLabel "Critical"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ;
    skos:prefLabel "Major"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ;
    skos:prefLabel "Minor"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ;
    skos:prefLabel "Warning"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

# =============================================================================
# Agents (foaf:Agent)
# =============================================================================

noria:TechCorpITOperationsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "TechCorp IT Operations Team"@en ;
    rdfs:comment "Team responsible for managing TechCorp's IT infrastructure."@en ;
    noria:agentWorkingHours "24/7 (on-call rotation)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "For critical issues, use the hotline number after creating a P1 ticket."@en .

noria:TechCorpDevOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "TechCorp DevOps Team"@en ;
    rdfs:comment "Team responsible for developing and operating the E-commerce Platform."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> ;
    noria:agentInstructions "Contact via internal chat for non-critical application issues."@en .

noria:JohnDoe a foaf:Agent, foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Engineer in the IT Operations Team."@en ;
    foaf:mbox "mailto:john.doe@techcorp.com" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

noria:JaneSmith a foaf:Agent, foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Application Manager for the E-commerce Platform."@en ;
    foaf:mbox "mailto:jane.smith@techcorp.com" ;
    noria:agentWorkingHours "9:30 am - 6:30 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

noria:ExternalCustomer a foaf:Agent, foaf:Person ;
    rdfs:label "External Customer"@en ;
    rdfs:comment "A representative of a customer reporting an issue."@en .

# KOS for agent contact method (defined in NORIA schema, but not explicitly listed in the example)
<kos/org/agent-contact-method> a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents."@en .

<kos/org/agent-contact-method/email> a skos:Concept ;
    skos:prefLabel "Email"@en ;
    skos:inScheme <kos/org/agent-contact-method> .

<kos/org/agent-contact-method/phone> a skos:Concept ;
    skos:prefLabel "Phone"@en ;
    skos:inScheme <kos/org/agent-contact-method> .

<kos/org/agent-contact-method/chat> a skos:Concept ;
    skos:prefLabel "Chat"@en ;
    skos:inScheme <kos/org/agent-contact-method> .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:DellPowerEdgeR750 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R750"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy noria:DellTechnologies .

noria:CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Data center switch and router series."@en ;
    noria:productManufacturedBy noria:CiscoSystems .

noria:OracleDatabaseSoftware a noria:ProductModel ;
    rdfs:label "Oracle Database Enterprise Edition"@en ;
    rdfs:comment "Enterprise-grade relational database management system software."@en ;
    noria:productManufacturedBy noria:OracleCorporation .

noria:DellTechnologies a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of Dell PowerEdge servers."@en .

noria:CiscoSystems a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

noria:OracleCorporation a org:Organization ;
    rdfs:label "Oracle Corporation"@en ;
    rdfs:comment "Developer of Oracle Database software."@en .

# =============================================================================
# Locations (noria:Room, noria:Locus)
# =============================================================================

noria:ParisDataCenter a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center facility located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:DataCenterRoomA a noria:Room ;
    rdfs:label "Data Center Room A"@en ;
    rdfs:comment "A server room within the Paris Data Center."@en ;
    bot:hasSpace noria:ParisDataCenter .

noria:RackA1_Position1 a noria:Locus ;
    rdfs:label "Rack A1, Position 1"@en ;
    rdfs:comment "Specific location for a server in Rack A1."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "1" ;
    bot:hasZone noria:DataCenterRoomA .

noria:RackA1_Position2 a noria:Locus ;
    rdfs:label "Rack A1, Position 2"@en ;
    rdfs:comment "Specific location for a server in Rack A1."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "2" ;
    bot:hasZone noria:DataCenterRoomA .

noria:RackA2_Position1 a noria:Locus ;
    rdfs:label "Rack A2, Position 1"@en ;
    rdfs:comment "Specific location for a database server in Rack A2."@en ;
    noria:locusLine "A2" ;
    noria:locusRow "1" ;
    bot:hasZone noria:DataCenterRoomA .

noria:RackA3_Position1 a noria:Locus ;
    rdfs:label "Rack A3, Position 1"@en ;
    rdfs:comment "Specific location for a load balancer in Rack A3."@en ;
    noria:locusLine "A3" ;
    noria:locusRow "1" ;
    bot:hasZone noria:DataCenterRoomA .

noria:RackA3_Position2 a noria:Locus ;
    rdfs:label "Rack A3, Position 2"@en ;
    rdfs:comment "Specific location for a core router in Rack A3."@en ;
    noria:locusLine "A3" ;
    noria:locusRow "2" ;
    bot:hasZone noria:DataCenterRoomA .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:WebServer01 a noria:Resource ;
    rdfs:label "E-commerce Web Server 01"@en ;
    rdfs:comment "Primary web server for the E-commerce Platform."@en ;
    noria:resourceManagedBy noria:TechCorpITOperationsTeam ;
    noria:resourceHostName "web01.ecommerce.techcorp.com" ;
    noria:resourceProductModel noria:DellPowerEdgeR750 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:EcommercePlatform ;
    noria:locatedAtLocus noria:RackA1_Position1 ;
    noria:resourceManagementIPAddress "10.0.0.101" .

noria:WebServer02 a noria:Resource ;
    rdfs:label "E-commerce Web Server 02"@en ;
    rdfs:comment "Secondary web server for the E-commerce Platform."@en ;
    noria:resourceManagedBy noria:TechCorpITOperationsTeam ;
    noria:resourceHostName "web02.ecommerce.techcorp.com" ;
    noria:resourceProductModel noria:DellPowerEdgeR750 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB-002" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:EcommercePlatform ;
    noria:locatedAtLocus noria:RackA1_Position2 ;
    noria:resourceManagementIPAddress "10.0.0.102" .

noria:DatabaseServer01 a noria:Resource ;
    rdfs:label "E-commerce Database Server 01"@en ;
    rdfs:comment "Critical database server for the E-commerce Platform."@en ;
    noria:resourceManagedBy noria:TechCorpITOperationsTeam ;
    noria:resourceHostName "db01.ecommerce.techcorp.com" ;
    noria:resourceProductModel noria:DellPowerEdgeR750 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DB-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-01-20T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:EcommercePlatform ;
    noria:locatedAtLocus noria:RackA2_Position1 ;
    noria:resourceManagementIPAddress "10.0.0.201" .

noria:LoadBalancer01 a noria:Resource ;
    rdfs:label "E-commerce Load Balancer 01"@en ;
    rdfs:comment "Load balancer distributing traffic to web servers."@en ;
    noria:resourceManagedBy noria:TechCorpITOperationsTeam ;
    noria:resourceHostName "lb01.ecommerce.techcorp.com" ;
    noria:resourceProductModel noria:CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/LoadBalancer> ;
    noria:resourceSerialNumber "SN-LB-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-01-10T09:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:EcommercePlatform ;
    noria:locatedAtLocus noria:RackA3_Position1 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:CoreRouter01 a noria:Resource ;
    rdfs:label "Data Center Core Router 01"@en ;
    rdfs:comment "Main router for the data center network."@en ;
    noria:resourceManagedBy noria:TechCorpITOperationsTeam ;
    noria:resourceHostName "cr01.dc.techcorp.com" ;
    noria:resourceProductModel noria:CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-CR-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-12-01T14:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:RackA3_Position2 ;
    noria:resourceManagementIPAddress "10.0.0.254" .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:WebServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebServer01 Ethernet 0"@en ;
    rdfs:comment "Management interface for WebServer01."@en ;
    noria:networkInterfaceOf noria:WebServer01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:WebServer01_Eth1 a noria:NetworkInterface ;
    rdfs:label "WebServer01 Ethernet 1"@en ;
    rdfs:comment "Data interface for WebServer01, connected to LoadBalancer01."@en ;
    noria:networkInterfaceOf noria:WebServer01 ;
    noria:networkInterfaceType "physical" ;
