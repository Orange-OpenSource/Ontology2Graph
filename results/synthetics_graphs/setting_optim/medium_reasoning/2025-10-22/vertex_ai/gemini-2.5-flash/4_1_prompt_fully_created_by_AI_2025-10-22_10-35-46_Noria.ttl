# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:DBRestartProcedure a noria:OperationPlan ;
    rdfs:label "Database Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the Oracle Database service."@en ;
    skos:example "Steps include: 1. Stop application services. 2. Stop database listener. 3. Stop database instance. 4. Start database instance. 5. Start database listener. 6. Start application services."@en ;
    noria:operationPlanPreCondition noria:DBServiceDownPreCondition ;
    noria:operationPlanPostCondition noria:DBServiceUpPostCondition .

noria:DBServiceDownPreCondition a noria:ActionPreCondition ;
    rdfs:label "Database Service Down Pre-Condition"@en ;
    rdfs:comment "Condition: Database service is not running or is unresponsive."@en .

noria:DBServiceUpPostCondition a noria:ActionPostCondition ;
    rdfs:label "Database Service Up Post-Condition"@en ;
    rdfs:comment "Outcome: Database service is running and accessible, and application services can connect."@en .

noria:NetworkInterfaceTroubleshootingGuide a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Guide"@en ;
    rdfs:comment "Guide for diagnosing and resolving issues with network interfaces."@en ;
    skos:example "Steps include: 1. Check physical connection. 2. Verify administrative status. 3. Check operational status. 4. Review interface logs. 5. Test connectivity."@en ;
    noria:operationPlanPreCondition noria:NetworkInterfaceIssuePreCondition ;
    noria:operationPlanPostCondition noria:NetworkInterfaceResolvedPostCondition .

noria:NetworkInterfaceIssuePreCondition a noria:ActionPreCondition ;
    rdfs:label "Network Interface Issue Pre-Condition"@en ;
    rdfs:comment "Condition: A network interface is reporting an error state (e.g., down, flapping)."@en .

noria:NetworkInterfaceResolvedPostCondition a noria:ActionPostCondition ;
    rdfs:label "Network Interface Resolved Post-Condition"@en ;
    rdfs:comment "Outcome: Network interface is stable and operational, connectivity restored."@en .

# =============================================================================
# Connections between entities and operations
# =============================================================================

# Linking EventRecords to OperationPlans (as proposed repair actions)
noria:ER_DBDown_Alert noria:alarmProposedRepairAction noria:DBRestartProcedure .
noria:ER_NetworkInterfaceDown_Alert noria:alarmProposedRepairAction noria:NetworkInterfaceTroubleshootingGuide .

# Linking ChangeRequests to OperationPlans (as correlated procedures)
noria:CR_DBUpgrade_20240601 noria:actionCorrelatedOperationPlan noria:DBUpgradeProcedure .
noria:CR_NetworkConfig_20240605 noria:actionCorrelatedOperationPlan noria:NetworkConfigUpdateProcedure .

noria:DBUpgradeProcedure a noria:OperationPlan ;
    rdfs:label "Oracle Database Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for performing a major version upgrade of the Oracle Database."@en .

noria:NetworkConfigUpdateProcedure a noria:OperationPlan ;
    rdfs:label "Network Configuration Update Procedure"@en ;
    rdfs:comment "Standard procedure for applying network configuration changes to core routers."@en .

# Additional connections for density
noria:TechCorpITOperationsTeam noria:agentManagesResource noria:WebServer01, noria:WebServer02, noria:DatabaseServer01, noria:LoadBalancer01, noria:CoreRouter01, noria:Link_LB01_WS01, noria:Link_LB01_WS02, noria:Link_LB01_CR01, noria:Link_CR01_DB01 .
noria:TechCorpDevOpsTeam noria:agentManagesResource noria:EcommercePlatform, noria:EcommerceFrontendModule, noria:EcommerceBackendModule .

noria:EcommercePlatform seas:subSystemOf noria:CustomerFacingWebAccess .
noria:DatabaseManagementSystem seas:subSystemOf noria:InternalDatabaseService .

noria:WebServer01 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .
noria:WebServer02 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .
noria:DatabaseServer01 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

noria:CoreRouter01_Gi0_0_1 noria:networkInterfaceRoutingPriorityMetric 100 .
noria:CoreRouter01_Gi0_0_2 noria:networkInterfaceRoutingPriorityMetric 100 .

noria:LoadBalancer01_Eth0 noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:LoadBalancer01_Eth1 noria:networkInterfaceLaserTxOpticalPower -3.5 ;
    noria:networkInterfaceLaserRxOpticalPower -6 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2.5 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -11 .

noria:DatabaseServer01 noria:clusterController noria:DatabaseManagementSystem .

# Document attachments (example)
noria:DBOutageScreenshot a noria:DocumentAttachment ;
    rdfs:label "Database Outage Screenshot"@en ;
    rdfs:comment "Screenshot of the database monitoring dashboard during the outage."@en ;
    dcterms:isPartOf noria:TT_DBOutage_20240515 ;
    dcterms:format "image/png" ;
    dcterms:source "https://ticketing.techcorp.com/attachments/TT-20240515-001-screenshot.png" .

noria:UpgradePlanDocument a noria:DocumentAttachment ;
    rdfs:label "Database Upgrade Plan"@en ;
    rdfs:comment "Detailed plan for the Oracle Database software upgrade."@en ;
    dcterms:isPartOf noria:CR_DBUpgrade_20240601 ;
    dcterms:format "application/pdf" ;
    dcterms:source "https://ticketing.techcorp.com/attachments/CR-20240601-001-plan.pdf" .

