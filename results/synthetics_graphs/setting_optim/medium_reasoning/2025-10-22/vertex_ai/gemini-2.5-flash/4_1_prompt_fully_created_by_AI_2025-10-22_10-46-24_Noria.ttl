# =============================================================================
# Procedural Elements (noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

<operationplan/DBRestartProcedure> a noria:OperationPlan ;
    rdfs:label "Database Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the PostgreSQL database service."@en ;
    noria:operationPlanPreCondition <actionprecondition/DBServiceStopped> ;
    noria:operationPlanPostCondition <actionpostcondition/DBServiceRunning> .

<actionprecondition/DBServiceStopped> a noria:ActionPreCondition ;
    rdfs:label "Database Service Stopped"@en ;
    rdfs:comment "Condition: The database service process is not running."@en .

<actionpostcondition/DBServiceRunning> a noria:ActionPostCondition ;
    rdfs:label "Database Service Running"@en ;
    rdfs:comment "Outcome: The database service process is running and accessible."@en .

<operationplan/FirewallRuleAdditionProcedure> a noria:OperationPlan ;
    rdfs:label "Firewall Rule Addition Procedure"@en ;
    rdfs:comment "Standard procedure for adding new rules to the data center firewall."@en ;
    noria:operationPlanPreCondition <actionprecondition/FirewallConfigBackup> ;
    noria:operationPlanPostCondition <actionpostcondition/NewRuleActive> .

<actionprecondition/FirewallConfigBackup> a noria:ActionPreCondition ;
    rdfs:label "Firewall Configuration Backup Exists"@en ;
    rdfs:comment "Condition: A recent backup of the firewall configuration is available."@en .

<actionpostcondition/NewRuleActive> a noria:ActionPostCondition ;
    rdfs:label "New Firewall Rule Active and Verified"@en ;
    rdfs:comment "Outcome: The new firewall rule is active and traffic flow is verified."@en .

# Linking operation plans to change requests (example)
<changerequest/FirewallRuleUpdate002> noria:actionCorrelatedOperationPlan <operationplan/FirewallRuleAdditionProcedure> .
<troubleticket/DBOutage001> noria:actionCorrelatedOperationPlan <operationplan/DBRestartProcedure> . # Assuming a restart is a simple operation plan

