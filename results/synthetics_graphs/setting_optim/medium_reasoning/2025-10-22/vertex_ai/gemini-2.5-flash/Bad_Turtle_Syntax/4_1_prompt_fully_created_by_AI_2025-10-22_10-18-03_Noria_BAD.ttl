# =============================================================================
# Locations (noria:Room, noria:Locus)
# =============================================================================

noria:Room_DataCenterA_Rm1 a noria:Room ;
    rdfs:label "Data Center A - Server Room 1"@en, "Centre de Données A - Salle Serveurs 1"@fr ;
    rdfs:comment "Primary data center server room for production systems."@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:Room_OfficeB_NetworkCloset a noria:Room ;
    rdfs:label "Office B - Network Closet"@en, "Bureau B - Armoire Réseau"@fr ;
    rdfs:comment "Small network closet housing local network equipment for Office B."@en ;
    noria:sitePrincipalAddress "456 Business Street"@en ;
    noria:sitePrincipalAddressCityName "Gotham City"@en ;
    noria:sitePrincipalAddressPostalCode "20002"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:Locus_RackA1_U23 a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific rack and unit location within Data Center A - Server Room 1."@en ;
    noria:locusLine "A1"@en ;
    noria:locusRow "23"@en ;
    bot:hasSubSpace noria:Room_DataCenterA_Rm1 . # Inverse of bot:containsZone, but noria:Locus is subClassOf bot:Space, so bot:hasSubSpace is more appropriate for containment.

noria:Locus_RackB5_U10 a noria:Locus ;
    rdfs:label "Rack B5, Unit 10"@en ;
    rdfs:comment "Specific rack and unit location within Data Center A - Server Room 1."@en ;
    noria:locusLine "B5"@en ;
    noria:locusRow "10"@en ;
    bot:hasSubSpace noria:Room_DataCenterA_Rm1 .

noria:Locus_OfficeB_Rack1_U5 a noria:Locus ;
    rdfs:label "Office B Rack 1, Unit 5"@en ;
    rdfs:comment "Location for network equipment in Office B network closet."@en ;
    noria:locusLine "Rack1"@en ;
    noria:locusRow "5"@en ;
    bot:hasSubSpace noria:Room_OfficeB_NetworkCloset .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNSServer01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en, "Serveur DNS Corporatif 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, running on Dell hardware."@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DEL-R740-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_CorporateDNS ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 ;
    noria:resourceManagementIPAddress observable:IPAddress_DNS01_Mgmt .

noria:Resource_WebFrontendVM01 a noria:Resource ;
    rdfs:label "Web Frontend VM 01"@en, "VM Frontend Web 01"@fr ;
    rdfs:comment "Virtual machine hosting part of the customer-facing web application."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupportTeam ;
    noria:resourceHostName "web-fe-vm01.app.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The hypervisor model, not the VM itself.
    noria:resourceLogisticId "ASSET-VM-WEB-001" ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceSerialNumber "VM-ID-WEB-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_CustomerPortal ;
    noria:resourceManagementIPAddress observable:IPAddress_WebVM01_Mgmt .

noria:Resource_CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01"@en, "Routeur Cœur 01"@fr ;
    rdfs:comment "Main router for internal network traffic and external connectivity."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "cr01.core.example.com" ;
    noria:resourceProductModel noria:ProductModel_JuniperMX ;
    noria:resourceLogisticId "ASSET-CR-001" ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-JUN-MX-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-06-20T09:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_CorporateDNS, noria:Application_CustomerPortal ; # Supports multiple applications
    noria:locatedAtLocus noria:Locus_RackB5_U10 ;
    noria:resourceManagementIPAddress observable:IPAddress_CR01_Mgmt .

noria:Resource_Firewall01 a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en, "Pare-feu Périmétrique 01"@fr ;
    rdfs:comment "Security appliance protecting the corporate network from external threats."@en ;
    noria:resourceManagedBy foaf:Agent_SecurityTeam ;
    noria:resourceHostName "fw01.perimeter.example.com" ;
    noria:resourceProductModel noria:ProductModel_PaloAltoFirewall ;
    noria:resourceLogisticId "ASSET-FW-001" ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-PA-FW-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-09-10T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_InternetAccessService ;
    noria:locatedAtLocus noria:Locus_RackB5_U10 ;
    noria:resourceManagementIPAddress observable:IPAddress_FW01_Mgmt .

noria:Resource_DatabaseServer01 a noria:Resource ;
    rdfs:label "Database Server 01"@en, "Serveur Base de Données 01"@fr ;
    rdfs:comment "Dedicated server for the main customer database."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupportTeam ;
    noria:resourceHostName "db01.app.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-DB-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DEL-R740-002" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-02-20T16:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_CustomerPortal, noria:Application_InternalCRM ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 ;
    noria:resourceManagementIPAddress observable:IPAddress_DB01_Mgmt .

noria:Resource_LoadBalancer01 a noria:Resource ;
    rdfs:label "Load Balancer 01"@en, "Répartiteur de Charge 01"@fr ;
    rdfs:comment "Virtual load balancer distributing traffic to web frontend VMs."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "lb01.app.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # Runs on hypervisor
    noria:resourceLogisticId "ASSET-LB-001" ;
    noria:resourceType <kos/Resource/type/VirtualAppliance> ;
    noria:resourceSerialNumber "VM-ID-LB-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-04-10T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_CustomerPortal ;
    noria:resourceManagementIPAddress observable:IPAddress_LB01_Mgmt .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "dns01-eth0"@en ;
    rdfs:comment "Ethernet interface for DNS server connectivity."@en ;
    noria:networkInterfaceOf noria:Resource_DNSServer01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Main network interface for DNS services."@en .

noria:NetworkInterface_CR01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "cr01-Gi0/0/0"@en ;
    rdfs:comment "Gigabit Ethernet interface on Core Router 01, connected to Firewall 01."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_CR01_to_FW01 ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceDescription "Uplink to perimeter firewall."@en .

noria:NetworkInterface_CR01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "cr01-Gi0/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface on Core Router 01, connected to internal network."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Internal network segment connection."@en .

noria:NetworkInterface_FW01_Ext a noria:NetworkInterface ;
    rdfs:label "fw01-external"@en ;
    rdfs:comment "External interface of Firewall 01, facing the internet."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_FW01_to_Internet ;
    noria:networkInterfaceDescription "Internet-facing interface."@en .

noria:NetworkInterface_FW01_Int a noria:NetworkInterface ;
    rdfs:label "fw01-internal"@en ;
    rdfs:comment "Internal interface of Firewall 01, connected to Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_CR01_to_FW01 ;
    noria:networkInterfaceDescription "Internal network interface."@en .

noria:NetworkInterface_WebVM01_Eth0 a noria:NetworkInterface ;
    rdfs:label "web-fe-vm01-eth0"@en ;
    rdfs:comment "Virtual Ethernet interface for Web Frontend VM 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebFrontendVM01 ;
    noria:networkInterfaceType "virtual"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_WebVM01_to_LB01 ;
    noria:networkInterfaceDescription "Primary virtual network interface."@en .

noria:NetworkInterface_DB01_Eth0 a noria:NetworkInterface ;
    rdfs:label "db01-eth0"@en ;
    rdfs:comment "Ethernet interface for Database Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DatabaseServer01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Main network interface for database services."@en .

noria:NetworkInterface_LB01_Eth0 a noria:NetworkInterface ;
    rdfs:label "lb01-eth0"@en ;
    rdfs:comment "Virtual Ethernet interface for Load Balancer 01."@en ;
    noria:networkInterfaceOf noria:Resource_LoadBalancer01 ;
    noria:networkInterfaceType "virtual"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_WebVM01_to_LB01 ;
    noria:networkInterfaceDescription "Virtual network interface for load balancing."@en .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NetworkLink_CR01_to_FW01 a noria:NetworkLink ;
    rdfs:label "Core Router 01 to Firewall 01 Link"@en, "Lien Routeur Cœur 01 vers Pare-feu 01"@fr ;
    rdfs:comment "High-speed link between the core router and the perimeter firewall."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:networkLinkId "LINK-CR01-FW01-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Firewall01 ;
    noria:networkLinkInstallationDate "2021-06-20T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps"@en .

noria:NetworkLink_FW01_to_Internet a noria:NetworkLink ;
    rdfs:label "Firewall 01 to Internet Uplink"@en, "Lien Pare-feu 01 vers Internet"@fr ;
    rdfs:comment "Primary internet uplink from the perimeter firewall."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:networkLinkId "LINK-FW01-INET-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_Firewall01 ;
    noria:networkLinkInstallationDate "2022-09-10T11:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic ISP Link"@en .

noria:NetworkLink_DNS01_to_CoreSwitch a noria:NetworkLink ;
    rdfs:label "DNS Server 01 to Core Switch Link"@en, "Lien Serveur DNS 01 vers Switch Cœur"@fr ;
    rdfs:comment "Link connecting DNS server to the core network switch (implicit)."@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam ;
    noria:networkLinkId "LINK-DNS01-CSW-001" ;
    noria:networkLinkTerminationResource noria:Resource_DNSServer01 ; # Assuming the other end is a core switch not explicitly modeled as a noria:Resource here.
    noria:networkLinkInstallationDate "2022-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 1Gbps"@en .

noria:NetworkLink_WebVM01_to_LB01 a noria:NetworkLink ;
    rdfs:label "Web VM 01 to Load Balancer 01 Link"@en, "Lien VM Web 01 vers Répartiteur de Charge 01"@fr ;
    rdfs:comment "Internal virtual network link between web VM and load balancer."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupportTeam ;
    noria:networkLinkId "LINK-WEBVM01-LB01-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_WebFrontendVM01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_LoadBalancer01 ;
    noria:networkLinkInstallationDate "2023-04-10T10:15:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Virtual Ethernet"@en .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

noria:Application_CorporateDNS a noria:Application ;
    rdfs:label "Corporate DNS Service"@en, "Service DNS Corporatif"@fr ;
    rdfs:comment "Provides name resolution services for all internal and external corporate systems."@en ;
    noria:applicationModelIdentifier "CORP-DNS-V1" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CORPDNS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Services"@en ;
    noria:applicationFunctionalSubDomain "Name Resolution"@en .

noria:Application_CustomerPortal a noria:Application ;
    rdfs:label "Customer Portal"@en, "Portail Client"@fr ;
    rdfs:comment "Web application allowing customers to manage their accounts and services."@en ;
    noria:applicationModelIdentifier "CUST-PORTAL-V2" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "CUSTPORTAL" ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Self-Service Portal"@en .

noria:Application_InternalCRM a noria:Application ;
    rdfs:label "Internal CRM System"@en, "Système CRM Interne"@fr ;
    rdfs:comment "Customer Relationship Management system used by internal sales and support teams."@en ;
    noria:applicationModelIdentifier "INT-CRM-V3" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "INTCRM" ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Sales & Support Operations"@en .

noria:Application_MonitoringPlatform a noria:Application ;
    rdfs:label "IT Monitoring Platform"@en, "Plateforme de Supervision IT"@fr ;
    rdfs:comment "Centralized platform for monitoring IT infrastructure and applications."@en ;
    noria:applicationModelIdentifier "IT-MON-V1" ;
    noria:applicationNumericalIdentifier 1004 ;
    noria:applicationShortIdentifier "ITMON" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations Management"@en ;
    noria:applicationFunctionalSubDomain "Performance & Availability Monitoring"@en .

noria:Application_InternetAccessService a noria:Application ;
    rdfs:label "Corporate Internet Access Service"@en, "Service Accès Internet Corporatif"@fr ;
