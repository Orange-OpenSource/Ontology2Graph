# =============================================================================
# Services (noria:Service)
# =============================================================================

noria:Service_InternetAccess a noria:Service ;
    rdfs:label "Enterprise Internet Access Service"@en, "Service d'Accès Internet Entreprise"@fr ;
    rdfs:comment "End-to-end service providing internet connectivity to all corporate users and systems."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystem noria:Application_InternetAccessService, noria:Resource_Firewall01, noria:Resource_CoreRouter01 .

noria:Service_CustomerFacingAPI a noria:Service ;
    rdfs:label "Customer Facing API Service"@en, "Service API Client"@fr ;
    rdfs:comment "Service exposing APIs for external partners and mobile applications."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystem noria:Application_CustomerPortal, noria:Resource_LoadBalancer01, noria:Resource_WebFrontendVM01, noria:Resource_DatabaseServer01 .

noria:Service_InternalDataAnalytics a noria:Service ;
    rdfs:label "Internal Data Analytics Service"@en, "Service d'Analyse de Données Interne"@fr ;
    rdfs:comment "Service providing data analytics capabilities for internal business intelligence."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystem noria:Application_InternalCRM, noria:Resource_DatabaseServer01 .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating that the primary DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNSServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "CRITICAL: DNS server dns01.corp.example.com is unreachable via ICMP."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Core Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a critical interface on the core router went down."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "INTERFACE-5-DOWN: Interface Gi0/0/0 on cr01.core.example.com changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_CheckFiberConnection .

noria:EventRecord_WebVMHighCPU a noria:EventRecord ;
    rdfs:label "Web VM High CPU Alert"@en ;
    rdfs:comment "Alert indicating sustained high CPU utilization on a web frontend VM."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebFrontendVM01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "WARNING: CPU utilization on web-fe-vm01.app.example.com exceeded 90% for 15 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_FirewallLoginAttempt a noria:EventRecord ;
    rdfs:label "Failed Firewall Login Attempt"@en ;
    rdfs:comment "Log entry for a failed login attempt on the perimeter firewall."@en ;
    noria:loggingTime "2024-04-20T08:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "SECURITY: Failed login attempt for user 'admin' from IP 1.2.3.4 on fw01.perimeter.example.com."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> ;
    noria:logOriginatingAgent <https://example.com/malicious_actor_1.2.3.4> . # Example of external agent

noria:EventRecord_CRMSlowQuery a noria:EventRecord ;
    rdfs:label "CRM Slow Database Query Alert"@en ;
    rdfs:comment "Alert indicating a database query for the CRM system is taking too long."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DatabaseServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "ALERT: Slow query detected on db01.app.example.com for CRM application. Duration: 15s."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_DNSConfigChange a noria:EventRecord ;
    rdfs:label "DNS Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change applied to the DNS server."@en ;
    noria:loggingTime "2024-04-19T15:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNSServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "INFO: User 'johndoe' applied configuration change 'add A record for new-service.example.com'."@en .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
