@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Ontology Metadata
# =============================================================================

<https://w3id.org/noria/ontology/>
	a voaf:Vocabulary, owl:Ontology ;
	dcterms:title "The NORIA Ontology"@en ;
    dcterms:description """The NORIA-O project is a data model for IT networks, events and operations information.
The ontology is developed using web technologies (e.g. RDF, OWL, SKOS) and is intended as a structure for realizing an IT Service Management (ITSM) Knowledge Graph (KG) for Anomaly Detection (AD) and Risk Management applications.
The model has been developed in collaboration with operational teams, and in connection with third parties linked vocabularies.
"""@en ;
	dcterms:creator "Lionel Tailhardat (https://orcid.org/0000-0001-5887-899X)" ;
	dcterms:creator "Yoan Chabot (https://orcid.org/0000-0001-5639-1504)" ;
	dcterms:creator "Raphaël Troncy (https://orcid.org/0000-0003-0457-1436)" ;
    dcterms:publisher <https://www.orange.com/> ;
    dcterms:license <https://spdx.org/licenses/BSD-4-Clause> ;
    vann:preferredNamespacePrefix "noria" ;
    vann:preferredNamespaceUri "https://w3id.org/noria/ontology/" ;
    dcterms:issued "2022-05-10"^^xsd:date ;
	dcterms:modified "2024-03-15"^^xsd:date ;
	owl:versionInfo "v0.3" ;
	owl:versionIRI <ontology/noria-0.3> ;
	owl:priorVersion <ontology/noria-0.2> ;
    rdfs:seeAlso <https://w3id.org/noria/doc/> ;
.

# =============================================================================
# Agents (foaf:Agent)
# =============================================================================

foaf:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en, "Équipe Admin DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, open a P1 ticket and call the hotline."@en ;
    foaf:mbox "mailto:dns-admin@example.com" .

foaf:Agent_NetworkOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team managing core network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Escalate network outages directly to the on-call engineer."@en ;
    foaf:mbox "mailto:net-ops@example.com" .

foaf:Agent_AppSupportTeam a foaf:Agent ;
    rdfs:label "Application Support Team"@en, "Équipe Support Applicatif"@fr ;
    rdfs:comment "Support for business-critical applications."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "All application issues must be logged in the CRM ticketing system."@en ;
    foaf:mbox "mailto:app-support@example.com" .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center"@en, "Centre Opérations Sécurité"@fr ;
    rdfs:comment "Monitors and responds to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlerts> ;
    noria:agentInstructions "Automated alerts are preferred for immediate security threats."@en ;
    foaf:mbox "mailto:soc@example.com" .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Lead Developer for Customer Portal."@en ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    foaf:mbox "mailto:john.doe@example.com" .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Network Engineer specializing in routing protocols."@en ;
    noria:agentWorkingHours "08:30-17:30 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    foaf:mbox "mailto:jane.smith@example.com" .

foaf:Agent_CustomerService a foaf:Agent ;
    rdfs:label "Customer Service Department"@en, "Service Client"@fr ;
    rdfs:comment "First point of contact for customer inquiries and issues."@en ;
    noria:agentWorkingHours "07:00-22:00 Mon-Sun"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Log all customer complaints in the dedicated CRM module."@en ;
    foaf:mbox "mailto:customerservice@example.com" .

