noria:TroubleTicket_DNSOutage a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en, "Incident Panne Serveur DNS"@fr ;
    rdfs:comment "Critical incident: Corporate DNS server is unreachable, impacting all internal services."@en ;
    dcterms:identifier "TT-2024-04-20-001" ;
    dcterms:created "2024-04-20T09:01:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Incident> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketTrigger noria:EventRecord_DNSOutageLog ;
    noria:troubleTicketSupervisionTool "Nagios Monitoring"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Unknown, suspected network connectivity issue or server crash."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_DNSAdminTeam, foaf:Agent_NetworkOpsTeam ;
    noria:troubleTicketRelatedService noria:Application_CorporateDNS ;
    noria:troubleTicketRelatedResource noria:Resource_DNSServer01 ;
    noria:troubleTicketImpacts noria:Application_CorporateDNS, noria:Service_InternetAccess ;
    noria:documentHRef "https://ticketing.example.com/TT-2024-04-20-001" .

noria:TroubleTicket_CustomerPortalSlow a noria:TroubleTicket ;
    rdfs:label "Customer Portal Performance Degradation"@en, "Dégradation Performance Portail Client"@fr ;
    rdfs:comment "Customers reporting slow response times on the portal."@en ;
    dcterms:identifier "TT-2024-04-20-002" ;
    dcterms:created "2024-04-20T10:20:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Incident> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketTrigger noria:EventRecord_WebVMHighCPU ;
    noria:troubleTicketSupervisionTool "Customer Feedback, Prometheus"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/PerformanceDegradation> ;
    noria:troubleTicketCause "High CPU on web frontend, potential database bottleneck."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ApplicationVendor> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_AppSupportTeam, foaf:Agent_CustomerService ;
    noria:troubleTicketRelatedService noria:Application_CustomerPortal ;
    noria:troubleTicketRelatedResource noria:Resource_WebFrontendVM01, noria:Resource_DatabaseServer01 ;
    noria:troubleTicketImpacts noria:Application_CustomerPortal, noria:Service_CustomerFacingAPI ;
    noria:documentHRef "https://ticketing.example.com/TT-2024-04-20-002" .

noria:TroubleTicket_RouterLinkFailure a noria:TroubleTicket ;
    rdfs:label "Core Router Link Failure"@en, "Panne Lien Routeur Cœur"@fr ;
    rdfs:comment "Incident: Core router uplink to firewall is down, causing partial internet outage."@en ;
    dcterms:identifier "TT-2024-04-20-003" ;
    dcterms:created "2024-04-20T09:06:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Incident> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketTrigger noria:EventRecord_RouterInterfaceDown ;
    noria:troubleTicketSupervisionTool "Zabbix Monitoring"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/PartialOutage> ;
    noria:troubleTicketCause "Physical fiber cut or transceiver failure on Gi0/0/0."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_NetworkOpsTeam, foaf:Agent_JaneSmith ;
    noria:troubleTicketRelatedService noria:Service_InternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_CoreRouter01, noria:NetworkLink_CR01_to_FW01 ;
    noria:troubleTicketImpacts noria:Service_InternetAccess, noria:Application_CorporateDNS ;
    noria:documentHRef "https://ticketing.example.com/TT-2024-04-20-003" .

