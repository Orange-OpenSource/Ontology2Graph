# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OperationPlan_CheckFiberConnection a noria:OperationPlan ;
    rdfs:label "Check Fiber Optic Connection Procedure"@en ;
    rdfs:comment "Standard operating procedure for troubleshooting fiber optic link failures."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_LinkDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_LinkUp .

noria:OperationPlan_RestartDNSService a noria:OperationPlan ;
    rdfs:label "Restart DNS Service Procedure"@en ;
    rdfs:comment "Procedure to restart the DNS service on a server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSServiceNotResponding ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSServiceResponding .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:ActionPreCondition_LinkDown a noria:ActionPreCondition ;
    rdfs:label "Network Link is Down"@en ;
    rdfs:comment "Condition: A network interface or link is reporting an 'administratively down' or 'operational down' status."@en .

noria:ActionPostCondition_LinkUp a noria:ActionPostCondition ;
    rdfs:label "Network Link is Up"@en ;
    rdfs:comment "Outcome: The network interface or link is reporting an 'operational up' status."@en .

noria:ActionPreCondition_DNSServiceNotResponding a noria:ActionPreCondition ;
    rdfs:label "DNS Service Not Responding"@en ;
    rdfs:comment "Condition: DNS queries to the server are failing or timing out."@en .

noria:ActionPostCondition_DNSServiceResponding a noria:ActionPostCondition ;
    rdfs:label "DNS Service Responding"@en ;
    rdfs:comment "Outcome: DNS queries to the server are successful."@en .

