# =============================================================================
# Knowledge Organization System (KOS) Concepts
# =============================================================================

# Application Types
<https://w3id.org/noria/kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .

noria:kos/application/type/ecommerce a skos:Concept ;
    skos:prefLabel "E-commerce Application"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

noria:kos/application/type/monitoring a skos:Concept ;
    skos:prefLabel "Monitoring System Application"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

noria:kos/application/type/crm a skos:Concept ;
    skos:prefLabel "Customer Relationship Management Application"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

noria:kos/application/type/infrastructure a skos:Concept ;
    skos:prefLabel "Infrastructure Application"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

# Application Business Importance
<https://w3id.org/noria/kos/application/business-importance> a skos:ConceptScheme ;
