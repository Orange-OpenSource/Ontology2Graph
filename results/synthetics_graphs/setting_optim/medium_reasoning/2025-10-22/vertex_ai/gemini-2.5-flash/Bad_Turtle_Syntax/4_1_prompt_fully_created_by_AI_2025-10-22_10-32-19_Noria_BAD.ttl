# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:WebServerRestartProcedure a noria:OperationPlan ;
    rdfs:label "Web Server Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting an E-commerce web server."@en ;
    skos:example "1. Check server status. 2. Attempt graceful shutdown. 3. Force power cycle if necessary. 4. Verify application health."@en ;
    noria:operationPlanPreCondition noria:PreCond_WebServerDown ;
    noria:operationPlanPostCondition noria:PostCond_WebServerUp .

noria:DBOptimizationProcedure a noria:OperationPlan ;
    rdfs:label "Database Performance Optimization Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving database performance bottlenecks."@en ;
    skos:example "1. Analyze slow queries. 2. Check index usage. 3. Review database configuration. 4. Apply necessary optimizations."@en ;
    noria:operationPlanPreCondition noria:PreCond_DBHighCPU ;
    noria:operationPlanPostCondition noria:PostCond_DBPerformanceRestored .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:PreCond_WebServerDown a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Web Server Down"@en ;
    rdfs:comment "The web server is not reachable or its services are not responding."@en ;
    skos:example "Ping fails, HTTP requests timeout."@en .

noria:PostCond_WebServerUp a noria:ActionPostCondition ;
    rdfs:label "Post-condition: Web Server Up and Running"@en ;
    rdfs:comment "The web server is reachable, and the application is serving requests successfully."@en ;
    skos:example "Ping succeeds, HTTP 200 OK for application endpoints."@en .

noria:PreCond_DBHighCPU a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Database High CPU Usage"@en ;
    rdfs:comment "Database server CPU utilization consistently above 90%."@en .

noria:PostCond_DBPerformanceRestored a noria:ActionPostCondition ;
    rdfs:label "Post-condition: Database Performance Restored"@en ;
    rdfs:comment "Database server CPU utilization returned to normal levels, and application response times are acceptable."@en .

