noria:kos/application/business-importance/low a skos:Concept ;
    skos:prefLabel "Low Business Importance"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .

# Application Status
<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ;
    rdfs:label "Application Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational status of application modules."@en .

noria:kos/application/status/InProduction a skos:Concept ;
    skos:prefLabel "In Production"@en ;
