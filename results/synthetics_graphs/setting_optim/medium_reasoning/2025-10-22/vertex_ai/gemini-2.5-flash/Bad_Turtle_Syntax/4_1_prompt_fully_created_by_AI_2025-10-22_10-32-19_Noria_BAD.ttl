noria:TT_ECommerceOutage_001 a noria:TroubleTicket ;
    rdfs:label "E-commerce Platform Outage"@en ;
    rdfs:comment "Critical incident: E-commerce platform is completely inaccessible to customers."@en ;
    dcterms:identifier "TT001"@en ;
    dcterms:created "2024-04-23T10:20:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity noria:kos/TroubleTicket/severity/Critical ;
    noria:troubleTicketType noria:kos/TroubleTicket/type/Incident ;
    noria:troubleTicketOrigin noria:kos/TroubleTicket/origin/Supervision ;
    noria:troubleTicketTrigger noria:Event_WebServer01Down_20240423T100000Z ;
    noria:troubleTicketStatusCurrent noria:kos/TroubleTicket/status/InProgress ;
    noria:troubleTicketRelatedService noria:OnlineSalesService ;
    noria:troubleTicketRelatedResource noria:WebServer01, noria:LoadBalancer01 ;
    noria:troubleTicketRelatedParty noria:TechCorpITOperationsTeam, noria:JohnDoeAdmin ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketDescription "Customers are unable to access the E-commerce website. Initial checks show WebServer01 is down and not responding to pings. Load balancer is reporting no healthy backend servers."@en ;
    noria:documentStatusHistory noria:Event_TTStatusChange_TT001_InProgress_20240423T103000Z ;
    noria:documentHRef <https://ticketing.techcorp.com/TT001> .

noria:TT_DBPerformanceIssue_002 a noria:TroubleTicket ;
    rdfs:label "Database Performance Degradation"@en ;
    rdfs:comment "Major incident: E-commerce platform experiencing slow response times due to database performance issues."@en ;
    dcterms:identifier "TT002"@en ;
    dcterms:created "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity noria:kos/TroubleTicket/severity/Major ;
    noria:troubleTicketType noria:kos/TroubleTicket/type/Problem ;
    noria:troubleTicketOrigin noria:kos/TroubleTicket/origin/Supervision ;
    noria:troubleTicketTrigger noria:Event_DBHighCPU_20240423T101500Z ;
    noria:troubleTicketStatusCurrent noria:kos/TroubleTicket/status/InProgress ;
    noria:troubleTicketRelatedService noria:OnlineSalesService ;
    noria:troubleTicketRelatedResource noria:DatabaseServer01 ;
    noria:troubleTicketRelatedParty noria:TechCorpITOperationsTeam ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketDescription "High CPU and I/O on DatabaseServer01, leading to slow queries and application timeouts. Investigating root cause."@en ;
    noria:documentHRef <https://ticketing.techcorp.com/TT002> .

noria:TT_CustomerLoginIssue_003 a noria:TroubleTicket ;
    rdfs:label "Customer Login Failure"@en ;
    rdfs:comment "Minor incident: Some customers report inability to log into their accounts."@en ;
