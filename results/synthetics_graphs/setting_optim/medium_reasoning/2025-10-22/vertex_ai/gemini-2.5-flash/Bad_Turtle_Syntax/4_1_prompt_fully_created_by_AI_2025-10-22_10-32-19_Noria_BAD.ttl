# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

noria:TechCorpITOperationsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "TechCorp IT Operations Team"@en ;
    rdfs:comment "Team responsible for the day-to-day operation and maintenance of IT infrastructure."@en ;
    noria:agentWorkingHours "24/7 (on-call rotation)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use the emergency hotline after hours."@en .

noria:TechCorpCustomerSupport a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "TechCorp Customer Support"@en ;
    rdfs:comment "First-line support for customer inquiries and issues."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Escalate technical issues to IT Operations Team."@en .

noria:JohnDoeAdmin a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead administrator for E-commerce platform infrastructure."@en ;
    foaf:mbox <mailto:john.doe@techcorp.com> ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> .

noria:JaneSmithManager a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Manager of the IT Operations Team."@en ;
    foaf:mbox <mailto:jane.smith@techcorp.com> ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en .

noria:ExternalVendorSupport a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "External Vendor Support"@en ;
    rdfs:comment "Third-party support for specific hardware components."@en ;
    noria:agentWorkingHours "Business hours only"@en .

# =============================================================================
# Locations (noria:Room, noria:Locus)
# =============================================================================

noria:DataCenterARoom1 a noria:Room ;
    rdfs:label "Data Center A - Server Room 1"@en ;
    rdfs:comment "Primary server room in Data Center A, hosting critical production systems."@en ;
    bot:hasSubSpace noria:RackA1Locus, noria:RackB2Locus .

noria:RackA1Locus a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of Web Servers and Load Balancers."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en .

noria:RackB2Locus a noria:Locus ;
    rdfs:label "Rack B2"@en ;
    rdfs:comment "Location of Database Servers and Core Network Switches."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "2"@en .

