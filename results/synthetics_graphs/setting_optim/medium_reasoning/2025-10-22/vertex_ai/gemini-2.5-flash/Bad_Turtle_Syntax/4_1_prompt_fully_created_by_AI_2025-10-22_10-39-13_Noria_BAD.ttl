# =============================================================================
# Locations (Sites, Rooms, Loci)
# =============================================================================

bot:Site_MainDataCenter a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for TechCorp."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressCountry "USA" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressStreet "Tech Avenue" ;
    wgs84_pos:lat "40.7128"^^xsd:float ;
    wgs84_pos:long "-74.0060"^^xsd:float .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within DC01."@en ;
    bot:hasSpace bot:Site_MainDataCenter .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Network equipment room within DC01."@en ;
    bot:hasSpace bot:Site_MainDataCenter .

noria:Locus_RackA1_U10 a noria:Locus ;
    rdfs:label "Rack A1, Unit 10"@en ;
    rdfs:comment "Specific location for a server in Server Room A."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "10" ;
    bot:containsZone noria:Room_ServerRoomA .

noria:Locus_RackA2_U5 a noria:Locus ;
    rdfs:label "Rack A2, Unit 5"@en ;
    rdfs:comment "Specific location for another server in Server Room A."@en ;
    noria:locusLine "A2" ;
    noria:locusRow "5" ;
    bot:containsZone noria:Room_ServerRoomA .

noria:Locus_RackB1_U1 a noria:Locus ;
    rdfs:label "Rack B1, Unit 1"@en ;
    rdfs:comment "Specific location for a router in Network Room B."@en ;
    noria:locusLine "B1" ;
    noria:locusRow "1" ;
    bot:containsZone noria:Room_NetworkRoomB .

noria:Locus_RackB1_U2 a noria:Locus ;
    rdfs:label "Rack B1, Unit 2"@en ;
    rdfs:comment "Specific location for a load balancer in Network Room B."@en ;
    noria:locusLine "B1" ;
    noria:locusRow "2" ;
    bot:containsZone noria:Room_NetworkRoomB .

