noria:OperationPlan_DBServiceRestart a noria:OperationPlan ;
    rdfs:label "Database Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the database service on a server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DBServiceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DBServiceUp .

noria:ActionPreCondition_DBServiceDown a noria:ActionPreCondition ;
    rdfs:label "Database Service is Down"@en ;
    rdfs:comment "Condition: Database process is not running or unresponsive."@en .

noria:ActionPostCondition_DBServiceUp a noria:ActionPostCondition ;
    rdfs:label "Database Service is Up"@en ;
    rdfs:comment "Outcome: Database process is running and accepting connections."@en .

noria:OperationPlan_NetworkCableReplacement a noria:OperationPlan ;
    rdfs:label "Network Cable Replacement Procedure"@en ;
    rdfs:comment "Procedure for identifying and replacing a faulty network cable."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_NetworkInterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_NetworkInterfaceUp .

noria:ActionPreCondition_NetworkInterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: A network interface reports an operational status of 'down'."@en .

noria:ActionPostCondition_NetworkInterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Outcome: The network interface reports an operational status of 'up' and traffic flows."@en .

