# =============================================================================
# Ontology Metadata
# =============================================================================

<https://w3id.org/noria/ontology/>
	a voaf:Vocabulary, owl:Ontology ;
	dcterms:title "The NORIA Ontology"@en ;
    dcterms:description """The NORIA-O project is a data model for IT networks, events and operations information.
The ontology is developed using web technologies (e.g. RDF, OWL, SKOS) and is intended as a structure for realizing an IT Service Management (ITSM) Knowledge Graph (KG) for Anomaly Detection (AD) and Risk Management applications.
The model has been developed in collaboration with operational teams, and in connection with third parties linked vocabularies.
"""@en ;
    bibo:status <http://purl.org/ontology/bibo/status/accepted> ;
	dcterms:creator "Lionel Tailhardat (https://orcid.org/0000-0001-5887-899X)" ;
	dcterms:creator "Yoan Chabot (https://orcid.org/0000-0001-5639-1504)" ;
	dcterms:creator "Raphaël Troncy (https://orcid.org/0000-0003-0457-1436)" ;
    dcterms:publisher <https://www.orange.com/> ;
    dcterms:license <https://spdx.org/licenses/BSD-4-Clause> ;
    vann:preferredNamespacePrefix "noria" ;
    vann:preferredNamespaceUri "https://w3id.org/noria/ontology/" ;
    dcterms:issued "2022-05-10"^^xsd:date ;
	dcterms:modified "2024-03-15"^^xsd:date ;
	owl:versionInfo "v0.3" ;
	owl:versionIRI <ontology/noria-0.3> ;
	owl:priorVersion <ontology/noria-0.2> ;
    rdfs:seeAlso <https://w3id.org/noria/doc/> ;
.

# =============================================================================
# KOS Concepts (Simplified for brevity, assuming these exist in the KOS)
# =============================================================================

# Application Types
<kos/application/type/infrastructure> a skos:Concept ; skos:prefLabel "Infrastructure Application"@en .
<kos/application/type/business-critical> a skos:Concept ; skos:prefLabel "Business Critical Application"@en .
<kos/application/type/monitoring> a skos:Concept ; skos:prefLabel "Monitoring Application"@en .
<kos/application/type/database> a skos:Concept ; skos:prefLabel "Database Application"@en .
<kos/application/type/web-server> a skos:Concept ; skos:prefLabel "Web Server Application"@en .
<kos/application/type/api-gateway> a skos:Concept ; skos:prefLabel "API Gateway Application"@en .

# Application Business Importance
<kos/application/business-importance/high> a skos:Concept ; skos:prefLabel "High Business Importance"@en .
<kos/application/business-importance/medium> a skos:Concept ; skos:prefLabel "Medium Business Importance"@en .
<kos/application/business-importance/low> a skos:Concept ; skos:prefLabel "Low Business Importance"@en .

# Application Module Status
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; skos:prefLabel "Development"@en .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ; skos:prefLabel "Maintenance"@en .

# Service Types
<kos/service/type/CustomerFacingService> a skos:Concept ; skos:prefLabel "Customer Facing Service"@en .
<kos/service/type/ResourceFacingService> a skos:Concept ; skos:prefLabel "Resource Facing Service"@en .

# Trouble Ticket Severity
<kos/TroubleTicket/severity/Critical> a skos:Concept ; skos:prefLabel "Critical"@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; skos:prefLabel "Major"@en .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; skos:prefLabel "Minor"@en .
<kos/TroubleTicket/severity/Warning> a skos:Concept ; skos:prefLabel "Warning"@en .

# Trouble Ticket Type
<kos/TroubleTicket/type/Failure> a skos:Concept ; skos:prefLabel "Failure"@en .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; skos:prefLabel "Assistance"@en .

# Trouble Ticket Origin
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; skos:prefLabel "Supervision System"@en .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; skos:prefLabel "Customer Report"@en .
<kos/TroubleTicket/origin/Internal> a skos:Concept ; skos:prefLabel "Internal Report"@en .

# Trouble Ticket Status
<kos/TroubleTicket/status/InProgress> a skos:Concept ; skos:prefLabel "In Progress"@en .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; skos:prefLabel "Resolved"@en .
<kos/TroubleTicket/status/Closed> a skos:Concept ; skos:prefLabel "Closed"@en .
<kos/TroubleTicket/status/New> a skos:Concept ; skos:prefLabel "New"@en .

# Trouble Ticket Category
<kos/TroubleTicket/trouble-category/TotalBreakdown> a skos:Concept ; skos:prefLabel "Total Breakdown"@en .
<kos/TroubleTicket/trouble-category/PerformanceDegradation> a skos:Concept ; skos:prefLabel "Performance Degradation"@en .

# Trouble Ticket Problem Responsibility
<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ; skos:prefLabel "Managed Backbone Networks"@en .
<kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> a skos:Concept ; skos:prefLabel "Contract Application Hosting Services"@en .

# Change Request Type
<kos/ChangeRequest/type/Standard> a skos:Concept ; skos:prefLabel "Standard Change"@en .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; skos:prefLabel "Emergency Change"@en .

# Change Request Cause
<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ; skos:prefLabel "Software Upgrade"@en .
<kos/ChangeRequest/cause/Configuration> a skos:Concept ; skos:prefLabel "Configuration Change"@en .

# Change Request Status
<kos/ChangeRequest/status/Approved> a skos:Concept ; skos:prefLabel "Approved"@en .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; skos:prefLabel "Implemented"@en .
<kos/ChangeRequest/status/Pending> a skos:Concept ; skos:prefLabel "Pending Approval"@en .

# Resource Types
<kos/Resource/type/Server> a skos:Concept ; skos:prefLabel "Server"@en .
<kos/Resource/type/Router> a skos:Concept ; skos:prefLabel "Router"@en .
<kos/Resource/type/LoadBalancer> a skos:Concept ; skos:prefLabel "Load Balancer"@en .
<kos/Resource/type/DatabaseServer> a skos:Concept ; skos:prefLabel "Database Server"@en .
<kos/Resource/type/VirtualMachine> a skos:Concept ; skos:prefLabel "Virtual Machine"@en .
<kos/Resource/type/Firewall> a skos:Concept ; skos:prefLabel "Firewall"@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; skos:prefLabel "Decommissioned"@en .
<kos/Resource/LifecycleState/Staging> a skos:Concept ; skos:prefLabel "Staging"@en .

# Resource Operational State
<kos/Resource/OperationalState/Up> a skos:Concept ; skos:prefLabel "Up"@en .
<kos/Resource/OperationalState/Down> a skos:Concept ; skos:prefLabel "Down"@en .
<kos/Resource/OperationalState/Degraded> a skos:Concept ; skos:prefLabel "Degraded"@en .

# Resource Administrative State
<kos/Resource/AdministrativeState/Enabled> a skos:Concept ; skos:prefLabel "Enabled"@en .
<kos/Resource/AdministrativeState/Disabled> a skos:Concept ; skos:prefLabel "Disabled"@en .

# Notification Severity
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; skos:prefLabel "Critical"@en .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; skos:prefLabel "Major"@en .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; skos:prefLabel "Minor"@en .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; skos:prefLabel "Warning"@en .
<Notification/Severity/PerceivedSeverity/Indeterminate> a skos:Concept ; skos:prefLabel "Indeterminate"@en .

# Notification Event Type
<kos/Notification/EventType/stateChange> a skos:Concept ; skos:prefLabel "State Change Event"@en .
<kos/Notification/EventType/thresholdCrossing> a skos:Concept ; skos:prefLabel "Threshold Crossing Alert"@en .
<kos/Notification/EventType/communicationAlarm> a skos:Concept ; skos:prefLabel "Communication Alarm"@en .
<kos/Notification/EventType/processingError> a skos:Concept ; skos:prefLabel "Processing Error Event"@en .
<kos/Notification/EventType/securityViolation> a skos:Concept ; skos:prefLabel "Security Violation Event"@en .

# Agent Contact Method
<kos/org/agent-contact-method/Email> a skos:Concept ; skos:prefLabel "Email"@en .
<kos/org/agent-contact-method/Phone> a skos:Concept ; skos:prefLabel "Phone"@en .
<kos/org/agent-contact-method/TicketingSystem> a skos:Concept ; skos:prefLabel "Ticketing System"@en .

# TroubleTicketNote Comment Type
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; skos:prefLabel "Internal Comment"@en .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; skos:prefLabel "Customer Comment"@en .

# TroubleTicketNote Operation Type
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; skos:prefLabel "Diagnosis"@en .
<kos/TroubleTicket/operationType/TestsAndMeasurements> a skos:Concept ; skos:prefLabel "Tests and Measurements"@en .
<kos/TroubleTicket/operationType/ConfigurationChange> a skos:Concept ; skos:prefLabel "Configuration Change"@en .

# =============================================================================
# Agents (Teams and Individuals)
# =============================================================================

foaf:Agent_ITOperationsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations and incident response."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "For critical incidents, open a P1 ticket and call the on-call engineer."@en .

foaf:Agent_NetworkAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Administration Team"@en ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit network change requests via the dedicated portal."@en .

foaf:Agent_DatabaseAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team responsible for database systems and data integrity."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri, on-call for critical issues"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Contact via phone for P1/P2 database incidents."@en .

foaf:Agent_AppDevTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team developing and maintaining the Customer Portal application."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For application bugs, create a ticket in Jira and assign to the team lead."@en .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Database Administrator."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_AliceJohnson a foaf:Agent ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "Customer Support Representative."@en ;
    noria:agentWorkingHours "8:00-16:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

