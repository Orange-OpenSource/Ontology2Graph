# =============================================================================
# Locations (Rooms and Loci)
# =============================================================================

noria:Room_DC1_SR1 a noria:Room ;
    rdfs:label "Data Center 1 Server Room 1"@en, "Salle Serveurs DC1-SR1"@fr ;
    rdfs:comment "Primary server room in Data Center 1."@en ;
    bot:hasZone noria:Locus_DC1_SR1_RackA1, noria:Locus_DC1_SR1_RackB2 .

noria:Room_Office_Comms a noria:Room ;
    rdfs:label "Head Office Communications Room"@en, "Salle Comms Siège Social"@fr ;
    rdfs:comment "Room housing network equipment for the head office."@en ;
    bot:hasZone noria:Locus_Office_Comms_RackC3 .

noria:Locus_DC1_SR1_RackA1 a noria:Locus ;
    rdfs:label "Rack A1 in DC1 Server Room 1"@en ;
    rdfs:comment "Specific rack location for critical infrastructure."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en .

noria:Locus_DC1_SR1_RackB2 a noria:Locus ;
    rdfs:label "Rack B2 in DC1 Server Room 1"@en ;
    rdfs:comment "Rack location for secondary infrastructure."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "2"@en .

noria:Locus_Office_Comms_RackC3 a noria:Locus ;
    rdfs:label "Rack C3 in Head Office Comms Room"@en ;
    rdfs:comment "Rack location for office network equipment."@en ;
    noria:locusLine "C"@en ;
    noria:locusRow "3"@en .

# =============================================================================
# Resources
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted in DC1."@en ;
    noria:resourceManagedBy foaf:Agent_NetOpsTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_DC1_SR1_RackA1 ;
    noria:resourceManagementIPAddress observable:IPv4Address_DNS01_MGMT .

noria:Resource_WEB01 a noria:Resource ;
    rdfs:label "Customer Portal Web Server 01"@en ;
    rdfs:comment "Frontend web server for the customer portal application."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupportL2 ;
    noria:resourceHostName "web01.portal.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-WEB-001" ;
    noria:resourceSerialNumber "SN-WEB-001-ABC" ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_DC1_SR1_RackB2 ;
    noria:resourceForApplication noria:Application_CustomerPortal ;
    noria:resourceManagementIPAddress observable:IPv4Address_WEB01_MGMT .

noria:Resource_DB01 a noria:Resource ;
    rdfs:label "Customer Portal Database Server 01"@en ;
    rdfs:comment "Backend database server for the customer portal application."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupportL2 ;
    noria:resourceHostName "db01.portal.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-DB-001" ;
    noria:resourceSerialNumber "SN-DB-001-DEF" ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-01T15:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_DC1_SR1_RackB2 ;
    noria:resourceForApplication noria:Application_CustomerPortal ;
    noria:resourceManagementIPAddress observable:IPv4Address_DB01_MGMT .

noria:Resource_Router_Edge1 a noria:Resource ;
    rdfs:label "Edge Router 1"@en ;
    rdfs:comment "Main router connecting the corporate network to the internet."@en ;
    noria:resourceManagedBy foaf:Agent_NetOpsTeam ;
    noria:resourceHostName "router-edge1.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_JuniperMX480 ;
    noria:resourceLogisticId "ASSET-RTR-001" ;
    noria:resourceSerialNumber "SN-RTR-001-GHI" ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-11-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Office_Comms_RackC3 ;
    noria:resourceManagementIPAddress observable:IPv4Address_RouterEdge1_MGMT .

noria:Resource_Firewall_DMZ a noria:Resource ;
    rdfs:label "DMZ Firewall"@en ;
    rdfs:comment "Firewall protecting the DMZ segment."@en ;
    noria:resourceManagedBy foaf:Agent_SecOpsCenter ;
    noria:resourceHostName "fw-dmz.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_PaloAltoFW ;
    noria:resourceLogisticId "ASSET-FW-001" ;
    noria:resourceSerialNumber "SN-FW-001-JKL" ;
    noria:resourceType <kos/Resource/type/firewall> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-02-10T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_DC1_SR1_RackA1 ;
    noria:resourceManagementIPAddress observable:IPv4Address_FWDMZ_MGMT .

noria:Resource_VM_AppGateway a noria:Resource ;
    rdfs:label "Application Gateway VM"@en ;
    rdfs:comment "Virtual machine acting as an application gateway for internal services."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupportL2 ;
    noria:resourceHostName "appgw-vm01.internal.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The hypervisor model, not the VM itself
    noria:resourceLogisticId "ASSET-VM-001" ;
    noria:resourceSerialNumber "VM-UUID-12345" ;
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:virtualServerStatus <kos/Resource/OperationalState/running> ;
    noria:resourceForApplication noria:Application_InternalCRM ;
    noria:resourceManagementIPAddress observable:IPv4Address_VMAppGateway_MGMT .

