foaf:Agent_Dell a foaf:Agent, org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en .

foaf:Agent_Cisco a foaf:Agent, org:Organization ;
