# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_NetOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for monitoring and maintaining network infrastructure."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "For critical incidents, call the hotline immediately. For non-critical, use ticketing system."@en .

foaf:Agent_AppSupportL2 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support L2"@en, "Support Applicatif N2"@fr ;
    rdfs:comment "Second-level support team for business applications."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Escalate to L3 if issue persists after initial diagnosis."@en .

foaf:Agent_SecOpsCenter a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en, "Centre Opérations Sécurité"@fr ;
    rdfs:comment "Monitors and responds to cybersecurity threats."@en ;
    noria:agentWorkingHours "24/7 Dedicated Team"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/secure-chat> ;
    noria:agentInstructions "Follow established incident response playbooks."@en .

foaf:Agent_AliceSmith a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

foaf:Agent_BobJohnson a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    noria:agentWorkingHours "9:30 am - 5:30 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

foaf:Agent_CharlieBrown a foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "IT Service Desk Agent."@en ;
    foaf:mbox <mailto:charlie.brown@example.com> ;
    noria:agentWorkingHours "7:00 am - 7:00 pm (Mon-Sun)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

foaf:Agent_CustomerSupport a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Customer Support Team"@en ;
    rdfs:comment "First line of contact for customer issues."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

foaf:Agent_VendorA a foaf:Agent, org:Organization ;
    rdfs:label "Hardware Solutions Inc."@en ;
    rdfs:comment "Vendor for network equipment."@en .

foaf:Agent_VendorB a foaf:Agent, org:Organization ;
    rdfs:label "Software Innovations Corp."@en ;
    rdfs:comment "Vendor for application software."@en .

