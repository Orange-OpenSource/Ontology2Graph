# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_DNS01_InterfaceDown a noria:EventRecord ;
    rdfs:label "DNS01 Interface Down Alert"@en ;
    rdfs:comment "Alert indicating that a network interface on DNS01 went down."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "Interface Ethernet 1 on dns01.corp.example.com changed state to down."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_WEB01_CPUHigh a noria:EventRecord ;
    rdfs:label "WEB01 High CPU Usage Alert"@en ;
    rdfs:comment "Alert for sustained high CPU usage on WEB01."@en ;
    noria:logOriginatingManagedObject noria:Resource_WEB01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "CPU usage on web01.portal.example.com exceeded 90% for 15 minutes."@en ;
    noria:loggingTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_DB01_DiskFull a noria:EventRecord ;
    rdfs:label "DB01 Disk Full Alert"@en ;
    rdfs:comment "Alert indicating that a disk on DB01 is nearly full."@en ;
    noria:logOriginatingManagedObject noria:Resource_DB01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "Disk /var/lib/mysql on db01.portal.example.com is 95% full."@en ;
    noria:loggingTime "2024-04-20T12:15:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_RouterEdge1_ConfigChange a noria:EventRecord ;
    rdfs:label "RouterEdge1 Configuration Change"@en ;
    rdfs:comment "Log entry for a configuration change on RouterEdge1."@en ;
    noria:logOriginatingManagedObject noria:Resource_Router_Edge1 ;
    noria:logOriginatingAgent foaf:Agent_AliceSmith ;
    noria:logText "Configuration changed by Alice Smith: added new static route."@en ;
    noria:loggingTime "2024-04-19T16:45:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord_FWDMZ_BlockedAttack a noria:EventRecord ;
    rdfs:label "DMZ Firewall Blocked Attack"@en ;
    rdfs:comment "Log entry for a blocked attack attempt detected by the DMZ firewall."@en ;
    noria:logOriginatingManagedObject noria:Resource_Firewall_DMZ ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "Blocked SQL Injection attempt from 203.0.113.42 on web01.portal.example.com."@en ;
    noria:loggingTime "2024-04-20T09:10:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

