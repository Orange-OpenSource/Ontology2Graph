noria:ProcedureExecutionContainer_CableReplacement a pep:ProcedureExecutionContainer ;
    rdfs:label "Cable Replacement Procedure Execution"@en ;
    rdfs:comment "Container for events related to the cable replacement on DNS01."@en ;
    dcterms:created "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    pep:hasProcedure noria:OperationPlan_CableReplacement ;
    pep:hasExecutor foaf:Agent_AliceSmith ;
    dcterms:description "Execution of the standard cable replacement procedure."@en .

noria:OperationPlan_CableReplacement a noria:OperationPlan ;
    rdfs:label "Standard Cable Replacement Procedure"@en ;
    rdfs:comment "Formal procedure for replacing faulty network cables."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_FaultyCableIdentified ;
    noria:operationPlanPostCondition noria:ActionPostCondition_ServiceRestored .

noria:ActionPreCondition_FaultyCableIdentified a noria:ActionPreCondition ;
    rdfs:label "Faulty Cable Identified"@en ;
    rdfs:comment "Pre-condition: A network cable has been identified as faulty and requires replacement."@en .

noria:ActionPostCondition_ServiceRestored a noria:ActionPostCondition ;
    rdfs:label "Service Restored"@en ;
    rdfs:comment "Post-condition: The affected network service is fully restored and operational."@en .

