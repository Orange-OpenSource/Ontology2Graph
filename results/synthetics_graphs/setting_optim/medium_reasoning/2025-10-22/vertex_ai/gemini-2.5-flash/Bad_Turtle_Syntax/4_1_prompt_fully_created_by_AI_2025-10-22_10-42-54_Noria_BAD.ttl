    noria:networkLinkId "DC1-CORE-LNK-001" ;
    noria:networkLinkType "fiber-optic"@en ;
    noria:networkLinkInstallationDate "2021-10-01T08:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_NetOpsTeam ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Router_Edge1 . # Simplified for example

