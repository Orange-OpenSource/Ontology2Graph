# =============================================================================
# Network Interfaces
# =============================================================================

:NetworkInterface001 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/0.0"@en ;
    rdfs:comment "Physical interface on Core Router 1 connected to ISP."@en ;
    noria:networkInterfaceOf :Resource001 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

:NetworkInterface002 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/1.0"@en ;
    rdfs:comment "Physical interface on Core Router 1 connected to internal network."@en ;
    noria:networkInterfaceOf :Resource001 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

:NetworkInterface003 a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
    rdfs:comment "Ethernet interface on Database Server 1."@en ;
    noria:networkInterfaceOf :Resource002 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

:NetworkInterface004 a noria:NetworkInterface ;
