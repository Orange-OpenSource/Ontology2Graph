# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

:Agent001 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC) Team"@en ;
    rdfs:comment "First line support team for network incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical incidents, call the hotline immediately. For minor issues, open a ticket."@en .

:Agent002 a foaf:Agent ;
    rdfs:label "Application Support Team A"@en ;
    rdfs:comment "Team responsible for managing critical business applications."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for non-urgent requests, use ticketing system for incidents."@en .

:Agent003 a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Specialized team for database infrastructure."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> .

:Agent004 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Engineer for Core Network."@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> .

:Agent005 a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Application Manager for CRM System."@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> .

:OrgUnit001 a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Overall department for IT infrastructure and application operations."@en ;
    org:hasMember :Agent001, :Agent002, :Agent003, :Agent004, :Agent005 .

# =============================================================================
# Product Models
# =============================================================================

:ProductModel001 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R750"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy :ManufacturerDell .

:ProductModel002 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Enterprise-grade network switch."@en ;
    noria:productManufacturedBy :ManufacturerCisco .

:ProductModel003 a noria:ProductModel ;
    rdfs:label "Juniper MX204"@en ;
    rdfs:comment "Compact, high-density universal routing platform."@en ;
    noria:productManufacturedBy :ManufacturerJuniper .

:ProductModel004 a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10"@en ;
    rdfs:comment "Versatile 2U rack server."@en ;
    noria:productManufacturedBy :ManufacturerHP .

:ManufacturerDell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en .

:ManufacturerCisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

:ManufacturerJuniper a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "Manufacturer of networking products."@en .

:ManufacturerHP a org:Organization ;
    rdfs:label "HP Inc."@en ;
    rdfs:comment "Manufacturer of computer hardware."@en .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

:Site001 a bot:Site ;
    rdfs:label "Main Data Center Paris"@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressStreet "Rue de la Paix" ;
    wgs84_pos:lat "48.8696"^^xsd:float ;
    wgs84_pos:long "2.3337"^^xsd:float .

:Room001 a noria:Room ;
    rdfs:label "Server Room A01"@en ;
    rdfs:comment "Primary server room in Main Data Center Paris."@en ;
    bot:hasSpace :Site001 .

:Locus001 a noria:Locus ;
    rdfs:label "Rack R01-A01"@en ;
    rdfs:comment "Location for critical infrastructure servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "01" ;
    bot:hasZone :Room001 .

:Locus002 a noria:Locus ;
    rdfs:label "Rack R02-A01"@en ;
    rdfs:comment "Location for network equipment."@en ;
    noria:locusLine "A" ;
    noria:locusRow "02" ;
    bot:hasZone :Room001 .

:Room002 a noria:Room ;
    rdfs:label "Network Equipment Room B01"@en ;
    rdfs:comment "Secondary network equipment room."@en ;
    bot:hasSpace :Site001 .

:Locus003 a noria:Locus ;
    rdfs:label "Rack N01-B01"@en ;
    rdfs:comment "Location for core routers."@en ;
    noria:locusLine "N" ;
    noria:locusRow "01" ;
    bot:hasZone :Room002 .

