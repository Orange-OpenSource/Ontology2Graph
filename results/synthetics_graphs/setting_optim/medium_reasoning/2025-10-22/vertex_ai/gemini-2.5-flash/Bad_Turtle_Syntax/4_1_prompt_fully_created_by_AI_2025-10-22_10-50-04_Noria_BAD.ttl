# Base URI for NORIA instances
@base <https://w3id.org/noria/instances/> .

# =============================================================================
# KOS Concepts (Knowledge Organization System)
# These are defined inline as required by the vocabulary for ranges of certain properties.
# =============================================================================

<https://w3id.org/noria/kos/application/type/infrastructure> a skos:Concept ;
    rdfs:label "Infrastructure Application"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

<https://w3id.org/noria/kos/application/type/business-critical> a skos:Concept ;
    rdfs:label "Business Critical Application"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

<https://w3id.org/noria/kos/application/type/monitoring> a skos:Concept ;
    rdfs:label "Monitoring Application"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

<https://w3id.org/noria/kos/application/type/database> a skos:Concept ;
    rdfs:label "Database Application"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

<https://w3id.org/noria/kos/application/business-importance/high> a skos:Concept ;
