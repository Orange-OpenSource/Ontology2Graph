# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating primary DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service unreachable."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    dcterms:type <kos/Notification/EventType/HostDown> .

noria:EventRecord_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a critical network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logText "Interface ge0/0/1 on router-core01 is DOWN. WAN link to Paris affected."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore1 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    dcterms:type <kos/Notification/EventType/InterfaceDown> .

noria:EventRecord_WebSrvHighCPU a noria:EventRecord ;
    rdfs:label "Web Server High CPU Warning"@en ;
    rdfs:comment "Warning log for high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "WARNING: CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    dcterms:type <kos/Notification/EventType/HighCPU> .

noria:EventRecord_FirewallBlockedAttack a noria:EventRecord ;
    rdfs:label "Firewall Blocked Attack Alert"@en ;
    rdfs:comment "Security alert from DMZ Firewall indicating a blocked attack attempt."@en ;
    noria:loggingTime "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    noria:logText "ALERT: SYN Flood attack detected and blocked from 192.0.2.10 on fw-dmz01."@en ;
    noria:logOriginatingManagedObject noria:Resource_FirewallDMZ ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> ;
    dcterms:type <kos/Notification/EventType/SecurityAlert> .

noria:EventRecord_DBConnectionError a noria:EventRecord ;
    rdfs:label "Database Connection Error Log"@en ;
    rdfs:comment "Log entry indicating intermittent database connection errors from CRM application."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logText "ERROR: Failed to connect to database 'crm_db' from application server 'app01'."@en ;
    noria:logOriginatingManagedObject noria:Application_InternalCRM ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    dcterms:type <kos/Notification/EventType/ApplicationError> .

noria:EventRecord_UserLoginFailure a noria:EventRecord ;
    rdfs:label "User Login Failure Alert"@en ;
    rdfs:comment "Alert for multiple failed login attempts on VPN Concentrator."@en ;
    noria:loggingTime "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    noria:logText "SECURITY: Multiple failed login attempts for user 'jdoe' from IP 203.0.113.5 on vpn01."@en ;
    noria:logOriginatingManagedObject noria:Resource_VPNConcentrator ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    dcterms:type <kos/Notification/EventType/SecurityAlert> ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

noria:TroubleTicket_DNSOutage_TT001 a noria:TroubleTicket ;
    rdfs:label "Critical DNS Service Outage"@en ;
    rdfs:comment "Primary DNS server is unreachable, causing widespread name resolution failures."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_DNSOutageLog ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Unknown, suspected hardware failure or network isolation."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_DNSAdminTeam, foaf:Agent_NetworkOps ;
    noria:troubleTicketRelatedService noria:Application_DNS_Service ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:documentHRef <https://ticketing.example.com/TT001> ;
    noria:documentExternalId "EXT-INC-2024-001" .

noria:TroubleTicket_WANLinkDown_TT002 a noria:TroubleTicket ;
    rdfs:label "WAN Link to Paris Down"@en ;
    rdfs:comment "WAN link to Paris edge location is down, impacting remote users and services."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/IsolatedCustomerSite> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
