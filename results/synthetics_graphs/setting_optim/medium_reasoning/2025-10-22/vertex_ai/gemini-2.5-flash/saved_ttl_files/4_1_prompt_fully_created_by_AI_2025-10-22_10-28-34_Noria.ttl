    rdfs:comment "Data center switch for high-density and high-performance networks."@en ;
    noria:productManufacturedBy <https://www.cisco.com> .

noria:ProductModel_HPProLiant a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10"@en ;
    rdfs:comment "Versatile rack server for various enterprise workloads."@en ;
    noria:productManufacturedBy <https://www.hpe.com> .

noria:ProductModel_JuniperMX a noria:ProductModel ;
    rdfs:label "Juniper MX Series Router"@en ;
    rdfs:comment "Edge and core router for service provider and enterprise networks."@en ;
    noria:productManufacturedBy <https://www.juniper.net> .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Industry-leading bare-metal hypervisor for virtualization."@en ;
    noria:productManufacturedBy <https://www.vmware.com> .

noria:ProductModel_PaloAltoFirewall a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-5200 Series Firewall"@en ;
    rdfs:comment "Next-generation firewall for enterprise security."@en ;
    noria:productManufacturedBy <https://www.paloaltonetworks.com> .

noria:ProductModel_NetAppStorage a noria:ProductModel ;
    rdfs:label "NetApp FAS8200 Storage System"@en ;
    rdfs:comment "Unified storage system for enterprise data management."@en ;
    noria:productManufacturedBy <https://www.netapp.com> .

# =============================================================================
# Locations (noria:Room, noria:Locus)
# =============================================================================

noria:Room_DataCenterA_Floor1 a noria:Room ;
    rdfs:label "Data Center A - Floor 1"@en ;
    rdfs:comment "Primary data center facility, first floor."@en ;
    bot:hasSubSpace noria:Locus_RackA1_DC1, noria:Locus_RackA2_DC1 .

noria:Room_ServerRoom_B2 a noria:Room ;
    rdfs:label "Server Room B2"@en ;
    rdfs:comment "Secondary server room for development and testing environments."@en ;
    bot:hasSubSpace noria:Locus_RackB5_SR2, noria:Locus_RackB6_SR2 .

noria:Room_EdgeLocation_Paris a noria:Room ;
    rdfs:label "Edge Location - Paris"@en ;
    rdfs:comment "Network edge point of presence in Paris."@en ;
    bot:hasSubSpace noria:Locus_CabinetC_EdgeParis .

noria:Room_CloudZone_East a noria:Room ;
    rdfs:label "Cloud Zone - East Region"@en ;
    rdfs:comment "Virtual location representing a cloud provider's East region."@en ;
    bot:hasSubSpace noria:Locus_VirtualPod_CloudEast .

noria:Locus_RackA1_DC1 a noria:Locus ;
    rdfs:label "Rack A1 in Data Center A"@en ;
    rdfs:comment "Physical rack A1 located in Data Center A, Floor 1."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_DataCenterA_Floor1 .

noria:Locus_RackA2_DC1 a noria:Locus ;
    rdfs:label "Rack A2 in Data Center A"@en ;
    rdfs:comment "Physical rack A2 located in Data Center A, Floor 1."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
    bot:hasSpace noria:Room_DataCenterA_Floor1 .

noria:Locus_RackB5_SR2 a noria:Locus ;
    rdfs:label "Rack B5 in Server Room B2"@en ;
    rdfs:comment "Physical rack B5 located in Server Room B2."@en ;
    noria:locusLine "B" ;
    noria:locusRow "5" ;
    bot:hasSpace noria:Room_ServerRoom_B2 .

noria:Locus_RackB6_SR2 a noria:Locus ;
    rdfs:label "Rack B6 in Server Room B2"@en ;
    rdfs:comment "Physical rack B6 located in Server Room B2."@en ;
    noria:locusLine "B" ;
    noria:locusRow "6" ;
    bot:hasSpace noria:Room_ServerRoom_B2 .

noria:Locus_CabinetC_EdgeParis a noria:Locus ;
    rdfs:label "Cabinet C in Paris Edge Location"@en ;
    rdfs:comment "Network cabinet C in the Paris edge location."@en ;
    noria:locusLine "C" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_EdgeLocation_Paris .

noria:Locus_VirtualPod_CloudEast a noria:Locus ;
    rdfs:label "Virtual Pod in Cloud East Region"@en ;
    rdfs:comment "Logical grouping of virtual resources in the East cloud region."@en ;
    noria:locusLine "Virtual" ;
    noria:locusRow "East" ;
    bot:hasSpace noria:Room_CloudZone_East .

