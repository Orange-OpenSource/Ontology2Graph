# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "dns01-eth0"@en ;
    rdfs:comment "Ethernet interface for DNS server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceConnects noria:NetworkLink_DC_Core ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Primary network interface for DNS services."@en .

noria:NetworkInterface_RouterCore1_Ge0_0_0 a noria:NetworkInterface ;
    rdfs:label "router-core01-ge0/0/0"@en ;
    rdfs:comment "Gigabit Ethernet interface connecting to Data Center Core."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore1 ;
    noria:networkInterfaceConnects noria:NetworkLink_DC_Core ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to DC core switch."@en .

noria:NetworkInterface_RouterCore1_Ge0_0_1 a noria:NetworkInterface ;
    rdfs:label "router-core01-ge0/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface connecting to WAN Paris."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore1 ;
    noria:networkInterfaceConnects noria:NetworkLink_WAN_Paris ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "WAN link to Paris edge location."@en .

noria:NetworkInterface_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "web01-eth0"@en ;
    rdfs:comment "Ethernet interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceConnects noria:NetworkLink_App_LAN ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Primary network interface for web application."@en .

noria:NetworkInterface_DBHost01_Eth0 a noria:NetworkInterface ;
    rdfs:label "db01-eth0"@en ;
    rdfs:comment "Ethernet interface for Database Host 01."@en ;
    noria:networkInterfaceOf noria:Resource_DBHost01 ;
    noria:networkInterfaceConnects noria:NetworkLink_App_LAN ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
