# =============================================================================
# Agents (foaf:Agent)
# =============================================================================

foaf:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Administration Team"@en ;
    rdfs:comment "Team responsible for managing DNS infrastructure and services."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use the dedicated hotline number after sending an email."@en .

foaf:Agent_NetworkOps a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing the core network infrastructure, including routers and switches."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always open a ticket first, then call the on-call engineer for P1/P2 incidents."@en .

foaf:Agent_AppDevTeam a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining corporate applications."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Submit all requests via the Jira ticketing system."@en .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlerts> ;
    noria:agentInstructions "Automated alerts are preferred for immediate action. Follow up with a ticket."@en .

foaf:Agent_JohnDoe a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Senior Network Engineer, member of Network Operations Team."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+33123456789" ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_JaneSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead Application Developer, member of Application Development Team."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:phone "+33987654321" ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> .

foaf:Agent_CustomerSupport a foaf:Agent ;
    rdfs:label "Customer Support Team"@en ;
    rdfs:comment "First-line support for customer inquiries and issues."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Escalate to L2 teams using the internal ticketing system."@en .

foaf:Agent_DBA_Team a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team responsible for database systems management and performance."@en ;
    noria:agentWorkingHours "08:30-17:30 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "For urgent database issues, contact via phone after ticket creation."@en .

foaf:Agent_CloudOps a foaf:Agent ;
    rdfs:label "Cloud Operations Team"@en ;
    rdfs:comment "Team managing cloud infrastructure and services."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ChatOps> ;
    noria:agentInstructions "Use ChatOps for real-time communication and incident response."@en .

foaf:Agent_NOC_Team a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "Centralized team monitoring network and system health."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/MonitoringSystem> ;
    noria:agentInstructions "Respond to automated alerts and escalate as per runbook procedures."@en .

foaf:Agent_VendorSupport a foaf:Agent ;
    rdfs:label "External Vendor Support"@en ;
    rdfs:comment "Third-party support for specific hardware or software."@en ;
    noria:agentWorkingHours "Varies by contract"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/VendorPortal> ;
    noria:agentInstructions "Open a case via the vendor's support portal, referencing internal ticket ID."@en .

foaf:Agent_ProjectManager a foaf:Agent ;
    rdfs:label "Project Management Office (PMO)"@en ;
    rdfs:comment "Team overseeing IT projects and initiatives."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "All project-related communications should be via email or project management tools."@en .

foaf:Agent_Auditor a foaf:Agent ;
    rdfs:label "Internal Audit Department"@en ;
    rdfs:comment "Department responsible for internal audits and compliance checks."@en ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SecurePortal> ;
    noria:agentInstructions "All audit requests and documentation exchanges must use the secure audit portal."@en .

