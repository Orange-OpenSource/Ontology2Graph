noria:OperationPlan_DNSFailover a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for failing over primary DNS to secondary DNS."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_PrimaryDNSDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_SecondaryDNSActive .

noria:OperationPlan_WANTroubleshooting a noria:OperationPlan ;
    rdfs:label "WAN Link Troubleshooting Guide"@en ;
    rdfs:comment "Guide for diagnosing and resolving issues on WAN links."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_WANLinkIssue ;
    noria:operationPlanPostCondition noria:ActionPostCondition_WANLinkRestored .

noria:OperationPlan_FirewallRuleDeployment a noria:OperationPlan ;
    rdfs:label "Firewall Rule Deployment Procedure"@en ;
    rdfs:comment "Procedure for safely deploying new firewall rules."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_FirewallChangeApproved ;
    noria:operationPlanPostCondition noria:ActionPostCondition_FirewallRuleActive .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:ActionPreCondition_PrimaryDNSDown a noria:ActionPreCondition ;
    rdfs:label "Primary DNS Server Unreachable"@en ;
    rdfs:comment "Condition: Primary DNS server (dns01.corp.example.com) is not responding to pings or DNS queries."@en .

noria:ActionPostCondition_SecondaryDNSActive a noria:ActionPostCondition ;
    rdfs:label "Secondary DNS Server Active"@en ;
    rdfs:comment "Outcome: Secondary DNS server is actively serving DNS queries and primary is isolated."@en .

noria:ActionPreCondition_WANLinkIssue a noria:ActionPreCondition ;
    rdfs:label "WAN Link Performance Degradation or Outage"@en ;
    rdfs:comment "Condition: Monitoring indicates high latency, packet loss, or complete outage on a WAN link."@en .

noria:ActionPostCondition_WANLinkRestored a noria:ActionPostCondition ;
    rdfs:label "WAN Link Operational"@en ;
    rdfs:comment "Outcome: WAN link is restored to normal operational status with acceptable performance metrics."@en .

noria:ActionPreCondition_FirewallChangeApproved a noria:ActionPreCondition ;
    rdfs:label "Firewall Change Request Approved"@en ;
    rdfs:comment "Condition: A Change Request for firewall rule modification has been formally approved."@en .

noria:ActionPostCondition_FirewallRuleActive a noria:ActionPostCondition ;
    rdfs:label "New Firewall Rule Active and Verified"@en ;
    rdfs:comment "Outcome: The new firewall rule is active, and connectivity tests confirm its correct functionality without unintended side effects."@en .

