# --- Services (noria:Service) ---
noria:Service_HAInternet a noria:Service ;
    rdfs:label "High Availability Internet Service"@en, "Service Internet Haute Disponibilité"@fr ;
    rdfs:comment "Ensures continuous internet access for critical business operations."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystem noria:AppModule_CIA_Prod .

noria:Service_CustomerDataManagement a noria:Service ;
    rdfs:label "Customer Data Management Service"@en, "Service de Gestion des Données Client"@fr ;
    rdfs:comment "Manages all customer-related data, underpinning the Customer Portal and Internal CRM."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystem noria:AppModule_CP_Dev ;
    seas:subSystem noria:AppModule_CRM_Prod .

# --- Event Records (noria:EventRecord) ---
noria:Event_DNS_CPU_Spike_20240310 a noria:EventRecord ;
    rdfs:label "DNS Server CPU Spike Alert"@en, "Alerte Pic CPU Serveur DNS"@fr ;
    rdfs:comment "High CPU utilization detected on DNS01 server."@en ;
    noria:loggingTime "2024-03-10T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_CorporateInternetAccess ; # Assuming monitoring is part of this app
    noria:logText "CPU utilization on dns01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:Event_CoreRtr_InterfaceDown_20240310 a noria:EventRecord ;
    rdfs:label "Core Router Interface Down"@en, "Interface Routeur Cœur Hors Service"@fr ;
    rdfs:comment "GigabitEthernet 0/0/1 on Core Router 01 went down."@en ;
    noria:loggingTime "2024-03-10T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRtr01 ;
    noria:logOriginatingManagementSystem noria:AppModule_CIA_Prod ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_WebSrv_LoginFailure_20240310 a noria:EventRecord ;
    rdfs:label "Web Server Login Failure"@en, "Échec de Connexion Serveur Web"@fr ;
    rdfs:comment "Multiple failed login attempts on WebSrv01 for customer portal."@en ;
    noria:loggingTime "2024-03-10T10:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:AppModule_CP_Dev ; # Assuming monitoring is part of this app module
    noria:logText "Failed login attempt for user 'malicious_user' from IP 203.0.113.42."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> ;
    noria:logOriginatingAgent noria:Agent_SecurityTeam . # Security team might be the "agent" detecting/logging this.

# --- Trouble Tickets (noria:TroubleTicket) ---
noria:TT_DNS_Outage_001 a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en, "Incident Panne Serveur DNS"@fr ;
    rdfs:comment "Corporate DNS server unreachable, impacting internet access."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketDetectionDateTime "2024-03-10T10:10:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:Application_CorporateInternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketRelatedParty noria:Agent_DNSAdminTeam ;
    noria:troubleTicketRelatedParty noria:Agent_NOC ;
    noria:troubleTicketTrigger noria:Event_DNS_CPU_Spike_20240310 ;
    noria:troubleTicketCause "High CPU load leading to service unresponsiveness."@en ;
    noria:troubleTicketImpacts noria:Application_CorporateInternetAccess ;
    noria:troubleTicketImpacts noria:Resource_DNS01 .

noria:TT_CustomerPortal_Slowdown_002 a noria:TroubleTicket ;
    rdfs:label "Customer Portal Performance Degradation"@en, "Dégradation Performance Portail Client"@fr ;
    rdfs:comment "Customers reporting slow response times on the portal."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketDetectionDateTime "2024-03-10T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Initialised> ;
    noria:troubleTicketRelatedService noria:Application_CustomerPortal ;
    noria:troubleTicketRelatedResource noria:Resource_WebSrv01 ;
    noria:troubleTicketRelatedParty noria:Agent_AppSupportTeam ;
    noria:troubleTicketTrigger noria:Event_WebSrv_LoginFailure_20240310 ; # Indirect trigger, as login failure might be a symptom
    noria:troubleTicketCause "Unidentified performance bottleneck in application layer."@en ;
    noria:troubleTicketImpacts noria:Application_CustomerPortal ;
    noria:troubleTicketImpacts noria:Resource_WebSrv01 .

# --- Trouble Ticket Notes (noria:TroubleTicketNote) ---
noria:TTN_DNS_Outage_001_Note1 a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Note 1"@en, "Note Panne DNS 1"@fr ;
    rdfs:comment "Initial diagnosis: High CPU on DNS01. Attempting restart of DNS service."@en ;
    dcterms:created "2024-03-10T10:12:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_Alice ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TT_DNS_Outage_001 .

noria:TTN_DNS_Outage_001_Note2 a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Note 2"@en, "Note Panne DNS 2"@fr ;
    rdfs:comment "DNS service restarted. CPU normalized. Monitoring for stability."@en ;
    dcterms:created "2024-03-10T10:25:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_Alice ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:isPartOf noria:TT_DNS_Outage_001 .

# --- Change Requests (noria:ChangeRequest) ---
noria:CR_DNS_Upgrade_001 a noria:ChangeRequest ;
    rdfs:label "DNS Software Upgrade"@en, "Mise à Jour Logiciel DNS"@fr ;
    rdfs:comment "Upgrade DNS server software to latest stable version for security patches."@en ;
    dcterms:created "2024-03-05T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-03-15T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-03-15T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_DNS01 ;
    noria:changeRequestImpact noria:Application_CorporateInternetAccess ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty noria:Agent_DNSAdminTeam ;
    noria:changeRequestPilotParty noria:Agent_Alice ;
    noria:changeRequestActorParty noria:Agent_Alice .

noria:CR_CRM_DB_Migration_002 a noria:ChangeRequest ;
    rdfs:label "CRM Database Migration"@en, "Migration Base de Données CRM"@fr ;
    rdfs:comment "Migrate CRM database to a new, more powerful server."@en ;
    dcterms:created "2024-02-20T11:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-03-20T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-03-21T06:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Major> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/NetworkExtension> ; # Using NetworkExtension as a proxy for infrastructure change
    noria:changeRequestImpact noria:Resource_DB01 ;
    noria:changeRequestImpact noria:Application_InternalCRM ;
    noria:changeRequestOutageDuration "PT8H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty noria:Agent_AppSupportTeam ;
    noria:changeRequestPilotParty noria:Agent_Bob ;
    noria:changeRequestActorParty noria:Agent_Bob .

# --- Operation Plans (noria:OperationPlan) ---
noria:OP_DNS_ServiceRestart a noria:OperationPlan ;
    rdfs:label "DNS Service Restart Procedure"@en, "Procédure de Redémarrage Service DNS"@fr ;
    rdfs:comment "Standard operating procedure for restarting the DNS service on a server."@en ;
    skos:example "Steps include checking service status, attempting graceful restart, forced restart if necessary, and post-restart verification."@en .

noria:OP_RouterInterfaceTroubleshoot a noria:OperationPlan ;
    rdfs:label "Router Interface Troubleshooting Guide"@en, "Guide de Dépannage Interface Routeur"@fr ;
    rdfs:comment "Procedure to diagnose and resolve issues with router interfaces."@en ;
    skos:example "Steps include checking physical connection, interface configuration, adjacent device status, and cable replacement."@en .

# --- Action Pre/Post Conditions ---
noria:APC_DNS_ServiceDown a noria:ActionPreCondition ;
    rdfs:label "DNS Service Down Pre-Condition"@en ;
    rdfs:comment "Condition: DNS service is not running or unresponsive."@en ;
    noria:operationPlanPreCondition noria:OP_DNS_ServiceRestart .

noria:APOC_DNS_ServiceUp a noria:ActionPostCondition ;
    rdfs:label "DNS Service Up Post-Condition"@en ;
    rdfs:comment "Expected outcome: DNS service is running and responding to queries."@en ;
    noria:operationPlanPostCondition noria:OP_DNS_ServiceRestart .

noria:APC_RouterInterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Router Interface Down Pre-Condition"@en ;
    rdfs:comment "Condition: Network interface operational status is 'down'."@en ;
    noria:operationPlanPreCondition noria:OP_RouterInterfaceTroubleshoot .

noria:APOC_RouterInterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Router Interface Up Post-Condition"@en ;
    rdfs:comment "Expected outcome: Network interface operational status is 'up'."@en ;
    noria:operationPlanPostCondition noria:OP_RouterInterfaceTroubleshoot .

