    rdfs:comment "Juniper compact, high-density universal routing platform."@en ;
    noria:productManufacturedBy <https://www.juniper.net> .

# --- Locations (bot:Site, noria:Room, noria:Locus) ---
noria:Site_ParisDC1 a bot:Site ;
    rdfs:label "Paris Data Center 1"@en, "Centre de Données Paris 1"@fr ;
    noria:siteId "PAR-DC1" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Site_LyonDC2 a bot:Site ;
    rdfs:label "Lyon Data Center 2"@en, "Centre de Données Lyon 2"@fr ;
    noria:siteId "LYN-DC2" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddressStreet "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room in Paris Data Center 1."@en ;
    bot:hasSpace noria:Site_ParisDC1 .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en, "Salle Réseau B"@fr ;
    rdfs:comment "Network equipment room in Lyon Data Center 2."@en ;
    bot:hasSpace noria:Site_LyonDC2 .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en, "Baie A1"@fr ;
    rdfs:comment "Location of critical DNS servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:containsZone noria:Room_ServerRoomA .

noria:Locus_RackB5 a noria:Locus ;
    rdfs:label "Rack B5"@en, "Baie B5"@fr ;
    rdfs:comment "Location of core network routers."@en ;
    noria:locusLine "B" ;
    noria:locusRow "5" ;
    bot:containsZone noria:Room_NetworkRoomB .

# --- Resources (noria:Resource) ---
noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en, "Serveur DNS d'Entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, located in Paris DC1."@en ;
    noria:resourceManagedBy noria:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://192.168.1.10> .

noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Application Server 01"@en, "Serveur d'Application Web 01"@fr ;
    rdfs:comment "Server hosting the main customer portal application."@en ;
    noria:resourceManagedBy noria:Agent_AppSupportTeam ;
    noria:resourceHostName "web01.app.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceForApplication noria:Application_CustomerPortal ;
    noria:resourceManagementIPAddress <http://10.0.0.50> .

noria:Resource_CoreRtr01 a noria:Resource ;
    rdfs:label "Core Router 01"@en, "Routeur Cœur 01"@fr ;
    rdfs:comment "Main core router in Paris DC1, handling inter-DC traffic."@en ;
    noria:resourceManagedBy noria:Agent_NOC ;
    noria:resourceHostName "corerouter01.example.com" ;
    noria:resourceProductModel noria:ProductModel_JuniperMX204 ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-06-20T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackB5 ;
    noria:resourceManagementIPAddress <http://172.16.0.1> .

noria:Resource_EdgeRtr02 a noria:Resource ;
    rdfs:label "Edge Router 02"@en, "Routeur de Bordure 02"@fr ;
    rdfs:comment "Edge router in Lyon DC2, connecting to external networks."@en ;
    noria:resourceManagedBy noria:Agent_NOC ;
    noria:resourceHostName "edgerouter02.example.com" ;
    noria:resourceProductModel noria:ProductModel_Cisco9300 ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-07-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackB5 ;
    noria:resourceManagementIPAddress <http://172.16.0.2> .

noria:Resource_DB01 a noria:Resource ;
    rdfs:label "Database Server 01"@en, "Serveur de Base de Données 01"@fr ;
    rdfs:comment "Database server for the internal CRM application."@en ;
    noria:resourceManagedBy noria:Agent_AppSupportTeam ;
    noria:resourceHostName "db01.crm.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-10T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceForApplication noria:Application_InternalCRM ;
    noria:resourceManagementIPAddress <http://10.0.1.10> .

# --- Network Interfaces (noria:NetworkInterface) ---
noria:NI_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en, "DNS01 Ethernet 0"@fr ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

