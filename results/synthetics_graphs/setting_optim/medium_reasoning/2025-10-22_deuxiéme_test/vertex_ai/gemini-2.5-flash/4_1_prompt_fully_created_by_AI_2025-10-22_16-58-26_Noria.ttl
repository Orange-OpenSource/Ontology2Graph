    noria:networkInterfaceConnects noria:NI_WebSrv01_Eth0 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_WebSrv01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_DB01 ;
    noria:resourceManagedBy noria:Agent_AppSupportTeam .

# --- Applications (noria:Application) ---
noria:Application_CorporateInternetAccess a noria:Application ;
    rdfs:label "Corporate Internet Access"@en, "Accès Internet d'Entreprise"@fr ;
    rdfs:comment "Provides internet connectivity for all corporate users."@en ;
