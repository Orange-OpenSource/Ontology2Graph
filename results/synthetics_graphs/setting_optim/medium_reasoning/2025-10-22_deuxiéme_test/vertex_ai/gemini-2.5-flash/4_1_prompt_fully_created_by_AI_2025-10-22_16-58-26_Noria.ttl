    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NI_EdgeRtr02_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "EdgeRtr02 GigabitEthernet 0/0/1"@en, "EdgeRtr02 GigabitEthernet 0/0/1"@fr ;
    rdfs:comment "Interface connecting Edge Router 02 to Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeRtr02 ;
