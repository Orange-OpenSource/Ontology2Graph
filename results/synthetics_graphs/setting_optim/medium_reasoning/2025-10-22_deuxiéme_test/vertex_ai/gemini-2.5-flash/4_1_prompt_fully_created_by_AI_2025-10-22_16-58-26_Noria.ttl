    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

# --- Network Links (noria:NetworkLink) ---
noria:NL_CoreRtr01_EdgeRtr02 a noria:NetworkLink ;
    rdfs:label "Link CoreRtr01 to EdgeRtr02"@en, "Lien CoreRtr01 vers EdgeRtr02"@fr ;
    rdfs:comment "High-speed link between core router in Paris and edge router in Lyon."@en ;
    noria:networkLinkId "NL-PAR-LYN-001" ;
    noria:networkLinkType "Fiber Optic"@en ;
    noria:networkLinkInstallationDate "2021-06-25T00:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NI_CoreRtr01_Gi0_0_1 ;
    noria:networkInterfaceConnects noria:NI_EdgeRtr02_Gi0_0_1 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRtr01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_EdgeRtr02 ;
    noria:resourceManagedBy noria:Agent_NOC .

noria:NL_WebSrv01_DB01 a noria:NetworkLink ;
    rdfs:label "Link WebSrv01 to DB01"@en, "Lien WebSrv01 vers DB01"@fr ;
