# Operation Plans (noria:OperationPlan)
# =============================================================================

<noria:OperationPlan/RouterFirmwareUpgradeProcedure> a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router firmware."@en ;
    noria:operationPlanPreCondition <noria:ActionPreCondition/BackupConfiguration> ;
    noria:operationPlanPostCondition <noria:ActionPostCondition/VerifyConnectivity> .

<noria:ActionPreCondition/BackupConfiguration> a noria:ActionPreCondition ;
    rdfs:label "Backup Configuration Pre-Condition"@en ;
    rdfs:comment "Ensure a full backup of the router configuration is performed before upgrade."@en .

<noria:ActionPostCondition/VerifyConnectivity> a noria:ActionPostCondition ;
    rdfs:label "Verify Connectivity Post-Condition"@en ;
    rdfs:comment "Verify network connectivity and service reachability after router reboot."@en .

# =============================================================================
# Connectivity and Density Check
# =============================================================================
# All entities created are linked:
# - Agents: manage resources/apps, involved in TT/CR.
# - Product Models: linked to resources.
# - Locations: sites contain rooms, rooms contain loci, resources located at loci.
# - Resources: managed by agents, have product models, located at loci, have network interfaces, contribute to applications, can be cluster controllers.
# - Network Interfaces: part of resources, connect to network links.
# - Network Links: connect network interfaces, have termination resources.
# - Applications: have modules, resources contribute to them.
# - Application Modules: part of applications, managed by agents, part of services.
# - Services: composed of application modules.
# - Event Records: originate from resources/apps/agents, can trigger TTs.
# - Trouble Tickets: related to services/resources/parties, triggered by events, have notes.
# - Trouble Ticket Notes: part of trouble tickets, created by agents, can correlate to events.
# - Change Requests: impact resources/apps/services, initiated/piloted/acted by agents.
# - Operation Plans: have pre/post conditions, can be correlated to actions.
# - Action Pre/Post Conditions: linked to operation plans.
# This ensures a dense and connected graph.
