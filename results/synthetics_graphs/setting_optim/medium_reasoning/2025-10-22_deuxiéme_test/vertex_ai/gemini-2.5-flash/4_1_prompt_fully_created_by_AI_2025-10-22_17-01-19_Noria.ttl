# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# --- Domain specific ---
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit, foaf:Person)
# =============================================================================

<foaf:Agent/AdminTeamA> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Administration Team A"@en ;
    rdfs:label "Équipe d'Administration IT A"@fr ;
    rdfs:comment "Team responsible for managing core IT infrastructure and applications."@en ;
    noria:agentWorkingHours "8:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all requests."@en .

<foaf:Agent/SupportTeamB> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Support Team B"@en ;
    rdfs:label "Équipe de Support Opérations Réseau B"@fr ;
    rdfs:comment "Team providing L2/L3 support for network infrastructure."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical incidents, call the hotline directly."@en .

<foaf:Agent/JohnDoe> a foaf:Agent, foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Developer for WebAppService."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:holdsAccount <noria:CorporateUserIdentifier/jdoe> .

<noria:CorporateUserIdentifier/jdoe> a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en .

<foaf:Agent/JaneSmith> a foaf:Agent, foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Incident Manager for critical services."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:holdsAccount <noria:CorporateUserIdentifier/jsmith> .

<noria:CorporateUserIdentifier/jsmith> a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    foaf:accountName "jsmith"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

<noria:ProductModel/ServerModelX> a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R750"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy <org:Organization/Dell> .

<org:Organization/Dell> a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

<noria:ProductModel/RouterModelY> a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9800"@en ;
    rdfs:comment "Enterprise-grade network router model."@en ;
    noria:productManufacturedBy <org:Organization/Cisco> .

<org:Organization/Cisco> a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of network equipment."@en .

<noria:ProductModel/SwitchModelZ> a noria:ProductModel ;
    rdfs:label "Juniper EX4650"@en ;
    rdfs:comment "Data center access switch model."@en ;
    noria:productManufacturedBy <org:Organization/Juniper> .

<org:Organization/Juniper> a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "Manufacturer of network equipment."@en .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

<bot:Site/ParisDC> a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:label "Centre de Données de Paris"@fr ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

<noria:Room/ServerRoom01> a noria:Room ;
    rdfs:label "Server Room 01"@en ;
    rdfs:label "Salle Serveurs 01"@fr ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace <bot:Site/ParisDC> .

<noria:Locus/RackA1> a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "First rack in Server Room 01."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace <noria:Room/ServerRoom01> .

<bot:Site/LyonOffice> a bot:Site ;
    rdfs:label "Lyon Office"@en ;
    rdfs:label "Bureau de Lyon"@fr ;
    noria:siteId "OFF-LYN-02" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddressStreet "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

<noria:Room/NetworkRoom02> a noria:Room ;
    rdfs:label "Network Room 02"@en ;
    rdfs:label "Salle Réseau 02"@fr ;
    rdfs:comment "Network equipment room in Lyon Office."@en ;
    bot:hasSpace <bot:Site/LyonOffice> .

<noria:Locus/RackB2> a noria:Locus ;
    rdfs:label "Rack B2"@en ;
    rdfs:comment "Second rack in Network Room 02."@en ;
    noria:locusLine "B" ;
    noria:locusRow "2" ;
    bot:hasSpace <noria:Room/NetworkRoom02> .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

<noria:Resource/DNS_Server_01> a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:label "Serveur DNS d'Entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, critical infrastructure."@en ;
    noria:resourceManagedBy <foaf:Agent/AdminTeamA> ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceProductModel <noria:ProductModel/ServerModelX> ;
    noria:resourceType <kos/Resource/type/PhysicalServer> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <noria:Locus/RackA1> ;
    noria:resourceManagementIPAddress <observable:IPAddress/192.168.1.10> .

<observable:IPAddress/192.168.1.10> a observable:IPAddress ;
    rdfs:label "IP Address 192.168.1.10"@en ;
    observable:ipAddressValue "192.168.1.10" .

<noria:Resource/Web_Server_02> a noria:Resource ;
    rdfs:label "Corporate Web Server 02"@en ;
    rdfs:label "Serveur Web d'Entreprise 02"@fr ;
    rdfs:comment "Web server hosting internal applications."@en ;
    noria:resourceManagedBy <foaf:Agent/AdminTeamA> ;
    noria:resourceHostName "web02.corp.example.com" ;
    noria:resourceLogisticId "ASSET-WEB-002" ;
    noria:resourceProductModel <noria:ProductModel/ServerModelX> ;
    noria:resourceType <kos/Resource/type/PhysicalServer> ;
    noria:resourceSerialNumber "SN-WEB-002-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-20T11:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <noria:Locus/RackA1> ;
    noria:resourceManagementIPAddress <observable:IPAddress/192.168.1.11> .

<observable:IPAddress/192.168.1.11> a observable:IPAddress ;
    rdfs:label "IP Address 192.168.1.11"@en ;
    observable:ipAddressValue "192.168.1.11" .

<noria:Resource/Core_Router_01> a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:label "Routeur Cœur 01"@fr ;
    rdfs:comment "Main router for the corporate network, located in Lyon."@en ;
    noria:resourceManagedBy <foaf:Agent/SupportTeamB> ;
    noria:resourceHostName "router01.lyon.example.com" ;
    noria:resourceLogisticId "ASSET-RTR-001" ;
    noria:resourceProductModel <noria:ProductModel/RouterModelY> ;
    noria:resourceType <kos/Resource/type/NetworkRouter> ;
    noria:resourceSerialNumber "SN-RTR-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-10-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <noria:Locus/RackB2> ;
    noria:resourceManagementIPAddress <observable:IPAddress/10.0.0.1> .

<observable:IPAddress/10.0.0.1> a observable:IPAddress ;
    rdfs:label "IP Address 10.0.0.1"@en ;
    observable:ipAddressValue "10.0.0.1" .

<noria:Resource/Access_Switch_03> a noria:Resource ;
    rdfs:label "Access Switch 03"@en ;
    rdfs:label "Commutateur d'Accès 03"@fr ;
    rdfs:comment "Access layer switch in Lyon office."@en ;
    noria:resourceManagedBy <foaf:Agent/SupportTeamB> ;
    noria:resourceHostName "switch03.lyon.example.com" ;
    noria:resourceLogisticId "ASSET-SWT-003" ;
    noria:resourceProductModel <noria:ProductModel/SwitchModelZ> ;
    noria:resourceType <kos/Resource/type/NetworkSwitch> ;
    noria:resourceSerialNumber "SN-SWT-003-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-10T14:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <noria:Locus/RackB2> ;
    noria:resourceManagementIPAddress <observable:IPAddress/10.0.0.2> .

<observable:IPAddress/10.0.0.2> a observable:IPAddress ;
    rdfs:label "IP Address 10.0.0.2"@en ;
    observable:ipAddressValue "10.0.0.2" .

<noria:Resource/VirtualMachine_AppDB> a noria:Resource ;
    rdfs:label "Application Database VM"@en ;
    rdfs:label "VM Base de Données Application"@fr ;
    rdfs:comment "Virtual machine hosting the database for WebAppService."@en ;
    noria:resourceManagedBy <foaf:Agent/AdminTeamA> ;
    noria:resourceHostName "appdb-vm01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-01T08:00:00Z"^^xsd:dateTime ;
    noria:clusterController <noria:Resource/Web_Server_02> ; # Assuming Web_Server_02 acts as a host/controller for this VM
    noria:resourceManagementIPAddress <observable:IPAddress/172.16.0.5> .

<observable:IPAddress/172.16.0.5> a observable:IPAddress ;
    rdfs:label "IP Address 172.16.0.5"@en ;
    observable:ipAddressValue "172.16.0.5" .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

<noria:NetworkInterface/DNS_Server_01_Eth0> a noria:NetworkInterface ;
    rdfs:label "DNS Server 01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS Server 01."@en ;
    noria:networkInterfaceOf <noria:Resource/DNS_Server_01> ;
    noria:networkInterfaceDescription "Uplink to core network" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

<noria:NetworkInterface/Web_Server_02_Eth0> a noria:NetworkInterface ;
    rdfs:label "Web Server 02 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Web Server 02."@en ;
    noria:networkInterfaceOf <noria:Resource/Web_Server_02> ;
    noria:networkInterfaceDescription "Uplink to core network" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

<noria:NetworkInterface/Core_Router_01_GigE0_0> a noria:NetworkInterface ;
    rdfs:label "Core Router 01 GigE 0/0"@en ;
    rdfs:comment "Interface connecting to the data center network."@en ;
    noria:networkInterfaceOf <noria:Resource/Core_Router_01> ;
    noria:networkInterfaceDescription "Link to Paris DC" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

<noria:NetworkInterface/Core_Router_01_GigE0_1> a noria:NetworkInterface ;
    rdfs:label "Core Router 01 GigE 0/1"@en ;
    rdfs:comment "Interface connecting to the Lyon office access switch."@en ;
    noria:networkInterfaceOf <noria:Resource/Core_Router_01> ;
    noria:networkInterfaceDescription "Link to Access Switch 03" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 .

<noria:NetworkInterface/Access_Switch_03_Port1> a noria:NetworkInterface ;
    rdfs:label "Access Switch 03 Port 1"@en ;
    rdfs:comment "Uplink port to Core Router 01."@en ;
    noria:networkInterfaceOf <noria:Resource/Access_Switch_03> ;
    noria:networkInterfaceDescription "Uplink to router01" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

<noria:NetworkLink/Link_DNS_Router> a noria:NetworkLink ;
    rdfs:label "Link between DNS Server and Core Router"@en ;
    rdfs:comment "High-speed link connecting DNS Server 01 to Core Router 01."@en ;
    noria:networkLinkId "NL-DNS-RTR-001" ;
    noria:networkLinkTerminationResourceOrigin <noria:Resource/DNS_Server_01> ;
    noria:networkLinkTerminationResourceDestination <noria:Resource/Core_Router_01> ;
    noria:networkInterfaceConnects <noria:NetworkInterface/DNS_Server_01_Eth0> ;
    noria:networkInterfaceConnects <noria:NetworkInterface/Core_Router_01_GigE0_0> ;
    noria:networkLinkInstallationDate "2022-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic 10Gbps" .

<noria:NetworkLink/Link_Web_Router> a noria:NetworkLink ;
    rdfs:label "Link between Web Server and Core Router"@en ;
    rdfs:comment "High-speed link connecting Web Server 02 to Core Router 01."@en ;
    noria:networkLinkId "NL-WEB-RTR-002" ;
    noria:networkLinkTerminationResourceOrigin <noria:Resource/Web_Server_02> ;
    noria:networkLinkTerminationResourceDestination <noria:Resource/Core_Router_01> ;
    noria:networkInterfaceConnects <noria:NetworkInterface/Web_Server_02_Eth0> ;
    noria:networkInterfaceConnects <noria:NetworkInterface/Core_Router_01_GigE0_0> ;
    noria:networkLinkInstallationDate "2022-03-20T11:45:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic 10Gbps" .

<noria:NetworkLink/Link_Router_Switch> a noria:NetworkLink ;
    rdfs:label "Link between Core Router and Access Switch"@en ;
    rdfs:comment "Link connecting Core Router 01 to Access Switch 03."@en ;
    noria:networkLinkId "NL-RTR-SWT-003" ;
    noria:networkLinkTerminationResourceOrigin <noria:Resource/Core_Router_01> ;
    noria:networkLinkTerminationResourceDestination <noria:Resource/Access_Switch_03> ;
    noria:networkInterfaceConnects <noria:NetworkInterface/Core_Router_01_GigE0_1> ;
    noria:networkInterfaceConnects <noria:NetworkInterface/Access_Switch_03_Port1> ;
    noria:networkLinkInstallationDate "2022-05-10T14:15:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Copper Ethernet 1Gbps" .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

<noria:Application/CorporateDNS> a noria:Application ;
    rdfs:label "Corporate DNS Service"@en ;
    rdfs:label "Service DNS d'Entreprise"@fr ;
    rdfs:comment "Provides DNS resolution for all internal corporate services."@en ;
    noria:applicationModelIdentifier "CORP-DNS" ;
    noria:applicationNumericalIdentifier 101 ;
    noria:applicationShortIdentifier "CDNS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "DNS Management" ;
    noria:resourceForApplication <noria:Resource/DNS_Server_01> .

<noria:Application/WebAppService> a noria:Application ;
    rdfs:label "Internal Web Application Service"@en ;
    rdfs:label "Service d'Application Web Interne"@fr ;
    rdfs:comment "Hosts various internal web applications for employees."@en ;
    noria:applicationModelIdentifier "INT-WEBAPP" ;
    noria:applicationNumericalIdentifier 102 ;
    noria:applicationShortIdentifier "IWAS" ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Business Operations" ;
    noria:applicationFunctionalSubDomain "Employee Tools" ;
    noria:resourceForApplication <noria:Resource/Web_Server_02> ;
    noria:resourceForApplication <noria:Resource/VirtualMachine_AppDB> .

# =============================================================================
# Application Modules (noria:ApplicationModule)
# =============================================================================

<noria:ApplicationModule/CorporateDNS_Prod> a noria:ApplicationModule ;
    rdfs:label "Corporate DNS Production Module"@en ;
    rdfs:label "Module de Production DNS d'Entreprise"@fr ;
    rdfs:comment "Production instance of the Corporate DNS Service."@en ;
    noria:applicationModuleOf <noria:Application/CorporateDNS> ;
    noria:applicationModuleName "CORP-DNS_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleAdministrationTeam <foaf:Agent/AdminTeamA> ;
    noria:applicationModuleAdministrationLeader <foaf:Agent/JohnDoe> ;
    noria:applicationModuleSupportTeam <foaf:Agent/SupportTeamB> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

<noria:ApplicationModule/WebAppService_Dev> a noria:ApplicationModule ;
    rdfs:label "Web Application Service Development Module"@en ;
    rdfs:label "Module de Développement Service Application Web"@fr ;
    rdfs:comment "Development instance of the Internal Web Application Service."@en ;
    noria:applicationModuleOf <noria:Application/WebAppService> ;
    noria:applicationModuleName "INT-WEBAPP_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleAdministrationTeam <foaf:Agent/AdminTeamA> ;
    noria:applicationModuleAdministrationLeader <foaf:Agent/JohnDoe> ;
    noria:applicationModuleSupportTeam <foaf:Agent/AdminTeamA> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Bronze> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled false ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InDevelopment> .

# =============================================================================
# Services (noria:Service)
# =============================================================================

<noria:Service/InternetAccessService> a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:label "Service d'Accès Internet d'Entreprise"@fr ;
    rdfs:comment "End-to-end service providing internet access to all corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <noria:ApplicationModule/CorporateDNS_Prod> ; # Service composed of application modules
    seas:subSystemOf <noria:ApplicationModule/WebAppService_Dev> .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

<noria:EventRecord/DNS_Log_Critical_20240423_1000> a noria:EventRecord ;
    rdfs:label "Critical DNS Log Entry"@en ;
    rdfs:comment "Log entry indicating a critical failure on the DNS server."@en ;
    noria:loggingTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:logText "DNS service failed to start on dns01.corp.example.com. Error code 503."@en ;
    noria:logOriginatingManagedObject <noria:Resource/DNS_Server_01> ;
    noria:logOriginatingManagementSystem <noria:Application/CorporateDNS> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<noria:EventRecord/Router_Interface_Down_20240423_1005> a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Event indicating that an interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigE0/0 on router01.lyon.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject <noria:Resource/Core_Router_01> ;
    noria:logOriginatingManagementSystem <noria:Application/CorporateDNS> ; # Assuming DNS app monitors network
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

<noria:EventRecord/WebApp_Error_Log_20240423_1010> a noria:EventRecord ;
    rdfs:label "Web App Error Log"@en ;
    rdfs:comment "Error log from WebAppService_Dev indicating a database connection issue."@en ;
    noria:loggingTime "2024-04-23T10:10:00Z"^^xsd:dateTime ;
    noria:logText "Database connection failed for WebAppService_Dev. Check appdb-vm01."@en ;
    noria:logOriginatingManagedObject <noria:Resource/VirtualMachine_AppDB> ;
    noria:logOriginatingManagementSystem <noria:Application/WebAppService> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

<noria:EventRecord/User_Login_Failure_20240423_1015> a noria:EventRecord ;
    rdfs:label "User Login Failure"@en ;
    rdfs:comment "Log entry for a failed login attempt by John Doe."@en ;
    noria:loggingTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:logText "Failed login attempt for user 'jdoe' on web02.corp.example.com."@en ;
    noria:logOriginatingManagedObject <noria:Resource/Web_Server_02> ;
