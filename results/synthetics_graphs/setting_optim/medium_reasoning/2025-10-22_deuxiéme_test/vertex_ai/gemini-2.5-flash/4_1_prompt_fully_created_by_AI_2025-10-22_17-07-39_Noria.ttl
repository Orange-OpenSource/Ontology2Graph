# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

<OperationPlan/InterfaceTroubleshooting> a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network interface issues."@en ;
    skos:example "Steps include checking physical connection, interface status, logs, and bouncing the interface."@en ;
    noria:operationPlanPreCondition <ActionPreCondition/InterfaceDown> ;
    noria:operationPlanPostCondition <ActionPostCondition/InterfaceUp> .

<OperationPlan/DNS_Server_Restart> a noria:OperationPlan ;
    rdfs:label "DNS Server Restart Procedure"@en ;
    rdfs:comment "Procedure for safely restarting a corporate DNS server."@en ;
    skos:example "Steps include checking service dependencies, notifying stakeholders, performing restart, and verifying service."@en ;
    noria:operationPlanPreCondition <ActionPreCondition/DNS_Service_Degraded> ;
    noria:operationPlanPostCondition <ActionPostCondition/DNS_Service_Restored> .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

<ActionPreCondition/InterfaceDown> a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: A network interface's operational status is 'down'."@en .

<ActionPostCondition/InterfaceUp> a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Expected outcome: The network interface's operational status is 'up' and traffic is flowing."@en .

<ActionPreCondition/DNS_Service_Degraded> a noria:ActionPreCondition ;
    rdfs:label "DNS Service Degraded"@en ;
    rdfs:comment "Condition: DNS queries are failing or experiencing high latency."@en .

<ActionPostCondition/DNS_Service_Restored> a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Expected outcome: DNS queries are successful and latency is within normal limits."@en .

# =============================================================================
# Connectivity and Density Check
# =============================================================================
# All entities created are linked to at least one other entity using NORIA properties.
# - Agents linked to Resources, ApplicationModules, TroubleTickets, ChangeRequests.
# - ProductModels linked to Resources.
# - Locations (Site, Room, Locus) linked to each other and to Resources.
# - Resources linked to Agents, ProductModels, Locations, NetworkInterfaces, Applications, EventRecords.
# - NetworkInterfaces linked to Resources and NetworkLinks.
# - NetworkLinks linked to NetworkInterfaces and Resources.
# - Applications linked to Resources, ApplicationModules, Services.
# - ApplicationModules linked to Applications, Agents, Services.
# - Services linked to ApplicationModules.
# - EventRecords linked to Resources, Applications, Agents, TroubleTickets, OperationPlans.
# - TroubleTickets linked to Services, Resources, Agents, EventRecords, TroubleTicketNotes.
# - TroubleTicketNotes linked to TroubleTickets, Agents, EventRecords.
# - ChangeRequests linked to Resources, Applications, Agents.
# - OperationPlans linked to ActionPreCondition, ActionPostCondition.
# - ActionPreCondition/PostCondition linked to OperationPlans.
# The graph is dense with various types of relationships reflecting IT infrastructure and incident management.
# No 'ldp' prefix used.
