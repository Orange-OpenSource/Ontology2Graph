# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

<event/DNSServerCPUSpike> a noria:EventRecord ;
    rdfs:label "DNS Server CPU Spike Alert"@en, "Alerte Pic CPU Serveur DNS"@fr ;
    rdfs:comment "High CPU utilization detected on DNS Server 01."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/DNSServer01> ;
    noria:logOriginatingManagementSystem <application/InternalMonitoringSystem> ;
    noria:logText "CPU usage on dns01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

<event/RouterInterfaceDown> a noria:EventRecord ;
    rdfs:label "Core Router Interface Down"@en, "Interface Routeur Cœur Hors Service"@fr ;
    rdfs:comment "Network interface ge-0/0/1 on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T10:15:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/CoreRouter01> ;
    noria:logOriginatingManagementSystem <application/InternalMonitoringSystem> ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<event/CRMLoginFailure> a noria:EventRecord ;
    rdfs:label "CRM Login Failure Alert"@en, "Alerte Échec Connexion GRC"@fr ;
    rdfs:comment "Multiple failed login attempts on CRM application."@en ;
    noria:loggingTime "2024-04-20T10:20:10Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <application/CRM> ;
    noria:logOriginatingManagementSystem <application/InternalMonitoringSystem> ;
    noria:logText "User 'jdoe' failed to login 5 times in 1 minute to CRM-DEV."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> ;
    noria:logOriginatingAgent <agent/SecurityTeam> . # Security team is notified/involved

<event/FirewallPolicyChange> a noria:EventRecord ;
    rdfs:label "Firewall Policy Change Log"@en, "Journal Modification Politique Pare-feu"@fr ;
    rdfs:comment "Configuration change detected on Firewall 01."@en ;
    noria:loggingTime "2024-04-19T15:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Firewall01> ;
    noria:logOriginatingManagementSystem <application/InternalMonitoringSystem> ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by Alice Smith (10.0.1.50)."@en ;
    noria:logOriginatingAgent <agent/AliceSmith> .

