# =============================================================================

<troubleticketnote/TT-20240420-001-Note01> a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis Note for TT-20240420-001"@en ;
    rdfs:comment "First note on DNS outage, confirming high CPU and network unreachability."@en ;
    dcterms:created "2024-04-20T10:35:00Z"^^xsd:dateTime ;
    dcterms:creator <agent/DNSAdminTeam> ;
    dcterms:isPartOf <troubleticket/TT-20240420-001> ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:description "Confirmed high CPU on dns01.corp.example.com. No ping response from core router. Investigating processes."@en ;
    dcterms:relation <event/DNSServerCPUSpike> .

<troubleticketnote/TT-20240420-001-Note02> a noria:TroubleTicketNote ;
    rdfs:label "Resolution Attempt Note for TT-20240420-001"@en ;
    rdfs:comment "Attempted to restart DNS service, CPU normalized, service restored."@en ;
    dcterms:created "2024-04-20T11:15:00Z"^^xsd:dateTime ;
    dcterms:creator <agent/DNSAdminTeam> ;
    dcterms:isPartOf <troubleticket/TT-20240420-001> ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:description "Restarted 'named' service. CPU usage dropped to 15%. DNS resolution confirmed working. Monitoring for stability."@en ;
    noria:troubleTicketNoteCorrelatedExecution <event/DNSServiceRestartLog> .

<event/DNSServiceRestartLog> a noria:EventRecord ;
    rdfs:label "DNS Service Restart Log"@en ;
    rdfs:comment "Log entry for the DNS service restart command."@en ;
    noria:loggingTime "2024-04-20T11:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/DNSServer01> ;
    noria:logOriginatingAgent <agent/DNSAdminTeam> ;
    noria:logText "Service 'named' restarted by admin user 'dns_admin'."@en .

