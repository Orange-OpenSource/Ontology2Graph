# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

<agent/DNSAdminTeam> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en, "Équipe d'Administration DNS"@fr ;
    rdfs:comment "Team responsible for corporate DNS server management and resolution."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

<agent/NetworkOpsCenter> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center (NOC)"@en, "Centre d'Opérations Réseau (COR)"@fr ;
    rdfs:comment "24/7 team monitoring network infrastructure and responding to incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Open a P1 ticket and call the NOC hotline for immediate attention."@en .

<agent/AppSupportTeam> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en, "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Submit a ticket through the internal portal for all application-related requests."@en .

<agent/SecurityTeam> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en, "Centre d'Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlert> ;
    noria:agentInstructions "Automated alerts are sent to the SIEM. For manual reporting, use the dedicated security incident portal."@en .

<agent/AliceSmith> a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+33123456789" ;
    noria:agentManagesResource <resource/CoreRouter01> ;
    noria:agentManagesResource <resource/Firewall01> .

<agent/BobJohnson> a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "+33987654321" ;
    noria:agentManagesResource <resource/WebServer01> ;
    noria:agentManagesResource <resource/DatabaseServer01> .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

<productmodel/DellPowerEdgeR740> a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model from Dell."@en ;
    noria:productManufacturedBy <org/DellTechnologies> .

<productmodel/CiscoCatalyst9000> a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9000 Series"@en ;
    rdfs:comment "Enterprise-class modular switch/router series."@en ;
    noria:productManufacturedBy <org/CiscoSystems> .

<productmodel/JuniperMXSeries> a noria:ProductModel ;
    rdfs:label "Juniper MX Series"@en ;
    rdfs:comment "Universal routing platform for service providers and enterprises."@en ;
    noria:productManufacturedBy <org/JuniperNetworks> .

<productmodel/HPProLiantDL380> a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10"@en ;
    rdfs:comment "Versatile 2U rack server for various workloads."@en ;
    noria:productManufacturedBy <org/HewlettPackardEnterprise> .

# =============================================================================
# Organizations (org:Organization)
# =============================================================================

<org/DellTechnologies> a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "American multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

<org/CiscoSystems> a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "American multinational technology conglomerate corporation that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

<org/JuniperNetworks> a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "American multinational corporation that develops and markets networking products, including routers, switches, network management software, network security products, and software-defined networking technology."@en .

<org/HewlettPackardEnterprise> a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise"@en ;
    rdfs:comment "American multinational enterprise information technology company based in Spring, Texas, United States. It is a business-focused organization with two divisions: Enterprise Group and Financial Services."@en .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

<site/ParisDC> a bot:Site ;
    rdfs:label "Paris Data Center"@en, "Centre de Données de Paris"@fr ;
    rdfs:comment "Primary data center for European operations."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

<room/ParisDC-A01> a noria:Room ;
    rdfs:label "Server Room A01"@en, "Salle Serveurs A01"@fr ;
    rdfs:comment "Main server room within Paris Data Center."@en ;
    bot:hasSpace <locus/ParisDC-A01-R01> ;
    bot:hasSpace <locus/ParisDC-A01-R02> .

<locus/ParisDC-A01-R01> a noria:Locus ;
    rdfs:label "Rack R01 in Server Room A01"@en, "Baie R01 dans Salle Serveurs A01"@fr ;
    rdfs:comment "Location of critical infrastructure servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "01" .

<locus/ParisDC-A01-R02> a noria:Locus ;
    rdfs:label "Rack R02 in Server Room A01"@en, "Baie R02 dans Salle Serveurs A01"@fr ;
    rdfs:comment "Location of network equipment."@en ;
    noria:locusLine "A" ;
    noria:locusRow "02" .

<site/LyonDC> a bot:Site ;
    rdfs:label "Lyon Data Center"@en, "Centre de Données de Lyon"@fr ;
    rdfs:comment "Secondary data center for disaster recovery and regional services."@en ;
    noria:siteId "DC-LYN-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

<room/LyonDC-B02> a noria:Room ;
    rdfs:label "Server Room B02"@en, "Salle Serveurs B02"@fr ;
    rdfs:comment "Virtualization and cloud infrastructure room in Lyon Data Center."@en ;
    bot:hasSpace <locus/LyonDC-B02-R03> .

<locus/LyonDC-B02-R03> a noria:Locus ;
    rdfs:label "Rack R03 in Server Room B02"@en, "Baie R03 dans Salle Serveurs B02"@fr ;
    rdfs:comment "Location of virtual machine hosts and load balancers."@en ;
    noria:locusLine "B" ;
    noria:locusRow "03" .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

<resource/DNSServer01> a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en, "Serveur DNS d'Entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network in Paris DC."@en ;
    noria:resourceManagedBy <agent/DNSAdminTeam> ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel <productmodel/DellPowerEdgeR740> ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <locus/ParisDC-A01-R01> ;
    noria:resourceManagementIPAddress <ip/10.0.0.10> .

<resource/WebServer01> a noria:Resource ;
    rdfs:label "Corporate Web Server 01"@en, "Serveur Web d'Entreprise 01"@fr ;
    rdfs:comment "Web server hosting internal applications."@en ;
    noria:resourceManagedBy <agent/AppSupportTeam> ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel <productmodel/HPProLiantDL380> ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB-01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <locus/ParisDC-A01-R01> ;
    noria:resourceForApplication <application/CorporateInternetAccess> ;
    noria:resourceManagementIPAddress <ip/10.0.0.20> .

<resource/DatabaseServer01> a noria:Resource ;
    rdfs:label "Corporate Database Server 01"@en, "Serveur de Base de Données d'Entreprise 01"@fr ;
    rdfs:comment "Database server for critical business applications."@en ;
    noria:resourceManagedBy <agent/AppSupportTeam> ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceProductModel <productmodel/DellPowerEdgeR740> ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DB-01-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-02-10T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <locus/ParisDC-A01-R01> ;
    noria:resourceForApplication <application/CRM> ;
    noria:resourceManagementIPAddress <ip/10.0.0.30> .

<resource/CoreRouter01> a noria:Resource ;
    rdfs:label "Core Router 01 (Paris)"@en, "Routeur Cœur 01 (Paris)"@fr ;
    rdfs:comment "Main router for Paris Data Center, connecting to WAN and other internal networks."@en ;
    noria:resourceManagedBy <agent/NetworkOpsCenter> ;
    noria:resourceHostName "cr01.paris.example.com" ;
    noria:resourceProductModel <productmodel/CiscoCatalyst9000> ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-CR-01-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-11-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <locus/ParisDC-A01-R02> ;
    noria:resourceManagementIPAddress <ip/10.0.1.1> .

<resource/Firewall01> a noria:Resource ;
    rdfs:label "Perimeter Firewall 01 (Paris)"@en, "Pare-feu Périmétrique 01 (Paris)"@fr ;
    rdfs:comment "Primary firewall protecting the Paris Data Center perimeter."@en ;
    noria:resourceManagedBy <agent/SecurityTeam> ;
    noria:resourceHostName "fw01.paris.example.com" ;
    noria:resourceProductModel <productmodel/JuniperMXSeries> ; # Using MX series as a firewall/router example
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-FW-01-JKL" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-12-01T13:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <locus/ParisDC-A01-R02> ;
    noria:resourceManagementIPAddress <ip/10.0.1.2> .

<resource/VirtualMachine01> a noria:Resource ;
    rdfs:label "Virtual Machine for Monitoring"@en, "Machine Virtuelle de Supervision"@fr ;
    rdfs:comment "Virtual machine hosting a component of the internal monitoring system."@en ;
    noria:resourceManagedBy <agent/AppSupportTeam> ;
    noria:resourceHostName "vm-mon01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceSerialNumber "VM-MON-01-MNO" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-20T08:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <locus/LyonDC-B02-R03> ;
    noria:resourceForApplication <application/InternalMonitoringSystem> ;
    noria:resourceManagementIPAddress <ip/10.1.0.10> .

<resource/LoadBalancer01> a noria:Resource ;
    rdfs:label "Application Load Balancer 01"@en, "Équilibreur de Charge Applicatif 01"@fr ;
    rdfs:comment "Load balancer distributing traffic to web servers."@en ;
    noria:resourceManagedBy <agent/NetworkOpsCenter> ;
    noria:resourceHostName "lb01.corp.example.com" ;
    noria:resourceProductModel <productmodel/HPProLiantDL380> ; # Representing a hardware load balancer
    noria:resourceType <kos/Resource/type/LoadBalancer> ;
    noria:resourceSerialNumber "SN-LB-01-PQR" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-10T16:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <locus/LyonDC-B02-R03> ;
    noria:resourceForApplication <application/CorporateInternetAccess> ;
    noria:resourceManagementIPAddress <ip/10.1.0.5> .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

<networkinterface/DNSServer01-eth0> a noria:NetworkInterface ;
    rdfs:label "DNS Server 01 Ethernet 0"@en, "Serveur DNS 01 Ethernet 0"@fr ;
    rdfs:comment "Primary network interface for DNS Server 01."@en ;
    noria:networkInterfaceOf <resource/DNSServer01> ;
    noria:networkInterfaceDescription "Management and DNS traffic interface."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

<networkinterface/CoreRouter01-ge001> a noria:NetworkInterface ;
    rdfs:label "Core Router 01 GigabitEthernet 0/0/1"@en, "Routeur Cœur 01 GigabitEthernet 0/0/1"@fr ;
    rdfs:comment "Interface connecting Core Router 01 to Firewall 01."@en ;
    noria:networkInterfaceOf <resource/CoreRouter01> ;
    noria:networkInterfaceDescription "Uplink to perimeter firewall."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

<networkinterface/Firewall01-portchannel10> a noria:NetworkInterface ;
    rdfs:label "Firewall 01 Port-Channel 10"@en, "Pare-feu 01 Port-Channel 10"@fr ;
    rdfs:comment "Aggregated interface connecting Firewall 01 to Core Router 01."@en ;
    noria:networkInterfaceOf <resource/Firewall01> ;
    noria:networkInterfaceDescription "Aggregated link from Core Router."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Aggregated> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

<networkinterface/WebServer01-eth0> a noria:NetworkInterface ;
    rdfs:label "Web Server 01 Ethernet 0"@en, "Serveur Web 01 Ethernet 0"@fr ;
    rdfs:comment "Primary network interface for Web Server 01."@en ;
    noria:networkInterfaceOf <resource/WebServer01> ;
    noria:networkInterfaceDescription "Interface for HTTP/HTTPS traffic."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

<networkinterface/DatabaseServer01-eth0> a noria:NetworkInterface ;
    rdfs:label "Database Server 01 Ethernet 0"@en, "Serveur DB 01 Ethernet 0"@fr ;
    rdfs:comment "Primary network interface for Database Server 01."@en ;
    noria:networkInterfaceOf <resource/DatabaseServer01> ;
    noria:networkInterfaceDescription "Interface for database traffic."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

<networkinterface/VirtualMachine01-eth0> a noria:NetworkInterface ;
    rdfs:label "VM Monitoring Ethernet 0"@en, "VM Supervision Ethernet 0"@fr ;
    rdfs:comment "Network interface for the monitoring virtual machine."@en ;
    noria:networkInterfaceOf <resource/VirtualMachine01> ;
    noria:networkInterfaceDescription "Interface for collecting monitoring data."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Virtual> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

<networkinterface/LoadBalancer01-eth0> a noria:NetworkInterface ;
    rdfs:label "Load Balancer 01 Ethernet 0"@en, "Équilibreur de Charge 01 Ethernet 0"@fr ;
    rdfs:comment "External facing interface for the load balancer."@en ;
    noria:networkInterfaceOf <resource/LoadBalancer01> ;
    noria:networkInterfaceDescription "Public facing interface."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

<networklink/CoreRouter01-Firewall01> a noria:NetworkLink ;
    rdfs:label "Link Core Router 01 to Firewall 01"@en, "Lien Routeur Cœur 01 vers Pare-feu 01"@fr ;
    rdfs:comment "High-speed link between core router and perimeter firewall."@en ;
    noria:networkLinkId "NL-CR01-FW01-001" ;
    noria:networkLinkTerminationResourceOrigin <resource/CoreRouter01> ;
    noria:networkLinkTerminationResourceDestination <resource/Firewall01> ;
    noria:networkInterfaceConnects <networkinterface/CoreRouter01-ge001> ;
    noria:networkInterfaceConnects <networkinterface/Firewall01-portchannel10> ;
    noria:networkLinkInstallationDate "2021-12-01T13:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic 10Gbps" .

<networklink/DNSServer01-CoreRouter01> a noria:NetworkLink ;
    rdfs:label "Link DNS Server 01 to Core Router 01"@en, "Lien Serveur DNS 01 vers Routeur Cœur 01"@fr ;
    rdfs:comment "Internal network link for DNS traffic."@en ;
    noria:networkLinkId "NL-DNS01-CR01-001" ;
    noria:networkLinkTerminationResourceOrigin <resource/DNSServer01> ;
    noria:networkLinkTerminationResourceDestination <resource/CoreRouter01> ;
    noria:networkInterfaceConnects <networkinterface/DNSServer01-eth0> ;
    noria:networkInterfaceConnects <networkinterface/CoreRouter01-ge001> ; # Simplified, assuming a logical connection
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 1Gbps" .

<networklink/WebServer01-LoadBalancer01> a noria:NetworkLink ;
    rdfs:label "Link Web Server 01 to Load Balancer 01"@en, "Lien Serveur Web 01 vers Équilibreur de Charge 01"@fr ;
    rdfs:comment "Internal link for web traffic from load balancer to web server."@en ;
    noria:networkLinkId "NL-WEB01-LB01-001" ;
    noria:networkLinkTerminationResourceOrigin <resource/LoadBalancer01> ;
    noria:networkLinkTerminationResourceDestination <resource/WebServer01> ;
    noria:networkInterfaceConnects <networkinterface/LoadBalancer01-eth0> ; # Simplified, assuming a logical connection
    noria:networkInterfaceConnects <networkinterface/WebServer01-eth0> ;
    noria:networkLinkInstallationDate "2022-05-10T16:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

<application/CorporateInternetAccess> a noria:Application ;
    rdfs:label "Corporate Internet Access"@en, "Accès Internet d'Entreprise"@fr ;
    rdfs:comment "Provides internet connectivity for all corporate users and services."@en ;
    noria:applicationModelIdentifier "CIA-APP" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CIA" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Service Development, Management and Operations" ;
    noria:applicationFunctionalSubDomain "Network Management" .

<application/CRM> a noria:Application ;
    rdfs:label "Customer Relationship Management (CRM)"@en, "Gestion de la Relation Client (GRC)"@fr ;
    rdfs:comment "System for managing customer interactions and data."@en ;
    noria:applicationModelIdentifier "CRM-APP" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType <kos/application/type/business> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
