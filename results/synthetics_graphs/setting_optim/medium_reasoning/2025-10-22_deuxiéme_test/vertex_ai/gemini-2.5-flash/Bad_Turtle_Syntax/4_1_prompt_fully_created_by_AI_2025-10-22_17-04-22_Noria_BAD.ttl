:DocAttach_NetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Network Diagram v2.1"@en ;
    rdfs:comment "Attached network diagram relevant to the router link down incident."@en ;
    dcterms:created "2024-04-20T09:15:00Z"^^xsd:dateTime ;
