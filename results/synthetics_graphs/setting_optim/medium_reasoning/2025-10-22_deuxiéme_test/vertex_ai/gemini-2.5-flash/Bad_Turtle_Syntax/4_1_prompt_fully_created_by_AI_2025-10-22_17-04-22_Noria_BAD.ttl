# =============================================================================
# Locations
# =============================================================================

:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en, "Centre de Données de Paris"@fr ;
    noria:siteId "PAR-DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within Paris Data Center."@en ;
    bot:hasSpace :Site_ParisDC .

:Locus_RackA1_U10 a noria:Locus ;
    rdfs:label "Rack A1, Unit 10"@en ;
    rdfs:comment "Specific location for a server in Rack A1, unit 10."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "10" ;
    bot:containsZone :Room_ServerRoomA .

:Locus_RackA1_U11 a noria:Locus ;
    rdfs:label "Rack A1, Unit 11"@en ;
    rdfs:comment "Specific location for a server in Rack A1, unit 11."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "11" ;
    bot:containsZone :Room_ServerRoomA .

:Locus_RackB2_U5 a noria:Locus ;
    rdfs:label "Rack B2, Unit 5"@en ;
    rdfs:comment "Specific location for a network device in Rack B2, unit 5."@en ;
    noria:locusLine "B2" ;
    noria:locusRow "5" ;
    bot:containsZone :Room_ServerRoomA .

