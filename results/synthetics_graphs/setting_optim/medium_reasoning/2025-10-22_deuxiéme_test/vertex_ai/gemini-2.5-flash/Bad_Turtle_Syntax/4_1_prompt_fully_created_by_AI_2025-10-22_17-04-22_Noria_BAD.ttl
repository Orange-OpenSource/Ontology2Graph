# =============================================================================
# Additional Connectivity and Density
# =============================================================================

# Link DNS server to its application
:Resource_DNS01 noria:resourceForApplication :App_CorpDNS .

# Link Web Server to its application
:Resource_WebSrv01 noria:resourceForApplication :App_WebApp .

# Link Firewall to its application (if it's considered part of a security application)
:Resource_Firewall01 noria:resourceForApplication :App_Monitoring . # Firewall is monitored by NMS

# Link Application Modules to their support teams
:AppMod_CorpDNS_Prod noria:applicationModuleSupportLeader :Agent_JohnDoe .
:AppMod_WebApp_Prod noria:applicationModuleSupportLeader :Agent_JaneSmith .

# Example of an EventRecord being mitigated by a TroubleTicket (or a procedure within it)
:Event_DNS_Down noria:alarmMitigatedBy :TT_DNS_Outage .

# Example of a TroubleTicketNote correlated with an execution (e.g., a command run)
# This would typically involve pep:ProcedureExecution instances, but for simplicity,
# we can link it to a conceptual execution container.
:TTNote_DNS_Investigation noria:troubleTicketNoteCorrelatedExecution :OpPlan_RestartDNS .

# Example of a resource's virtual server status
:Resource_WebSrv01 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

# Example of network interface optical power readings
:NetIF_Firewall01_Ext noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

