:CR_Firewall_RuleUpdate a noria:ChangeRequest ;
    rdfs:label "Firewall Rule Update for New Application"@en, "Mise à Jour Règle Pare-feu Nouvelle Application"@fr ;
    rdfs:comment "Change request to add new firewall rules for an upcoming application deployment."@en ;
    dcterms:created "2024-04-18T10:00:00Z"^^xsd:dateTime ;
    dcterms:description "Open ports 8080 and 8443 from internal network to web02.app.example.com."@en ;
    noria:changeRequestPlannedStartTime "2024-04-25T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-25T23:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/NetworkExtension> ;
    noria:changeRequestImpact :Resource_Firewall01 ;
    noria:changeRequestOutageDuration "PT0H0M0S"^^xsd:duration ; # No outage expected
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/FirewallRuleChange> ;
    noria:changeRequestInitiatorParty :Agent_JohnDoe ;
    noria:changeRequestPilotParty :Agent_SecurityTeam ;
    noria:changeRequestActorParty :Agent_SecurityTeam ;
    noria:changeRequestIsRegulated true ;
    noria:documentHRef "https://itsm.example.com/cr/FW-20240418-001" ;
    noria:documentExternalId "CR-20240418-001" ;
    noria:documentStatusHistory :Event_CR_Approved .

:CR_Router_OSUpgrade a noria:ChangeRequest ;
    rdfs:label "Core Router OS Upgrade"@en, "Mise à Jour OS Routeur Cœur"@fr ;
    rdfs:comment "Scheduled OS upgrade for Core Router 01 to apply security patches."@en ;
    dcterms:created "2024-04-15T14:00:00Z"^^xsd:dateTime ;
    dcterms:description "Upgrade Cisco IOS-XE on router-core01 to version 17.6.3."@en ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Major> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact :Resource_RouterCore01 ;
    noria:changeRequestOutageDuration "PT0H30M0S"^^xsd:duration ; # 30 minutes outage expected
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty :Agent_NetworkOps ;
    noria:changeRequestPilotParty :Agent_NetworkOps ;
    noria:changeRequestActorParty :Agent_NetworkOps ;
    noria:changeRequestIsRegulated true ;
    noria:documentHRef "https://itsm.example.com/cr/RTR-20240415-002" ;
    noria:documentExternalId "CR-20240415-002" .

