# =============================================================================
# Services
# =============================================================================

:Service_InternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en, "Service Accès Internet Entreprise"@fr ;
    rdfs:comment "End-to-end service providing internet connectivity to corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :App_CorpDNS, :App_Monitoring, :Resource_Firewall01, :Resource_RouterCore01 .

:Service_CustomerPortal a noria:Service ;
    rdfs:label "Customer Portal Service"@en, "Service Portail Client"@fr ;
    rdfs:comment "Aggregated service for customer self-service portal."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :AppMod_WebApp_Prod, :App_CorpDNS, :Resource_DB01 . # Assuming a DB resource exists

:Resource_DB01 a noria:Resource ;
    rdfs:label "Database Server 01"@en, "Serveur Base de Données 01"@fr ;
    rdfs:comment "Database server for the customer portal application."@en ;
    noria:resourceManagedBy :Agent_AppSupport ;
    noria:resourceHostName "db01.app.example.com" ;
    noria:resourceProductModel :ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/DatabaseServer> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceForApplication :App_WebApp .

# =============================================================================
# Event Records
# =============================================================================

:Event_DNS_Down a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Alert"@en ;
    rdfs:comment "Automated alert indicating primary DNS server is unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_DNS01 ;
    noria:logOriginatingManagementSystem :App_Monitoring ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN!"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction :OpPlan_RestartDNS .

:Event_Router_InterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Log"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem :App_Monitoring ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

:Event_WebSrv_HighCPU a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert for sustained high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem :App_Monitoring ;
    noria:logText "WARNING: CPU utilization on web01.app.example.com is 95% for 15 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

:Event_Firewall_Alert a noria:EventRecord ;
    rdfs:label "Firewall Security Alert"@en ;
    rdfs:comment "Security alert from firewall indicating suspicious activity."@en ;
    noria:loggingTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Firewall01 ;
    noria:logOriginatingManagementSystem :App_Monitoring ; # Or a SIEM system
    noria:logText "ALERT: Multiple failed login attempts from external IP 203.0.113.42"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logOriginatingAgent :Agent_SecurityTeam . # Security team is attributed as the source of the alert analysis

:Event_CR_Approved a noria:EventRecord ;
    rdfs:label "Change Request Approved Notification"@en ;
    rdfs:comment "System notification that a change request has been approved."@en ;
    noria:loggingTime "2024-04-19T15:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem :App_Monitoring ; # Assuming NMS also handles CR notifications
    noria:logOriginatingAgent :Agent_JohnDoe ;
    noria:logText "Change Request CR-20240419-001 approved by John Doe."@en .

# =============================================================================
# Operation Plans (Procedures)
# =============================================================================

:OpPlan_RestartDNS a noria:OperationPlan ;
    rdfs:label "Restart DNS Service Procedure"@en ;
    rdfs:comment "Standard operating procedure to restart the corporate DNS service."@en ;
    skos:example "Steps include checking service status, attempting graceful restart, force restart if necessary, and verifying resolution."@en ;
    noria:operationPlanPreCondition :PreCond_DNSUnreachable ;
    noria:operationPlanPostCondition :PostCond_DNSFunctional .

:PreCond_DNSUnreachable a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unreachable"@en ;
    rdfs:comment "Condition: DNS service is not responding to queries."@en .

:PostCond_DNSFunctional a noria:ActionPostCondition ;
    rdfs:label "DNS Service Functional"@en ;
    rdfs:comment "Expected outcome: DNS service is responding to queries and name resolution is successful."@en .

:OpPlan_InterfaceTroubleshoot a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Procedure to diagnose and resolve issues with a network interface."@en ;
    skos:example "Steps include checking cable, port status, interface configuration, and physical inspection."@en .

# =============================================================================
# Trouble Tickets
# =============================================================================

:TT_DNS_Outage a noria:TroubleTicket ;
    rdfs:label "Critical DNS Service Outage"@en, "Panne Critique Service DNS"@fr ;
    rdfs:comment "Incident reported due to complete outage of corporate DNS service."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Unidentified software crash on DNS01."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService :App_CorpDNS ;
    noria:troubleTicketRelatedResource :Resource_DNS01 ;
    noria:troubleTicketRelatedParty :Agent_DNSAdminTeam ;
    noria:troubleTicketTrigger :Event_DNS_Down ;
    noria:documentHRef "https://itsm.example.com/tt/DNS-20240420-001" ;
    noria:documentExternalId "INC-DNS-001" ;
    noria:troubleTicketImpacts :App_WebApp, :Service_InternetAccess .

:TT_Router_LinkDown a noria:TroubleTicket ;
    rdfs:label "Router Link Down Incident"@en, "Incident Lien Routeur Hors Service"@fr ;
    rdfs:comment "Incident reported for a network link going down on a core router."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "Zabbix" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/DowngradingEquipment> ;
    noria:troubleTicketCause "Physical cable fault on Gi0/0/1."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedResource :Resource_RouterCore01 ;
    noria:troubleTicketRelatedParty :Agent_NetworkOps ;
    noria:troubleTicketTrigger :Event_Router_InterfaceDown ;
    noria:documentHRef "https://itsm.example.com/tt/RTR-20240420-002" ;
    noria:documentExternalId "INC-RTR-002" ;
    noria:troubleTicketImpacts :Service_InternetAccess .

:TT_WebSrv_Perf a noria:TroubleTicket ;
    rdfs:label "Web Server Performance Degradation"@en, "Dégradation Performance Serveur Web"@fr ;
    rdfs:comment "Performance issue on the customer portal web server."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Minor> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P3> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/NoIntervention> ;
    noria:troubleTicketSupervisionTool "Dynatrace" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/CorruptedService> ;
    noria:troubleTicketCause "High CPU due to inefficient database queries."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T17:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService :AppMod_WebApp_Prod ;
    noria:troubleTicketRelatedResource :Resource_WebSrv01 ;
    noria:troubleTicketRelatedParty :Agent_AppSupport ;
    noria:troubleTicketTrigger :Event_WebSrv_HighCPU ;
    noria:documentHRef "https://itsm.example.com/tt/WEB-20240420-003" ;
    noria:documentExternalId "INC-WEB-003" ;
    noria:troubleTicketImpacts :Service_CustomerPortal .

# =============================================================================
# Trouble Ticket Notes
# =============================================================================

:TTNote_DNS_Investigation a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Investigation Note"@en ;
    rdfs:comment "Initial investigation steps for the DNS outage."@en ;
    dcterms:created "2024-04-20T09:10:00Z"^^xsd:dateTime ;
    dcterms:creator :Agent_JohnDoe ;
    dcterms:description "Checked server logs, no obvious errors. Attempted service restart via SSH, no response. Escalating to L2."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf :TT_DNS_Outage .

:TTNote_WebSrv_Restart a noria:TroubleTicketNote ;
    rdfs:label "Web Server Restart Note"@en ;
    rdfs:comment "Action taken to mitigate web server performance issue."@en ;
    dcterms:created "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    dcterms:creator :Agent_JaneSmith ;
    dcterms:description "Restarted Apache and Tomcat services. CPU usage dropped to 30%. Monitoring for recurrence."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:isPartOf :TT_WebSrv_Perf .

