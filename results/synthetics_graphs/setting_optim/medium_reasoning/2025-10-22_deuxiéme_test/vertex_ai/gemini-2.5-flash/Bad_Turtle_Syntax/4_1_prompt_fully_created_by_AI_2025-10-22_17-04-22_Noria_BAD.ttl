:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en, "Serveur DNS Entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, physical machine."@en ;
    noria:resourceManagedBy :Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_RackA1_U10 ;
    noria:resourceManagementIPAddress "10.0.0.10" .

:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en, "Routeur Cœur 01"@fr ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceManagedBy :Agent_NetworkOps ;
    noria:resourceHostName "router-core01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceLogisticId "ASSET-RTR-001" ;
    noria:resourceSerialNumber "SN-RTR01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_RackB2_U5 ;
    noria:resourceManagementIPAddress "10.0.0.254" .

:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Server 01"@en, "Serveur Web 01"@fr ;
    rdfs:comment "Virtual machine hosting the corporate web application."@en ;
    noria:resourceManagedBy :Agent_AppSupport ;
    noria:resourceHostName "web01.app.example.com" ;
    noria:resourceProductModel :ProductModel_VMwareESXi ; # The hypervisor model, not the VM itself
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceLogisticId "ASSET-VM-WEB01" ;
    noria:resourceSerialNumber "VM-WEB01-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-01T08:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_RackA1_U11 ; # Located on a host in this locus
    noria:resourceManagementIPAddress "172.16.1.10" ;
    noria:clusterController :Resource_VMHost01 . # Assuming VMHost01 is the actual host

:Resource_VMHost01 a noria:Resource ;
    rdfs:label "VMware ESXi Host 01"@en, "Hôte VMware ESXi 01"@fr ;
    rdfs:comment "Physical server hosting virtual machines."@en ;
    noria:resourceManagedBy :Agent_NetworkOps ; # Or a dedicated virtualization team
    noria:resourceHostName "vmhost01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Hypervisor> ;
    noria:resourceLogisticId "ASSET-HOST-001" ;
    noria:resourceSerialNumber "SN-HOST01-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-10T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_RackA1_U11 ;
    noria:resourceManagementIPAddress "10.0.0.20" .

:Resource_Firewall01 a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en, "Pare-feu Périmétrique 01"@fr ;
    rdfs:comment "Main firewall protecting the corporate network perimeter."@en ;
    noria:resourceManagedBy :Agent_SecurityTeam ;
    noria:resourceHostName "fw01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_PaloAltoFirewall ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceLogisticId "ASSET-FW-001" ;
    noria:resourceSerialNumber "SN-FW01-JKL" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-08-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_RackB2_U5 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

# =============================================================================
# Network Interfaces
# =============================================================================

:NetIF_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "dns01.corp.example.com:eth0"@en ;
    rdfs:comment "Ethernet interface for DNS server."@en ;
    noria:networkInterfaceOf :Resource_DNS01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Primary network interface for DNS services."@en .

:NetIF_RouterCore01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "router-core01.corp.example.com:GigabitEthernet0/0/1"@en ;
    rdfs:comment "Uplink interface from Core Router 01 to DNS server segment."@en ;
    noria:networkInterfaceOf :Resource_RouterCore01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Connects to DNS server subnet."@en .

:NetIF_RouterCore01_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "router-core01.corp.example.com:GigabitEthernet0/0/2"@en ;
    rdfs:comment "Uplink interface from Core Router 01 to Web Server segment."@en ;
    noria:networkInterfaceOf :Resource_RouterCore01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Connects to Web server subnet."@en .

:NetIF_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "web01.app.example.com:eth0"@en ;
    rdfs:comment "Virtual Ethernet interface for Web Server 01."@en ;
    noria:networkInterfaceOf :Resource_WebSrv01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceDescription "Primary network interface for web application."@en .

:NetIF_Firewall01_Ext a noria:NetworkInterface ;
    rdfs:label "fw01.corp.example.com:External"@en ;
    rdfs:comment "External interface of Firewall 01, connected to ISP."@en ;
    noria:networkInterfaceOf :Resource_Firewall01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "WAN uplink to internet."@en .

:NetIF_Firewall01_Int a noria:NetworkInterface ;
    rdfs:label "fw01.corp.example.com:Internal"@en ;
    rdfs:comment "Internal interface of Firewall 01, connected to corporate network."@en ;
    noria:networkInterfaceOf :Resource_Firewall01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "LAN downlink to core router."@en .

# =============================================================================
# Network Links
# =============================================================================

:NetLink_CoreToDNS a noria:NetworkLink ;
    rdfs:label "Link Core Router 01 to DNS 01"@en ;
    rdfs:comment "Physical link between Core Router 01 and DNS Server 01."@en ;
    noria:networkLinkId "NL-CR01-DNS01" ;
    noria:networkLinkTerminationResourceOrigin :Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination :Resource_DNS01 ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:networkInterfaceConnects :NetIF_RouterCore01_Gi0_0_1 ;
    noria:networkInterfaceConnects :NetIF_DNS01_Eth0 .

:NetLink_CoreToWeb a noria:NetworkLink ;
    rdfs:label "Link Core Router 01 to Web Server 01"@en ;
    rdfs:comment "Logical link between Core Router 01 and Web Server 01's virtual network."@en ;
    noria:networkLinkId "NL-CR01-WEB01" ;
    noria:networkLinkTerminationResourceOrigin :Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination :Resource_WebSrv01 ;
    noria:networkLinkInstallationDate "2023-05-01T08:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Virtual Ethernet" ;
    noria:networkInterfaceConnects :NetIF_RouterCore01_Gi0_0_2 ;
    noria:networkInterfaceConnects :NetIF_WebSrv01_Eth0 .

:NetLink_FirewallExt a noria:NetworkLink ;
    rdfs:label "Link Firewall 01 External to ISP"@en ;
    rdfs:comment "External link from Firewall 01 to Internet Service Provider."@en ;
    noria:networkLinkId "NL-FW01-EXT" ;
    noria:networkLinkTerminationResource :Resource_Firewall01 ; # One end is Firewall01
    noria:networkLinkInstallationDate "2022-08-01T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic WAN" ;
    noria:networkInterfaceConnects :NetIF_Firewall01_Ext .

:NetLink_FirewallInt a noria:NetworkLink ;
    rdfs:label "Link Firewall 01 Internal to Core Router 01"@en ;
    rdfs:comment "Internal link from Firewall 01 to Core Router 01."@en ;
    noria:networkLinkId "NL-FW01-INT" ;
    noria:networkLinkTerminationResourceOrigin :Resource_Firewall01 ;
    noria:networkLinkTerminationResourceDestination :Resource_RouterCore01 ;
    noria:networkLinkInstallationDate "2022-08-01T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:networkInterfaceConnects :NetIF_Firewall01_Int ;
    noria:networkInterfaceConnects :NetIF_RouterCore01_Gi0_0_2 . # Assuming Gi0/0/2 also connects to firewall for internal traffic

# =============================================================================
# Applications
# =============================================================================

:App_CorpDNS a noria:Application ;
    rdfs:label "Corporate DNS Service"@en, "Service DNS d'Entreprise"@fr ;
    rdfs:comment "Provides name resolution services for the entire corporate network."@en ;
    noria:applicationModelIdentifier "CORP-DNS" ;
    noria:applicationShortIdentifier "DNS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Infrastructure Services" ;
    noria:applicationFunctionalSubDomain "Network Services" ;
    noria:elementManagedBy :Agent_DNSAdminTeam .

:App_WebApp a noria:Application ;
    rdfs:label "Customer Portal Web Application"@en, "Application Web Portail Client"@fr ;
    rdfs:comment "Public-facing web application for customer interactions."@en ;
    noria:applicationModelIdentifier "CUST-PORTAL" ;
    noria:applicationShortIdentifier "CPORTAL" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Online Services" ;
    noria:elementManagedBy :Agent_AppSupport .

:App_Monitoring a noria:Application ;
    rdfs:label "Network Monitoring System"@en, "Système de Supervision Réseau"@fr ;
    rdfs:comment "Monitors the health and performance of network devices and services."@en ;
    noria:applicationModelIdentifier "NMS-PROD" ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Monitoring and Alerting" ;
    noria:elementManagedBy :Agent_NetworkOps .

# =============================================================================
# Application Modules
# =============================================================================

:AppMod_CorpDNS_Prod a noria:ApplicationModule ;
    rdfs:label "Corporate DNS Production Module"@en, "Module DNS Production Entreprise"@fr ;
    rdfs:comment "Production instance of the Corporate DNS Service."@en ;
    noria:applicationModuleOf :App_CorpDNS ;
