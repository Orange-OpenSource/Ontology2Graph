    dcterms:isPartOf :TT_Router_LinkDown ;
    dcterms:format "application/pdf" ;
    dcterms:identifier "NET-DIAG-V2.1.pdf" .

:DocAttach_FirewallConfig a noria:DocumentAttachment ;
