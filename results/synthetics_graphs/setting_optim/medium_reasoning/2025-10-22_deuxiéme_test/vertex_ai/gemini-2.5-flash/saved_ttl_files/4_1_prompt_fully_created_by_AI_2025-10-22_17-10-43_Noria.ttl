    noria:applicationModuleIdentifier "FRONTEND" ;
    noria:applicationModuleAdministrationTeam noria:Agent_AppSupportTeam ;
    noria:applicationModuleSupportTeam noria:Agent_AppSupportTeam ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Silver> ;
    noria:applicationModuleSlaLevelDate "2023-03-10T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled false .

# =============================================================================
# Services (noria:Service)
# =============================================================================

noria:Service_InternetConnectivity a noria:Service ;
    rdfs:label "Internet Connectivity Service"@en, "Service de Connectivité Internet"@fr ;
    rdfs:comment "End-to-end service providing internet access to the organization."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystem noria:ApplicationModule_CIA_Prod ;
    seas:subSystem noria:Resource_CoreRouter01, noria:Resource_EdgeRouter01, noria:Resource_PerimeterFirewall01 .

noria:Service_CustomerDataManagement a noria:Service ;
    rdfs:label "Customer Data Management Service"@en, "Service de Gestion des Données Clients"@fr ;
    rdfs:comment "Service encompassing customer portal and internal CRM for data management."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystem noria:ApplicationModule_CP_Backend, noria:ApplicationModule_CRM_Frontend ;
    seas:subSystem noria:Resource_WebServer01, noria:Resource_DBServer01 .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord_DNS_CPU_Spike a noria:EventRecord ;
    rdfs:label "DNS Server CPU Spike Alert"@en ;
    rdfs:comment "High CPU utilization detected on DNS server."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CPU usage on dns01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:alarmProposedRepairAction noria:OperationPlan_RestartDNSCache .

noria:EventRecord_CoreRouter_InterfaceDown a noria:EventRecord ;
    rdfs:label "Core Router Interface Down"@en ;
    rdfs:comment "Network interface Gi0/0/2 on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T10:15:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/2, changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_CheckPhysicalLink .

noria:EventRecord_Firewall_LoginFailure a noria:EventRecord ;
    rdfs:label "Firewall Admin Login Failure"@en ;
    rdfs:comment "Multiple failed login attempts on Perimeter Firewall 01 admin interface."@en ;
    noria:loggingTime "2024-04-20T10:20:15Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_PerimeterFirewall01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "Failed login attempt for user 'admin' from IP 192.168.1.100 on fw01.corp.example.com."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logOriginatingAgent noria:Agent_SecurityTeam . # Assuming security team is notified and logs this.

noria:EventRecord_CustomerPortal_Error a noria:EventRecord ;
    rdfs:label "Customer Portal Application Error"@en ;
    rdfs:comment "Repeated 500 Internal Server Errors on Customer Portal backend."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Application_CustomerPortal ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "Application error: java.lang.NullPointerException in CustomerService.java."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

noria:TroubleTicket_DNSOutage a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en, "Incident Panne Serveur DNS"@fr ;
    rdfs:comment "DNS server unreachable causing widespread internet access issues."@en ;
    dcterms:identifier "TT-20240420-001" ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_DNS_CPU_Spike ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "High CPU load leading to service unresponsiveness."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T11:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty noria:Agent_DNSAdminTeam, noria:Agent_NOC ;
    noria:troubleTicketRelatedService noria:Application_CorpInternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketImpacts noria:Application_CorpInternetAccess, noria:Resource_DNS01 ;
    noria:documentHRef "https://itsm.example.com/tt/TT-20240420-001" .

noria:TroubleTicket_CustomerPortalSlowdown a noria:TroubleTicket ;
    rdfs:label "Customer Portal Performance Degradation"@en, "Dégradation Performance Portail Client"@fr ;
    rdfs:comment "Customers reporting slow response times and occasional errors on the portal."@en ;
    dcterms:identifier "TT-20240420-002" ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketTrigger noria:EventRecord_CustomerPortal_Error ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "APM Tool" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/DowngradingEquipment> ;
    noria:troubleTicketCause "Database connection pool exhaustion."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty noria:Agent_AppSupportTeam ;
    noria:troubleTicketRelatedService noria:Application_CustomerPortal ;
    noria:troubleTicketRelatedResource noria:Resource_WebServer01, noria:Resource_DBServer01 ;
    noria:troubleTicketImpacts noria:Application_CustomerPortal, noria:Resource_WebServer01, noria:Resource_DBServer01 ;
    noria:documentHRef "https://itsm.example.com/tt/TT-20240420-002" .

# =============================================================================
# Trouble Ticket Notes (noria:TroubleTicketNote)
# =============================================================================

noria:TroubleTicketNote_DNS_Note1 a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage - Initial Diagnosis"@en ;
    rdfs:comment "Confirmed high CPU on dns01.corp.example.com. Attempting to restart DNS service."@en ;
    dcterms:created "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_Alice ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage .

noria:TroubleTicketNote_DNS_Note2 a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage - Resolution Attempt"@en ;
    rdfs:comment "Restarted BIND service, CPU normalized. Monitoring service availability."@en ;
    dcterms:created "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_Alice ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage ;
    noria:troubleTicketNoteCorrelatedExecution noria:EventRecord_DNS_ServiceRestart .

noria:EventRecord_DNS_ServiceRestart a noria:EventRecord ;
    rdfs:label "DNS Service Restart Log"@en ;
    rdfs:comment "Log entry for DNS service restart command execution."@en ;
    noria:loggingTime "2024-04-20T10:40:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingAgent noria:Agent_Alice ;
    noria:logText "Service 'bind9' restarted by user 'asmith'."@en .

