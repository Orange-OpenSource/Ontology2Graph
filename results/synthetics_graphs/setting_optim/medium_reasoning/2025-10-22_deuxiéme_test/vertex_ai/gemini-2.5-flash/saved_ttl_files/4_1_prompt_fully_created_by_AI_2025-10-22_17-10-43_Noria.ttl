# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for DNS Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_ServerLAN .

noria:NetworkInterface_WebServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebServer01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebServer01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_ServerLAN .

noria:NetworkInterface_CoreRouter01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 01 to Server LAN."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_ServerLAN .

noria:NetworkInterface_CoreRouter01_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet0/0/2"@en ;
    rdfs:comment "Interface connecting Core Router 01 to Edge Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_CoreEdgeLink .

noria:NetworkInterface_EdgeRouter01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "EdgeRouter01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface connecting Edge Router 01 to Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_CoreEdgeLink .

noria:NetworkInterface_EdgeRouter01_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "EdgeRouter01 GigabitEthernet0/0/2"@en ;
    rdfs:comment "Interface connecting Edge Router 01 to Perimeter Firewall 01."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_EdgeFirewallLink .

noria:NetworkInterface_PerimeterFirewall01_Eth0 a noria:NetworkInterface ;
    rdfs:label "PerimeterFirewall01 Ethernet 0"@en ;
    rdfs:comment "Interface connecting Perimeter Firewall 01 to Edge Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_PerimeterFirewall01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_EdgeFirewallLink .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NetworkLink_ServerLAN a noria:NetworkLink ;
    rdfs:label "Server LAN Link"@en, "Lien LAN Serveurs"@fr ;
    rdfs:comment "Local Area Network segment connecting servers to the core router."@en ;
    noria:networkLinkId "LAN-SERVER-01" ;
    noria:networkLinkType "Ethernet LAN" ;
    noria:networkLinkInstallationDate "2021-10-01T08:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent_NOC ;
    noria:networkLinkTerminationResource noria:Resource_DNS01, noria:Resource_WebServer01, noria:Resource_CoreRouter01 .

noria:NetworkLink_CoreEdgeLink a noria:NetworkLink ;
    rdfs:label "Core-Edge Router Link"@en, "Lien Routeur Cœur-Bordure"@fr ;
    rdfs:comment "High-speed link between core and edge routers."@en ;
    noria:networkLinkId "LINK-CR01-ER01" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2021-11-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent_NOC ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_EdgeRouter01 .

noria:NetworkLink_EdgeFirewallLink a noria:NetworkLink ;
    rdfs:label "Edge-Firewall Link"@en, "Lien Bordure-Pare-feu"@fr ;
    rdfs:comment "Link between edge router and perimeter firewall."@en ;
    noria:networkLinkId "LINK-ER01-FW01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-02-05T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent_SecurityTeam ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_EdgeRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_PerimeterFirewall01 .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

noria:Application_CorpInternetAccess a noria:Application ;
    rdfs:label "Corporate Internet Access"@en, "Accès Internet d'Entreprise"@fr ;
    rdfs:comment "Provides internet connectivity for all corporate users and services."@en ;
    noria:applicationModelIdentifier "CIA-APP" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CIA" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Internet Gateway Management" .

noria:Application_CustomerPortal a noria:Application ;
    rdfs:label "Customer Portal"@en, "Portail Client"@fr ;
    rdfs:comment "Web application allowing customers to manage their accounts and services."@en ;
    noria:applicationModelIdentifier "CUSTPORTAL-APP" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "CPORTAL" ;
    noria:applicationType <kos/application/type/customer-facing> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Self-Service Portal" .

noria:Application_InternalCRM a noria:Application ;
    rdfs:label "Internal CRM"@en, "CRM Interne"@fr ;
    rdfs:comment "Customer Relationship Management system for internal sales and support teams."@en ;
    noria:applicationModelIdentifier "CRM-APP" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "ICRM" ;
    noria:applicationType <kos/application/type/internal-business> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Sales and Support Operations" .

noria:Application_MonitoringSystem a noria:Application ;
    rdfs:label "Monitoring System"@en, "Système de Supervision"@fr ;
    rdfs:comment "System for collecting metrics, logs, and alerts from IT infrastructure."@en ;
    noria:applicationModelIdentifier "MONITOR-APP" ;
    noria:applicationNumericalIdentifier 1004 ;
    noria:applicationShortIdentifier "MONSYS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Performance and Event Management" .

