    noria:resourceManagedBy noria:Agent_AppSupportTeam ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-R740-WEB01" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_CustomerPortal ;
    noria:locatedAtLocus noria:Locus_Rack1 ;
    noria:resourceManagementIPAddress "10.0.0.20" .

noria:Resource_DBServer01 a noria:Resource ;
    rdfs:label "Database Server 01"@en, "Serveur Base de Données 01"@fr ;
    rdfs:comment "Backend database for Customer Portal and CRM."@en ;
    noria:resourceLogisticId "ASSET-DB-001" ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceManagedBy noria:Agent_AppSupportTeam ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-R740-DB01" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-05T11:00:00Z"^^xsd:dateTime ;
