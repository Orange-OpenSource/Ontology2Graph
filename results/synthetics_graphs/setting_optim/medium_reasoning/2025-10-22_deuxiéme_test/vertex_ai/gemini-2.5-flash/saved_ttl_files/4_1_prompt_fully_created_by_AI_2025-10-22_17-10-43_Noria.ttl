# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix org: <http://www.w3.org/ns/org#> .

# --- Domain specific ---
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix bot:  <https://w3id.org/bot#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

noria:Agent_DNSAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en, "Équipe d'Administration DNS"@fr ;
    rdfs:comment "Team responsible for corporate DNS server management and resolution."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for non-urgent issues, direct call for critical outages."@en .

noria:Agent_NOC a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en, "Centre d'Opérations Réseau"@fr ;
    rdfs:comment "24/7 team monitoring network infrastructure and responding to alerts."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Follow incident response procedures for network-related events."@en .

noria:Agent_AppSupportTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en, "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing level 2 support for business applications."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Escalate to L3 development team if issue persists after initial diagnosis."@en .

noria:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en, "Centre d'Opérations de Sécurité"@fr ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlert> ;
    noria:agentInstructions "Prioritize critical security alerts and follow established playbooks."@en .

noria:Agent_Alice a foaf:Agent ;
    rdfs:label "Alice Smith"@en, "Alice Dupont"@fr ;
    rdfs:comment "Individual IT administrator, member of DNS Admin Team."@en ;
    foaf:mbox "mailto:alice.smith@example.com" ;
    foaf:holdsAccount noria:CUid_Alice ;
    noria:agentManagesResource noria:Resource_DNS01 .

noria:CUid_Alice a noria:CorporateUserIdentifier ;
    rdfs:label "Alice's Corporate User ID"@en ;
    foaf:accountName "asmith" ;
    rdfs:comment "Corporate login for Alice Smith."@en .

noria:Agent_Bob a foaf:Agent ;
    rdfs:label "Bob Johnson"@en, "Bob Martin"@fr ;
    rdfs:comment "Individual network engineer, member of Network Operations Center."@en ;
    foaf:mbox "mailto:bob.johnson@example.com" ;
    foaf:holdsAccount noria:CUid_Bob ;
    noria:agentManagesResource noria:Resource_CoreRouter01 .

noria:CUid_Bob a noria:CorporateUserIdentifier ;
    rdfs:label "Bob's Corporate User ID"@en ;
    foaf:accountName "bjohnson" ;
    rdfs:comment "Corporate login for Bob Johnson."@en .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model commonly used for enterprise applications."@en ;
    noria:productManufacturedBy noria:Org_Dell .

noria:ProductModel_Cisco9300 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Cisco enterprise-class stackable access layer switch."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:ProductModel_PaloAltoPA500 a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-500"@en ;
    rdfs:comment "Next-generation firewall for enterprise perimeter security."@en ;
    noria:productManufacturedBy noria:Org_PaloAlto .

noria:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

noria:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

noria:Org_PaloAlto a org:Organization ;
    rdfs:label "Palo Alto Networks"@en ;
    rdfs:comment "Manufacturer of cybersecurity hardware and software."@en .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

noria:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en, "Centre de Données de Paris"@fr ;
    noria:siteId "PARIS-DC-01" ;
    noria:siteType "Data Center"@en ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" ;
    rdfs:comment "Primary data center for European operations."@en .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within Paris Data Center."@en ;
    bot:hasSpace noria:Locus_Rack1, noria:Locus_Rack2 ;
    bot:hasElement noria:Resource_DNS01, noria:Resource_WebServer01 .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en, "Salle Réseau B"@fr ;
    rdfs:comment "Dedicated room for network equipment."@en ;
    bot:hasSpace noria:Locus_Rack3 ;
    bot:hasElement noria:Resource_CoreRouter01, noria:Resource_PerimeterFirewall01 .

noria:Locus_Rack1 a noria:Locus ;
    rdfs:label "Rack 1, Server Room A"@en ;
    rdfs:comment "Location of critical servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

noria:Locus_Rack2 a noria:Locus ;
    rdfs:label "Rack 2, Server Room A"@en ;
    rdfs:comment "Location of database servers and virtual hosts."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" .

noria:Locus_Rack3 a noria:Locus ;
    rdfs:label "Rack 3, Network Room B"@en ;
    rdfs:comment "Location of core network devices."@en ;
    noria:locusLine "B" ;
    noria:locusRow "3" .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en, "Serveur DNS d'Entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, critical infrastructure."@en ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceManagedBy noria:Agent_DNSAdminTeam ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-R740-DNS01" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_CorpInternetAccess ;
    noria:locatedAtLocus noria:Locus_Rack1 ;
    noria:resourceManagementIPAddress "10.0.0.10" .

noria:Resource_WebServer01 a noria:Resource ;
    rdfs:label "Web Server 01"@en, "Serveur Web 01"@fr ;
