# Document Attachments (noria:DocumentAttachment)
# =============================================================================

noria:DocumentAttachment_NetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Network Diagram - Paris DC"@en ;
    rdfs:comment "PDF document showing the network topology of the Paris Data Center."@en ;
    dcterms:created "2023-10-01T10:00:00Z"^^xsd:dateTime ;
    dcterms:format "application/pdf" ;
    dcterms:source "https://docs.example.com/network_diagram_paris_dc.pdf" ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage, noria:ChangeRequest_FirewallRuleUpdate .

noria:DocumentAttachment_ServerLogExtract a noria:DocumentAttachment ;
    rdfs:label "DNS Server Log Extract"@en ;
    rdfs:comment "Text file containing relevant log entries from the DNS server during the incident."@en ;
    dcterms:created "2024-04-20T10:50:00Z"^^xsd:dateTime ;
    dcterms:format "text/plain" ;
    dcterms:source "https://logs.example.com/dns01_logs_20240420.txt" ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage .
