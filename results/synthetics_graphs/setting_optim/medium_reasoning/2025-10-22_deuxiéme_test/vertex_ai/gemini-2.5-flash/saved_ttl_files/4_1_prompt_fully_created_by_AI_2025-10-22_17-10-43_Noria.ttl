# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OperationPlan_RestartDNSCache a noria:OperationPlan ;
    rdfs:label "Restart DNS Cache Procedure"@en ;
    rdfs:comment "Standard operating procedure to restart DNS caching service on a server."@en ;
    skos:example "Steps: 1. SSH to server. 2. Check BIND status. 3. Restart BIND service. 4. Verify DNS resolution."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_HighDNSServerCPU ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSServiceRestored .

noria:OperationPlan_CheckPhysicalLink a noria:OperationPlan ;
    rdfs:label "Check Physical Network Link Procedure"@en ;
    rdfs:comment "Procedure to diagnose and resolve physical layer network link issues."@en ;
    skos:example "Steps: 1. Check cable integrity. 2. Verify SFP/transceiver status. 3. Check port configuration. 4. Reseat cable/SFP."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_NetworkInterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_NetworkInterfaceUp .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:ActionPreCondition_HighDNSServerCPU a noria:ActionPreCondition ;
    rdfs:label "High DNS Server CPU Pre-Condition"@en ;
    rdfs:comment "Condition where DNS server CPU utilization is consistently high, indicating potential service degradation."@en .

noria:ActionPostCondition_DNSServiceRestored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored Post-Condition"@en ;
    rdfs:comment "Condition where DNS service is responsive and CPU utilization is within normal limits."@en .

noria:ActionPreCondition_NetworkInterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Pre-Condition"@en ;
    rdfs:comment "Condition where a critical network interface reports an operational 'down' status."@en .

noria:ActionPostCondition_NetworkInterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up Post-Condition"@en ;
    rdfs:comment "Condition where the previously down network interface reports an operational 'up' status."@en .

