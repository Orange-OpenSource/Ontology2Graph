# --- Network Links ---
<networklink/Uplink_ISP_A> a noria:NetworkLink ;
    rdfs:label "Uplink to ISP A"@en ;
    rdfs:comment "Primary internet uplink via ISP A."@en ;
    noria:networkLinkId "NL-ISP-A-001" ;
    noria:networkLinkTerminationResourceOrigin <resource/Router_Core01> ;
    noria:networkLinkInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic" ;
    noria:resourceManagedBy <agent/Team_NetworkOps> .

<networklink/Core_Access_Link> a noria:NetworkLink ;
    rdfs:label "Core-Access Link"@en ;
    rdfs:comment "Internal link between Core Router 01 and Access Switch 01."@en ;
    noria:networkLinkId "NL-CORE-ACC-001" ;
    noria:networkLinkTerminationResourceOrigin <resource/Router_Core01> ;
    noria:networkLinkTerminationResourceDestination <resource/Switch_Access01> ;
    noria:networkLinkInstallationDate "2022-04-01T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:resourceManagedBy <agent/Team_NetworkOps> .

<networkinterface/Router_Core01_GE0_0_0> noria:networkInterfaceConnects <networklink/Uplink_ISP_A> .
<networkinterface/Router_Core01_GE0_0_1> noria:networkInterfaceConnects <networklink/Core_Access_Link> .
<networkinterface/Switch_Access01_Port1> noria:networkInterfaceConnects <networklink/Core_Access_Link> .

# --- Applications ---
<application/CorporateWebsite> a noria:Application ;
    rdfs:label "Corporate Website"@en, "Site Web Corporatif"@fr ;
    rdfs:comment "The official public website of the company."@en ;
    noria:applicationModelIdentifier "CORPWEB" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CW" ;
    noria:applicationType <kos/application/type/CustomerFacing> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Marketing and Sales" ;
    noria:applicationFunctionalSubDomain "Customer Engagement" .

<application/CRMSystem> a noria:Application ;
    rdfs:label "CRM System"@en, "Système CRM"@fr ;
    rdfs:comment "Customer Relationship Management system for sales and support."@en ;
    noria:applicationModelIdentifier "CRM" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType <kos/application/type/InternalBusiness> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Sales and Service" .

<application/MonitoringPlatform> a noria:Application ;
    rdfs:label "Monitoring Platform"@en, "Plateforme de Supervision"@fr ;
    rdfs:comment "Centralized platform for infrastructure and application monitoring."@en ;
    noria:applicationModelIdentifier "MONITOR" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "MON" ;
    noria:applicationType <kos/application/type/Infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "IT Operations" ;
    noria:applicationFunctionalSubDomain "Performance Management" .

# --- Application Modules ---
<applicationmodule/CorporateWebsite_Prod> a noria:ApplicationModule ;
    rdfs:label "Corporate Website Production Module"@en, "Module de Production Site Web Corporatif"@fr ;
    rdfs:comment "Production instance of the Corporate Website application."@en ;
    noria:applicationModuleOf <application/CorporateWebsite> ;
    noria:applicationModuleName "CORPWEB_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
