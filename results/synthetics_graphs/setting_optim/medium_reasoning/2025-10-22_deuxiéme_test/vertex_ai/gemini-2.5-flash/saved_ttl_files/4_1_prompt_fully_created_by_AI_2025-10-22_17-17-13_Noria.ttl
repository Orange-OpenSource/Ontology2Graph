    rdfs:label "Cisco Systems Inc."@en .

<org/DellTechnologies> a org:Organization ;
    rdfs:label "Dell Technologies"@en .

<org/JuniperNetworks> a org:Organization ;
    rdfs:label "Juniper Networks"@en .

# --- Locations ---
<site/Paris_DC01> a bot:Site ;
    rdfs:label "Paris Data Center 01"@en, "Centre de Données Paris 01"@fr ;
    noria:siteId "PAR-DC01" ;
    noria:siteType "Data Center"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressPostalCode "75002" .

<room/Paris_DC01_ServerRoomA> a noria:Room ;
    rdfs:label "Server Room A - DC01"@en, "Salle Serveurs A - DC01"@fr ;
    rdfs:comment "Main server room in Paris Data Center 01."@en ;
    bot:hasSpace <site/Paris_DC01> .

<locus/Paris_DC01_RackA1_U24> a noria:Locus ;
    rdfs:label "Rack A1, Unit 24"@en ;
    rdfs:comment "Specific location within Server Room A."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "24" ;
    bot:containsZone <room/Paris_DC01_ServerRoomA> .

<locus/Paris_DC01_RackB2_U10> a noria:Locus ;
    rdfs:label "Rack B2, Unit 10"@en ;
    rdfs:comment "Specific location within Server Room A."@en ;
    noria:locusLine "B2" ;
    noria:locusRow "10" ;
    bot:containsZone <room/Paris_DC01_ServerRoomA> .

