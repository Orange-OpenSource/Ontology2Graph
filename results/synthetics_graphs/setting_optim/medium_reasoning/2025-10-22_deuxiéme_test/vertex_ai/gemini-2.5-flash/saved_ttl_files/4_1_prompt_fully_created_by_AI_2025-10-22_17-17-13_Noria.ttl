    noria:resourceManagementIPAddress <observable/IP_10.0.0.2> ;
    noria:resourceForApplication <application/CorporateWebsite> .

<resource/Switch_Access01> a noria:Resource ;
    rdfs:label "Access Switch 01"@en, "Commutateur d'Accès 01"@fr ;
    rdfs:comment "Provides network access for servers in Rack A1."@en ;
