    noria:applicationModuleAdministrationLeader <agent/Person_BobJohnson> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-03-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

<applicationmodule/CRMSystem_Dev> a noria:ApplicationModule ;
    rdfs:label "CRM System Development Module"@en, "Module de Développement Système CRM"@fr ;
    rdfs:comment "Development instance of the CRM System application."@en ;
    noria:applicationModuleOf <application/CRMSystem> ;
    noria:applicationModuleName "CRM_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> ;
    noria:applicationModuleSupportTeam <agent/Team_AppSupport> ;
