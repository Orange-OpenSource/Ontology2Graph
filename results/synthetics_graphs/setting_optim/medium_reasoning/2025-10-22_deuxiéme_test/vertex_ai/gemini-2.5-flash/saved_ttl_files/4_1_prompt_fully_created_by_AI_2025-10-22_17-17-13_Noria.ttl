# --- Services ---
<service/InternetAccessService> a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en, "Service d'Accès Internet Corporatif"@fr ;
    rdfs:comment "Provides internet connectivity for all corporate users and applications."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <application/CorporateWebsite> ; # Example of linking an application module to a service
    seas:subSystemOf <application/CRMSystem> .

<service/SecureDataTransfer> a noria:Service ;
    rdfs:label "Secure Data Transfer Service"@en, "Service de Transfert de Données Sécurisé"@fr ;
    rdfs:comment "Ensures secure and encrypted data transfer between internal systems and external partners."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf <application/MonitoringPlatform> .

# --- Event Records ---
<eventrecord/Log_Router_InterfaceDown> a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface went down on Core Router 01."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down"@en ;
    noria:logOriginatingManagedObject <resource/Router_Core01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<eventrecord/Log_WebServer_HighCPU> a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-23T10:15:30Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject <resource/Server_Web01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

<eventrecord/Log_Security_LoginFailure> a noria:EventRecord ;
    rdfs:label "Security Login Failure Event"@en ;
    rdfs:comment "Multiple failed login attempts detected on a critical system."@en ;
    noria:loggingTime "2024-04-23T09:45:10Z"^^xsd:dateTime ;
    noria:logText "User 'attacker' failed to login 5 times from IP 192.168.1.100."@en ;
    noria:logOriginatingManagedObject <resource/Server_Web01> ; # Assuming web server is the target
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ; # SIEM is part of monitoring
    noria:logOriginatingAgent <agent/Person_AliceSmith> ; # Alice might be the one who noticed it
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

# --- Operation Plans and Conditions ---
<operationplan/RouterInterfaceTroubleshooting> a noria:OperationPlan ;
    rdfs:label "Router Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving router interface issues."@en ;
    noria:operationPlanPreCondition <actionprecondition/InterfaceDownDetected> ;
    noria:operationPlanPostCondition <actionpostcondition/InterfaceRestored> .

<actionprecondition/InterfaceDownDetected> a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Detected"@en ;
    rdfs:comment "Condition: An EventRecord with Critical severity and 'interface down' message is received."@en .

<actionpostcondition/InterfaceRestored> a noria:ActionPostCondition ;
    rdfs:label "Network Interface Restored"@en ;
    rdfs:comment "Expected outcome: Network interface operational status is 'Up' and traffic flows normally."@en .

# --- Trouble Tickets ---
<troubleticket/TT_20240423_001> a noria:TroubleTicket ;
    rdfs:label "Core Router Interface Down Incident"@en ;
    rdfs:comment "Critical incident: Core Router 01's uplink interface to ISP A is down, impacting corporate internet access."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketCause "Fiber cut on ISP A's side."@en ;
    noria:troubleTicketSupervisionTool "Monitoring Platform"@en ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty <agent/Team_NetworkOps> ;
    noria:troubleTicketRelatedService <service/InternetAccessService> ;
    noria:troubleTicketRelatedResource <resource/Router_Core01> ;
    noria:troubleTicketImpacts <applicationmodule/CorporateWebsite_Prod> ;
    noria:troubleTicketImpacts <resource/Server_Web01> ;
    noria:troubleTicketTrigger <eventrecord/Log_Router_InterfaceDown> ;
    dcterms:identifier "TT-20240423-001" ;
    noria:documentHRef "https://ticketing.example.com/TT-20240423-001" .

<troubleticket/TT_20240423_002> a noria:TroubleTicket ;
    rdfs:label "CRM System Performance Degradation"@en ;
