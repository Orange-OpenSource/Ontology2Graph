# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix org: <http://www.w3.org/ns/org#> .

# --- Domain specific ---
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit, foaf:Person)
# =============================================================================

<Agent/AdminTeamA> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Infrastructure Admin Team"@en ;
    rdfs:label "Équipe d'Administration Infrastructure IT"@fr ;
    rdfs:comment "Team responsible for core IT infrastructure management, including servers and network devices."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentInstructions "Contact via ticketing system for routine requests, emergency hotline for critical incidents."@en .

<Agent/SupportTeamB> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:label "Centre d'Opérations Réseau (COR)"@fr ;
    rdfs:comment "24/7 team monitoring network health and responding to alerts."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentInstructions "Automated alerts are routed directly, manual contact via dedicated secure chat."@en .

<Agent/JohnDoe> a foaf:Agent, foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:label "Jean Dupont"@fr ;
    rdfs:comment "Lead developer for the WebAppService."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en .

<Agent/JaneSmith> a foaf:Agent, foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:label "Jeanne Martin"@fr ;
    rdfs:comment "Incident Manager responsible for critical service restoration."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentWorkingHours "On-call 24/7 for P1 incidents"@en .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

<ProductModel/ServerModelX> a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R750"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy <Organization/Dell> .

<ProductModel/RouterModelY> a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9800 Series"@en ;
    rdfs:comment "Enterprise-grade core router model."@en ;
    noria:productManufacturedBy <Organization/Cisco> .

<ProductModel/SwitchModelZ> a noria:ProductModel ;
    rdfs:label "Juniper EX4650"@en ;
    rdfs:comment "High-density access switch model."@en ;
    noria:productManufacturedBy <Organization/Juniper> .

<Organization/Dell> a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

<Organization/Cisco> a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

<Organization/Juniper> a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

<Location/ParisDC> a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:label "Centre de Données de Paris"@fr ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

<Location/ServerRoom01> a noria:Room ;
    rdfs:label "Server Room 01"@en ;
    rdfs:label "Salle Serveurs 01"@fr ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace <Location/ParisDC> .

<Location/RackA1> a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Specific rack location for servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace <Location/ServerRoom01> .

<Location/LyonOffice> a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:label "Bureau Régional de Lyon"@fr ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building"@en ;
    noria:sitePrincipalAddressStreet "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

<Location/NetworkRoom02> a noria:Room ;
    rdfs:label "Network Room 02"@en ;
    rdfs:label "Salle Réseau 02"@fr ;
    rdfs:comment "Network equipment room in the Lyon office."@en ;
    bot:hasSpace <Location/LyonOffice> .

<Location/RackB2> a noria:Locus ;
    rdfs:label "Rack B2"@en ;
    rdfs:comment "Specific rack location for network equipment."@en ;
    noria:locusLine "B" ;
    noria:locusRow "2" ;
    bot:hasSpace <Location/NetworkRoom02> .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

<Resource/DNS_Server_01> a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, located in Paris DC."@en ;
    noria:resourceManagedBy <Agent/AdminTeamA> ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel <ProductModel/ServerModelX> ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-DNS-01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <Location/RackA1> ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

<Resource/Web_Server_02> a noria:Resource ;
    rdfs:label "Corporate Web Server 02"@en ;
    rdfs:comment "Web server hosting critical internal applications, located in Paris DC."@en ;
    noria:resourceManagedBy <Agent/AdminTeamA> ;
    noria:resourceHostName "web02.corp.example.com" ;
    noria:resourceProductModel <ProductModel/ServerModelX> ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-WEB-02-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-02-20T11:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <Location/RackA1> ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.11> .

<Resource/Core_Router_01> a noria:Resource ;
    rdfs:label "Core Router 01 - Lyon"@en ;
    rdfs:comment "Main router for the Lyon office, connecting to the corporate backbone."@en ;
    noria:resourceManagedBy <Agent/SupportTeamB> ;
    noria:resourceHostName "lyon-cr01.corp.example.com" ;
    noria:resourceProductModel <ProductModel/RouterModelY> ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "SN-CR-01-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <Location/RackB2> ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

<Resource/Access_Switch_03> a noria:Resource ;
    rdfs:label "Access Switch 03 - Lyon"@en ;
    rdfs:comment "Access layer switch in Lyon office, providing connectivity to end-users."@en ;
    noria:resourceManagedBy <Agent/SupportTeamB> ;
    noria:resourceHostName "lyon-as03.corp.example.com" ;
    noria:resourceProductModel <ProductModel/SwitchModelZ> ;
    noria:resourceType <kos/Resource/type/switch> ;
    noria:resourceSerialNumber "SN-AS-03-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-06-01T14:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <Location/RackB2> ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.2> .

<Resource/VirtualMachine_AppDB> a noria:Resource ;
    rdfs:label "Application Database VM"@en ;
    rdfs:comment "Virtual machine hosting the database for the WebAppService."@en ;
    noria:resourceManagedBy <Agent/AdminTeamA> ;
    noria:resourceHostName "appdb-vm01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-01T16:00:00Z"^^xsd:dateTime ;
    noria:clusterController <Resource/Web_Server_02> ; # Assuming Web_Server_02 acts as a host/controller for VMs
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.10> .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

<NetworkInterface/DNS_Server_01_Eth0> a noria:NetworkInterface ;
    rdfs:label "DNS Server 01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS_Server_01."@en ;
    noria:networkInterfaceOf <Resource/DNS_Server_01> ;
    noria:networkInterfaceType <http://example.com/kos/networkInterfaceType/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceDescription "Uplink to core network" .

<NetworkInterface/Web_Server_02_Eth0> a noria:NetworkInterface ;
    rdfs:label "Web Server 02 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Web_Server_02."@en ;
    noria:networkInterfaceOf <Resource/Web_Server_02> ;
    noria:networkInterfaceType <http://example.com/kos/networkInterfaceType/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceDescription "Uplink to core network" .

<NetworkInterface/Core_Router_01_GigE0_0> a noria:NetworkInterface ;
    rdfs:label "Core Router 01 GigE0/0"@en ;
    rdfs:comment "Interface connecting Core_Router_01 to DNS_Server_01."@en ;
    noria:networkInterfaceOf <Resource/Core_Router_01> ;
    noria:networkInterfaceType <http://example.com/kos/networkInterfaceType/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceDescription "Link to Paris DC" .

<NetworkInterface/Core_Router_01_GigE0_1> a noria:NetworkInterface ;
    rdfs:label "Core Router 01 GigE0/1"@en ;
    rdfs:comment "Interface connecting Core_Router_01 to Access_Switch_03."@en ;
    noria:networkInterfaceOf <Resource/Core_Router_01> ;
    noria:networkInterfaceType <http://example.com/kos/networkInterfaceType/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 ;
    noria:networkInterfaceDescription "Link to Lyon Access Switch" .

<NetworkInterface/Access_Switch_03_Port1> a noria:NetworkInterface ;
    rdfs:label "Access Switch 03 Port 1"@en ;
    rdfs:comment "Uplink port from Access_Switch_03 to Core_Router_01."@en ;
    noria:networkInterfaceOf <Resource/Access_Switch_03> ;
    noria:networkInterfaceType <http://example.com/kos/networkInterfaceType/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceDescription "Uplink to Core Router" .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

<NetworkLink/Link_DNS_Router> a noria:NetworkLink ;
    rdfs:label "Link between DNS Server and Core Router"@en ;
    rdfs:comment "Physical link connecting DNS_Server_01 to Core_Router_01."@en ;
    noria:networkLinkId "NL-PAR-LYN-01" ;
    noria:networkLinkType "Fiber Optic"@en ;
    noria:networkLinkInstallationDate "2023-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects <NetworkInterface/DNS_Server_01_Eth0> ;
    noria:networkInterfaceConnects <NetworkInterface/Core_Router_01_GigE0_0> ;
    noria:networkLinkTerminationResourceOrigin <Resource/DNS_Server_01> ;
    noria:networkLinkTerminationResourceDestination <Resource/Core_Router_01> ;
    noria:resourceManagedBy <Agent/SupportTeamB> .

<NetworkLink/Link_Router_Switch> a noria:NetworkLink ;
    rdfs:label "Link between Core Router and Access Switch"@en ;
    rdfs:comment "Physical link connecting Core_Router_01 to Access_Switch_03."@en ;
    noria:networkLinkId "NL-LYN-INT-02" ;
    noria:networkLinkType "Copper Ethernet"@en ;
    noria:networkLinkInstallationDate "2022-06-01T14:30:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects <NetworkInterface/Core_Router_01_GigE0_1> ;
    noria:networkInterfaceConnects <NetworkInterface/Access_Switch_03_Port1> ;
    noria:networkLinkTerminationResourceOrigin <Resource/Core_Router_01> ;
    noria:networkLinkTerminationResourceDestination <Resource/Access_Switch_03> ;
    noria:resourceManagedBy <Agent/SupportTeamB> .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

<Application/CorporateDNS> a noria:Application ;
    rdfs:label "Corporate DNS Service"@en ;
    rdfs:label "Service DNS d'Entreprise"@fr ;
    rdfs:comment "Provides name resolution for all internal corporate services."@en ;
    noria:applicationModelIdentifier "CORP-DNS" ;
    noria:applicationNumericalIdentifier 101 ;
    noria:applicationShortIdentifier "CDNS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "DNS Management" ;
    noria:resourceForApplication <Resource/DNS_Server_01> .

<Application/WebAppService> a noria:Application ;
    rdfs:label "Internal Web Application Service"@en ;
    rdfs:label "Service d'Application Web Interne"@fr ;
    rdfs:comment "Hosts various internal web applications for employees."@en ;
    noria:applicationModelIdentifier "INT-WEBAPP" ;
    noria:applicationNumericalIdentifier 102 ;
    noria:applicationShortIdentifier "IWAS" ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Business Operations" ;
    noria:applicationFunctionalSubDomain "Employee Productivity" ;
    noria:resourceForApplication <Resource/Web_Server_02> ;
    noria:resourceForApplication <Resource/VirtualMachine_AppDB> .

<Application/NetworkManagement> a noria:Application ;
    rdfs:label "Network Management System"@en ;
    rdfs:label "Système de Gestion de Réseau"@fr ;
    rdfs:comment "Monitors and manages all network devices across the corporate infrastructure."@en ;
    noria:applicationModelIdentifier "NMS-CORP" ;
    noria:applicationNumericalIdentifier 103 ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Operations" ;
    noria:applicationFunctionalSubDomain "Monitoring & Control" ;
    noria:resourceForApplication <Resource/Core_Router_01> ;
    noria:resourceForApplication <Resource/Access_Switch_03> .

# =============================================================================
# Application Modules (noria:ApplicationModule)
# =============================================================================

<ApplicationModule/CorporateDNS_Prod> a noria:ApplicationModule ;
    rdfs:label "Corporate DNS Production Module"@en ;
    rdfs:label "Module de Production DNS d'Entreprise"@fr ;
    rdfs:comment "Production instance of the Corporate DNS Service."@en ;
    noria:applicationModuleOf <Application/CorporateDNS> ;
    noria:applicationModuleName "CORP-DNS_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleAdministrationTeam <Agent/AdminTeamA> ;
    noria:applicationModuleAdministrationLeader <Agent/JohnDoe> ;
    noria:applicationModuleSupportTeam <Agent/SupportTeamB> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleHotlineEnabled true .

<ApplicationModule/WebAppService_Dev> a noria:ApplicationModule ;
    rdfs:label "Web App Service Development Module"@en ;
    rdfs:label "Module de Développement Service App Web"@fr ;
    rdfs:comment "Development instance of the Internal Web Application Service."@en ;
    noria:applicationModuleOf <Application/WebAppService> ;
    noria:applicationModuleName "INT-WEBAPP_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleAdministrationTeam <Agent/AdminTeamA> ;
    noria:applicationModuleAdministrationLeader <Agent/JohnDoe> ;
    noria:applicationModuleSupportGroup <Agent/AdminTeamA> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Bronze> ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> ;
    noria:applicationModuleHotlineEnabled false .

# =============================================================================
# Services (noria:Service)
# =============================================================================

<Service/InternetAccessService> a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:label "Service d'Accès Internet d'Entreprise"@fr ;
    rdfs:comment "End-to-end service providing internet access to all corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystem <ApplicationModule/CorporateDNS_Prod> ;
    seas:subSystem <ApplicationModule/WebAppService_Dev> ;
    seas:subSystem <Application/NetworkManagement> .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

<EventRecord/DNS_Outage_Alert_01> a noria:EventRecord ;
    rdfs:label "DNS Server Outage Alert"@en ;
    rdfs:comment "Critical alert indicating DNS_Server_01 is unreachable."@en ;
    noria:loggingTime "2024-04-20T08:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <Resource/DNS_Server_01> ;
    noria:logOriginatingManagementSystem <Application/NetworkManagement> ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction <OperationPlan/RestartDNSService> .

<EventRecord/Router_Interface_Down_02> a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core_Router_01 went down."@en ;
    noria:loggingTime "2024-04-20T07:58:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <Resource/Core_Router_01> ;
    noria:logOriginatingManagementSystem <Application/NetworkManagement> ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigE0/0, changed state to down" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

<EventRecord/WebApp_Error_Log_03> a noria:EventRecord ;
    rdfs:label "Web App Error Log"@en ;
    rdfs:comment "Error log from WebAppService_Dev indicating database connection issues."@en ;
    noria:loggingTime "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <Resource/VirtualMachine_AppDB> ;
    noria:logOriginatingManagementSystem <Application/WebAppService> ;
    noria:logText "ERROR: Database connection failed for user 'webapp_dev'" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

<EventRecord/User_Login_Failed_04> a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Security event: multiple failed login attempts for a user."@en ;
    noria:loggingTime "2024-04-20T10:05:10Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <Resource/Web_Server_02> ;
    noria:logOriginatingManagementSystem <Application/NetworkManagement> ; # Assuming NMS also collects security logs
    noria:logOriginatingAgent <Agent/JohnDoe> ; # Assuming JohnDoe's account was targeted
    noria:logText "Authentication failure for user 'jdoe' from IP 1.2.3.4" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

<TroubleTicket/TT-20240420-001> a noria:TroubleTicket ;
    rdfs:label "Critical DNS Outage"@en ;
    rdfs:label "Panne DNS Critique"@fr ;
    rdfs:comment "Corporate DNS server is unreachable, impacting all internal services."@en ;
    dcterms:identifier "TT-20240420-001" ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger <EventRecord/DNS_Outage_Alert_01> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Network connectivity issue to DNS server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T08:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty <Agent/SupportTeamB> ;
    noria:troubleTicketRelatedParty <Agent/JaneSmith> ;
    noria:troubleTicketRelatedService <Application/CorporateDNS> ;
    noria:troubleTicketRelatedResource <Resource/DNS_Server_01> ;
    noria:troubleTicketImpacts <Application/CorporateDNS> ;
    noria:troubleTicketImpacts <Service/InternetAccessService> ;
    noria:documentHRef <http://ticketing.example.com/TT-20240420-001> .

<TroubleTicket/TT-20240420-002> a noria:TroubleTicket ;
    rdfs:label "Web App DB Connectivity Issue"@en ;
    rdfs:label "Problème de Connectivité DB App Web"@fr ;
    rdfs:comment "Development web application experiencing database connection errors."@en ;
