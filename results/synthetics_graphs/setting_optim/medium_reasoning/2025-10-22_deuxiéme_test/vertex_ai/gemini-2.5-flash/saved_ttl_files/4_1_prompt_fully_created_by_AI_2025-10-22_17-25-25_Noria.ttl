# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

<ActionPreCondition/DNSServiceDown> a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unreachable"@en ;
    rdfs:comment "Condition: DNS service is not responding to queries."@en .

<ActionPostCondition/DNSServiceUp> a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Outcome: DNS service is responding to queries successfully."@en .

<ActionPreCondition/NetworkInterfaceDown> a noria:ActionPreCondition ;
    rdfs:label "Network Interface Operational Status Down"@en ;
    rdfs:comment "Condition: A network interface's operational status is reported as 'down'."@en .

<ActionPostCondition/InterfaceStatusKnown> a noria:ActionPostCondition ;
    rdfs:label "Network Interface Status Diagnosed"@en ;
    rdfs:comment "Outcome: The cause of the network interface's status (e.g., administrative down, physical fault) is identified."@en .

