# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

<OperationPlan/RouterFirmwareUpgradeProcedure> a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router firmware."@en ;
    noria:operationPlanPreCondition <ActionPreCondition/RouterBackupExists> ;
    noria:operationPlanPostCondition <ActionPostCondition/RouterOperationalAfterUpgrade> .

<ActionPreCondition/RouterBackupExists> a noria:ActionPreCondition ;
    rdfs:label "Router Configuration Backup Exists"@en ;
    rdfs:comment "Ensures a recent configuration backup is available before firmware upgrade."@en .

<ActionPostCondition/RouterOperationalAfterUpgrade> a noria:ActionPostCondition ;
    rdfs:label "Router Operational After Upgrade"@en ;
    rdfs:comment "Verifies router is fully operational and routing traffic correctly after firmware upgrade."@en .

<OperationPlan/WebAppDeploymentProcedure> a noria:OperationPlan ;
    rdfs:label "Web Application Deployment Procedure"@en ;
    rdfs:comment "Procedure for deploying new web applications."@en ;
    noria:operationPlanPreCondition <ActionPreCondition/WebAppCodeReviewed> ;
    noria:operationPlanPostCondition <ActionPostCondition/WebAppAccessibleAndFunctional> .

<ActionPreCondition/WebAppCodeReviewed> a noria:ActionPreCondition ;
    rdfs:label "Web Application Code Reviewed"@en ;
    rdfs:comment "Ensures the web application code has passed security and quality reviews."@en .

<ActionPostCondition/WebAppAccessibleAndFunctional> a noria:ActionPostCondition ;
    rdfs:label "Web Application Accessible and Functional"@en ;
    rdfs:comment "Confirms the new web application is accessible and all its functionalities are working as expected."@en .

