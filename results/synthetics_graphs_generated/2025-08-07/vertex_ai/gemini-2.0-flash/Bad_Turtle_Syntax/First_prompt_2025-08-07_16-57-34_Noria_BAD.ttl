@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ex: <http://example.com/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix seas: <https://w3id.org/seas/> .

# Entities
ex:ApplicationModule1
    a noria:ApplicationModule ;
    rdfs:label "Billing Module Instance"@en ;
    rdfs:comment "Specific instance of the billing application."@en ;
    noria:applicationModuleName "Billing_Prod1" ;
    noria:applicationModuleIdentifier "Prod1" ;
    noria:applicationModuleOf ex:BillingApplication ;
    noria:applicationModuleAdministrationTeam ex:AdminTeam ;
    noria:applicationModuleSupportTeam ex:SupportTeam ;
    noria:applicationModuleSlaLevel ex:GoldSLA ;
    noria:applicationModuleStatus ex:StatusActive .

ex:BillingApplication
    a noria:Application ;
    rdfs:label "Billing Application"@en ;
    rdfs:comment "Core application for customer billing."@en ;
    noria:applicationModelIdentifier "BillingApp" ;
    noria:applicationShortIdentifier "BILLING" ;
    noria:applicationType ex:TypeBusinessCritical ;
    noria:applicationBusinessImportance ex:ImportanceHigh .

ex:Router1
    a noria:Resource ;
    rdfs:label "Core Router 1"@en ;
    rdfs:comment "Core router in the network infrastructure."@en ;
    noria:resourceHostName "router1.example.com" ;
    noria:resourceLogisticId "RT-001" ;
    noria:resourceType ex:TypeRouter ;
    noria:resourceManagedBy ex:NetworkTeam ;
    noria:locatedAtLocus ex:Locus1 .

ex:Firewall1
    a noria:Resource ;
    rdfs:label "Firewall 1"@en ;
    rdfs:comment "Main firewall protecting the network."@en ;
    noria:resourceHostName "firewall1.example.com" ;
    noria:resourceLogisticId "FW-001" ;
    noria:resourceType ex:TypeFirewall ;
    noria:resourceManagedBy ex:SecurityTeam ;
    noria:locatedAtLocus ex:Locus2 .

ex:LoadBalancer1
    a noria:Resource ;
    rdfs:label "Load Balancer 1"@en ;
    rdfs:comment "Load balancer distributing traffic."@en ;
    noria:resourceHostName "lb1.example.com" ;
    noria:resourceLogisticId "LB-001" ;
    noria:resourceType ex:TypeLoadBalancer ;
    noria:resourceManagedBy ex:NetworkTeam ;
    noria:locatedAtLocus ex:Locus3 .

ex:NetworkInterface1
    a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
    rdfs:comment "Main network interface of Router1."@en ;
    noria:networkInterfaceOf ex:Router1 ;
    noria:networkInterfaceType ex:TypePhysicalInterface ;
    noria:networkInterfaceAdministrativeStatus ex:StatusUp ;
    noria:networkInterfaceOperationalStatus ex:StatusUp ;
    noria:networkInterfaceConnects ex:NetworkLink1 .

ex:NetworkInterface2
    a noria:NetworkInterface ;
    rdfs:label "eth1"@en ;
    rdfs:comment "Main network interface of Firewall1."@en ;
    noria:networkInterfaceOf ex:Firewall1 ;
    noria:networkInterfaceType ex:TypePhysicalInterface ;
    noria:networkInterfaceAdministrativeStatus ex:StatusUp ;
    noria:networkInterfaceOperationalStatus ex:StatusUp ;
    noria:networkInterfaceConnects ex:NetworkLink1 .

ex:NetworkLink1
    a noria:NetworkLink ;
    rdfs:label "Link between Router1 and Firewall1"@en ;
    rdfs:comment "Physical link connecting Router1 and Firewall1."@en ;
    noria:networkLinkId "LNK-001" ;
    noria:networkLinkTerminationResourceOrigin ex:Router1 ;
    noria:networkLinkTerminationResourceDestination ex:Firewall1 ;
    noria:resourceManagedBy ex:NetworkTeam .

ex:AdminTeam
    a org:OrganizationalUnit ;
    rdfs:label "Billing Admin Team"@en ;
    rdfs:comment "Team responsible for administering the billing application."@en .

ex:SupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Billing Support Team"@en ;
    rdfs:comment "Team responsible for supporting the billing application."@en .

ex:NetworkTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing the network infrastructure."@en .

ex:SecurityTeam
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations Team"@en ;
    rdfs:comment "Team responsible for managing security infrastructure."@en .

ex:GoldSLA
    a skos:Concept ;
    rdfs:label "Gold SLA"@en ;
    rdfs:comment "Gold service level agreement."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

ex:StatusActive
    a skos:Concept ;
    rdfs:label "Active"@en ;
    rdfs:comment "Application module is active."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

ex:TypeBusinessCritical
    a skos:Concept ;
    rdfs:label "Business Critical"@en ;
    rdfs:comment "Application is business critical."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .

ex:TypeRouter
    a skos:Concept ;
    rdfs:label "Router"@en ;
    rdfs:comment "Network router."@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> .

ex:TypeFirewall
    a skos:Concept ;
    rdfs:label "Firewall"@en ;
    rdfs:comment "Network firewall."@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> .

ex:TypeLoadBalancer
    a skos:Concept ;
    rdfs:label "Load Balancer"@en ;
    rdfs:comment "Network load balancer."@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> .

ex:TypePhysicalInterface
    a skos:Concept ;
    rdfs:label "Physical Interface"@en ;
    rdfs:comment "Physical network interface."@en .

ex:StatusUp
    a skos:Concept ;
    rdfs:label "Up"@en ;
    rdfs:comment "Interface is up."@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> .

ex:Locus1
    a noria:Locus ;
    rdfs:label "Locus 1"@en ;
    rdfs:comment "Location of Router 1."@en .

ex:Locus2
    a noria:Locus ;
    rdfs:label "Locus 2"@en ;
    rdfs:comment "Location of Firewall 1."@en .

ex:Locus3
    a noria:Locus ;
    rdfs:label "Locus 3"@en ;
    rdfs:comment "Location of Load Balancer 1."@en .
