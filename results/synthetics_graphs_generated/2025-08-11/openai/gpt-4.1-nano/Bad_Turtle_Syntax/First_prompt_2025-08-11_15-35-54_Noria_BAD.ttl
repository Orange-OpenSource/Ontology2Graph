@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing core network infrastructure."@en .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector in the network."@en ;
  noria:structuralElementObservable <https://example.com/observable/connectionCount> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/observable/trafficVolume> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments."@en ;
  noria:structuralElementObservable <https://example.com/observable/segmentConnection> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that facilitates data transfer between other nodes."@en ;
  noria:structuralElementObservable <https://example.com/observable/dataFlow> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/observable/multiplexCapacity> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:structuralElementObservable <https://example.com/observable/superNodeLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A virtual machine hosting critical services."@en ;
  noria:resourceLogisticId "VM-CRITICAL-001" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/virtualMachine> ;
  noria:resourceHostName "vm-critical-01" .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A physical server in data center."@en ;
  noria:resourceLogisticId "Server-DC-02" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/server> ;
  noria:resourceHostName "server-02" .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Main server room."@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Secondary data center."@en .

<https://example.com/ServiceA> a noria:Service ;
  rdfs:label "Service A"@en ;
  rdfs:comment "Customer-facing web application."@en ;
  noria:serviceType <https://kos/service/type/customerFacingService> ;
  noria:serviceRelatedResource <https://example.com/Resource1> .

<https://example.com/ApplicationX> a noria:Application ;
  rdfs:label "Application X"@en ;
  rdfs:comment "Core business application."@en ;
  noria:applicationModelIdentifier "AppX-Model-2023" ;
  noria:applicationNumericalIdentifier 12345 ;
  noria:applicationShortIdentifier "AppX" ;
  noria:applicationType <https://kos/application/type/businessApplication> ;
  noria:applicationBusinessImportance <https://skos.org/kos/application/business-importance/critical> ;
  noria:applicationFunctionalDomain "Customer Management"@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Link 1"@en ;
  rdfs:comment "Optical fiber link between data centers."@en ;
  noria:networkLinkId "NL-DC1-DC2" ;
  noria:networkLinkType "Optical Fiber"@en ;
  noria:networkLinkInstallationDate "2022-06-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/Event1> a noria:EventRecord ;
  rdfs:label "Link Up Event"@en ;
  rdfs:comment "Event indicating link is operational."@en ;
  noria:loggingTime "2023-03-20T14:22:00"^^xsd:dateTime ;
  noria:logText "Link NL-DC1-DC2 is now active."@en ;
  noria:logOriginatingManagedObject <https://example.com/Resource1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:logOriginatingAgent <https://example.com/Agent1> ;
  noria:alarmSeverity <https://skos.org/kos/Notification/Severity/Major> ;
  noria:alarmProposedRepairAction <https://example.com/OperationPlan1> .

<https://example.com/Agent1> a foaf:Agent ;
  rdfs:label "Network Monitoring Agent"@en ;
  rdfs:comment "Automated network monitoring system."@en .

<https://example.com/OperationPlan1> a noria:OperationPlan ;
  rdfs:label "Activate Backup Link"@en ;
  rdfs:comment "Procedure to activate backup network link."@en .

<https://example.com/observable/connectionCount> a noria:StructuralObservable ;
  rdfs:label "Connection Count"@en .

<https://example.com/observable/trafficVolume> a noria:StructuralObservable ;
  rdfs:label "Traffic Volume"@en .

<https://example.com/observable/segmentConnection> a noria:StructuralObservable ;
  rdfs:label "Segment Connection"@en .

<https://example.com/observable/dataFlow> a noria:StructuralObservable ;
  rdfs:label "Data Flow"@en .

<https://example.com/observable/multiplexCapacity> a noria:StructuralObservable ;
  rdfs:label "Multiplex Capacity"@en .

<https://example.com/observable/superNodeLoad> a noria:StructuralObservable ;
  rdfs:label "Super Node Load"@en .

<https://example.com/observable/operationCount> a noria:StructuralObservable ;
  rdfs:label "Operation Count"@en .

<https://example.com/observable/trafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en .

<https://example.com/observable/connectionSpeed> a noria:StructuralObservable ;
  rdfs:label "Connection Speed"@en .

<https://example.com/observable/latency> a noria:StructuralObservable ;
  rdfs:label "Network Latency"@en .

<https://example.com/observable/packetLoss> a noria:StructuralObservable ;
  rdfs:label "Packet Loss"@en .

<https://example.com/observable/availability> a noria:StructuralObservable ;
  rdfs:label "Resource Availability"@en .

<https://example.com/observable/uptime> a noria:StructuralObservable ;
  rdfs:label "System Uptime"@en .

<https://example.com/observable/errorRate> a noria:StructuralObservable ;
  rdfs:label "Error Rate"@en .

<https://example.com/observable/throughput> a noria:StructuralObservable ;
  rdfs:label "Network Throughput"@en .

<https://example.com/observable/connectionQuality> a noria:StructuralObservable ;
  rdfs:label "Connection Quality"@en .

<https://example.com/observable/trafficPattern> a noria:StructuralObservable ;
  rdfs:label "Traffic Pattern"@en .

<https://example.com/observable/segmentUtilization> a noria:StructuralObservable ;
  rdfs:label "Segment Utilization"@en .

<https://example.com/observable/backupStatus> a noria:StructuralObservable ;
  rdfs:label "Backup Status"@en .

<https://example.com/observable/aggregateLoad> a noria:StructuralObservable ;
  rdfs:label "Aggregate Load"@en .

<https://example.com/observable/overallCapacity> a noria:StructuralObservable ;
  rdfs:label "Overall Capacity"@en .

<https://example.com/observable/systemHealth> a noria:StructuralObservable ;
  rdfs:label "System Health"@en .

<https://example.com/observable/trafficEfficiency> a noria:StructuralObservable ;
  rdfs:label "Traffic Efficiency"@en .

<https://example.com/observable/connectionStability> a noria:StructuralObservable ;
  rdfs:label "Connection Stability"@en .

<https://example.com/observable/monitoringStatus> a noria:StructuralObservable ;
  rdfs:label "Monitoring Status"@en .

<https://example.com/observable/alertRate> a noria:StructuralObservable ;
  rdfs:label "Alert Rate"@en .

<https://example.com/observable/incidentCount> a noria:StructuralObservable ;
  rdfs:label "Incident Count"@en .

<https://example.com/observable/responseTime> a noria:StructuralObservable ;
