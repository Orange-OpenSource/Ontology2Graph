@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a core network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector in the network."@en ;
  noria:structuralElementObservableData <https://example.com/NodeDegree> ;
  noria:structuralElementObservable <https://example.com/NodeDegreeObservable> ;
  noria:structuralObservableOf <https://example.com/HighDegreeNode> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservableData <https://example.com/TrafficLoad> ;
  noria:structuralElementObservable <https://example.com/TrafficLoadObservable> ;
  noria:structuralObservableOf <https://example.com/centralNode> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node serving as a bridge between different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/LinkStatus> ;
  noria:structuralElementObservable <https://example.com/LinkStatusObservable> ;
  noria:structuralObservableOf <https://example.com/connectorNode> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that facilitates data flow between hubs and other nodes."@en ;
  noria:structuralElementObservableData <https://example.com/IntermediaryLoad> ;
  noria:structuralElementObservable <https://example.com/IntermediaryLoadObservable> ;
  noria:structuralObservableOf <https://example.com/intermediaryNode> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node that handles multiple data streams or protocols."@en ;
  noria:structuralElementObservableData <https://example.com/StreamCount> ;
  noria:structuralElementObservable <https://example.com/StreamCountObservable> ;
  noria:structuralObservableOf <https://example.com/multiplexNode> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching node representing a superordinate network component."@en ;
  noria:structuralElementObservableData <https://example.com/SuperNodeCapacity> ;
  noria:structuralElementObservable <https://example.com/SuperNodeCapacityObservable> ;
  noria:structuralObservableOf <https://example.com/superNode> .

<https://example.com/NodeA> a noria:StructuralElement ;
  rdfs:label "Node A"@en ;
  rdfs:comment "A connector node linking to Node B and Node C."@en ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> ;
  noria:structuralElementObservableData <https://example.com/NodeA_Load> ;
  noria:structuralElementObservable <https://example.com/NodeA_LoadObservable> .

<https://example.com/NodeB> a noria:StructuralElement ;
  rdfs:label "Node B"@en ;
  rdfs:comment "An intermediary node in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> ;
  noria:structuralElementObservableData <https://example.com/NodeB_Traffic> ;
  noria:structuralElementObservable <https://example.com/NodeB_TrafficObservable> .

<https://example.com/NodeC> a noria:StructuralElement ;
  rdfs:label "Node C"@en ;
  rdfs:comment "A high-degree hub node."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> ;
  noria:structuralElementObservableData <https://example.com/NodeC_PacketLoss> ;
  noria:structuralElementObservable <https://example.com/NodeC_PacketLossObservable> .

<https://example.com/NodeD> a noria:StructuralElement ;
