@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node with high centrality in the network."@en ;
  noria:structuralElementObservable <https://example.com/trafficVolume> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node linking different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/segmentConnections> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/dataFlowRate> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An aggregated node representing a superstructure."@en ;
  noria:structuralElementObservable <https://example.com/aggregateTraffic> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A critical server in the data center."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceHostName "server1.datacenter.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceSerialNumber "SN-987654" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2020-05-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A virtual machine hosting critical applications."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceHostName "vm-application.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
  noria:resourceSerialNumber "SN-123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2021-03-10T09:30:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelY> ;
  noria:resourceManagedBy <https://example.com/CloudOpsTeam> .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of server1."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "Gigabit Ethernet Interface"@en ;
  noria:networkInterfaceOf <https://example.com/Resource1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceRoutingPriorityMetric 100 ;
  noria:networkInterfaceLaserTxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPower -3 ;
  noria:networkInterfaceLaserRxOpticalPowerAverage -2.5 ;
  noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
  noria:networkInterfaceLaserRxLowPowerWarningThreshold -4 .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Link1"@en ;
  rdfs:comment "Optical fiber link between server1 and switch1."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkType "fiber" ;
  noria:networkLinkInstallationDate "2019-11-20T08:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource3> .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "A core router in the backbone."@en ;
  noria:resourceLogisticId "LOG54321" ;
  noria:locatedAtLocus <https://example.com/LocusC> ;
  noria:resourceHostName "core-router1.backbone.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
  noria:resourceSerialNumber "SN-654321" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2018-07-01T12:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelZ> ;
  noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Main server room."@en .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Secondary data center."@en .

<https://example.com/LocusC> a noria:Locus ;
  rdfs:label "Locus C"@en ;
  rdfs:comment "Backbone core location."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team responsible for server management."@en .

<https://example.com/CloudOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Cloud Operations Team"@en ;
  rdfs:comment "Team managing virtualized resources."@en .

<https://example.com/ProductModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "High-performance server model."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ProductModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Virtual machine template."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerB> .

<https://example.com/ProductModelZ> a noria:ProductModel ;
  rdfs:label "Model Z"@en ;
  rdfs:comment "Core router model."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerC> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "Manufacturer A"@en ;
  rdfs:comment "Leading server manufacturer."@en .

<https://example.com/ManufacturerB> a org:Organization ;
  rdfs:label "Manufacturer B"@en ;
  rdfs:comment "Virtualization platform provider."@en .

<https://example.com/ManufacturerC> a org:Organization ;
  rdfs:label "Manufacturer C"@en ;
  rdfs:comment "Router manufacturer."@en .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team managing network infrastructure."@en .

<https://example.com/ConnectionCount> a noria:StructuralObservable ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections."@en .

<https://example.com/TrafficVolume> a noria:StructuralObservable ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Network traffic volume in Mbps."@en .

<https://example.com/DataFlowRate> a noria:StructuralObservable ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data flow through the node."@en .

<https://example.com/StreamCount> a noria:StructuralObservableData ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/AggregateTraffic> a noria:StructuralObservable ;
  rdfs:label "Aggregate Traffic"@en ;
  rdfs:comment "Total traffic passing through super node."@en .
