@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a core hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/centralNode> a noria:FunctionalElement ;
  rdfs:label "Central Functional Node"@en ;
  rdfs:comment "A central node responsible for core services."@en ;
  noria:elementDistinguishedName "CentralNode01" ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionQuality> ;
  noria:elementManagedBy <https://example.com/NetworkSupport> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/DataCenterTeam> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:structuralElementObservableData <https://example.com/aggregateTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A critical server resource."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:resourceHostName "server1.example.com" ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceSerialNumber "SN-987654" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  noria:resourceManagedBy <https://example.com/ITAdminTeam> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A virtual machine resource."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:resourceHostName "vm2.example.com" ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
  noria:resourceSerialNumber "SN-123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Provisioned> ;
  noria:resourceInstallationDate "2023-03-10T09:30:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelY> ;
  noria:resourceManagedBy <https://example.com/CloudOps> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber link between Resource1 and Resource2."@en ;
  noria:networkLinkId "NLINK-001" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2021-06-01T08:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Resource1."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "Gigabit Ethernet port 0/0/1"@en ;
  noria:networkInterfaceOf <https://example.com/Resource1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
  noria:networkInterfaceRoutingPriorityMetric 100 ;
  noria:networkInterfaceLaserTxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPower -3 .

<https://example.com/NetworkInterface2> a noria:NetworkInterface ;
  rdfs:label "eth1"@en ;
  rdfs:comment "Secondary virtual network interface."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceDescription "VLAN interface 10"@en ;
  noria:networkInterfaceOf <https://example.com/Resource2> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
  noria:networkInterfaceRoutingPriorityMetric 200 ;
  noria:networkInterfaceLaserTxOpticalPower -1 ;
  noria:networkInterfaceLaserRxOpticalPower -2 .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Main server room."@en ;
  noria:locusLine "Line: L1"@en ;
  noria:locusRow "Row: R1"@en .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Data center rack B."@en ;
  noria:locusLine "Line: L2"@en ;
  noria:locusRow "Row: R2"@en .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team managing core IT resources."@en .

<https://example.com/CloudOps> a org:OrganizationalUnit ;
  rdfs:label "Cloud Operations"@en ;
  rdfs:comment "Team managing virtualized resources."@en .

<https://example.com/DataCenterTeam> a org:OrganizationalUnit ;
  rdfs:label "Data Center Team"@en ;
  rdfs:comment "Team overseeing data center resources."@en .

<https://example.com/NetworkManagement> a org:OrganizationalUnit ;
  rdfs:label "Network Management"@en ;
  rdfs:comment "High-level network management team."@en .

<https://example.com/ITAdminTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Administration"@en ;
  rdfs:comment "Team responsible for server administration."@en .

<https://example.com/ProductModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "Manufacturer's model for server hardware."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ProductModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Manufacturer's model for virtual machine."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerB> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "ACME Corp"@en ;
  rdfs:comment "Hardware manufacturer."@en .

<https://example.com/ManufacturerB> a org:Organization ;
  rdfs:label "VirtualTech"@en ;
  rdfs:comment "VM provider."@en .

<https://example.com/NetworkSupport> a org:OrganizationalUnit ;
  rdfs:label "Network Support"@en ;
  rdfs:comment "Support team for network issues."@en .

<https://example.com/NetworkSupport> a org:OrganizationalUnit ;
  rdfs:label "Network Support"@en ;
  rdfs:comment "Support team for network issues."@en .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team managing core IT resources."@en .

<https://example.com/CloudOps> a org:OrganizationalUnit ;
  rdfs:label "Cloud Operations"@en ;
  rdfs:comment "Team managing virtualized resources."@en .

<https://example.com/DataCenterTeam> a org:OrganizationalUnit ;
  rdfs:label "Data Center Team"@en ;
  rdfs:comment "Team overseeing data center resources."@en .

<https://example.com/NetworkManagement> a org:OrganizationalUnit ;
  rdfs:label "Network Management"@en ;
  rdfs:comment "High-level network management team."@en .

<https://example.com/ITAdminTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Administration"@en ;
  rdfs:comment "Team responsible for server administration."@en .