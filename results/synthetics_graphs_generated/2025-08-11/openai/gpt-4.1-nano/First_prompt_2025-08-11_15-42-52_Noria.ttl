@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with a high number of connections, acting as a connector."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralElementObservable <https://example.com/connectionCountObs> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node acting as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/trafficVolume> ;
  noria:structuralElementObservableData <https://example.com/trafficData> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting multiple subnetworks."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:structuralElementObservableData <https://example.com/statusData> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/dataFlowRate> ;
  noria:structuralElementObservableData <https://example.com/flowData> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamCount> ;
  noria:structuralElementObservableData <https://example.com/streamData> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Node representing a superordinate network component."@en ;
  noria:structuralElementObservable <https://example.com/superTraffic> ;
  noria:structuralElementObservableData <https://example.com/superData> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "Physical server hosting critical applications."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:resourceHostName "server1.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceProductModel <https://example.com/ModelX> ;
  noria:resourceSerialNumber "SN987654" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2020-05-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceManagementIPAddress "192.168.1.10" ;
  noria:clusterController <https://example.com/ClusterController1> .

<https://example.com/ModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "Manufacturer's model identifier for Resource 1."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "ACME Corp."@en ;
  rdfs:comment "Manufacturer of Model X."@en .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Specific location within Server Room 314."@en ;
  noria:locusLine "Line:L, in Room:Server room 314" .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Virtual machine instance for testing."@en ;
  noria:resourceLogisticId "LOG54321" ;
  noria:resourceHostName "vm-test.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceProductModel <https://example.com/ModelY> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Provisioned> ;
  noria:resourceInstallationDate "2022-01-10T09:30:00Z"^^xsd:dateTime ;
  noria:clusterController <https://example.com/ClusterController2> .

<https://example.com/ModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Virtualization platform model."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerB> .

<https://example.com/ManufacturerB> a org:Organization ;
  rdfs:label "BetaTech"@en ;
  rdfs:comment "Manufacturer of Model Y."@en .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Location within Virtual Lab."@en ;
  noria:locusRow "Row:5" .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/ClusterController1> a noria:Resource ;
  rdfs:label "Cluster Controller 1"@en ;
  rdfs:comment "Controller managing Resource 1 cluster."@en .

<https://example.com/ClusterController2> a noria:Resource ;
  rdfs:label "Cluster Controller 2"@en ;
  rdfs:comment "Controller managing Resource 2 cluster."@en .

<https://example.com/connectionCount> a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections."@en .

<https://example.com/connectionCountObs> a noria:StructuralObservable ;
  rdfs:label "Connection Count Observable"@en ;
  rdfs:comment "Observable for connection count."@en .

<https://example.com/trafficVolume> a noria:Property ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Volume of traffic passing through the node."@en .

<https://example.com/trafficData> a noria:StructuralObservable ;
  rdfs:label "Traffic Data"@en ;
  rdfs:comment "Observable data for traffic volume."@en .

<https://example.com/dataFlowRate> a noria:Property ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data flow in Mbps."@en .

<https://example.com/flowData> a noria:StructuralObservable ;
  rdfs:label "Flow Data"@en ;
  rdfs:comment "Observable for data flow rate."@en .

<https://example.com/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of active streams."@en .

<https://example.com/streamData> a noria:StructuralObservable ;
  rdfs:label "Stream Data"@en ;
  rdfs:comment "Observable for stream data."@en .

<https://example.com/superTraffic> a noria:Property ;
  rdfs:label "Super Traffic"@en ;
  rdfs:comment "Aggregate traffic for super node."@en .

<https://example.com/superData> a noria:StructuralObservable ;
  rdfs:label "Super Data"@en ;
  rdfs:comment "Observable for super node traffic data."@en .