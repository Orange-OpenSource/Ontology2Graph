@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a core network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector in the network."@en ;
  noria:structuralElementObservable <https://example.com/NodeTrafficVolume> ;
  noria:structuralObservableOf <https://example.com/HubNode> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central to multiple network segments."@en ;
  noria:structuralElementObservable <https://example.com/NodeLatency> ;
  noria:structuralObservableOf <https://example.com/HighDegreeNode> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network domains."@en ;
  noria:structuralElementObservable <https://example.com/LinkStatus> ;
  noria:structuralObservableOf <https://example.com/CentralNode> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/IntermediaryTraffic> ;
  noria:structuralObservableOf <https://example.com/ConnectorNode> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/StreamCount> ;
  noria:structuralObservableOf <https://example.com/IntermediaryNode> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs."@en ;
  noria:structuralElementObservable <https://example.com/SuperNodeTraffic> ;
  noria:structuralObservableOf <https://example.com/MultiplexNode> .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for managing core network nodes."@en .

<https://example.com/NodeTrafficVolume> a noria:StructuralObservable ;
  rdfs:label "Node Traffic Volume"@en ;
  rdfs:comment "The volume of traffic passing through a node."@en .

<https://example.com/NodeLatency> a noria:StructuralObservable ;
  rdfs:label "Node Latency"@en ;
  rdfs:comment "The latency measured at a node."@en .

<https://example.com/LinkStatus> a noria:StructuralObservable ;
  rdfs:label "Link Status"@en ;
  rdfs:comment "The operational status of a network link."@en .

<https://example.com/IntermediaryTraffic> a noria:StructuralObservable ;
  rdfs:label "Intermediary Traffic"@en ;
  rdfs:comment "Traffic passing through an intermediary node."@en .

<https://example.com/StreamCount> a noria:StructuralObservable ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams handled by a multiplex node."@en .

<https://example.com/SuperNodeTraffic> a noria:StructuralObservable ;
  rdfs:label "Super Node Traffic"@en ;
  rdfs:comment "Aggregated traffic for a super node."@en .

<https://example.com/HubNode> a noria:hubNode ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub with high connectivity."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/HighDegreeNode> a noria:highDegreeNode ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/CentralNode> a noria:centralNode ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central to multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/ConnectorNode> a noria:connectorNode ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network domains."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/IntermediaryNode> a noria:intermediaryNode ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/MultiplexNode> a noria:multiplexNode ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/SuperNode> a noria:superNode ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An aggregating super node."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .