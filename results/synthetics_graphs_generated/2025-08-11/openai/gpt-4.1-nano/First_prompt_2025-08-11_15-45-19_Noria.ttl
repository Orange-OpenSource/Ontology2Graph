@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a central point in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is critical for network operation, connecting multiple subsystems."@en ;
  noria:structuralElementObservable <https://example.com/trafficVolume> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments or systems."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that acts as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/dataFlowRate> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiplexing of multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/multiplexEfficiency> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level analysis."@en ;
  noria:structuralElementObservable <https://example.com/superNodeLoad> .

<https://example.com/ResourceA> a noria:Resource ;
  rdfs:label "Resource A"@en ;
  rdfs:comment "A critical network resource."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceHostName "hostA.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceSerialNumber "SN-987654" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  rdfs:label "Resource A"@en ;
  rdfs:comment "A server resource in the data center."@en ;
  noria:resourceManagedBy <https://org/example/ITSupportTeam> .

<https://example.com/ResourceB> a noria:Resource ;
  rdfs:label "Resource B"@en ;
  rdfs:comment "A virtual machine resource."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceHostName "vm-b.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
  noria:resourceSerialNumber "SN-123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Provisioned> ;
  noria:resourceInstallationDate "2023-03-10T09:30:00Z"^^xsd:dateTime ;
  rdfs:label "Resource B"@en ;
  noria:resourceManagedBy <https://org/example/CloudOps> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber link between Resource A and Resource B."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkInstallationDate "2022-02-20T12:00:00Z"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber"@en ;
  noria:networkLinkTerminationResource <https://example.com/ResourceA> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/ResourceB> .

<https://example.com/NetworkInterfaceA> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Resource A."@en ;
  noria:networkInterfaceType "physical"@en ;
  noria:networkInterfaceDescription "Gigabit Ethernet port 0"@en ;
  noria:networkInterfaceOf <https://example.com/ResourceA> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
  noria:networkInterfaceRoutingPriorityMetric 100 ;
  noria:networkInterfaceLaserTxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPower -3 .

<https://example.com/NetworkInterfaceB> a noria:NetworkInterface ;
  rdfs:label "eth1"@en ;
  rdfs:comment "Secondary network interface of Resource B."@en ;
  noria:networkInterfaceType "virtual"@en ;
  noria:networkInterfaceDescription "Virtual NIC for VM B."@en ;
  noria:networkInterfaceOf <https://example.com/ResourceB> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
  noria:networkInterfaceRoutingPriorityMetric 200 ;
  noria:networkInterfaceLaserTxOpticalPower -1 ;
  noria:networkInterfaceLaserRxOpticalPower -2 .

<https://example.com/ResourceA_Location> a noria:Locus ;
  rdfs:label "Rack 5, Slot 3"@en ;
  noria:locusLine "Line: L, in Rack 5"@en ;
  noria:locusRow "Row: R"@en .

<https://example.com/ResourceB_Location> a noria:Locus ;
  rdfs:label "Rack 2, Slot 1"@en ;
  noria:locusLine "Line: L, in Rack 2"@en ;
  noria:locusRow "Row: S"@en .

<https://org/example/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team responsible for managing network resources."@en .

<https://org/example/CloudOps> a org:OrganizationalUnit ;
  rdfs:label "Cloud Operations"@en ;
  rdfs:comment "Team managing virtualized resources and cloud infrastructure."@en .

<https://example.com/latencyMeasurement> a noria:structuralObservableOf ;
  rdfs:label "Latency Measurement"@en ;
  rdfs:comment "Average latency between Resource A and Resource B."@en .

<https://example.com/trafficVolume> a noria:structuralObservable ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Network traffic volume passing through Resource A."@en .

<https://example.com/connectionStatus> a noria:structuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Current status of the connection between Resource A and Resource B."@en .

<https://example.com/multiplexEfficiency> a noria:structuralObservable ;
  rdfs:label "Multiplexing Efficiency"@en ;
  rdfs:comment "Efficiency metric for multiplexed data streams."@en .

<https://example.com/superNodeLoad> a noria:structuralObservable ;
  rdfs:label "Super Node Load"@en ;
  rdfs:comment "Current load percentage on the super node."@en .