@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections, acting as a critical connector."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralElementObservable <https://example.com/connectionCountObs> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node serving as a central point in the topology."@en ;
  noria:structuralElementObservable <https://example.com/trafficVolume> ;
  noria:structuralElementObservableData <https://example.com/trafficVolumeData> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en ;
  noria:structuralElementObservable <https://example.com/segmentConnections> ;
  noria:structuralElementObservableData <https://example.com/connectionCountData> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/dataFlowRate> ;
  noria:structuralElementObservableData <https://example.com/dataFlowData> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/multiplexLoad> ;
  noria:structuralElementObservableData <https://example.com/loadData> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Node with super high connectivity and importance."@en ;
  noria:structuralElementObservable <https://example.com/superTraffic> ;
  noria:structuralElementObservableData <https://example.com/trafficData> .

<https://example.com/NetworkOperations> a org:Organization ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network management."@en .

<https://example.com/connectionCount> a noria:StructuralObservable ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections at the node."@en .

<https://example.com/connectionCountObs> a noria:structuralElementObservable ;
  rdfs:label "Connection Count Observable"@en .

<https://example.com/connectionCountData> a noria:structuralElementObservableData ;
  rdfs:label "Connection Count Data"@en ;
  rdfs:comment "Data representing the number of connections."@en .

<https://example.com/trafficVolume> a noria:StructuralObservable ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Volume of traffic passing through the node."@en .

<https://example.com/trafficVolumeObs> a noria:structuralElementObservable ;
  rdfs:label "Traffic Volume Observable"@en .

<https://example.com/trafficVolumeData> a noria:structuralElementObservableData ;
  rdfs:label "Traffic Volume Data"@en ;
  rdfs:comment "Data representing traffic volume."@en .

<https://example.com/connectionSegment> a noria:StructuralObservable ;
  rdfs:label "Segment Connections"@en ;
  rdfs:comment "Connections between segments."@en .

<https://example.com/connectionCountData> a noria:structuralElementObservableData ;
  rdfs:label "Connection Count Data"@en .

<https://example.com/segmentConnections> a noria:structuralElementObservable ;
  rdfs:label "Segment Connections"@en .

<https://example.com/dataFlowRate> a noria:StructuralObservable ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data flow through intermediary nodes."@en .

<https://example.com/dataFlowData> a noria:structuralElementObservableData ;
  rdfs:label "Data Flow Data"@en .

<https://example.com/multiplexLoad> a noria:StructuralObservable ;
  rdfs:label "Multiplex Load"@en ;
  rdfs:comment "Load on multiplex nodes."@en .

<https://example.com/loadData> a noria:structuralElementObservableData ;
  rdfs:label "Load Data"@en .

<https://example.com/superTraffic> a noria:StructuralObservable ;
  rdfs:label "Super Node Traffic"@en ;
  rdfs:comment "Traffic handled by super nodes."@en .

<https://example.com/trafficData> a noria:structuralElementObservableData ;
  rdfs:label "Traffic Data"@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "Physical server in data center."@en ;
  noria:resourceLogisticId "SRV-DC-001" ;
  noria:resourceHostName "server1.datacenter.local" ;
  noria:resourceType <http://purl.org/ontology/bibo/Hardware> ;
  noria:locatedAtLocus <https://example.com/Room1> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceInstallationDate "2020-05-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ModelX> ;
  noria:resourceManagementIPAddress "192.168.1.10" ;
  noria:agentManagesResource <https://example.com/NetworkOpsTeam> .

<https://example.com/Room1> a noria:Room ;
  rdfs:label "Server Room 1"@en ;
  rdfs:comment "Main server room."@en .

<https://example.com/ModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "High-performance server model."@en ;
  org:organization <https://example.com/ManufacturerY> .

<https://example.com/ManufacturerY> a org:Organization ;
  rdfs:label "Manufacturer Y"@en ;
  rdfs:comment "Hardware manufacturer."@en .

<https://example.com/NetworkOpsTeam> a org:Organization ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Responsible for network management."@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber link between site A and site B."@en ;
  noria:networkLinkId "NL-AB-001" ;
  noria:networkLinkInstallationDate "2021-03-10T09:00:00Z"^^xsd:dateTime .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Virtual machine in cloud environment."@en ;
  noria:resourceLogisticId "VM-Cloud-007" ;
  noria:resourceHostName "vm.cloudprovider.com" ;
  noria:resourceType <http://purl.org/ontology/bibo/Software> ;
  noria:locatedAtLocus <https://example.com/CloudRegion> ;
  noria:resourceSerialNumber "SN789012" ;
  noria:resourceInstallationDate "2022-01-20T12:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/VMModelZ> ;
  noria:resourceManagementIPAddress "10.0.0.5" .

<https://example.com/CloudRegion> a noria:Locus ;
  rdfs:label "Cloud Region"@en ;
  rdfs:comment "Cloud data center region."@en .

<https://example.com/VMModelZ> a noria:ProductModel ;
  rdfs:label "VM Model Z"@en ;
  rdfs:comment "Cloud VM configuration."@en ;
  org:organization <https://example.com/CloudProvider> .

<https://example.com/CloudProvider> a org:Organization ;
  rdfs:label "Cloud Provider"@en ;
  rdfs:comment "Cloud service provider."@en .

