@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node with high centrality, crucial for network integrity."@en ;
  noria:structuralElementObservable <https://example.com/trafficVolume> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node linking different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/segmentCount> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node mediating between other nodes."@en ;
  noria:structuralElementObservable <https://example.com/latency> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  noria:structuralElementObservable <https://example.com/aggregateTraffic> .

<https://example.com/NetworkOperations> a org:Organization ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team managing network infrastructure."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A critical network resource."@en ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceHostName "host1.example.com" .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A secondary network resource."@en ;
  noria:locatedAtLocus <https://example.com/LocusB> .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Locus in Server Room 314."@en .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Locus in Data Center 2."@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber connection between Resource1 and Resource2."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/Resource1_NIC> a noria:NetworkInterface ;
  rdfs:label "Resource1 NIC"@en ;
  rdfs:comment "Network interface of Resource 1."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceOperationalStatus <https://example.com/statusUp> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOf <https://example.com/Resource1> .

<https://example.com/Resource2_NIC> a noria:NetworkInterface ;
  rdfs:label "Resource2 NIC"@en ;
  rdfs:comment "Network interface of Resource 2."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceOperationalStatus <https://example.com/statusDown> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOf <https://example.com/Resource2> .

<https://example.com/statusUp> a skos:Concept ;
  rdfs:label "Up"@en .

<https://example.com/statusDown> a skos:Concept ;
  rdfs:label "Down"@en .

<https://example.com/trafficVolume> a noria:Property ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Volume of traffic passing through the node."@en .

<https://example.com/connectionCount> a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of connections at the node."@en .

<https://example.com/segmentCount> a noria:Property ;
  rdfs:label "Segment Count"@en ;
  rdfs:comment "Number of network segments connected."@en .

<https://example.com/aggregateTraffic> a noria:Property ;
  rdfs:label "Aggregated Traffic"@en ;
  rdfs:comment "Total traffic passing through super node."@en .

<https://example.com/latency> a noria:Property ;
  rdfs:label "Latency"@en ;
  rdfs:comment "Network latency in milliseconds."@en .

<https://example.com/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .