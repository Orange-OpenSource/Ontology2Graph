@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/entity1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A central hub router connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/Org1> ;
  noria:structuralElementObservable noria:structuralElementObservableOf ;
  noria:structuralElementObservableOf <https://example.com/structObs1> .

<https://example.com/entity2> a noria:StructuralElement ;
  rdfs:label "Edge Switch"@en ;
  rdfs:comment "An edge switch with high connectivity degree."@en ;
  noria:elementManagedBy <https://example.com/Org2> ;
  noria:structuralElementObservable noria:structuralElementObservableOf ;
  noria:structuralElementObservableOf <https://example.com/structObs2> .

<https://example.com/entity3> a noria:StructuralElement ;
  rdfs:label "Data Center Server"@en ;
  rdfs:comment "A server within the data center, high degree node."@en ;
  noria:elementManagedBy <https://example.com/Org1> ;
  noria:structuralElementObservable noria:structuralElementObservableOf ;
  noria:structuralElementObservableOf <https://example.com/structObs3> .

<https://example.com/entity4> a noria:FunctionalElement ;
  rdfs:label "Authentication Service"@en ;
  rdfs:comment "A critical service responsible for user authentication."@en ;
  noria:elementManagedBy <https://example.com/Org3> ;
  noria:application <https://example.com/app1> .

<https://example.com/entity5> a noria:Application ;
  rdfs:label "User Authentication System"@en ;
  rdfs:comment "Handles user login and credential verification."@en ;
  noria:applicationModelIdentifier "AuthSys-2023" ;
  noria:applicationType <https://w3id.org/noria/kos/application/type#CustomerFacingService> ;
  noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance#High> ;
  noria:applicationFunctionalDomain "Security and Access Control" .

<https://example.com/entity6> a noria:Service ;
  rdfs:label "Login Service"@en ;
  rdfs:comment "Provides login and session management."@en ;
  noria:serviceType <https://w3id.org/noria/kos/service/type#CustomerFacingService> ;
  noria:serviceRelatedApplication <https://example.com/app1> .

<https://example.com/entity7> a noria:Resource ;
  rdfs:label "Firewall Appliance"@en ;
  rdfs:comment "Firewall device protecting the network perimeter."@en ;
  noria:resourceLogisticId "FW-DC-01" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type#Physical> ;
  noria:resourceSerialNumber "SN123456789" ;
  noria:resourceHostName "firewall-dc1" ;
  noria:locatedAtLocus <https://example.com/locus1> ;
  noria:resourceManagedBy <https://example.com/Org2> .

<https://example.com/locus1> a noria:Locus ;
  rdfs:label "Main Data Center"@en ;
  rdfs:comment "Location of core network resources."@en .

<https://example.com/structObs1> a noria:structuralObservableOf ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current traffic load on the core router."@en .

<https://example.com/structObs2> a noria:structuralObservableOf ;
  rdfs:label "Port Status"@en ;
  rdfs:comment "Operational status of switch ports."@en .

<https://example.com/structObs3> a noria:structuralObservableOf ;
  rdfs:label "CPU Usage"@en ;
  rdfs:comment "Current CPU utilization of the server."@en .

<https://example.com/Org1> a org:Organization ;
  rdfs:label "Network Operations Center"@en ;
  rdfs:comment "Responsible for core network management."@en .

<https://example.com/Org2> a org:Organization ;
  rdfs:label "Data Center Support Team"@en ;
  rdfs:comment "Manages physical network resources."@en .

<https://example.com/Org3> a org:Organization ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Handles security and access control."@en .

<https://example.com/app1> a noria:Application ;
  rdfs:label "Auth System App"@en ;
  rdfs:comment "Application for user authentication."@en .

<https://example.com/Service1> a noria:Service ;
  rdfs:label "Login Service"@en ;
  rdfs:comment "Service providing user login functionality."@en ;
  noria:serviceType <https://w3id.org/noria/kos/service/type#CustomerFacingService> ;
  noria:serviceRelatedApplication <https://example.com/app1> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Firewall Device"@en ;
  rdfs:comment "Firewall hardware device."@en ;
  noria:resourceLogisticId "FW-DC-01" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type#Physical> ;
  noria:resourceSerialNumber "SN123456789" ;
  noria:resourceHostName "firewall-dc1" ;
  noria:locatedAtLocus <https://example.com/locus1> ;
  noria:resourceManagedBy <https://example.com/Org2> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link DC1-DC2"@en ;
  rdfs:comment "Optical fiber connection between data centers."@en ;
  noria:networkLinkId "Link-DC1-DC2" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2020-05-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Core Switch"@en ;
  rdfs:comment "Core network switch."@en ;
  noria:resourceLogisticId "SW-DC-02" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type#Physical> ;
  noria:resourceSerialNumber "SN987654321" ;
  noria:resourceHostName "core-switch-02" ;
  noria:locatedAtLocus <https://example.com/locus1> ;
  noria:resourceManagedBy <https://example.com/Org1> .

# Hub node: central, high-degree node connected to multiple entities
<https://example.com/entity1> noria:connectedTo <https://example.com/entity2> , <https://example.com/entity3> , <https://example.com/entity4> .

# High-degree node: resource with many relations
<https://example.com/entity2> noria:connectedTo <https://example.com/entity1> , <https://example.com/entity3> .

# Central node: application linking multiple resources and services
<https://example.com/app1> noria:relatedResource <https://example.com/Resource1> , <https://example.com/Resource2> .

# Connector node: resource connecting network links
<https://example.com/Resource2> noria:connectedTo <https://example.com/NetworkLink1> .

# Intermediary node: application mediating between resources and services
<https://example.com/app1> noria:applicationRelatedResource <https://example.com/Resource1> .

# Multiplex node: resource involved in multiple relations
<https://example.com/Resource1> noria:connectedTo <https://example.com/Resource2> , <https://example.com/Resource3> .

# Super node: resource with extensive relations
<https://example.com/entity1> noria:connectedTo <https://example.com/entity2> , <https://example.com/entity3> , <https://example.com/entity4> , <https://example.com/entity5> .

# Dismiss isolated nodes: all nodes have at least one relation, as above.