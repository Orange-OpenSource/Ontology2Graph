<https://example.com/NetworkOps> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for network management."@en .

<https://example.com/degreeMetric> a noria:Property ;
  rdfs:label "Degree Metric"@en ;
  rdfs:comment "Number of connections for a node."@en .

<https://example.com/centralityObservable> a noria:StructuralObservable ;
  rdfs:label "Centrality Observable"@en ;
  rdfs:comment "A measure of node importance in the network."@en .

<https://example.com/connectionCount> a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections."@en .

<https://example.com/dataFlowRate> a noria:Property ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data transfer through the node."@en .

<https://example.com/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of concurrent data streams."@en .

<https://example.com/aggregationLevel> a noria:Property ;
  rdfs:label "Aggregation Level"@en ;
  rdfs:comment "Level of data aggregation in super node."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A network resource contributing to the infrastructure."@en ;
  noria:resourceHostName "host1.example.com" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceManagedBy <https://example.com/NetworkOps> .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Physical location within the data center."@en ;
  noria:locusLine "L1" ;
  noria:locusRow "R1" .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A virtual network component."@en ;
  noria:resourceHostName "virtual-resource2" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceManagedBy <https://example.com/NetworkOps> .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Virtual location within cloud infrastructure."@en ;
  noria:locusLine "L2" ;
  noria:locusRow "R2" .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber connection between Resource1 and Resource2."@en ;
  noria:networkLinkId "NL1" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/Resource1> noria:networkInterfaceConnects <https://example.com/NetworkLink1> .
<https://example.com/Resource2> noria:networkInterfaceConnects <https://example.com/NetworkLink1> .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0" ;
  rdfs:comment "Primary network interface."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceOf <https://example.com/Resource1> ;
  noria:networkInterfaceRoutingPriorityMetric 100 ;
  noria:networkInterfaceLaserTxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPower -3 .

<https://example.com/NetworkInterface2> a noria:NetworkInterface ;
  rdfs:label "veth0" ;
  rdfs:comment "Virtual network interface."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceOf <https://example.com/Resource2> ;
  noria:networkInterfaceRoutingPriorityMetric 200 ;
  noria:networkInterfaceLaserTxOpticalPower -1 ;
  noria:networkInterfaceLaserRxOpticalPower -2 .

<https://example.com/Resource1> noria:resourceType <https://example.com/ResourceType/Router> .
<https://example.com/Resource2> noria:resourceType <https://example.com/ResourceType/VirtualMachine> .

<https://example.com/ResourceType/Router> a skos:Concept ;
  rdfs:label "Router"@en ;
  skos:inScheme <https://example.com/kos/resourceType> .

<https://example.com/ResourceType/VirtualMachine> a skos:Concept ;
  rdfs:label "Virtual Machine"@en ;
  skos:inScheme <https://example.com/kos/resourceType> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with high connectivity degree, acting as a critical junction."@en ;
  noria:structuralElementObservableData <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node serving as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/latency> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node acting as a connector between different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionQuality> ;
  noria:elementManagedBy <https://example.com/NetworkSupport> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node facilitating data flow between source and destination."@en ;
  noria:structuralElementObservable <https://example.com/throughput> ;
  noria:elementManagedBy <https://example.com/ITTeam> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node supporting multiple data streams simultaneously."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/NetworkEngineering> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Highly connected super node with extensive links."@en ;
  noria:structuralElementObservable <https://example.com/networkLoad> ;
  noria:elementManagedBy <https://example.com/NetworkLeadership> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "Core router in data center."@en ;
  noria:resourceLogisticId "LR-DC-001" ;
  noria:resourceHostName "core-router-01.datacenter.local" ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/router> ;
  noria:resourceSerialNumber "SN-123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/operational> ;
  noria:resourceInstallationDate "2020-05-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ModelX> ;
  noria:resourceManagedBy <https://org/NetworkTeam> .

<https://example.com/ModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "High-performance enterprise router."@en ;
  noria:productManufacturedBy <https://org/RouterMakers> .

<https://org/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://org/RouterMakers> a org:Organization ;
  rdfs:label "Router Manufacturing Inc."@en ;
  rdfs:comment "Manufacturer of network hardware."@en .

<https://example.com/NetworkOperations> a foaf:Agent ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Network operations team responsible for managing core network elements."@en .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administration"@en ;
  rdfs:comment "Admin team overseeing network configurations."@en .

<https://example.com/NetworkSupport> a foaf:Agent ;
  rdfs:label "Network Support"@en ;
  rdfs:comment "Support team for network troubleshooting."@en .

<https://example.com/ITTeam> a foaf:Agent ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team responsible for IT infrastructure."@en .

<https://example.com/NetworkEngineering> a foaf:Agent ;
  rdfs:label "Network Engineering"@en ;
  rdfs:comment "Engineers designing and maintaining network topology."@en .

<https://example.com/NetworkLeadership> a foaf:Agent ;
  rdfs:label "Network Leadership"@en ;
  rdfs:comment "Senior network management team."@en .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Main server room in data center."@en .

<https://example.com/trafficLoad> a noria:Property ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load in Mbps."@en .

<https://example.com/latency> a noria:Property ;
  rdfs:label "Latency"@en ;
  rdfs:comment "Network latency in milliseconds."@en .

<https://example.com/connectionQuality> a noria:Property ;
  rdfs:label "Connection Quality"@en ;
  rdfs:comment "Quality indicator of network connection."@en .

<https://example.com/throughput> a noria:Property ;
  rdfs:label "Throughput"@en ;
  rdfs:comment "Data throughput in Mbps."@en .

<https://example.com/networkLoad> a noria:Property ;
  rdfs:label "Network Load"@en ;
  rdfs:comment "Overall network load indicator."@en .

<https://example.com/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of active data streams."@en .

<https://example.com/ModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "Model of core router."@en .

<https://org/RouterMakers> a org:Organization ;
  rdfs:label "Router Makers Inc."@en .

<https://org/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en .

<https://org/NetworkSupport> a org:OrganizationalUnit ;
  rdfs:label "Network Support Group"@en .

