  rdfs:comment "A node supporting multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/observable/MultiplexNodeLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/superNode> a noria:StructuralElement ;
