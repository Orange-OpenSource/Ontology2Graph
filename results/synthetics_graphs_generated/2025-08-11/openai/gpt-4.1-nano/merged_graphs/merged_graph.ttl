<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a core network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMetric> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central to a specific sub-network."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/ConnectivityTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that acts as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/throughputMetric> ;
  noria:elementManagedBy <https://example.com/NetworkSupport> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/StreamManagement> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching node with extensive connectivity."@en ;
  noria:structuralElementObservable <https://example.com/superTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkLeadership> .

<https://example.com/NetworkOperations> a org:Organization ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "The organization responsible for network management."@en .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team managing high-degree nodes."@en ;
  org:member <https://example.com/NetworkOperations> .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Admin responsible for central nodes."@en .

<https://example.com/ConnectivityTeam> a foaf:Agent ;
  rdfs:label "Connectivity Support Team"@en ;
  rdfs:comment "Team managing connector nodes."@en .

<https://example.com/NetworkSupport> a foaf:Agent ;
  rdfs:label "Network Support"@en ;
  rdfs:comment "Team managing intermediary nodes."@en .

<https://example.com/StreamManagement> a foaf:Agent ;
  rdfs:label "Stream Management"@en ;
  rdfs:comment "Team managing multiplex nodes."@en .

<https://example.com/NetworkLeadership> a foaf:Agent ;
  rdfs:label "Network Leadership"@en ;
  rdfs:comment "Oversees super nodes."@en .

<https://example.com/latencyMetric> a noria:structuralElementObservableData ;
  rdfs:label "Latency Metric"@en ;
  rdfs:comment "Average latency in milliseconds."@en .

<https://example.com/trafficLoad> a noria:structuralElementObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load in Mbps."@en .

<https://example.com/connectionStatus> a noria:structuralElementObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of the network connection (up/down)."@en .

<https://example.com/throughputMetric> a noria:structuralElementObservableData ;
  rdfs:label "Throughput Metric"@en ;
  rdfs:comment "Data throughput in Mbps."@en .

<https://example.com/streamCount> a noria:structuralElementObservableData ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of active data streams."@en .

<https://example.com/superTraffic> a noria:structuralElementObservable ;
  rdfs:label "Super Node Traffic"@en ;
  rdfs:comment "Aggregate traffic handled by super node."@en .

<https://example.com/trafficNode> a noria:StructuralElement ;
  rdfs:label "Traffic Node"@en ;
  rdfs:comment "A node involved in traffic routing."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/connectionNode> a noria:StructuralElement ;
  rdfs:label "Connection Node"@en ;
  rdfs:comment "A node that manages connections."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/ConnectivityTeam> .

<https://example.com/virtualNode> a noria:StructuralElement ;
  rdfs:label "Virtual Node"@en ;
  rdfs:comment "A virtualized network node."@en ;
