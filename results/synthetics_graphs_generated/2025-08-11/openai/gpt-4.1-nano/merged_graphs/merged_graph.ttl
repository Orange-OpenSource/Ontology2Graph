@prefix seas: <https://w3id.org/seas/> .
@prefix ob: <http://ontology.tno.nl/saref#> .

# Hub Node: Central Network Hub
<https://example.com/HubNetwork> a noria:ManagedElement ;
  rdfs:label "Main Network Hub"@en ;
  rdfs:comment "The central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

# High-Degree Node: Core Router
<https://example.com/CoreRouter> a noria:StructuralElement, seas:System ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "High-degree core router managing multiple connections."@en ;
  noria:structuralElementObservable <https://example.com/RouterLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

# Central Node: Data Center
<https://example.com/DataCenter> a noria:StructuralElement, seas:System ;
  rdfs:label "Main Data Center"@en ;
  rdfs:comment "The central data processing facility."@en ;
  noria:structuralElementObservable <https://example.com/PowerSupplyStatus> ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

# Connector Node: Switch
<https://example.com/Switch1> a noria:StructuralElement, seas:System ;
  rdfs:label "Switch 1"@en ;
  rdfs:comment "Network switch connecting servers and routers."@en ;
  noria:structuralElementObservable <https://example.com/PortStatus> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

# Intermediary Node: Firewall
<https://example.com/Firewall> a noria:StructuralElement, seas:System ;
  rdfs:label "Firewall"@en ;
  rdfs:comment "Firewall managing security between network segments."@en ;
  noria:structuralElementObservable <https://example.com/FirewallStatus> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

# Multiplex Node: Virtual Machine Cluster
<https://example.com/VMCluster> a noria:StructuralElement, seas:System ;
  rdfs:label "VM Cluster"@en ;
  rdfs:comment "Cluster of virtual machines providing multiple services."@en ;
  noria:structuralElementObservable <https://example.com/VMLoad> ;
  noria:elementManagedBy <https://example.com/CloudOps> .

# Super Node: Global Network Backbone
<https://example.com/GlobalBackbone> a noria:StructuralElement, seas:System ;
  rdfs:label "Global Network Backbone"@en ;
  rdfs:comment "The overarching backbone connecting all regional networks."@en ;
  noria:structuralElementObservable <https://example.com/BackboneTraffic> ;
  noria:elementManagedBy <https://example.com/GlobalNetworkTeam> .

# Entities linked via relations
<https://example.com/NetworkAdmin> a org:Organization ;
  rdfs:label "Network Administration Team"@en ;
  rdfs:comment "Responsible for managing core network devices."@en .

<https://example.com/NetworkOperations> a org:Organization ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Team overseeing network operations."@en .

<https://example.com/ITSupportTeam> a org:Organization ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Supports data center infrastructure."@en .

<https://example.com/SecurityTeam> a org:Organization ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Manages security devices like firewalls."@en .

<https://example.com/CloudOps> a org:Organization ;
  rdfs:label "Cloud Operations"@en ;
  rdfs:comment "Manages virtualized resources."@en .

<https://example.com/GlobalNetworkTeam> a org:Organization ;
  rdfs:label "Global Network Team"@en ;
  rdfs:comment "Oversees the global backbone network."@en .

# Relations between entities
<https://example.com/HubNetwork> noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/CoreRouter> noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/DataCenter> noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/Switch1> noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/Firewall> noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/VMCluster> noria:elementManagedBy <https://example.com/CloudOps> .

<https://example.com/GlobalBackbone> noria:elementManagedBy <https://example.com/GlobalNetworkTeam> .

# Observable properties for nodes
<https://example.com/RouterLoad> a noria:Property ;
  rdfs:label "Router Load"@en ;
  rdfs:comment "Current load on the router."@en .

<https://example.com/PowerSupplyStatus> a noria:Property ;
  rdfs:label "Power Supply Status"@en ;
  rdfs:comment "Operational status of power supply."@en .

<https://example.com/PortStatus> a noria:Property ;
  rdfs:label "Port Status"@en ;
  rdfs:comment "Status of network ports."@en .

<https://example.com/FirewallStatus> a noria:Property ;
  rdfs:label "Firewall Status"@en ;
  rdfs:comment "Operational status of the firewall."@en .

<https://example.com/VMLoad> a noria:Property ;
  rdfs:label "VM Load"@en ;
  rdfs:comment "Current load on virtual machines."@en .

<https://example.com/BackboneTraffic> a noria:Property ;
  rdfs:label "Backbone Traffic"@en ;
  rdfs:comment "Traffic volume on the global backbone."@en .

# End of graph
