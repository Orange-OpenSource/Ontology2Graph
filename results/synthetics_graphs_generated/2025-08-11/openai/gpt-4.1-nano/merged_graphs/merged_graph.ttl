  rdfs:comment "A super node aggregating multiple sub-nodes."@en ;
  noria:structuralElementObservable <https://example.com/aggregateTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkSupervisors> .

<https://example.com/NetworkOperations> a org:Organization ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "The organization responsible for network management."@en .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
