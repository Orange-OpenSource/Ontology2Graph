# Additional nodes for relations and hubs can be added similarly, ensuring each node has at least one link and follows the schema constraints.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central node acting as a core router hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, serving as a switch in the network."@en ;
  noria:structuralElementObservableData <https://example.com/PowerUsageData> ;
  noria:structuralElementDistinguishedName "Switch-01" .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Data Center Server"@en ;
  rdfs:comment "A central node with high connectivity, hosting critical services."@en ;
  noria:structuralElementObservableData <https://example.com/CPUUtilization> ;
  noria:structuralElementDistinguishedName "Server-DC1" .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/TrafficFlow> ;
  noria:structuralElementDistinguishedName "Firewall-Conn" .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node balancing load across servers."@en ;
  noria:structuralElementObservableData <https://example.com/LoadMetrics> ;
  noria:structuralElementDistinguishedName "LoadBalancer-01" .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/StreamBandwidth> ;
  noria:structuralElementDistinguishedName "Mux-Stream" .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and central nodes."@en ;
  noria:structuralElementObservableData <https://example.com/AggregateTraffic> ;
  noria:structuralElementDistinguishedName "SuperNode-Alpha" .

<https://example.com/HubNode> a noria:StructuralElement ;
  rdfs:label "Network Hub"@en ;
  rdfs:comment "A hub node with high connectivity, acting as a central point."@en ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> ;
  noria:structuralElementObservableData <https://example.com/TrafficVolume> ;
  noria:structuralElementDistinguishedName "Hub-Alpha" .

<https://example.com/HighDegreeNode2> a noria:StructuralElement ;
  rdfs:label "Distribution Switch"@en ;
  rdfs:comment "A high-degree node distributing traffic to multiple endpoints."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps> ;
  noria:structuralElementObservableData <https://example.com/PortUtilization> ;
  noria:structuralElementDistinguishedName "DistSwitch-02" .

<https://example.com/CentralNode2> a noria:StructuralElement ;
  rdfs:label "Main Database Server"@en ;
  rdfs:comment "A central node hosting the main database with high connectivity."@en ;
  noria:elementManagedBy <https://example.com/DBTeam> ;
  noria:structuralElementObservableData <https://example.com/DBLoad> ;
  noria:structuralElementDistinguishedName "DB-Server-01" .

<https://example.com/ConnectorNode2> a noria:StructuralElement ;
  rdfs:label "VPN Gateway"@en ;
  rdfs:comment "A connector node providing VPN access."@en ;
  noria:elementManagedBy <https://example.com/SecurityTeam> ;
  noria:structuralElementObservableData <https://example.com/VPNTraffic> ;
  noria:structuralElementDistinguishedName "VPN-Gateway-01" .

<https://example.com/IntermediaryNode2> a noria:StructuralElement ;
  rdfs:label "Application Load Balancer"@en ;
  rdfs:comment "An intermediary node balancing application traffic."@en ;
  noria:elementManagedBy <https://example.com/AppOps> ;
  noria:structuralElementObservableData <https://example.com/AppLoad> ;
  noria:structuralElementDistinguishedName "AppLB-01" .

<https://example.com/MultiplexNode2> a noria:StructuralElement ;
  rdfs:label "Data Stream Multiplexer"@en ;
  rdfs:comment "A multiplex node aggregating multiple data streams."@en ;
  noria:elementManagedBy <https://example.com/StreamOps> ;
  noria:structuralElementObservableData <https://example.com/StreamBandwidth2> ;
  noria:structuralElementDistinguishedName "Mux-Stream-02" .

<https://example.com/SuperNode2> a noria:StructuralElement ;
  rdfs:label "Global Super Node"@en ;
  rdfs:comment "An overarching super node aggregating multiple hubs."@en ;
  noria:elementManagedBy <https://example.com/GlobalOps> ;
  noria:structuralElementObservableData <https://example.com/GlobalTraffic> ;
  noria:structuralElementDistinguishedName "SuperNode-Gamma" .

<https://example.com/HubNode2> a noria:StructuralElement ;
  rdfs:label "Regional Hub"@en ;
  rdfs:comment "A regional hub node with high connectivity."@en ;
  noria:elementManagedBy <https://example.com/RegionNetwork> ;
  noria:structuralElementObservableData <https://example.com/RegionalTraffic> ;
  noria:structuralElementDistinguishedName "RegionalHub-01" .

<https://example.com/HighDegreeNode3> a noria:StructuralElement ;
