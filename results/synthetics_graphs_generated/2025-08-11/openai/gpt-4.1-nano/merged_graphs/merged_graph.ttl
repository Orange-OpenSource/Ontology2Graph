<https://example.com/latencyMeasurement> a noria:structuralObservableOf ;
  rdfs:label "Latency Measurement"@en ;
  rdfs:comment "Average latency between Resource A and Resource B."@en .

<https://example.com/trafficVolume> a noria:structuralObservable ;
