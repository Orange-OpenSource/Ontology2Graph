<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber connecting Resource A and Resource B."@en ;
  noria:networkLinkId "NLINK001" ;
  noria:networkLinkType "Optical Fiber"@en ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/ResourceA> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/ResourceB> .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Virtual Link 1"@en ;
  rdfs:comment "Virtual network connection between Resource C and Resource B."@en ;
  noria:networkLinkId "NLINK002" ;
  noria:networkLinkType "Virtual Network"@en ;
  noria:networkLinkInstallationDate "2023-03-10T12:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/ResourceC> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/ResourceB> .

<https://example.com/trafficVolume> a noria:Property ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Measured traffic volume in Mbps."@en .

<https://example.com/latencyMetric> a noria:Property ;
  rdfs:label "Latency Metric"@en ;
  rdfs:comment "Network latency in milliseconds."@en .

<https://example.com/connectionStatus> a noria:Property ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of the connection (e.g., active, inactive)."@en .

<https://example.com/superNodeLoad> a noria:Property ;
  rdfs:label "Super Node Load"@en ;
  rdfs:comment "Current load percentage on the super node."@en .

<https://example.com/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams handled."@en .

<https://example.com/superNodeLoad> a noria:Property ;
  rdfs:label "Super Node Load"@en ;
  rdfs:comment "Current load percentage on the super node."@en .

<https://example.com/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams handled."@en .

<https://example.com/trafficFlow> a noria:Property ;
  rdfs:label "Traffic Flow"@en ;
  rdfs:comment "Flow of traffic through the network."@en .

<https://example.com/ResourceA> noria:structuralElementObservable <https://example.com/trafficFlow> .

<https://example.com/ResourceB> noria:structuralElementObservable <https://example.com/connectionStatus> .

<https://example.com/ResourceC> noria:structuralElementObservable <https://example.com/latencyMetric> .

<https://example.com/HubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with high connectivity, acting as a critical junction."@en ;
  noria:structuralElementObservable <https://example.com/trafficVolume> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node serving as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/trafficFlow> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node that connects different network domains."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/throughput> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamCount> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Node with super high connectivity and importance."@en ;
  noria:structuralElementObservable <https://example.com/superNodeLoad> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/noria/graph/ExampleGraph> a owl:Ontology ;
    rdfs:label "Example Noria Knowledge Graph"@en ;
    rdfs:comment "A sample knowledge graph demonstrating various node types and relations based on the Noria schema."@en .

# Hub Node: Central Router
<https://example.com/routerCentral> a noria:StructuralElement ;
    rdfs:label "Central Router"@en ;
    rdfs:comment "The main backbone router connecting multiple network segments."@en ;
    noria:elementDistinguishedName "Router-01" .

# High-Degree Node: Data Center
<https://example.com/dataCenter> a noria:StructuralElement ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "The primary data center hosting critical infrastructure."@en .

# Connector Node: Switch
<https://example.com/switchA> a noria:StructuralElement ;
    rdfs:label "Switch A"@en ;
    rdfs:comment "A core switch connecting servers and routers."@en ;
    noria:elementDistinguishedName "Switch-A" ;
    noria:structuralElementObservable noria:structuralElementObservableData .

# Intermediary Node: Virtual Machine
<https://example.com/vmAppServer> a noria:StructuralElement ;
    rdfs:label "Application Server VM"@en ;
    rdfs:comment "A virtual machine hosting application services."@en ;
    noria:elementDistinguishedName "VM-APP-01" .

# Multiplex Node: Network Link
<https://example.com/linkFiber> a noria:NetworkLink ;
    rdfs:label "Fiber Optic Link"@en ;
    rdfs:comment "High-speed fiber optic connection between Data Center and Router."@en ;
    noria:networkLinkId "FiberLink-01" .

# Super Node: Network System
<https://example.com/networkSystem> a noria:Service ;
    rdfs:label "Corporate Network System"@en ;
    rdfs:comment "The entire corporate network infrastructure."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/CorporateNetwork> .

# Relations: Nodes linked via schema relations

# Hub node connected to high-degree node
<https://example.com/routerCentral> noria:structuralElementObservable noria:structuralElementObservableData ;
    noria:structuralElementObservableOf <https://example.com/dataCenter> .

<https://example.com/dataCenter> noria:locatedAtLocus <https://example.com/locusMain> .

# Central node connected to connector node
<https://example.com/switchA> noria:structuralElementObservable noria:structuralElementObservableData ;
    noria:structuralElementObservableOf <https://example.com/vmAppServer> .

<https://example.com/vmAppServer> noria:eventRelatedElement <https://example.com/linkFiber> .

# Connector node linked to intermediary node
<https://example.com/linkFiber> noria:networkLinkTerminationResource <https://example.com/dataCenter> ;
    noria:networkLinkTerminationResource <https://example.com/routerCentral> .

<https://example.com/vmAppServer> noria:structuralElementObservable noria:structuralElementObservableData ;
    noria:structuralElementObservableOf <https://example.com/switchA> .

# Intermediary node linked to high-degree node
<https://example.com/vmAppServer> noria:eventRelatedElement <https://example.com/routerCentral> .

# Multiplex node connected to multiple nodes
<https://example.com/linkFiber> noria:networkLinkId "FiberLink-01" ;
    noria:networkLinkTerminationResourceOrigin <https://example.com/dataCenter> ;
    noria:networkLinkTerminationResourceDestination <https://example.com/routerCentral> .

# Super node representing the entire system
<https://example.com/networkSystem> noria:structuralElementObservable noria:structuralElementObservableData ;
    noria:structuralElementObservableOf <https://example.com/dataCenter> , <https://example.com/routerCentral> , <https://example.com/switchA> , <https://example.com/vmAppServer> , <https://example.com/linkFiber> .

# Additional descriptive nodes
<https://example.com/locusMain> a noria:Locus ;
    rdfs:label "Main Locus"@en ;
    rdfs:comment "Main physical location of the data center."@en .

<https://example.com/organization> a org:OrganizationalUnit ;
    rdfs:label "IT Operations"@en ;
    rdfs:comment "The IT Operations team responsible for network management."@en .

# Link nodes to organization
<https://example.com/routerCentral> noria:elementManagedBy <https://example.com/organization> .
<https://example.com/switchA> noria:elementManagedBy <https://example.com/organization> .
<https://example.com/dataCenter> noria:elementManagedBy <https://example.com/organization> .

# End of example graph
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node with high centrality, crucial for network integrity."@en ;
  noria:structuralElementObservable <https://example.com/trafficVolume> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node linking different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/segmentCount> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node mediating between other nodes."@en ;
  noria:structuralElementObservable <https://example.com/latency> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  noria:structuralElementObservable <https://example.com/aggregateTraffic> .

<https://example.com/NetworkOperations> a org:Organization ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team managing network infrastructure."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A critical network resource."@en ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceHostName "host1.example.com" .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A secondary network resource."@en ;
  noria:locatedAtLocus <https://example.com/LocusB> .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Locus in Server Room 314."@en .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Locus in Data Center 2."@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber connection between Resource1 and Resource2."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/Resource1_NIC> a noria:NetworkInterface ;
  rdfs:label "Resource1 NIC"@en ;
  rdfs:comment "Network interface of Resource 1."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceOperationalStatus <https://example.com/statusUp> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOf <https://example.com/Resource1> .

<https://example.com/Resource2_NIC> a noria:NetworkInterface ;
  rdfs:label "Resource2 NIC"@en ;
  rdfs:comment "Network interface of Resource 2."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceOperationalStatus <https://example.com/statusDown> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOf <https://example.com/Resource2> .

<https://example.com/statusUp> a skos:Concept ;
  rdfs:label "Up"@en .

<https://example.com/statusDown> a skos:Concept ;
  rdfs:label "Down"@en .

<https://example.com/trafficVolume> a noria:Property ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Volume of traffic passing through the node."@en .

<https://example.com/connectionCount> a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of connections at the node."@en .

<https://example.com/segmentCount> a noria:Property ;
  rdfs:label "Segment Count"@en ;
  rdfs:comment "Number of network segments connected."@en .

<https://example.com/aggregateTraffic> a noria:Property ;
  rdfs:label "Aggregated Traffic"@en ;
  rdfs:comment "Total traffic passing through super node."@en .

<https://example.com/latency> a noria:Property ;
  rdfs:label "Latency"@en ;
  rdfs:comment "Network latency in milliseconds."@en .

<https://example.com/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .
