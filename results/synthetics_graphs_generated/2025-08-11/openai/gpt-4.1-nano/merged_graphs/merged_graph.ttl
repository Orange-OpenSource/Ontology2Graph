  noria:elementManagedBy <https://example.com/EdgeTeam> ;
  noria:structuralElementObservableData <https://example.com/EdgePortUtilization> ;
  noria:structuralElementDistinguishedName "EdgeSwitch-03" .

<https://example.com/CentralNode3> a noria:StructuralElement ;
  rdfs:label "Application Server"@en ;
