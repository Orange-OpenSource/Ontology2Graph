  rdfs:label "Latency Metric"@en ;
  rdfs:comment "Measurement of network latency at high-degree nodes."@en .

<https://example.com/throughputObservable> a noria:structuralObservable ;
  rdfs:label "Throughput Observable"@en ;
  rdfs:comment "Monitoring throughput at central nodes."@en .

<https://example.com/connectionStatus> a noria:structuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of connections at connector nodes."@en .

<https://example.com/dataFlowRate> a noria:structuralObservableData ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data flow through intermediary nodes."@en .

<https://example.com/streamCount> a noria:structuralObservable ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed at multiplex nodes."@en .

<https://example.com/aggregateTraffic> a noria:structuralObservable ;
  rdfs:label "Aggregated Traffic"@en ;
  rdfs:comment "Total traffic handled by super nodes."@en .

