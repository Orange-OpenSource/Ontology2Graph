<https://example.com/streamCount> a noria:structuralObservableData ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/loadDistribution> a noria:structuralObservable ;
  rdfs:label "Load Distribution"@en ;
  rdfs:comment "Distribution of load across multiple nodes."@en .

