  noria:structuralElementObservable <https://example.com/observable/HighDegreeNodeStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central within a specific sub-network."@en ;
  noria:structuralElementObservable <https://example.com/observable/CentralNodeLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node acting as a connector between different network segments."@en ;
  noria:structuralElementObservable <https://example.com/observable/ConnectorNodeTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node facilitating data flow between hubs."@en ;
  noria:structuralElementObservable <https://example.com/observable/IntermediaryNodeStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
