  noria:resourceProductModel <https://example.com/ProductModelY> ;
  noria:resourceManagedBy <https://example.com/BackupTeam> .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Main server room."@en ;
  noria:locusLine "L" ;
  noria:locusRow "1" .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Secondary server room."@en ;
  noria:locusLine "L" ;
  noria:locusRow "2" .

<https://example.com/NetworkAdminTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Admin Team"@en ;
  rdfs:comment "Team responsible for network resources."@en .

<https://example.com/BackupTeam> a org:OrganizationalUnit ;
  rdfs:label "Backup Team"@en ;
  rdfs:comment "Team managing backup resources."@en .

<https://example.com/ProductModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "High-performance server model."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ProductModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Standard server model."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerB> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "TechCorp"@en ;
  rdfs:comment "Manufacturer of high-performance servers."@en .

<https://example.com/ManufacturerB> a org:Organization ;
  rdfs:label "BuildIt"@en ;
  rdfs:comment "Manufacturer of standard servers."@en .

<https://example.com/HubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Operations team managing network infrastructure."@en .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node with high centrality in the network."@en ;
  noria:structuralElementObservable <https://example.com/centralityScore> .

<https://example.com/connection1> a noria:NetworkLink ;
  rdfs:label "Link 1"@en ;
  rdfs:comment "Optical fiber connection between Resource1 and Resource2."@en ;
  noria:networkLinkId "NLK-001" ;
  noria:networkLinkInstallationDate "2019-11-01T08:00:00Z"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/connection2> a noria:NetworkLink ;
  rdfs:label "Link 2"@en ;
  rdfs:comment "Virtual connection between Resource1 and Resource2."@en ;
  noria:networkLinkId "NLK-002" ;
  noria:networkLinkInstallationDate "2020-06-15T09:00:00Z"^^xsd:dateTime ;
  noria:networkLinkType "Virtual" .

<https://example.com/Resource1> noria:connectedTo <https://example.com/connection1> ;
  noria:connectedTo <https://example.com/connection2> .

<https://example.com/Resource2> noria:connectedTo <https://example.com/connection1> .

<https://example.com/connection1> a noria:NetworkLink ;
  rdfs:label "Optical Fiber Link"@en .

<https://example.com/connection2> a noria:NetworkLink ;
  rdfs:label "Virtual Link"@en .

<https://example.com/centralityScore> a noria:Property ;
  rdfs:label "Centrality Score"@en ;
  rdfs:comment "A measure of node centrality in the network."@en .

<https://example.com/degreeMetric> a noria:Property ;
  rdfs:label "Degree Metric"@en ;
  rdfs:comment "Number of connections for a node."@en .

<https://example.com/connectionCount> a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of connections for a node."@en .

<https://example.com/aggregationScore> a noria:Property ;
  rdfs:label "Aggregation Score"@en ;
  rdfs:comment "Score indicating the level of aggregation in super nodes."@en .

<https://example.com/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams handled by multiplex nodes."@en .

<https://example.com/dataFlowRate> a noria:Property ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data flow through intermediary nodes."@en .
