  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector."@en ;
  noria:structuralElementObservable noria:virtualServerStatus ;
  noria:structuralElementObservableData 42 ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node with high centrality, connecting multiple subsystems."@en ;
  noria:structuralElementObservable noria:virtualServerStatus ;
  noria:structuralElementObservableData "Active"^^xsd:string ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node acting as a bridge between different network segments."@en ;
  noria:structuralElementObservable noria:networkInterfaceOperationalStatus ;
  noria:structuralElementObservableData 1 ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node facilitating communication between hubs."@en ;
  noria:structuralElementObservable noria:networkInterfaceRoutingPriorityMetric ;
  noria:structuralElementObservableData 100 ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple protocols or services."@en ;
  noria:structuralElementObservable noria:networkInterfaceLaserTxOpticalPower ;
  noria:structuralElementObservableData -2 ;
  noria:elementManagedBy <https://example.com/OpticalSupport> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:structuralElementObservable noria:virtualServerStatus ;
  noria:structuralElementObservableData "Operational"^^xsd:string ;
  noria:elementManagedBy <https://example.com/ManagementTeam> .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Team managing network operations."@en .

<https://example.com/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support"@en ;
  rdfs:comment "Team providing IT support services."@en .

<https://example.com/OpticalSupport> a org:OrganizationalUnit ;
  rdfs:label "Optical Support"@en ;
  rdfs:comment "Team managing optical network components."@en .

<https://example.com/ManagementTeam> a org:OrganizationalUnit ;
  rdfs:label "Management Team"@en ;
  rdfs:comment "High-level management team."@en .
