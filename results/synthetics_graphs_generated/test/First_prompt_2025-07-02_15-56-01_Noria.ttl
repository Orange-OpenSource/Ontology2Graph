@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ex: <http://example.com/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix seas: <https://w3id.org/seas/> .

# Entities
ex:ApplicationModuleA_extra
    a noria:ApplicationModule ;
    rdfs:label "Application Module A" ;
    rdfs:comment "A critical application module." ;
    noria:applicationModuleName "AppModuleA" ;
    noria:applicationModuleIdentifier "AM001" ;
    noria:applicationModuleOf ex:ApplicationX_extra ;
    noria:applicationModuleAdministrationTeam ex:TeamAlpha_extra .

ex:ApplicationModuleB_extra
    a noria:ApplicationModule ;
    rdfs:label "Application Module B" ;
    rdfs:comment "Another application module." ;
    noria:applicationModuleName "AppModuleB" ;
    noria:applicationModuleIdentifier "AM002" ;
    noria:applicationModuleOf ex:ApplicationY_extra ;
    noria:applicationModuleSupportTeam ex:TeamBeta_extra .

ex:ApplicationX_extra
    a noria:Application ;
    rdfs:label "Application X" ;
    rdfs:comment "A core application." ;
    noria:applicationShortIdentifier "AppX" ;
    noria:applicationModelIdentifier "AppModelX" .

ex:ApplicationY_extra
    a noria:Application ;
    rdfs:label "Application Y" ;
    rdfs:comment "An important application." ;
    noria:applicationShortIdentifier "AppY" ;
    noria:applicationModelIdentifier "AppModelY" .

ex:Resource1_extra
    a noria:Resource ;
    rdfs:label "Resource 1" ;
    rdfs:comment "A server in the data center." ;
    noria:resourceHostName "server1.example.com" ;
    noria:resourceLogisticId "RL001" ;
    noria:locatedAtLocus ex:LocusA_extra .

ex:Resource2_extra
    a noria:Resource ;
    rdfs:label "Resource 2" ;
    rdfs:comment "Another server in the data center." ;
    noria:resourceHostName "server2.example.com" ;
    noria:resourceLogisticId "RL002" ;
    noria:locatedAtLocus ex:LocusB_extra .

ex:NetworkInterface1_extra
    a noria:NetworkInterface ;
    rdfs:label "eth0" ;
    rdfs:comment "Network interface of Resource 1." ;
    noria:networkInterfaceOf ex:Resource1_extra ;
    noria:networkInterfaceConnects ex:NetworkLink1_extra .

ex:NetworkInterface2_extra
    a noria:NetworkInterface ;
    rdfs:label "eth1" ;
    rdfs:comment "Network interface of Resource 2." ;
    noria:networkInterfaceOf ex:Resource2_extra ;
    noria:networkInterfaceConnects ex:NetworkLink1_extra .

ex:NetworkLink1_extra
    a noria:NetworkLink ;
    rdfs:label "Link between Server1 and Server2" ;
    rdfs:comment "A high-bandwidth link." ;
    noria:networkLinkId "NL001" ;
    noria:networkLinkTerminationResourceOrigin ex:Resource1_extra ;
    noria:networkLinkTerminationResourceDestination ex:Resource2_extra .

ex:TroubleTicket1_extra
    a noria:TroubleTicket ;
    rdfs:label "Trouble Ticket 1" ;
    rdfs:comment "A ticket related to Application X." ;
    dcterms:identifier "TT001" ;
    noria:troubleTicketRelatedService ex:ApplicationX_extra .

ex:ChangeRequest1_extra
    a noria:ChangeRequest ;
    rdfs:label "Change Request 1" ;
    rdfs:comment "A change request impacting Resource 1." ;
    dcterms:identifier "CR001" ;
    noria:changeRequestImpact ex:Resource1_extra .

ex:TeamAlpha_extra
    a org:OrganizationalUnit ;
    rdfs:label "Team Alpha" ;
    rdfs:comment "The administration team for Application Module A." .

ex:TeamBeta_extra
    a org:OrganizationalUnit ;
    rdfs:label "Team Beta" ;
    rdfs:comment "The support team for Application Module B." .

ex:LocusA_extra
    a noria:Locus ;
    rdfs:label "Locus A" ;
    rdfs:comment "Location of Resource 1." ;
    bot:containedIn ex:Room1 .

ex:LocusB_extra
    a noria:Locus ;
    rdfs:label "Locus B" ;
    rdfs:comment "Location of Resource 2." ;
    bot:containedIn ex:Room1 .

ex:Room1
    a noria:Room ;
    rdfs:label "Server Room 1" ;
    rdfs:comment "A server room." .

# Relationships and Node Types
ex:ApplicationX_extra
    noria:resourceForApplication ex:Resource1_extra, ex:Resource2_extra . # High-degree node (ApplicationX_extra)

ex:Resource1_extra
    noria:resourceManagedBy ex:TeamAlpha_extra ; # Connector node (Resource1_extra)
    noria:networkInterfaceOf ex:NetworkInterface1_extra .

ex:Resource2_extra
    noria:resourceManagedBy ex:TeamBeta_extra ; # Connector node (Resource2_extra)
    noria:networkInterfaceOf ex:NetworkInterface2_extra .

ex:NetworkLink1_extra
    noria:networkLinkTerminationResourceOrigin ex:Resource1_extra ; # Intermediary node (NetworkLink1_extra)
    noria:networkLinkTerminationResourceDestination ex:Resource2_extra .

ex:TroubleTicket1_extra
    noria:eventRelatedElement ex:ApplicationX_extra . # Multiplex node (TroubleTicket1_extra)

ex:ChangeRequest1_extra
    noria:eventRelatedElement ex:Resource1_extra . # Multiplex node (ChangeRequest1_extra)

ex:TeamAlpha_extra
    a foaf:Agent ;
    org:memberOf ex:ApplicationModuleA_extra . # Hub node (TeamAlpha_extra)

ex:TeamBeta_extra
    a foaf:Agent ;
    org:memberOf ex:ApplicationModuleB_extra . # Hub node (TeamBeta_extra)

ex:ApplicationModuleA_extra
    seas:subSystemOf ex:ApplicationX_extra . # Central node (ApplicationModuleA_extra)

ex:ApplicationModuleB_extra
    seas:subSystemOf ex:ApplicationY_extra . # Central node (ApplicationModuleB_extra)

ex:Site1 a bot:Site ;
    rdfs:label "Data Center Site" ;
    noria:siteId "DC001" ;
    bot:hasSpace ex:Room1 . # Super node (Site1)
