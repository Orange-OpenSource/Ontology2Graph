@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ex: <http://example.com/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix seas: <https://w3id.org/seas/> .

# Entities
ex:ApplicationModuleA_extra
    a noria:ApplicationModule ;
    rdfs:label "Application Module A" ;
    rdfs:comment "A critical application module." ;
    noria:applicationModuleName "AppModuleA" ;
    noria:applicationModuleIdentifier "AM001" ;
    noria:applicationModuleOf ex:ApplicationX_extra ;
    noria:applicationModuleAdministrationTeam ex:TeamAlpha_extra .

ex:ApplicationModuleB_extra
    a noria:ApplicationModule ;
    rdfs:label "Application Module B" ;
    rdfs:comment "Another application module." ;
    noria:applicationModuleName "AppModuleB" ;
    noria:applicationModuleIdentifier "AM002" ;
    noria:applicationModuleOf ex:ApplicationY_extra ;
    noria:applicationModuleSupportTeam ex:TeamBeta_extra .

ex:ApplicationX_extra
    a noria:Application ;
    rdfs:label "Application X" ;
    rdfs:comment "A core application." ;
    noria:applicationShortIdentifier "AppX" ;
    noria:applicationModelIdentifier "AppModelX" .

ex:ApplicationY_extra
    a noria:Application ;
    rdfs:label "Application Y" ;
    rdfs:comment "An important application." ;
    noria:applicationShortIdentifier "AppY" ;
    noria:applicationModelIdentifier "AppModelY" .

ex:Resource1_extra
    a noria:Resource ;
    rdfs:label "Resource 1" ;
    rdfs:comment "A server resource." ;
    noria:resourceHostName "server1.example.com" ;
    noria:resourceLogisticId "RL001" ;
    noria:locatedAtLocus ex:LocusA_extra .

ex:Resource2_extra
    a noria:Resource ;
    rdfs:label "Resource 2" ;
    rdfs:comment "Another server resource." ;
    noria:resourceHostName "server2.example.com" ;
    noria:resourceLogisticId "RL002" ;
    noria:locatedAtLocus ex:LocusB_extra .

ex:Resource3_extra
    a noria:Resource ;
    rdfs:label "Resource 3" ;
    rdfs:comment "A network device resource." ;
    noria:resourceHostName "router1.example.com" ;
    noria:resourceLogisticId "RL003" ;
    noria:locatedAtLocus ex:LocusC_extra .

ex:Resource4_extra
    a noria:Resource ;
    rdfs:label "Resource 4" ;
    rdfs:comment "A database server resource." ;
    noria:resourceHostName "dbserver1.example.com" ;
    noria:resourceLogisticId "RL004" ;
    noria:locatedAtLocus ex:LocusD_extra .

ex:NetworkInterface1_extra
    a noria:NetworkInterface ;
    rdfs:label "eth0" ;
    rdfs:comment "Primary network interface." ;
    noria:networkInterfaceOf ex:Resource1_extra ;
    noria:networkInterfaceConnects ex:NetworkLink1_extra .

ex:NetworkInterface2_extra
    a noria:NetworkInterface ;
    rdfs:label "eth1" ;
    rdfs:comment "Secondary network interface." ;
    noria:networkInterfaceOf ex:Resource2_extra ;
    noria:networkInterfaceConnects ex:NetworkLink2_extra .

ex:NetworkInterface3_extra
    a noria:NetworkInterface ;
    rdfs:label "ge-0/0/1" ;
    rdfs:comment "Router interface." ;
    noria:networkInterfaceOf ex:Resource3_extra ;
    noria:networkInterfaceConnects ex:NetworkLink1_extra .

ex:NetworkInterface4_extra
    a noria:NetworkInterface ;
    rdfs:label "ge-0/0/2" ;
    rdfs:comment "Router interface." ;
    noria:networkInterfaceOf ex:Resource3_extra ;
    noria:networkInterfaceConnects ex:NetworkLink2_extra .

ex:NetworkLink1_extra
    a noria:NetworkLink ;
    rdfs:label "Link A" ;
    rdfs:comment "A high-bandwidth network link." ;
    noria:networkLinkId "NL001" ;
    noria:networkLinkTerminationResourceOrigin ex:Resource1_extra ;
    noria:networkLinkTerminationResourceDestination ex:Resource3_extra .

ex:NetworkLink2_extra
    a noria:NetworkLink ;
    rdfs:label "Link B" ;
    rdfs:comment "A backup network link." ;
    noria:networkLinkId "NL002" ;
    noria:networkLinkTerminationResourceOrigin ex:Resource2_extra ;
    noria:networkLinkTerminationResourceDestination ex:Resource3_extra .

ex:TeamAlpha_extra
    a org:OrganizationalUnit ;
    rdfs:label "Team Alpha" ;
    rdfs:comment "Administration team." .

ex:TeamBeta_extra
    a org:OrganizationalUnit ;
    rdfs:label "Team Beta" ;
    rdfs:comment "Support team." .

ex:LocusA_extra
    a noria:Locus ;
    rdfs:label "Locus A" ;
    rdfs:comment "Location of Resource 1." .

ex:LocusB_extra
    a noria:Locus ;
    rdfs:label "Locus B" ;
    rdfs:comment "Location of Resource 2." .

ex:LocusC_extra
    a noria:Locus ;
    rdfs:label "Locus C" ;
    rdfs:comment "Location of Resource 3." .

ex:LocusD_extra
    a noria:Locus ;
    rdfs:label "Locus D" ;
    rdfs:comment "Location of Resource 4." .

ex:ServiceZ_extra
    a noria:Service ;
    rdfs:label "Service Z" ;
    rdfs:comment "A critical service." ;
    seas:subSystemOf ex:ApplicationModuleA_extra, ex:ApplicationModuleB_extra .

ex:TroubleTicket1_extra
    a noria:TroubleTicket ;
    rdfs:label "Trouble Ticket 1" ;
    rdfs:comment "A ticket related to Resource 1." ;
    noria:troubleTicketRelatedResource ex:Resource1_extra ;
    noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity/Major_extra> .

ex:ChangeRequest1_extra
    a noria:ChangeRequest ;
    rdfs:label "Change Request 1" ;
    rdfs:comment "A change request impacting Application X." ;
    noria:changeRequestImpact ex:ApplicationX_extra ;
    noria:changeRequestCategory <https://w3id.org/noria/kos/ChangeRequest/category/InternalIntervention_extra> .

# Relationships and Node Types

# Hub Node: Resource3_extra (connected to multiple network interfaces and links)
ex:Resource3_extra
    noria:resourceForApplication ex:ApplicationX_extra, ex:ApplicationY_extra ;
    noria:resourceManagedBy ex:TeamAlpha_extra .

# High-Degree Node: NetworkLink1_extra (connected to multiple network interfaces)
ex:NetworkLink1_extra
    noria:networkLinkTerminationResource ex:Resource1_extra, ex:Resource3_extra .

# Central Node: ApplicationX_extra (used by multiple resources)
ex:ApplicationX_extra
    noria:resourceForApplication ex:Resource1_extra, ex:Resource2_extra .

# Connector Node: NetworkInterface3_extra (connects Resource3_extra and NetworkLink1_extra)
ex:NetworkInterface3_extra
    noria:networkInterfaceOf ex:Resource3_extra ;
    noria:networkInterfaceConnects ex:NetworkLink1_extra .

# Intermediary Node: ApplicationModuleA_extra (connects ApplicationX_extra and ServiceZ_extra)
ex:ApplicationModuleA_extra
    seas:subSystemOf ex:ServiceZ_extra .

# Multiplex Node: Resource1_extra (part of ApplicationX_extra and connected to NetworkLink1_extra)
ex:Resource1_extra
    noria:resourceForApplication ex:ApplicationX_extra ;
    noria:locatedAtLocus ex:LocusA_extra .

# Super Node: ServiceZ_extra (aggregates ApplicationModuleA_extra and ApplicationModuleB_extra)
ex:ServiceZ_extra
    seas:subSystemOf ex:ApplicationModuleA_extra, ex:ApplicationModuleB_extra .
