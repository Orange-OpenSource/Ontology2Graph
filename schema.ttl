@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

sc:C6 a owl:Class ;
    rdfs:subClassOf sc:C8 .

sc:R1 a owl:ObjectProperty,
        owl:ReflexiveProperty,
        owl:TransitiveProperty .

sc:R4 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:domain sc:C9 ;
    rdfs:range sc:C9 .

sc:R5 a owl:ObjectProperty,
        owl:ReflexiveProperty,
        owl:SymmetricProperty .

sc:R7 a owl:ObjectProperty,
        owl:ReflexiveProperty .

sc:R9 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:domain sc:C2 ;
    rdfs:range sc:C2 .

sc:R10 a owl:ObjectProperty ;
    rdfs:domain sc:C10 ;
    rdfs:range sc:C4 .

sc:R2 a owl:ObjectProperty ;
    rdfs:domain sc:C3 ;
    rdfs:range sc:C1 ;
    rdfs:subPropertyOf sc:R10 ;
    owl:inverseOf sc:R3 .

sc:R3 a owl:ObjectProperty ;
    rdfs:domain sc:C1 ;
    rdfs:range sc:C3 ;
    owl:inverseOf sc:R2 .

sc:R6 a owl:ObjectProperty ;
    rdfs:domain sc:C5 ;
    rdfs:range sc:C7 ;
    owl:inverseOf sc:R8 .

sc:R8 a owl:ObjectProperty ;
    rdfs:domain sc:C7 ;
    rdfs:range sc:C5 ;
    owl:inverseOf sc:R6 .

sc:C1 a owl:Class ;
    rdfs:subClassOf sc:C4 .

sc:C5 a owl:Class ;
    rdfs:subClassOf sc:C9 .

sc:C2 a owl:Class ;
    rdfs:subClassOf owl:Thing ;
    owl:disjointWith sc:C8 .

sc:C3 a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    owl:disjointWith sc:C9 .

sc:C4 a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    owl:disjointWith sc:C7 .

sc:C7 a owl:Class ;
    rdfs:subClassOf sc:C8 ;
    owl:disjointWith sc:C4 .

sc:C8 a owl:Class ;
    rdfs:subClassOf sc:C9 ;
    owl:disjointWith sc:C2 .

sc:C10 a owl:Class ;
    rdfs:subClassOf owl:Thing .

sc:C9 a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    owl:disjointWith sc:C3 .

